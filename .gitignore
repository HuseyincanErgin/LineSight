# ======================================================================
# V17 - EXPORT LOADING FEEDBACK ONLY
#   Adds a clear loading/progress dialog when the PDF report button is clicked.
#   Core analytics, PDF builder, AI summary, upload, charts and navigation stay unchanged.
# ======================================================================

def _export_text_v17(self, tr, en):
    try:
        return self.tr(en, tr)
    except Exception:
        return tr if getattr(self, "language", "TR") == "TR" else en


def _center_dialog_v17(self, dlg, w=440, h=235):
    try:
        self.update_idletasks()
        x = self.winfo_x() + max(0, (self.winfo_width() - w) // 2)
        y = self.winfo_y() + max(0, (self.winfo_height() - h) // 2)
        dlg.geometry(f"{w}x{h}+{x}+{y}")
    except Exception:
        dlg.geometry(f"{w}x{h}")


def _open_report_folder_v17(out_dir):
    try:
        if os.name == "nt":
            os.startfile(str(out_dir))
        elif sys.platform == "darwin":
            subprocess.Popen(["open", str(out_dir)])
        else:
            subprocess.Popen(["xdg-open", str(out_dir)])
    except Exception:
        pass


def _show_export_loading_v17(self):
    """Immediate visual feedback after clicking the report button."""
    try:
        dlg = ctk.CTkToplevel(self)
        self._export_dialog_v17 = dlg
        dlg.title(_export_text_v17(self, "Rapor hazırlanıyor", "Preparing report"))
        dlg.resizable(False, False)
        dlg.configure(fg_color=COL_BG)
        dlg.transient(self)
        dlg.protocol("WM_DELETE_WINDOW", lambda: None)
        _center_dialog_v17(self, dlg)

        card = ctk.CTkFrame(
            dlg,
            fg_color=COL_CARD,
            corner_radius=24,
            border_width=1,
            border_color=COL_BORDER,
        )
        card.pack(fill="both", expand=True, padx=18, pady=18)

        icon = ctk.CTkLabel(
            card,
            text="⟳",
            width=44,
            height=44,
            fg_color=COL_ACCENT_SOFT,
            corner_radius=16,
            font=("Segoe UI", 22, "bold"),
            text_color=COL_ACCENT,
        )
        icon.pack(pady=(18, 8))

        title = ctk.CTkLabel(
            card,
            text=_export_text_v17(self, "Veriler inceleniyor", "Analyzing data"),
            font=("Segoe UI", 20, "bold"),
            text_color=COL_TEXT,
        )
        title.pack(pady=(0, 4))

        detail = ctk.CTkLabel(
            card,
            text=_export_text_v17(
                self,
                "AI özeti, KPI'lar ve PDF rapor çıktısı hazırlanıyor. Lütfen bekle.",
                "AI summary, KPIs and PDF report output are being prepared. Please wait.",
            ),
            font=("Segoe UI", 12),
            text_color=COL_MUTED,
            wraplength=360,
            justify="center",
        )
        detail.pack(pady=(0, 12))

        progress = ctk.CTkProgressBar(
            card,
            mode="indeterminate",
            height=10,
            corner_radius=999,
            progress_color=COL_ACCENT,
        )
        progress.pack(fill="x", padx=34, pady=(0, 10))
        try:
            progress.start()
        except Exception:
            pass

        status = ctk.CTkLabel(
            card,
            text=_export_text_v17(self, "Yükleniyor...", "Loading..."),
            font=("Segoe UI", 12, "bold"),
            text_color=COL_ACCENT,
        )
        status.pack(pady=(0, 16))

        refs = {"dlg": dlg, "title": title, "detail": detail, "progress": progress, "status": status, "card": card}

        def animate(i=0):
            try:
                if not getattr(self, "_export_running_v17", False):
                    return
                if not dlg.winfo_exists():
                    return
                dots = "." * ((i % 3) + 1)
                status.configure(text=_export_text_v17(self, f"Yükleniyor{dots}", f"Loading{dots}"))
                dlg.after(420, lambda: animate(i + 1))
            except Exception:
                pass

        animate()
        try:
            dlg.grab_set()
            dlg.lift()
            dlg.focus_force()
        except Exception:
            pass
        return refs
    except Exception:
        return None


def _finish_export_loading_v17(self, refs, final_path, out_dir, err):
    self._export_running_v17 = False

    try:
        if refs and refs.get("progress") and refs["progress"].winfo_exists():
            try:
                refs["progress"].stop()
            except Exception:
                pass
            refs["progress"].set(1 if err is None else 0)
    except Exception:
        pass

    if err is not None:
        try:
            self.data_status.configure(
                text=_export_text_v17(self, f"PDF hatası:\n{err}", f"PDF failed:\n{err}"),
                text_color=COL_BAD,
            )
        except Exception:
            pass

        try:
            if refs and refs.get("dlg") and refs["dlg"].winfo_exists():
                refs["title"].configure(text=_export_text_v17(self, "Rapor oluşturulamadı", "Report could not be created"), text_color=COL_BAD)
                refs["detail"].configure(text=str(err), text_color=COL_MUTED)
                refs["status"].configure(text=_export_text_v17(self, "İşlem durduruldu", "Process stopped"), text_color=COL_BAD)
                ctk.CTkButton(
                    refs["card"],
                    text=_export_text_v17(self, "Kapat", "Close"),
                    height=34,
                    corner_radius=12,
                    fg_color=COL_BAD,
                    hover_color="#a83232",
                    command=refs["dlg"].destroy,
                ).pack(pady=(0, 14), padx=34, fill="x")
                refs["dlg"].protocol("WM_DELETE_WINDOW", refs["dlg"].destroy)
        except Exception:
            pass
        return

    try:
        size = os.path.getsize(str(final_path))
    except Exception:
        size = 0

    try:
        self.data_status.configure(
            text=_export_text_v17(
                self,
                f"PDF kaydedildi:\n{final_path.name}\n{size/1024:.1f} KB",
                f"PDF saved:\n{final_path.name}\n{size/1024:.1f} KB",
            ),
            text_color=COL_GOOD,
        )
    except Exception:
        pass

    # Keep the old useful behavior: open the folder, but remove the sudden final messagebox.
    _open_report_folder_v17(out_dir)

    try:
        if refs and refs.get("dlg") and refs["dlg"].winfo_exists():
            refs["title"].configure(text=_export_text_v17(self, "Rapor hazır", "Report ready"), text_color=COL_GOOD)
            refs["detail"].configure(
                text=_export_text_v17(
                    self,
                    f"PDF başarıyla oluşturuldu ve klasör açıldı.\nDosya: {final_path.name}",
                    f"PDF was created successfully and the folder was opened.\nFile: {final_path.name}",
                ),
                text_color=COL_MUTED,
            )
            refs["status"].configure(text=_export_text_v17(self, "Tamamlandı", "Completed"), text_color=COL_GOOD)

            btn_row = ctk.CTkFrame(refs["card"], fg_color="transparent")
            btn_row.pack(fill="x", padx=34, pady=(0, 14))
            btn_row.grid_columnconfigure(0, weight=1)
            btn_row.grid_columnconfigure(1, weight=1)

            ctk.CTkButton(
                btn_row,
                text=_export_text_v17(self, "Klasörü Aç", "Open Folder"),
                height=34,
                corner_radius=12,
                fg_color=COL_ACCENT,
                hover_color=COL_ACCENT_2,
                command=lambda: _open_report_folder_v17(out_dir),
            ).grid(row=0, column=0, sticky="ew", padx=(0, 6))
            ctk.CTkButton(
                btn_row,
                text=_export_text_v17(self, "Kapat", "Close"),
                height=34,
                corner_radius=12,
                fg_color=COL_CARD_ALT,
                hover_color=COL_PANEL_2,
                text_color=COL_TEXT,
                command=refs["dlg"].destroy,
            ).grid(row=0, column=1, sticky="ew", padx=(6, 0))
            refs["dlg"].protocol("WM_DELETE_WINDOW", refs["dlg"].destroy)
    except Exception:
        pass


def export_report_v17_loading(self):
    from pathlib import Path

    if getattr(self, "_export_running_v17", False):
        try:
            dlg = getattr(self, "_export_dialog_v17", None)
            if dlg and dlg.winfo_exists():
                dlg.lift()
                dlg.focus_force()
        except Exception:
            pass
        return

    self._export_running_v17 = True
    refs = _show_export_loading_v17(self)

    lang = getattr(self, "language", "TR")
    out_dir = _safe_reports_dir_v13()
    stamp = dt.datetime.now().strftime("%Y%m%d_%H%M%S")
    prefix = "LineSight_Rapor" if lang != "EN" else "LineSight_Report"
    final_path = out_dir / f"{prefix}_{stamp}.pdf"

    try:
        self.data_status.configure(
            text=_export_text_v17(self, "Veriler inceleniyor...\nRapor hazırlanıyor...", "Analyzing data...\nPreparing report..."),
            text_color=COL_MUTED,
        )
        self.update_idletasks()
    except Exception:
        pass

    df = self.df
    source = self.data_source

    def worker():
        err = None
        try:
            ai = _ai_summary_for_pdf_v14(self)
            build_pdf_styled_v15(df, str(final_path), ai=ai, source_name=source, language=lang)
            _validate_pdf_file_v4(str(final_path))
        except Exception as e:
            err = e
        try:
            self.after(0, lambda: _finish_export_loading_v17(self, refs, final_path, out_dir, err))
        except Exception:
            pass

    threading.Thread(target=worker, daemon=True).start()


LineSightApp.export_report = export_report_v17_loading


# ======================================================================
# RUN
# ======================================================================


# ======================================================================
# V10 - FINAL BUGFIX PATCH (combined build)
#   (1) Missing sys/subprocess imports -> PDF export crashed
#   (2) Tables rendered empty/unreadable -> explicit row foreground + unique style
#   (3) Card text overflow -> title/value clipped to one safe line
#   (4) Oversized AI bubbles -> height fits the actual text length
# ======================================================================
import sys
import subprocess


def table_readable_v10(self, parent, df, height=10, expand=False):
    frame = ctk.CTkFrame(parent, fg_color=COL_CARD, corner_radius=12,
                         border_width=1, border_color=COL_BORDER)
    frame.pack(fill="both", expand=expand, padx=10, pady=6)

    style = ttk.Style()
    try:
        style.theme_use("clam")
    except Exception:
        pass

    style_name = f"FP{id(frame)}.Treeview"
    head_name = style_name + ".Heading"
    style.configure(style_name,
                    background=COL_CARD_ALT, fieldbackground=COL_CARD_ALT,
                    foreground=COL_TEXT, rowheight=26, borderwidth=0,
                    relief="flat", font=("Segoe UI", 9.5))
    style.configure(head_name,
                    background=COL_PANEL_2, foreground=COL_TEXT,
                    relief="flat", font=("Segoe UI", 9.5, "bold"))
    style.map(style_name,
              background=[("selected", COL_ACCENT)],
              foreground=[("selected", "#ffffff")])

    cols = [str(c) for c in df.columns]
    tree = ttk.Treeview(frame, columns=cols, show="headings",
                        height=height, style=style_name)
    for c in cols:
        tree.heading(c, text=c)
        tree.column(c, width=max(95, min(180, len(c) * 10)), anchor="center")

    tree.tag_configure("odd", background=COL_CARD_ALT, foreground=COL_TEXT)
    tree.tag_configure("even", background=COL_CARD, foreground=COL_TEXT)

    for i, (_, r) in enumerate(df.iterrows()):
        vals = []
        for c in df.columns:
            v = r[c]
            try:
                if isinstance(v, float):
                    v = f"{v:.3f}".rstrip("0").rstrip(".") if v % 1 else f"{int(v)}"
            except Exception:
                pass
            vals.append("" if v is None else str(v))
        tree.insert("", "end", values=vals, tags=("even" if i % 2 == 0 else "odd",))

    vsb = ttk.Scrollbar(frame, orient="vertical", command=tree.yview)
    hsb = ttk.Scrollbar(frame, orient="horizontal", command=tree.xview)
    tree.configure(yscrollcommand=vsb.set, xscrollcommand=hsb.set)
    tree.pack(side="top", fill="both", expand=True, padx=8, pady=(8, 2))
    hsb.pack(side="bottom", fill="x", padx=8, pady=(0, 8))
    vsb.place(relx=0.99, rely=0.03, relheight=0.84, anchor="ne")


def _clip_v10(text, n):
    text = str(text or "")
    return text if len(text) <= n else text[: n - 1] + "…"


def kpi_card_safe_v10(self, parent, title, value, color, col, subtitle=""):
    card = ctk.CTkFrame(parent, height=78, fg_color=COL_CARD, corner_radius=13,
                        border_width=1, border_color=COL_BORDER)
    card.grid(row=0, column=col, padx=5, pady=4, sticky="nsew")
    parent.grid_columnconfigure(col, weight=1)
    card.grid_propagate(False)
    ctk.CTkLabel(card, text=_clip_v10(title, 22).upper(), font=("Segoe UI", 9.5, "bold"),
                 text_color=COL_MUTED, anchor="w").pack(anchor="w", padx=12, pady=(11, 1), fill="x")
    ctk.CTkLabel(card, text=_clip_v10(value, 18), font=("Segoe UI", 19, "bold"),
                 text_color=color, anchor="w").pack(anchor="w", padx=12, fill="x")
    return card


def _bubble_height_v10(text, chars_per_line):
    lines = 0
    for para in str(text or "").split("\n"):
        lines += max(1, -(-len(para) // max(20, chars_per_line)))
    return max(64, min(640, lines * 22 + 30))


def add_bubble_fit_v10(self, who, text, user):
    wrap = ctk.CTkFrame(self._chat, fg_color="transparent")
    wrap.pack(fill="x", pady=9)

    if who in ("You", "User"):
        who = self.tr("You", "Sen")
    elif who in ("AI Analyst", "Gemini"):
        who = self.tr("AI Analyst", "AI Analist")

    bubble_color = COL_ACCENT if user else COL_CARD_ALT
    bubble = ctk.CTkFrame(wrap, fg_color=bubble_color, corner_radius=16,
                          border_width=0 if user else 1, border_color=COL_BORDER)

    chat_w = self._chat.winfo_width()
    if chat_w < 400:
        chat_w = max(640, self.content.winfo_width() - 420)
    chars_per_line = max(40, int((chat_w - 120) / 8.4))

    if user:
        bubble.pack(anchor="e", padx=(110, 12))
        ctk.CTkLabel(bubble, text=who, font=("Segoe UI", 10, "bold"),
                     text_color="#dbeafe").pack(anchor="w", padx=16, pady=(9, 1))
        ctk.CTkLabel(bubble, text=text, font=("Segoe UI", 14),
                     wraplength=min(560, chat_w - 160), justify="left",
                     text_color="#ffffff").pack(anchor="w", padx=16, pady=(2, 12))
        self._scroll_chat_bottom()
        return None

    bubble.pack(anchor="w", padx=12, fill="x", expand=True)
    ctk.CTkLabel(bubble, text=who, font=("Segoe UI", 10, "bold"),
                 text_color=COL_ACCENT).pack(anchor="w", padx=16, pady=(9, 1))
    box = ctk.CTkTextbox(bubble, height=_bubble_height_v10(text, chars_per_line),
                         wrap="word", fg_color=bubble_color, border_width=0,
                         text_color=COL_TEXT, font=("Segoe UI", 14),
                         activate_scrollbars=False)
    box.pack(fill="x", expand=True, padx=14, pady=(0, 12))
    box.insert("1.0", str(text or ""))
    box.configure(state="disabled")
    self._scroll_chat_bottom()
    return box


def finish_bubble_fit_v10(self, widget, text):
    if widget is not None and widget.winfo_exists():
        if isinstance(widget, ctk.CTkTextbox):
            chat_w = self._chat.winfo_width()
            if chat_w < 400:
                chat_w = max(640, self.content.winfo_width() - 420)
            cpl = max(40, int((chat_w - 120) / 8.4))
            widget.configure(state="normal")
            widget.delete("1.0", "end")
            widget.insert("1.0", str(text or ""))
            widget.configure(height=_bubble_height_v10(text, cpl))
            widget.configure(state="disabled")
        else:
            widget.configure(text=text)
    self.chat_history.append({"role": "assistant", "text": text})
    self._scroll_chat_bottom()


def export_report_pdf_v10(self):
    out_dir = _v7_reports_dir()
    stamp = dt.datetime.now().strftime("%Y%m%d_%H%M%S")
    lang = getattr(self, "language", "TR")
    prefix = "LineSight_Yonetici_Raporu" if lang != "EN" else "LineSight_Executive_Report"
    final_path = out_dir / f"{prefix}_{stamp}.pdf"
    tmp_path = out_dir / f".__tmp_{prefix}_{stamp}.pdf"
    try:
        self.data_status.configure(text=self.tr("Building PDF...", "PDF hazırlanıyor..."),
                                   text_color=COL_MUTED)
        self.update_idletasks()
        if tmp_path.exists():
            tmp_path.unlink()
        build_pdf_report_canvas_v9(self.df, tmp_path,
                                   source_name=self.data_source, language=lang)
        _validate_pdf_file_v4(str(tmp_path))
        os.replace(str(tmp_path), str(final_path))
        size = _validate_pdf_file_v4(str(final_path))
        self.data_status.configure(
            text=self.tr(f"PDF saved:\n{final_path.name}\n{size/1024:.1f} KB",
                         f"PDF kaydedildi:\n{final_path.name}\n{size/1024:.1f} KB"),
            text_color=COL_GOOD,
        )
        try:
            if os.name == "nt":
                os.startfile(str(out_dir))
            elif sys.platform == "darwin":
                subprocess.Popen(["open", str(out_dir)])
            else:
                subprocess.Popen(["xdg-open", str(out_dir)])
        except Exception:
            pass
    except Exception as e:
        try:
            if tmp_path.exists():
                tmp_path.unlink()
        except Exception:
            pass
        self.data_status.configure(
            text=self.tr(f"PDF export failed:\n{e}", f"PDF hatası:\n{e}"),
            text_color=COL_BAD,
        )


LineSightApp._table = table_readable_v10
LineSightApp._kpi_card = kpi_card_safe_v10
LineSightApp._add_bubble = add_bubble_fit_v10
LineSightApp._finish_bubble = finish_bubble_fit_v10
LineSightApp.export_report = export_report_pdf_v10


# ======================================================================
# V11 - GUARANTEED-VISIBLE TABLE (replaces ttk.Treeview entirely)
#   Root cause: ttk.Treeview shares a global style; in this multi-page app
#   the style gets reconfigured repeatedly, so rows render but their colors
#   collapse to an unreadable state. We bypass ttk and draw the table with
#   pure CustomTkinter widgets, so colors are always correct.
# ======================================================================
def _fmt_cell_v11(v):
    try:
        if isinstance(v, float):
            return f"{v:.3f}".rstrip("0").rstrip(".") if v % 1 else f"{int(v)}"
    except Exception:
        pass
    return "" if v is None else str(v)


def table_ctk_v11(self, parent, df, height=10, expand=False):
    outer = ctk.CTkFrame(parent, fg_color=COL_CARD, corner_radius=12,
                         border_width=1, border_color=COL_BORDER)
    outer.pack(fill="both", expand=expand, padx=10, pady=6)

    cols = [str(c) for c in df.columns]
    ncol = max(1, len(cols))

    # Header row
    header = ctk.CTkFrame(outer, fg_color=COL_PANEL_2, corner_radius=8)
    header.pack(fill="x", padx=8, pady=(8, 0))
    for j, c in enumerate(cols):
        header.grid_columnconfigure(j, weight=1, uniform="col")
        ctk.CTkLabel(header, text=c, font=("Segoe UI", 10, "bold"),
                     text_color=COL_TEXT, anchor="center").grid(
            row=0, column=j, sticky="nsew", padx=1, pady=6)

    # Scrollable body
    body = ctk.CTkScrollableFrame(outer, fg_color="transparent",
                                  height=max(120, height * 27),
                                  scrollbar_button_color=COL_PANEL_2,
                                  scrollbar_button_hover_color=COL_ACCENT)
    body.pack(fill="both", expand=True, padx=8, pady=(2, 8))
    for j in range(ncol):
        body.grid_columnconfigure(j, weight=1, uniform="col")

    for i, (_, r) in enumerate(df.iterrows()):
        rowbg = COL_CARD_ALT if i % 2 else COL_CARD
        for j, c in enumerate(df.columns):
            cell = ctk.CTkLabel(body, text=_fmt_cell_v11(r[c]),
                                font=("Segoe UI", 10), text_color=COL_TEXT,
                                fg_color=rowbg, anchor="center", corner_radius=0)
            cell.grid(row=i, column=j, sticky="nsew", padx=1, pady=1)


LineSightApp._table = table_ctk_v11


# ======================================================================
# V12 - FINAL FIXES
#   (1) Large tables froze the app -> cap rendered rows (default 100) and add
#       a "showing X of Y" note so big files (1000+ rows) never hang.
#   (2) KPI value clipped/overflowed the card -> taller card + centered layout.
#   (3) PDF export silently auto-saved -> bring back the Save-As dialog so the
#       user picks where to save, with a robust fallback.
# ======================================================================
def table_ctk_v12(self, parent, df, height=10, expand=False, max_rows=100):
    outer = ctk.CTkFrame(parent, fg_color=COL_CARD, corner_radius=12,
                         border_width=1, border_color=COL_BORDER)
    outer.pack(fill="both", expand=expand, padx=10, pady=6)

    total = len(df)
    shown = df.head(max_rows)
    cols = [str(c) for c in shown.columns]
    ncol = max(1, len(cols))

    # "showing X of Y" note for capped tables
    if total > max_rows:
        note = self.tr(f"Showing first {max_rows} of {total:,} rows.",
                       f"{total:,} satırın ilk {max_rows} tanesi gösteriliyor.") \
            if hasattr(self, "tr") else f"Showing first {max_rows} of {total:,} rows."
        ctk.CTkLabel(outer, text=note, font=("Segoe UI", 10),
                     text_color=COL_MUTED, anchor="w").pack(anchor="w", padx=12, pady=(8, 0))

    header = ctk.CTkFrame(outer, fg_color=COL_PANEL_2, corner_radius=8)
    header.pack(fill="x", padx=8, pady=(8, 0))
    for j, c in enumerate(cols):
        header.grid_columnconfigure(j, weight=1, uniform="col")
        ctk.CTkLabel(header, text=c, font=("Segoe UI", 10, "bold"),
                     text_color=COL_TEXT, anchor="center").grid(
            row=0, column=j, sticky="nsew", padx=1, pady=6)

    body = ctk.CTkScrollableFrame(outer, fg_color="transparent",
                                  height=max(120, height * 27),
                                  scrollbar_button_color=COL_PANEL_2,
                                  scrollbar_button_hover_color=COL_ACCENT)
    body.pack(fill="both", expand=True, padx=8, pady=(2, 8))
    for j in range(ncol):
        body.grid_columnconfigure(j, weight=1, uniform="col")

    # Build each row as ONE label (joined) — far lighter than one widget per cell,
    # so even the capped 100 rows render instantly. We pad columns for alignment.
    for i, (_, r) in enumerate(shown.iterrows()):
        rowbg = COL_CARD_ALT if i % 2 else COL_CARD
        for j, c in enumerate(shown.columns):
            ctk.CTkLabel(body, text=_fmt_cell_v11(r[c]),
                         font=("Segoe UI", 10), text_color=COL_TEXT,
                         fg_color=rowbg, anchor="center", corner_radius=0).grid(
                row=i, column=j, sticky="nsew", padx=1, pady=1)


def kpi_card_fixed_v12(self, parent, title, value, color, col, subtitle=""):
    # Taller card + centered vertical layout so the value never spills out.
    card = ctk.CTkFrame(parent, height=92, fg_color=COL_CARD, corner_radius=13,
                        border_width=1, border_color=COL_BORDER)
    card.grid(row=0, column=col, padx=5, pady=4, sticky="nsew")
    parent.grid_columnconfigure(col, weight=1)
    card.grid_propagate(False)
    inner = ctk.CTkFrame(card, fg_color="transparent")
    inner.place(relx=0.0, rely=0.5, anchor="w", x=12)  # vertically centered
    ctk.CTkLabel(inner, text=_clip_v10(title, 22).upper(), font=("Segoe UI", 9.5, "bold"),
                 text_color=COL_MUTED, anchor="w").pack(anchor="w", pady=(0, 3))
    ctk.CTkLabel(inner, text=_clip_v10(value, 18), font=("Segoe UI", 20, "bold"),
                 text_color=color, anchor="w").pack(anchor="w")
    return card


def export_report_with_dialog_v12(self):
    # Ask the user WHERE to save (this is what was missing).
    lang = getattr(self, "language", "TR")
    initial = ("LineSight_Yonetici_Raporu.pdf" if lang != "EN"
               else "LineSight_Executive_Report.pdf")
    try:
        path = filedialog.asksaveasfilename(
            title=self.tr("Save PDF Report", "PDF Raporu Kaydet") if hasattr(self, "tr") else "Save PDF Report",
            defaultextension=".pdf",
            filetypes=[("PDF", "*.pdf")],
            initialfile=initial,
        )
    except Exception:
        path = ""

    # If the dialog is unavailable/cancelled, fall back to the reports folder.
    if not path:
        path = str(_v7_reports_dir() / (initial.replace(".pdf", "")
                   + "_" + dt.datetime.now().strftime("%Y%m%d_%H%M%S") + ".pdf"))

    if not str(path).lower().endswith(".pdf"):
        path += ".pdf"

    folder = os.path.dirname(os.path.abspath(path)) or os.getcwd()
    tmp_path = os.path.join(folder, ".__fp_tmp_report.pdf")
    try:
        self.data_status.configure(
            text=self.tr("Building PDF...", "PDF hazırlanıyor...") if hasattr(self, "tr") else "Building PDF...",
            text_color=COL_MUTED)
        self.update_idletasks()
        if os.path.exists(tmp_path):
            os.remove(tmp_path)
        build_pdf_report_canvas_v9(self.df, tmp_path,
                                   source_name=self.data_source, language=lang)
        _validate_pdf_file_v4(tmp_path)
        os.replace(tmp_path, path)
        size = _validate_pdf_file_v4(path)
        self.data_status.configure(
            text=(self.tr(f"PDF saved:\n{os.path.basename(path)}\n{size/1024:.1f} KB",
                          f"PDF kaydedildi:\n{os.path.basename(path)}\n{size/1024:.1f} KB")
                  if hasattr(self, "tr") else f"PDF saved: {os.path.basename(path)}"),
            text_color=COL_GOOD)
        try:
            if os.name == "nt":
                os.startfile(path)
            elif sys.platform == "darwin":
                subprocess.Popen(["open", path])
            else:
                subprocess.Popen(["xdg-open", path])
        except Exception:
            pass
    except Exception as e:
        try:
            if os.path.exists(tmp_path):
                os.remove(tmp_path)
        except Exception:
            pass
        self.data_status.configure(
            text=(self.tr(f"PDF export failed:\n{e}", f"PDF hatası:\n{e}")
                  if hasattr(self, "tr") else f"PDF failed: {e}"),
            text_color=COL_BAD)


LineSightApp._table = table_ctk_v12
LineSightApp._kpi_card = kpi_card_fixed_v12
LineSightApp.export_report = export_report_with_dialog_v12


# ======================================================================
# V13 - RAW DATA TIDY + WIDE COLUMNS + PDF THAT RELIABLY OPENS
#   (1) Remove the redundant "showing all 500 rows" subtitle on Raw Data.
#   (2) Give each column a sensible minimum width so values like
#       ProductionDate are not cut off.
#   (3) PDF export: save to a guaranteed-writable folder, verify the bytes,
#       then OPEN THE FOLDER (not the file) so Adobe never reports
#       "file not found" on a stale/virtual path.
# ======================================================================
def _col_width_v13(colname, sample_values):
    name = str(colname).lower()
    longest = max([len(str(colname))] + [len(str(v)) for v in sample_values[:30]] or [0])
    # wide columns for dates/times/notes
    if any(t in name for t in ("date", "time", "tarih", "note", "not", "açıklama", "aciklama")):
        return max(150, min(220, longest * 8))
    return max(80, min(180, longest * 9))


def table_ctk_v13(self, parent, df, height=10, expand=False, max_rows=100):
    outer = ctk.CTkFrame(parent, fg_color=COL_CARD, corner_radius=12,
                         border_width=1, border_color=COL_BORDER)
    outer.pack(fill="both", expand=expand, padx=10, pady=6)

    total = len(df)
    shown = df.head(max_rows)
    cols = [str(c) for c in shown.columns]

    if total > max_rows:
        note = (self.tr(f"Showing first {max_rows} of {total:,} rows.",
                        f"{total:,} satırın ilk {max_rows} tanesi gösteriliyor.")
                if hasattr(self, "tr") else f"Showing first {max_rows} of {total:,} rows.")
        ctk.CTkLabel(outer, text=note, font=("Segoe UI", 10),
                     text_color=COL_MUTED, anchor="w").pack(anchor="w", padx=12, pady=(8, 0))

    # Pre-compute per-column widths from sample values so nothing gets clipped.
    widths = {c: _col_width_v13(c, [shown.iloc[r][c] for r in range(len(shown))])
              for c in shown.columns}

    # Horizontal scroll wrapper for wide tables (many columns).
    hwrap = ctk.CTkScrollableFrame(outer, fg_color="transparent",
                                   orientation="horizontal",
                                   height=max(140, height * 27) + 14,
                                   scrollbar_button_color=COL_PANEL_2,
                                   scrollbar_button_hover_color=COL_ACCENT)
    hwrap.pack(fill="both", expand=True, padx=8, pady=(4, 8))

    grid = ctk.CTkFrame(hwrap, fg_color="transparent")
    grid.pack(fill="both", expand=True)

    # header
    for j, c in enumerate(cols):
        ctk.CTkLabel(grid, text=c, width=widths[shown.columns[j]],
                     font=("Segoe UI", 10, "bold"), text_color=COL_TEXT,
                     fg_color=COL_PANEL_2, anchor="center", corner_radius=0).grid(
            row=0, column=j, sticky="nsew", padx=1, pady=(0, 1))

    for i, (_, r) in enumerate(shown.iterrows()):
        rowbg = COL_CARD_ALT if i % 2 else COL_CARD
        for j, c in enumerate(shown.columns):
            ctk.CTkLabel(grid, text=_fmt_cell_v11(r[c]), width=widths[c],
                         font=("Segoe UI", 10), text_color=COL_TEXT,
                         fg_color=rowbg, anchor="center", corner_radius=0).grid(
                row=i + 1, column=j, sticky="nsew", padx=1, pady=1)


def show_raw_data_v13(self):
    self.clear_content()
    area = ctk.CTkFrame(self.content, fg_color="transparent")
    area.pack(fill="both", expand=True)
    # No subtitle — the table itself shows the "first N of total" note.
    self._page_title(area, self.tr("Raw Data Explorer", "Ham Veri Gezgini"), None, icon="⌘")
    self._table(area, self.df, height=30, expand=True)


def _safe_reports_dir_v13():
    """A folder we can definitely write to and reopen (Documents > LineSight_Reports)."""
    from pathlib import Path
    home = Path.home()
    for base in [home / "Documents", home / "Belgeler", home / "Desktop",
                 home / "Masaüstü", home]:
        try:
            if base.exists():
                out = base / "LineSight_Reports"
                out.mkdir(parents=True, exist_ok=True)
                return out
        except Exception:
            continue
    out = home / "LineSight_Reports"
    out.mkdir(parents=True, exist_ok=True)
    return out


def export_report_v13(self):
    """Write the PDF to a known-good folder, verify it, then open the FOLDER."""
    from pathlib import Path
    lang = getattr(self, "language", "TR")
    out_dir = _safe_reports_dir_v13()
    stamp = dt.datetime.now().strftime("%Y%m%d_%H%M%S")
    prefix = "LineSight_Rapor" if lang != "EN" else "LineSight_Report"
    final_path = out_dir / f"{prefix}_{stamp}.pdf"
    tmp_path = out_dir / f".__tmp_{stamp}.pdf"
    try:
        self.data_status.configure(
            text=(self.tr("Building PDF...", "PDF hazırlanıyor...") if hasattr(self, "tr") else "Building PDF..."),
            text_color=COL_MUTED)
        self.update_idletasks()

        if tmp_path.exists():
            tmp_path.unlink()
        build_pdf_report_canvas_v9(self.df, str(tmp_path),
                                   source_name=self.data_source, language=lang)
        _validate_pdf_file_v4(str(tmp_path))
        os.replace(str(tmp_path), str(final_path))
        size = _validate_pdf_file_v4(str(final_path))

        self.data_status.configure(
            text=(self.tr(f"PDF saved to:\n{final_path}\n{size/1024:.1f} KB",
                          f"PDF kaydedildi:\n{final_path}\n{size/1024:.1f} KB")
                  if hasattr(self, "tr") else f"PDF saved: {final_path}"),
            text_color=COL_GOOD)

        # Open the CONTAINING FOLDER (not the file). This avoids Adobe's
        # "file not found" on stale/virtual paths and lets the user click it.
        try:
            if os.name == "nt":
                os.startfile(str(out_dir))
            elif sys.platform == "darwin":
                subprocess.Popen(["open", str(out_dir)])
            else:
                subprocess.Popen(["xdg-open", str(out_dir)])
        except Exception:
            pass
    except Exception as e:
        try:
            if tmp_path.exists():
                tmp_path.unlink()
        except Exception:
            pass
        self.data_status.configure(
            text=(self.tr(f"PDF export failed:\n{e}", f"PDF hatası:\n{e}")
                  if hasattr(self, "tr") else f"PDF failed: {e}"),
            text_color=COL_BAD)


LineSightApp._table = table_ctk_v13
LineSightApp.show_raw_data = show_raw_data_v13
LineSightApp.export_report = export_report_v13


# ======================================================================
# V14 - AI-SUMMARY PDF, ZERO DEPENDENCIES, ALWAYS-WORKS BUTTON
#   Why the button "did nothing": the PDF builder imported reportlab inside
#   the function. On machines without reportlab installed, it raised
#   ModuleNotFoundError and the only feedback was a tiny status label.
#
#   This patch:
#   - Builds the PDF with a PURE-PYTHON writer (build_minimal_pdf_report_v4),
#     so no external library is required and it can never silently fail to import.
#   - Asks Gemini (if a key is set) for a real executive summary, else uses the
#     local analysis engine — either way the PDF contains an AI summary.
#   - Runs generation in a background thread so the UI never freezes.
#   - Shows a clear popup on success/failure (not just the corner label).
# ======================================================================
from tkinter import messagebox as _mbox_v14


def _ai_summary_for_pdf_v14(self):
    """Return an AI dict {headline, narrative, machines, operator_shift_note}.
    Uses Gemini when a key is present; otherwise the deterministic local engine."""
    df = self.df
    key = getattr(self, "api_key", "") or get_api_key()
    lang = getattr(self, "language", "TR")
    # 1) Try Gemini for a genuine, fresh summary.
    if key:
        try:
            res = ai_analyze(df, api_key=key)
            if res and res.get("source") == "gemini":
                return res
        except Exception:
            pass
    # 2) Cached analysis from the AI page, if any.
    if getattr(self, "ai_cache", None):
        return self.ai_cache
    # 3) Local deterministic summary (always available).
    try:
        return _report_ai_safe_v8(df, lang)
    except Exception:
        headline, insights = generate_ai_insights(df)
        return {"source": "local", "headline": headline,
                "machines": [{"machine": i["machine"], "priority": i["priority"],
                              "recommendation": i["message"]} for i in insights],
                "narrative": "", "operator_shift_note": ""}


def export_report_v14(self):
    from pathlib import Path

    lang = getattr(self, "language", "TR")
    out_dir = _safe_reports_dir_v13()
    stamp = dt.datetime.now().strftime("%Y%m%d_%H%M%S")
    prefix = "LineSight_Rapor" if lang != "EN" else "LineSight_Report"
    final_path = out_dir / f"{prefix}_{stamp}.pdf"

    # Immediate feedback so the user knows the click registered.
    try:
        self.data_status.configure(
            text=(self.tr("Preparing AI report...", "AI raporu hazırlanıyor...")
                  if hasattr(self, "tr") else "Preparing AI report..."),
            text_color=COL_MUTED)
        self.update_idletasks()
    except Exception:
        pass

    df = self.df
    source = self.data_source

    def worker():
        err = None
        try:
            ai = _ai_summary_for_pdf_v14(self)
            # Pure-python PDF (no reportlab dependency) with the AI summary inside.
            build_minimal_pdf_report_v4(df, ai=ai, output_path=str(final_path),
                                        source_name=source)
            _validate_pdf_file_v4(str(final_path))
        except Exception as e:
            err = e
        # Back to the UI thread for status + popup + folder open.
        try:
            self.after(0, lambda: _export_done_v14(self, final_path, out_dir, err))
        except Exception:
            pass

    threading.Thread(target=worker, daemon=True).start()


def _export_done_v14(self, final_path, out_dir, err):
    if err is not None:
        try:
            self.data_status.configure(
                text=(self.tr(f"PDF failed:\n{err}", f"PDF hatası:\n{err}")
                      if hasattr(self, "tr") else f"PDF failed: {err}"),
                text_color=COL_BAD)
        except Exception:
            pass
        try:
            _mbox_v14.showerror(
                self.tr("PDF Error", "PDF Hatası") if hasattr(self, "tr") else "PDF Error",
                str(err))
        except Exception:
            pass
        return

    size = 0
    try:
        size = os.path.getsize(str(final_path))
    except Exception:
        pass

    try:
        self.data_status.configure(
            text=(self.tr(f"PDF saved:\n{final_path.name}\n{size/1024:.1f} KB",
                          f"PDF kaydedildi:\n{final_path.name}\n{size/1024:.1f} KB")
                  if hasattr(self, "tr") else f"PDF saved: {final_path.name}"),
            text_color=COL_GOOD)
    except Exception:
        pass

    # Open the folder so the user can click the PDF (avoids Adobe stale-path error).
    try:
        if os.name == "nt":
            os.startfile(str(out_dir))
        elif sys.platform == "darwin":
            subprocess.Popen(["open", str(out_dir)])
        else:
            subprocess.Popen(["xdg-open", str(out_dir)])
    except Exception:
        pass

    # Clear, visible confirmation popup with the exact location.
    try:
        msg = (self.tr(
            f"Report created successfully.\n\nSaved to:\n{final_path}",
            f"Rapor başarıyla oluşturuldu.\n\nKaydedildiği yer:\n{final_path}")
            if hasattr(self, "tr") else f"Report saved:\n{final_path}")
        _mbox_v14.showinfo(
            self.tr("Report Ready", "Rapor Hazır") if hasattr(self, "tr") else "Report Ready",
            msg)
    except Exception:
        pass


LineSightApp.export_report = export_report_v14


# ======================================================================
# V15 - STYLED DARK "AUTO-CORRECT" LOOK PDF (pure-python, no reportlab)
#   Mimics the user's Auto-Correct report: dark background, red title header,
#   metric cards, colored right-aligned value rows, numbered recommendation
#   cards, and a red "critical risk" + green "expected impact" footer.
#   Draws everything with raw PDF content-stream commands so it needs NO
#   external library and can never silently fail to import.
# ======================================================================

# ---- palette (0-1 RGB for PDF) ----
_V15 = {
    "bg":        (0.043, 0.067, 0.122),   # #0b1120 deep navy
    "panel":     (0.094, 0.129, 0.208),   # #18213a section header bar
    "card":      (0.071, 0.106, 0.180),   # #12182e card fill
    "card_brd":  (0.176, 0.231, 0.345),   # #2d3b58 card border
    "text":      (0.890, 0.925, 0.973),   # near white
    "muted":     (0.541, 0.627, 0.749),   # #8aa0bf
    "faint":     (0.380, 0.451, 0.561),   # dim label
    "red":       (0.937, 0.267, 0.267),   # #ef4444
    "amber":     (0.961, 0.620, 0.043),   # #f59e0b
    "green":     (0.133, 0.773, 0.369),   # #22c55e
    "blue":      (0.310, 0.549, 1.000),   # #4f8cff
    "purple":    (0.545, 0.361, 0.965),   # #8b5cf6
    "purple_bg": (0.149, 0.106, 0.235),   # dark purple panel
    "red_bg":    (0.204, 0.090, 0.094),   # dark red card
    "green_bg":  (0.071, 0.169, 0.118),   # dark green card
    "red_brd":   (0.545, 0.176, 0.176),
    "green_brd": (0.122, 0.380, 0.247),
}

PAGE_W, PAGE_H = 595.0, 842.0


class _PDFCanvas_v15:
    """Tiny content-stream canvas: filled rects, lines, and positioned text."""
    def __init__(self):
        self.pages = []
        self.cmds = []

    def new_page(self, bg):
        if self.cmds:
            self.pages.append("\n".join(self.cmds))
            self.cmds = []
        r, g, b = bg
        self.cmds.append(f"{r:.3f} {g:.3f} {b:.3f} rg 0 0 {PAGE_W} {PAGE_H} re f")

    def finish(self):
        if self.cmds:
            self.pages.append("\n".join(self.cmds))
            self.cmds = []

    def rect(self, x, y, w, h, color, radius=0):
        r, g, b = color
        # (radius is visual-only; raw rects are square but the look is close)
        self.cmds.append(f"{r:.3f} {g:.3f} {b:.3f} rg {x:.2f} {y:.2f} {w:.2f} {h:.2f} re f")

    def stroke_rect(self, x, y, w, h, color, lw=1.0):
        r, g, b = color
        self.cmds.append(
            f"{r:.3f} {g:.3f} {b:.3f} RG {lw:.2f} w {x:.2f} {y:.2f} {w:.2f} {h:.2f} re S")

    def line(self, x1, y1, x2, y2, color, lw=1.0):
        r, g, b = color
        self.cmds.append(
            f"{r:.3f} {g:.3f} {b:.3f} RG {lw:.2f} w {x1:.2f} {y1:.2f} m {x2:.2f} {y2:.2f} l S")

    def text(self, x, y, s, size, color, bold=False):
        r, g, b = color
        font = "/F2" if bold else "/F1"
        s = _pdf_string_v4(s)
        self.cmds.append(
            f"{r:.3f} {g:.3f} {b:.3f} rg BT {font} {size:.1f} Tf {x:.2f} {y:.2f} Td ({s}) Tj ET")

    def text_right(self, x_right, y, s, size, color, bold=False):
        # crude width estimate for Helvetica
        w = self._approx_width(_pdf_safe_text_v4(s), size, bold)
        self.text(x_right - w, y, s, size, color, bold)

    def text_center(self, cx, y, s, size, color, bold=False):
        w = self._approx_width(_pdf_safe_text_v4(s), size, bold)
        self.text(cx - w / 2.0, y, s, size, color, bold)

    @staticmethod
    def _approx_width(s, size, bold=False):
        # average Helvetica advance ~0.52em (bold ~0.55em)
        k = 0.55 if bold else 0.52
        return len(s) * size * k

    def build_bytes(self):
        self.finish()
        objects = []

        def add(s):
            objects.append(s)
            return len(objects)

        add("<< /Type /Catalog /Pages 2 0 R >>")
        add("PAGES")
        f1 = add("<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica >>")
        f2 = add("<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica-Bold >>")

        page_ids = []
        for content in self.pages:
            stream = content.encode("latin-1", "replace")
            cid = add(f"<< /Length {len(stream)} >>\nstream\n"
                      + stream.decode("latin-1") + "\nendstream")
            pid = add(f"<< /Type /Page /Parent 2 0 R /MediaBox [0 0 {PAGE_W:.0f} {PAGE_H:.0f}] "
                      f"/Resources << /Font << /F1 {f1} 0 R /F2 {f2} 0 R >> >> "
                      f"/Contents {cid} 0 R >>")
            page_ids.append(pid)

        objects[1] = (f"<< /Type /Pages /Kids [{' '.join(str(p)+' 0 R' for p in page_ids)}] "
                      f"/Count {len(page_ids)} >>")

        pdf = bytearray()
        pdf.extend(b"%PDF-1.4\n%LineSight\n")
        offsets = [0]
        for i, obj in enumerate(objects, start=1):
            offsets.append(len(pdf))
            pdf.extend(f"{i} 0 obj\n".encode("latin-1"))
            pdf.extend(obj.encode("latin-1", "replace"))
            pdf.extend(b"\nendobj\n")
        xref = len(pdf)
        pdf.extend(f"xref\n0 {len(objects)+1}\n".encode("latin-1"))
        pdf.extend(b"0000000000 65535 f \n")
        for off in offsets[1:]:
            pdf.extend(f"{off:010d} 00000 n \n".encode("latin-1"))
        pdf.extend(f"trailer\n<< /Size {len(objects)+1} /Root 1 0 R >>\n"
                   f"startxref\n{xref}\n%%EOF\n".encode("latin-1"))
        return bytes(pdf)


def _v15_section_header(c, y, title):
    """Full-width panel bar with a small caps label, returns new y (below bar)."""
    c.rect(40, y - 26, PAGE_W - 80, 26, _V15["panel"])
    c.text(54, y - 18, _spaced_caps_v15(title), 9.5, _V15["muted"], bold=True)
    return y - 26


def _spaced_caps_v15(s):
    s = _pdf_safe_text_v4(s).upper()
    return " ".join(list(s.replace(" ", "  ")))  # letter-spaced look


def _v15_metric_card(c, x, y, w, h, label, value, value_color):
    c.rect(x, y - h, w, h, _V15["card"])
    c.stroke_rect(x, y - h, w, h, _V15["card_brd"], 0.8)
    c.text_center(x + w / 2, y - 22, _spaced_caps_v15(label), 7.5, _V15["faint"], bold=True)
    c.text_center(x + w / 2, y - 48, value, 20, value_color, bold=True)


def _v15_value_row(c, y, left, right, right_color, h=24):
    c.rect(40, y - h, PAGE_W - 80, h, _V15["card"])
    c.text(54, y - 16, left, 9.5, _V15["text"])
    c.text_right(PAGE_W - 54, y - 16, right, 9.5, right_color, bold=True)
    return y - h - 4


def _v15_rec_card(c, y, num, title, body_lines):
    pad = 12
    line_h = 12
    body_h = max(1, len(body_lines)) * line_h
    h = 22 + body_h + pad
    x = 50
    w = PAGE_W - 100
    c.rect(x, y - h, w, h, _V15["card"])
    c.stroke_rect(x, y - h, w, h, _V15["card_brd"], 0.8)
    # numbered circle (drawn as small filled square-ish badge)
    c.rect(x + 12, y - 26, 16, 16, _V15["blue"])
    c.text_center(x + 20, y - 22, str(num), 9, (1, 1, 1), bold=True)
    c.text(x + 38, y - 22, title, 10.5, _V15["text"], bold=True)
    ty = y - 40
    for ln in body_lines:
        c.text(x + 38, ty, ln, 8.8, _V15["muted"])
        ty -= line_h
    return y - h - 10


def build_pdf_styled_v15(df, output_path, ai=None, source_name="Data", language="TR"):
    """Auto-Correct styled, dependency-free executive PDF."""
    TR = str(language or "TR").upper() == "TR"
    if ai is None:
        try:
            ai = _report_ai_safe_v8(df, language)
        except Exception:
            ai = {"headline": "", "machines": [], "narrative": "", "operator_shift_note": ""}

    k = overall_kpis(df)
    ms = build_machine_summary(df)
    shift = build_group_summary(df, "Shift")
    now = dt.datetime.now().strftime("%d.%m.%Y %H:%M:%S")

    def L(tr, en):
        return tr if TR else en

    c = _PDFCanvas_v15()

    # ---------------- PAGE 1 ----------------
    c.new_page(_V15["bg"])

    # Title header
    c.text(42, PAGE_H - 46, "LineSight", 26, _V15["red"], bold=True)
    c.text(42, PAGE_H - 64, L("Uretim Kalitesi & Bakim Karar Destek Platformu",
                              "Production Quality & Maintenance Decision Platform"),
           10, _V15["muted"])
    c.text(42, PAGE_H - 78, L("SPC . Cp/Cpk . Kritiklik Skoru . AI Analiz",
                              "SPC . Cp/Cpk . Criticality . AI Analysis"),
           8, _V15["faint"])
    # date top-right
    c.text_right(PAGE_W - 42, PAGE_H - 40, L("Olusturulma Tarihi", "Generated"), 8, _V15["faint"])
    c.text_right(PAGE_W - 42, PAGE_H - 54, now, 9.5, _V15["muted"], bold=True)
    # red separator
    c.rect(0, PAGE_H - 92, PAGE_W, 2, _V15["red"])

    # Title bar card (report name)
    c.rect(40, PAGE_H - 138, PAGE_W - 80, 34, _V15["card"])
    c.stroke_rect(40, PAGE_H - 138, PAGE_W - 80, 34, _V15["card_brd"], 0.8)
    c.text(54, PAGE_H - 126, L("Yonetici Uretim Raporu", "Executive Production Report"),
           13, _V15["text"], bold=True)

    y = PAGE_H - 158

    # SYSTEM METRICS section
    y = _v15_section_header(c, y, L("SISTEM METRIKLERI", "SYSTEM METRICS"))
    y -= 10
    cards_top = y
    cw = (PAGE_W - 80 - 2 * 12) / 3.0
    cardh = 64
    pr = k["pass_rate"]
    pr_col = _V15["green"] if pr >= 95 else _V15["amber"] if pr >= 90 else _V15["red"]
    fc_col = _V15["red"]
    cpk = k.get("cpk")
    cpk_col = _V15["green"] if (cpk or 0) >= 1.33 else _V15["amber"] if (cpk or 0) >= 1.0 else _V15["red"]
    _v15_metric_card(c, 40, cards_top, cw, cardh,
                     L("TOPLAM KONTROL", "INSPECTIONS"), f"{k['total']:,}", _V15["blue"])
    _v15_metric_card(c, 40 + cw + 12, cards_top, cw, cardh,
                     L("GECME ORANI", "PASS RATE"), f"{pr:.1f}%", pr_col)
    _v15_metric_card(c, 40 + 2 * (cw + 12), cards_top, cw, cardh,
                     "CPK", f"{cpk:.2f}" if cpk is not None else "N/A", cpk_col)
    y = cards_top - cardh - 12

    # second metric row: cost / failure rate / downtime
    cards_top = y
    _v15_metric_card(c, 40, cards_top, cw, cardh,
                     L("HATA MALIYETI", "FAILURE COST"), f"${k['cost']:,.0f}", _V15["red"])
    _v15_metric_card(c, 40 + cw + 12, cards_top, cw, cardh,
                     L("HATA ORANI", "FAILURE RATE"), f"{k['fail_rate']:.1f}%", _V15["amber"])
    _v15_metric_card(c, 40 + 2 * (cw + 12), cards_top, cw, cardh,
                     L("DURUS (DK)", "DOWNTIME (MIN)"), f"{k['downtime']:,.0f}", _V15["blue"])
    y = cards_top - cardh - 16

    # MACHINE RISK SUMMARY section (top machines, value-row style)
    y = _v15_section_header(c, y, L("MAKINE RISK OZETI", "MACHINE RISK SUMMARY"))
    y -= 8
    top_ms = ms.head(8) if not ms.empty else ms
    for _, r in top_ms.iterrows():
        cpk_v = r["Cpk"]
        col = _V15["green"] if (pd.notna(cpk_v) and cpk_v >= 1.33) else \
              _V15["amber"] if (pd.notna(cpk_v) and cpk_v >= 1.0) else _V15["red"]
        left = f"{r['Machine_ID']}  -  {L('ariza','fail')} {r['Failure_Rate']:.1f}%  .  ${r['Failure_Cost']:,.0f}"
        right = f"Cpk {cpk_v:.2f}  .  {L('skor','score')} {r['Criticality_Score']:.0f}" if pd.notna(cpk_v) \
                else f"{L('skor','score')} {r['Criticality_Score']:.0f}"
        y = _v15_value_row(c, y, left, right, col)
        if y < 120:
            break

    # SHIFT SUMMARY section
    y -= 6
    if y > 170:
        y = _v15_section_header(c, y, L("VARDIYA OZETI", "SHIFT SUMMARY"))
        y -= 8
        for _, r in shift.iterrows():
            col = _V15["red"] if r["Failure_Rate"] >= 12 else _V15["amber"] if r["Failure_Rate"] >= 8 else _V15["green"]
            left = f"{r['Shift']}  -  {int(r['Inspections'])} {L('kontrol','checks')}"
            right = f"{L('ariza','fail')} {r['Failure_Rate']:.1f}%  .  ${r['Failure_Cost']:,.0f}"
            y = _v15_value_row(c, y, left, right, col)
            if y < 90:
                break

    # footer line page 1
    c.text(42, 30, L("LineSight - Uretim Kalitesi Raporu", "LineSight - Production Quality Report"),
           7.5, _V15["faint"])
    c.text_right(PAGE_W - 42, 30, now, 7.5, _V15["faint"])

    # ---------------- PAGE 2 ----------------
    c.new_page(_V15["bg"])

    # purple AI header card
    c.rect(40, PAGE_H - 96, PAGE_W - 80, 56, _V15["purple_bg"])
    c.stroke_rect(40, PAGE_H - 96, PAGE_W - 80, 56, _V15["purple"], 0.8)
    c.text(58, PAGE_H - 62, "* " + L("AI Cozumleri & Onerileri", "AI Solutions & Recommendations"),
           14, _V15["text"], bold=True)
    src = ai.get("source", "local")
    badge = L("GEMINI AI", "GEMINI AI") if src == "gemini" else L("YEREL ANALIZ MOTORU", "LOCAL ANALYSIS ENGINE")
    c.text(58, PAGE_H - 80, "o " + badge, 8, _V15["muted"])
    c.stroke_rect(PAGE_W - 150, PAGE_H - 74, 96, 20, _V15["purple"], 0.8)
    c.text_center(PAGE_W - 102, PAGE_H - 68, badge.split()[0], 8, _V15["purple"], bold=True)

    y = PAGE_H - 116

    # DURUM OZETI (status summary)
    y = _v15_section_header(c, y, L("DURUM OZETI", "STATUS SUMMARY"))
    y -= 10
    headline = ai.get("headline", "") or L("Ozet bulunamadi.", "No summary available.")
    box_lines = _wrap_text_v4(headline, 92)
    nh = max(1, len(box_lines))
    c.rect(40, y - (nh * 13 + 14), PAGE_W - 80, nh * 13 + 14, _V15["card"])
    ty = y - 16
    for ln in box_lines:
        c.text(54, ty, ln, 9.2, _V15["text"])
        ty -= 13
    y = y - (nh * 13 + 14) - 16

    # SOMUT ONERILER (numbered recommendation cards)
    y = _v15_section_header(c, y, L("SOMUT ONERILER", "CONCRETE RECOMMENDATIONS"))
    y -= 12
    machines = ai.get("machines", [])[:4]
    for idx, mrec in enumerate(machines, start=1):
        mid = mrec.get("machine", "")
        pr = mrec.get("priority", "")
        rec = mrec.get("recommendation", "")
        title = f"{mid}  -  {pr}"
        body = _wrap_text_v4(rec, 88)[:3]
        if y - (40 + len(body) * 12) < 150:
            break
        y = _v15_rec_card(c, y, idx, title, body)

    # KRITIK RISK (red) + BEKLENEN ETKI (green) footer cards
    foot_h = 78
    foot_y = max(y, 150)
    half = (PAGE_W - 80 - 16) / 2.0
    # red
    c.rect(40, foot_y - foot_h, half, foot_h, _V15["red_bg"])
    c.stroke_rect(40, foot_y - foot_h, half, foot_h, _V15["red_brd"], 0.8)
    c.text(52, foot_y - 16, "! " + L("KRITIK RISK", "CRITICAL RISK"), 9, _V15["red"], bold=True)
    risk_txt = L(
        f"En kritik makinede acil mudahale yapilmazsa hata maliyeti ve durus suresi artar.",
        f"Without urgent action on the top machine, failure cost and downtime will rise.")
    ry = foot_y - 30
    for ln in _wrap_text_v4(risk_txt, 44)[:4]:
        c.text(52, ry, ln, 8, _V15["muted"]); ry -= 11
    # green
    gx = 40 + half + 16
    c.rect(gx, foot_y - foot_h, half, foot_h, _V15["green_bg"])
    c.stroke_rect(gx, foot_y - foot_h, half, foot_h, _V15["green_brd"], 0.8)
    c.text(gx + 12, foot_y - 16, "OK " + L("BEKLENEN ETKI", "EXPECTED IMPACT"), 9, _V15["green"], bold=True)
    imp_txt = L(
        "Oncelikli makinede merkezleme + varyasyon dusurme ile Cpk hedefe yaklasir, hata maliyeti dususur.",
        "Centering and variation reduction on the priority machine moves Cpk toward target and cuts failure cost.")
    gy = foot_y - 30
    for ln in _wrap_text_v4(imp_txt, 44)[:4]:
        c.text(gx + 12, gy, ln, 8, _V15["muted"]); gy -= 11

    c.text(42, 30, L("LineSight - Gizli", "LineSight - Confidential"), 7.5, _V15["faint"])
    c.text_right(PAGE_W - 42, 30, now, 7.5, _V15["faint"])

    data = c.build_bytes()
    with open(output_path, "wb") as f:
        f.write(data)
    return output_path


# ---- v15 export: use the styled dark PDF, AI summary inside, threaded, popup ----
def export_report_v15(self):
    from pathlib import Path
    lang = getattr(self, "language", "TR")
    out_dir = _safe_reports_dir_v13()
    stamp = dt.datetime.now().strftime("%Y%m%d_%H%M%S")
    prefix = "LineSight_Rapor" if lang != "EN" else "LineSight_Report"
    final_path = out_dir / f"{prefix}_{stamp}.pdf"
    try:
        self.data_status.configure(
            text=(self.tr("Preparing AI report...", "AI raporu hazırlanıyor...")
                  if hasattr(self, "tr") else "Preparing AI report..."),
            text_color=COL_MUTED)
        self.update_idletasks()
    except Exception:
        pass
    df = self.df
    source = self.data_source

    def worker():
        err = None
        try:
            ai = _ai_summary_for_pdf_v14(self)
            build_pdf_styled_v15(df, str(final_path), ai=ai,
                                 source_name=source, language=lang)
            _validate_pdf_file_v4(str(final_path))
        except Exception as e:
            err = e
        try:
            self.after(0, lambda: _export_done_v14(self, final_path, out_dir, err))
        except Exception:
            pass

    threading.Thread(target=worker, daemon=True).start()


LineSightApp.export_report = export_report_v15




