    prompts = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=16, border_width=1, border_color=COL_BORDER)
    prompts.pack(fill="x", padx=12, pady=(0, 10))
    ctk.CTkLabel(prompts, text=self.tr("Prompt Starters", "Hazır Sorular"), font=("Segoe UI", 13, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=12, pady=(12, 8))
