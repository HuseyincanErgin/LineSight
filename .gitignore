        ctk.CTkLabel(intro, text=self.tr("This area is intentionally large so the AI answers remain readable in screenshots and live presentations.", "Bu alan özellikle büyük bırakıldı; AI cevapları ekran görüntüsünde ve canlı sunumda rahat okunur."), font=("Segoe UI", 13), text_color=COL_MUTED, wraplength=900, justify="left").pack(anchor="w", padx=18, pady=(0, 18))

