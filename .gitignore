# ======================================================================
# FINAL FIX PATCH (v4) - PDF THAT OPENS + TRULY LARGE AI CHAT
# ======================================================================
def _pdf_safe_text_v4(value):
    """Return PDF-friendly text. Keep it simple so fallback PDF never breaks."""
    if value is None:
        return ""
    text = str(value)
    repl = {
        "—": "-", "–": "-", "•": "-", "✓": "OK", "✦": "*",
        "ı": "i", "İ": "I", "ğ": "g", "Ğ": "G", "ü": "u", "Ü": "U",
        "ş": "s", "Ş": "S", "ö": "o", "Ö": "O", "ç": "c", "Ç": "C",
        "₺": "TL", "€": "EUR", "’": "'", "“": '"', "”": '"',
    }
    for a, b in repl.items():
        text = text.replace(a, b)
    return text.encode("latin-1", "replace").decode("latin-1")


def _wrap_text_v4(text, max_chars=95):
    import textwrap
    text = _pdf_safe_text_v4(text).replace("\r", " ")
    lines = []
    for part in text.split("\n"):
        part = part.strip()
        if not part:
            lines.append("")
        else:
            lines.extend(textwrap.wrap(part, width=max_chars, break_long_words=False, replace_whitespace=False))
    return lines


def _pdf_string_v4(text):
    text = _pdf_safe_text_v4(text)
    return text.replace("\\", "\\\\").replace("(", "\\(").replace(")", "\\)")


def build_minimal_pdf_report_v4(df, ai=None, output_path="LineSight_Report.pdf", source_name="Data"):
    """
    Dependency-free fallback PDF generator.
    It creates a valid multi-page PDF using standard Helvetica fonts only.
    This prevents 0-byte/broken PDF outputs even if ReportLab fails on a user's PC.
    """
    if ai is None:
        ai = ai_analyze(df)

    k = overall_kpis(df)
    machine = build_machine_summary(df)
    op = build_group_summary(df, "Operator_ID")
    shift = build_group_summary(df, "Shift")
    now = dt.datetime.now().strftime("%Y-%m-%d %H:%M")

    cp_txt = f"{k['cp']:.2f}" if k.get('cp') is not None else "N/A"
    cpk_txt = f"{k['cpk']:.2f}" if k.get('cpk') is not None else "N/A"

    content_lines = []
    def add_title(t):
        content_lines.append(("TITLE", t))
    def add_h(t):
        content_lines.append(("H", t))
    def add_p(t):
        for line in _wrap_text_v4(t, 92):
            content_lines.append(("P", line))
        content_lines.append(("SP", ""))
    def add_table(title, rows):
        add_h(title)
        for r in rows:
            add_p(" | ".join(_pdf_safe_text_v4(x) for x in r))

    add_title("LineSight - Executive Production Report")
    add_p(f"Generated: {now} | Dataset: {source_name}")
    add_p(f"Inspections: {k['total']:,} | Pass Rate: {k['pass_rate']:.1f}% | Failure Rate: {k['fail_rate']:.1f}% | Failure Cost: ${k['cost']:,.0f} | Cp/Cpk: {cp_txt}/{cpk_txt}")
    add_h("Executive Summary")
    add_p(ai.get("headline", "No executive headline generated."))
    if ai.get("narrative"):
        add_p(ai.get("narrative"))
    if ai.get("operator_shift_note"):
        add_p("Operator / Shift: " + ai.get("operator_shift_note"))

    add_h("Priority Recommendations")
    recs = ai.get("machines", []) or []
    if recs:
        for item in recs[:7]:
            add_p(f"{item.get('machine','Unknown')} - {item.get('priority','')}: {item.get('recommendation','')}")
    else:
        add_p("No AI recommendations available.")

    if not machine.empty:
        rows = [["Machine", "Fail", "FailRate", "Cost", "Downtime", "Cp", "Cpk", "Score"]]
        for _, r in machine.iterrows():
            rows.append([
                r.get("Machine_ID", ""),
                f"{int(r.get('Failures',0))}",
                f"{float(r.get('Failure_Rate',0)):.2f}%",
                f"${float(r.get('Failure_Cost',0)):,.0f}",
                f"{float(r.get('Downtime_Minutes',0)):,.0f}",
                f"{float(r.get('Cp',0)):.2f}" if pd.notna(r.get('Cp', np.nan)) else "-",
                f"{float(r.get('Cpk',0)):.2f}" if pd.notna(r.get('Cpk', np.nan)) else "-",
                f"{float(r.get('Criticality_Score',0)):.1f}",
            ])
        add_table("Machine Analysis", rows)

    if not op.empty:
        rows = [["Operator", "Inspections", "Failures", "FailRate", "PassRate", "Cost"]]
        for _, r in op.head(10).iterrows():
            rows.append([
                r.get("Operator_ID", ""), f"{int(r.get('Inspections',0))}", f"{int(r.get('Failures',0))}",
                f"{float(r.get('Failure_Rate',0)):.2f}%", f"{float(r.get('Pass_Rate',0)):.2f}%", f"${float(r.get('Failure_Cost',0)):,.0f}",
            ])
        add_table("Operator Performance", rows)

    if not shift.empty:
        rows = [["Shift", "Inspections", "Failures", "FailRate", "PassRate", "Cost"]]
        for _, r in shift.iterrows():
            rows.append([
                r.get("Shift", ""), f"{int(r.get('Inspections',0))}", f"{int(r.get('Failures',0))}",
                f"{float(r.get('Failure_Rate',0)):.2f}%", f"{float(r.get('Pass_Rate',0)):.2f}%", f"${float(r.get('Failure_Cost',0)):,.0f}",
            ])
        add_table("Shift Performance", rows)

    add_h("Cp / Cpk Interpretation")
    add_p(f"Overall capability verdict: {capability_verdict(k.get('cpk'))}. Guide: Cpk >= 1.33 is capable, 1.00-1.33 is marginal, and below 1.00 is not capable. Improve Cpk by centering the mean, reducing variation, recalibrating tools and using SPC warning limits.")

    # Build pages as PDF drawing commands.
    pages = []
    y_start = 790
    y = y_start
    cmds = ["0.96 0.98 1 rg 0 0 595 842 re f", "0.05 0.12 0.25 rg 0 805 595 37 re f"]

    def flush_page():
        nonlocal cmds, y
        cmds.append("0.36 0.43 0.55 rg BT /F1 8 Tf 450 18 Td (LineSight Report) Tj ET")
        pages.append("\n".join(cmds))
        y = y_start
        cmds = ["0.96 0.98 1 rg 0 0 595 842 re f", "0.05 0.12 0.25 rg 0 805 595 37 re f"]

    for kind, text in content_lines:
        if y < 55:
            flush_page()
        if kind == "TITLE":
            cmds.append(f"1 1 1 rg BT /F2 19 Tf 42 816 Td ({_pdf_string_v4(text)}) Tj ET")
            y = 770
        elif kind == "H":
            y -= 10
            if y < 60:
                flush_page()
            cmds.append(f"0.06 0.18 0.37 rg BT /F2 13 Tf 42 {y} Td ({_pdf_string_v4(text)}) Tj ET")
            y -= 18
        elif kind == "P":
            if text:
                cmds.append(f"0.07 0.13 0.24 rg BT /F1 9.2 Tf 42 {y} Td ({_pdf_string_v4(text)}) Tj ET")
            y -= 13
        elif kind == "SP":
            y -= 4
    flush_page()

    objects = []
    def add_obj(s):
        objects.append(s)
        return len(objects)

    catalog_id = add_obj("<< /Type /Catalog /Pages 2 0 R >>")
    pages_id = add_obj("PAGES_PLACEHOLDER")
    font1_id = add_obj("<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica >>")
    font2_id = add_obj("<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica-Bold >>")

    page_ids = []
    for content in pages:
        stream = content.encode("latin-1", "replace")
        content_id = add_obj(f"<< /Length {len(stream)} >>\nstream\n" + stream.decode("latin-1") + "\nendstream")
        page_id = add_obj(f"<< /Type /Page /Parent 2 0 R /MediaBox [0 0 595 842] /Resources << /Font << /F1 {font1_id} 0 R /F2 {font2_id} 0 R >> >> /Contents {content_id} 0 R >>")
        page_ids.append(page_id)

    objects[pages_id-1] = f"<< /Type /Pages /Kids [{' '.join(str(pid) + ' 0 R' for pid in page_ids)}] /Count {len(page_ids)} >>"

    pdf = bytearray()
    pdf.extend(b"%PDF-1.4\n%LineSight\n")
    offsets = [0]
    for i, obj in enumerate(objects, start=1):
        offsets.append(len(pdf))
        pdf.extend(f"{i} 0 obj\n".encode("latin-1"))
        pdf.extend(obj.encode("latin-1", "replace"))
        pdf.extend(b"\nendobj\n")
    xref_pos = len(pdf)
    pdf.extend(f"xref\n0 {len(objects)+1}\n".encode("latin-1"))
    pdf.extend(b"0000000000 65535 f \n")
    for off in offsets[1:]:
        pdf.extend(f"{off:010d} 00000 n \n".encode("latin-1"))
    pdf.extend(f"trailer\n<< /Size {len(objects)+1} /Root 1 0 R >>\nstartxref\n{xref_pos}\n%%EOF\n".encode("latin-1"))

    with open(output_path, "wb") as f:
        f.write(pdf)
    return output_path


def _validate_pdf_file_v4(path):
    if not path or not os.path.exists(path):
        raise RuntimeError("PDF file was not created.")
    size = os.path.getsize(path)
    if size < 1024:
        raise RuntimeError(f"PDF file is too small ({size} bytes).")
    with open(path, "rb") as f:
        head = f.read(8)
        f.seek(max(0, size - 2048))
        tail = f.read()
    if not head.startswith(b"%PDF"):
        raise RuntimeError("Output file does not start with a PDF header.")
    if b"%%EOF" not in tail:
        raise RuntimeError("Output file is missing the PDF EOF marker.")
    return size


def _open_file_v4(path):
    """Open a saved file without breaking on spaces/Turkish characters in Windows paths."""
    import sys
    import subprocess
    try:
        if os.name == "nt":
            os.startfile(path)  # Handles Unicode/space paths much better than file:// URLs on Windows.
        elif sys.platform == "darwin":
            subprocess.Popen(["open", path])
        else:
            subprocess.Popen(["xdg-open", path])
        return True, ""
    except Exception as e:
        return False, str(e)


def export_report_pdf_v4(self):
    """Very defensive PDF export: build temp -> validate -> copy final -> validate -> open final path."""
    import tempfile
    import shutil

    final_path = filedialog.asksaveasfilename(
        title="Save PDF Report",
        defaultextension=".pdf",
        filetypes=[("PDF Report", "*.pdf")],
        initialfile="LineSight_Executive_Report.pdf",
    )
    if not final_path:
        return

    final_path = os.path.abspath(final_path)
    if not final_path.lower().endswith(".pdf"):
        final_path += ".pdf"

    tmp_fd, tmp_path = tempfile.mkstemp(prefix="linesight_report_", suffix=".pdf")
    os.close(tmp_fd)
    try:
        os.remove(tmp_path)  # ReportLab prefers creating the file itself.
    except Exception:
        pass

    try:
        self.data_status.configure(text="Building PDF report...", text_color=COL_MUTED)
        self.update_idletasks()

        ai = self.ai_cache or ai_analyze(self.df, api_key=self.api_key)
        self.ai_cache = ai

        # First try the prettier ReportLab PDF. If anything goes wrong, fallback to a minimal valid PDF.
        try:
            build_pdf_report_v3(self.df, ai=ai, output_path=tmp_path, source_name=self.data_source)
            _validate_pdf_file_v4(tmp_path)
        except Exception as pretty_error:
            try:
                if os.path.exists(tmp_path):
                    os.remove(tmp_path)
            except Exception:
                pass
            build_minimal_pdf_report_v4(self.df, ai=ai, output_path=tmp_path, source_name=self.data_source)
            _validate_pdf_file_v4(tmp_path)

        # Copy, do not webbrowser-open the temp path. Validate the final exact file that the user will see.
        final_dir = os.path.dirname(final_path)
        if final_dir and not os.path.exists(final_dir):
            os.makedirs(final_dir, exist_ok=True)
        shutil.copyfile(tmp_path, final_path)
        final_size = _validate_pdf_file_v4(final_path)

        self.data_status.configure(
            text=f"PDF saved successfully:\n{os.path.basename(final_path)}\n{final_size/1024:.1f} KB",
            text_color=COL_GOOD,
        )
        opened, open_error = _open_file_v4(final_path)
        if not opened:
            self.data_status.configure(
                text=f"PDF saved successfully, but auto-open failed:\n{final_path}\n{open_error}",
                text_color=COL_WARN,
            )
    except Exception as e:
        self.data_status.configure(text=f"PDF export failed:\n{e}", text_color=COL_BAD)
    finally:
        try:
            if os.path.exists(tmp_path):
                os.remove(tmp_path)
        except Exception:
            pass


def quick_done_v4(self, result):
    self.ai_cache = result
    if not (hasattr(self, "_analysis_status") and self._analysis_status.winfo_exists()):
        return
    self._analysis_status.configure(
        text="Gemini connected" if result.get("source") == "gemini" else "Local analysis active",
        text_color=COL_GOOD if result.get("source") == "gemini" else COL_MUTED,
    )
    self._render_quick_analysis(result)


def show_ai_insights_v4_true_big_chat(self):
    """AI page: chat owns the page. Side panel is narrow and scrollable."""
    self.clear_content()
    page = ctk.CTkFrame(self.content, fg_color="transparent")
    page.pack(fill="both", expand=True)
    page.grid_columnconfigure(0, weight=8)
    page.grid_columnconfigure(1, weight=2)
    page.grid_rowconfigure(0, weight=1)

    # LEFT: giant chat workspace, no top cards stealing height.
    chat_shell = ctk.CTkFrame(page, fg_color=COL_CARD, corner_radius=24,
                              border_width=1, border_color=COL_BORDER)
    chat_shell.grid(row=0, column=0, sticky="nsew", padx=(22, 10), pady=18)
    chat_shell.grid_columnconfigure(0, weight=1)
    chat_shell.grid_rowconfigure(1, weight=1)

    chat_head = ctk.CTkFrame(chat_shell, fg_color="transparent")
    chat_head.grid(row=0, column=0, sticky="ew", padx=20, pady=(18, 10))
    titlebox = ctk.CTkFrame(chat_head, fg_color="transparent")
    titlebox.pack(side="left", fill="x", expand=True)
    ctk.CTkLabel(titlebox, text="✦ AI Decision Workbench", font=("Segoe UI", 25, "bold"), text_color=COL_TEXT).pack(anchor="w")
    ctk.CTkLabel(titlebox, text="Large readable conversation mode - AI answers now use the main screen area.", font=("Segoe UI", 12), text_color=COL_MUTED).pack(anchor="w", pady=(3, 0))
    ctk.CTkButton(chat_head, text="Clear Chat", width=98, height=34, corner_radius=12,
                  fg_color=COL_PANEL_2, hover_color=COL_CARD_ALT, text_color=COL_TEXT,
                  command=self._clear_chat).pack(side="right", padx=(10, 0))

    self._chat = ctk.CTkScrollableFrame(
        chat_shell,
        fg_color=COL_BG,
        corner_radius=20,
        scrollbar_button_color=COL_PANEL_2,
        scrollbar_button_hover_color=COL_ACCENT,
    )
    self._chat.grid(row=1, column=0, sticky="nsew", padx=18, pady=(0, 12))

    if self.chat_history:
        for h in self.chat_history:
            self._add_bubble("You" if h["role"] == "user" else "AI Analyst", h["text"], user=(h["role"] == "user"))
    else:
        intro = ctk.CTkFrame(self._chat, fg_color=COL_CARD_ALT, corner_radius=18,
                             border_width=1, border_color=COL_BORDER)
        intro.pack(fill="x", padx=14, pady=18)
        ctk.CTkLabel(intro, text="Ask a production question to start the analysis.",
                     font=("Segoe UI", 18, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=18, pady=(18, 6))
        ctk.CTkLabel(intro, text="Examples: 'en fazla hata yapan operatör kim?', 'gece vardiyası için ne yapmalıyız?', 'Cpk değerini nasıl artırırız?'", 
                     font=("Segoe UI", 13), text_color=COL_MUTED, wraplength=950, justify="left").pack(anchor="w", padx=18, pady=(0, 18))

    inrow = ctk.CTkFrame(chat_shell, fg_color="transparent")
    inrow.grid(row=2, column=0, sticky="ew", padx=18, pady=(0, 18))
    self._chat_entry = ctk.CTkEntry(
        inrow,
        placeholder_text="Ask about machines, operators, night shift, Cpk, maintenance priorities or improvement actions...",
        height=52,
        corner_radius=16,
        fg_color=COL_CARD_ALT,
        border_color=COL_BORDER,
        text_color=COL_TEXT,
        font=("Segoe UI", 15),
    )
    self._chat_entry.pack(side="left", fill="x", expand=True)
    self._chat_entry.bind("<Return>", lambda e: self._send_chat())
    ctk.CTkButton(inrow, text="Send", width=112, height=52, corner_radius=16,
                  fg_color=COL_ACCENT, hover_color=COL_ACCENT_2,
                  font=("Segoe UI", 14, "bold"), command=self._send_chat).pack(side="left", padx=(12, 0))

    # RIGHT: compact scrollable control rail.
    side = ctk.CTkScrollableFrame(
        page,
        fg_color=COL_CARD,
        corner_radius=24,
        border_width=1,
        border_color=COL_BORDER,
        scrollbar_button_color=COL_PANEL_2,
        scrollbar_button_hover_color=COL_ACCENT,
    )
    side.grid(row=0, column=1, sticky="nsew", padx=(10, 22), pady=18)

    ctk.CTkLabel(side, text="Control Panel", font=("Segoe UI", 19, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=14, pady=(16, 4))
    ctk.CTkLabel(side, text="Prompts, alerts, API and PDF export are here so chat stays huge.", font=("Segoe UI", 11), text_color=COL_MUTED, wraplength=230, justify="left").pack(anchor="w", padx=14, pady=(0, 12))

    keybox = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=16, border_width=1, border_color=COL_BORDER)
    keybox.pack(fill="x", padx=12, pady=(0, 10))
    ctk.CTkLabel(keybox, text="Gemini API Key", font=("Segoe UI", 12, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=12, pady=(12, 6))
    self._key_entry = ctk.CTkEntry(keybox, placeholder_text="paste AIza... key", show="*", height=36,
                                   corner_radius=11, fg_color=COL_CARD_ALT, border_color=COL_BORDER, text_color=COL_TEXT)
    self._key_entry.pack(fill="x", padx=12)
    if self.api_key:
        self._key_entry.insert(0, self.api_key)
    ctk.CTkButton(keybox, text="Save Key", height=34, corner_radius=10, fg_color=COL_GOOD,
                  hover_color="#16a34a", command=self._save_key).pack(fill="x", padx=12, pady=(10, 6))
    self._ai_status = ctk.CTkLabel(keybox, text=("Gemini connected" if self.api_key else "Local analyst mode"),
                                   font=("Segoe UI", 11), text_color=(COL_GOOD if self.api_key else COL_MUTED))
    self._ai_status.pack(anchor="w", padx=12, pady=(0, 12))

    analysis = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=16, border_width=1, border_color=COL_BORDER)
    analysis.pack(fill="x", padx=12, pady=(0, 10))
    top = ctk.CTkFrame(analysis, fg_color="transparent")
    top.pack(fill="x", padx=12, pady=(12, 4))
    ctk.CTkLabel(top, text="Executive Alerts", font=("Segoe UI", 13, "bold"), text_color=COL_TEXT).pack(side="left")
    ctk.CTkButton(top, text="Refresh", width=72, height=26, corner_radius=9,
                  fg_color=COL_ACCENT, hover_color=COL_ACCENT_2, command=self._run_quick_analysis).pack(side="right")
    self._analysis_status = ctk.CTkLabel(analysis, text="", font=("Segoe UI", 10), text_color=COL_MUTED)
    self._analysis_status.pack(anchor="w", padx=12)
    self._analysis_body = ctk.CTkFrame(analysis, fg_color="transparent")
    self._analysis_body.pack(fill="x", padx=12, pady=(6, 12))

    prompts = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=16, border_width=1, border_color=COL_BORDER)
    prompts.pack(fill="x", padx=12, pady=(0, 10))
    ctk.CTkLabel(prompts, text="Prompt Starters", font=("Segoe UI", 13, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=12, pady=(12, 8))
    preset_questions = [
        "Which machine is most critical and why?",
        "Which shift and operator produce the most failures?",
        "Is the overall process capability (Cpk) acceptable?",
        "How should I prioritize maintenance across machines?",
        "Makine değil operatör bazında en riskli kişi kim?",
    ]
    for q in preset_questions:
        ctk.CTkButton(prompts, text=q, anchor="w", height=40, corner_radius=11,
                      fg_color=COL_CARD_ALT, hover_color=COL_ACCENT_SOFT,
                      text_color=COL_TEXT, font=("Segoe UI", 11),
                      command=lambda qq=q: self._submit_question(qq)).pack(fill="x", padx=12, pady=4)
    ctk.CTkLabel(prompts, text="", height=4).pack()

    pdfbox = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=16, border_width=1, border_color=COL_BORDER)
    pdfbox.pack(fill="x", padx=12, pady=(0, 14))
    ctk.CTkLabel(pdfbox, text="Report Output", font=("Segoe UI", 13, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=12, pady=(12, 4))
    ctk.CTkLabel(pdfbox, text="Uses a validated PDF build pipeline and opens the final saved file directly.", font=("Segoe UI", 10.5), text_color=COL_MUTED, wraplength=220, justify="left").pack(anchor="w", padx=12, pady=(0, 8))
    ctk.CTkButton(pdfbox, text="Export PDF Report", height=38, corner_radius=10,
                  fg_color=COL_ACCENT, hover_color=COL_ACCENT_2,
                  command=self.export_report).pack(fill="x", padx=12, pady=(0, 12))

    if self.ai_cache is not None:
        self._render_quick_analysis(self.ai_cache)
    else:
        self._run_quick_analysis()


def add_bubble_v4_big_readable(self, who, text, user):
    wrap = ctk.CTkFrame(self._chat, fg_color="transparent")
    wrap.pack(fill="x", pady=10)

    bubble = ctk.CTkFrame(
        wrap,
        fg_color=(COL_ACCENT if user else COL_CARD_ALT),
        corner_radius=20,
        border_width=(0 if user else 1),
        border_color=COL_BORDER,
    )

    panel_w = max(850, self.content.winfo_width() - 600)
    if user:
        bubble.pack(anchor="e", padx=14)
        wrap_len = min(720, panel_w - 170)
    else:
        bubble.pack(anchor="w", padx=14, fill="x", expand=True)
        wrap_len = min(1150, panel_w)

    ctk.CTkLabel(bubble, text=who, font=("Segoe UI", 10, "bold"),
                 text_color=("#dbeafe" if user else COL_ACCENT)).pack(anchor="w", padx=20, pady=(14, 2))
    lbl = ctk.CTkLabel(
        bubble,
        text=text,
        font=("Segoe UI", 16),
        wraplength=wrap_len,
        justify="left",
        text_color="#ffffff" if user else COL_TEXT,
    )
    lbl.pack(anchor="w", padx=20, pady=(3, 16), fill="x" if not user else None, expand=(not user))
    self._scroll_chat_bottom()
    return lbl


# Apply final v4 overrides.
LineSightApp.export_report = export_report_pdf_v4
LineSightApp._quick_done = quick_done_v4
LineSightApp.show_ai_insights = show_ai_insights_v4_true_big_chat
LineSightApp._add_bubble = add_bubble_v4_big_readable



# ======================================================================
# V5 - REPORT STYLE + LIVE CLOCK + THEME/LANGUAGE CONTROLS
# ======================================================================

def set_palette_v5(mode="Dark"):
    """Update global UI colors. New widgets/pages use these colors immediately."""
    global COL_BG, COL_PANEL, COL_PANEL_2, COL_CARD, COL_CARD_ALT, COL_ACCENT, COL_ACCENT_2
    global COL_ACCENT_SOFT, COL_GOOD, COL_WARN, COL_BAD, COL_TEXT, COL_MUTED, COL_BORDER, COL_SHADOW
    mode = str(mode or "Dark")
    if mode.lower().startswith("light") or mode.lower().startswith("aç") or mode.lower().startswith("ac"):
        COL_BG = "#eef3fb"
        COL_PANEL = "#ffffff"
        COL_PANEL_2 = "#f4f7fc"
        COL_CARD = "#ffffff"
        COL_CARD_ALT = "#edf3ff"
        COL_ACCENT = "#2563eb"
        COL_ACCENT_2 = "#7c3aed"
        COL_ACCENT_SOFT = "#dbeafe"
        COL_GOOD = "#16a34a"
        COL_WARN = "#d97706"
        COL_BAD = "#dc2626"
        COL_TEXT = "#0f172a"
        COL_MUTED = "#64748b"
        COL_BORDER = "#cbd5e1"
        COL_SHADOW = "#d9e2ef"
        ctk.set_appearance_mode("light")
    else:
        COL_BG = "#081120"
        COL_PANEL = "#0d1728"
        COL_PANEL_2 = "#111f35"
        COL_CARD = "#122038"
        COL_CARD_ALT = "#182845"
        COL_ACCENT = "#4f8cff"
        COL_ACCENT_2 = "#7c5cff"
        COL_ACCENT_SOFT = "#18345f"
        COL_GOOD = "#22c55e"
        COL_WARN = "#f59e0b"
        COL_BAD = "#ef4444"
        COL_TEXT = "#ecf3ff"
        COL_MUTED = "#8aa0bf"
        COL_BORDER = "#23314b"
        COL_SHADOW = "#0b1322"
        ctk.set_appearance_mode("dark")


def tr_v5(self, en, tr):
    return tr if getattr(self, "language", "TR") == "TR" else en


def premium_init_v5(self):
    ctk.CTk.__init__(self)
    self.theme_mode = "Dark"
    self.language = "TR"
    set_palette_v5(self.theme_mode)
    self.title("LineSight - Executive Decision Hub")
    self.geometry("1480x940")
    self.minsize(1200, 800)
    self.configure(fg_color=COL_BG)

    self.df = create_demo_data()
    self.data_source = "Demo data"
    self.active_button = None
    self.current_nav_label = "Dashboard"
    self._canvas = None
    self.ai_cache = None
    self.api_key = get_api_key()
    self.chat_history = []
    self._clock_job = None
    self.show_login_screen()


def _update_clock_v5(self):
    if hasattr(self, "clock_label") and self.clock_label is not None:
        try:
            if self.clock_label.winfo_exists():
                lang = getattr(self, "language", "TR")
                now = dt.datetime.now()
                if lang == "TR":
                    txt = now.strftime("%d.%m.%Y  %H:%M:%S")
                else:
                    txt = now.strftime("%Y-%m-%d  %H:%M:%S")
                self.clock_label.configure(text=txt)
                self._clock_job = self.after(1000, self._update_clock)
                return
        except Exception:
            pass
    self._clock_job = None


def _refresh_current_page_v5(self):
    label = getattr(self, "current_nav_label", "Dashboard")
    nav_map = {
        "Dashboard": self.show_dashboard,
        "Machine Analysis": self.show_machine_analysis,
        "Operator / Shift": self.show_operator_shift,
        "Process Capability": self.show_capability,
        "AI Analysis": self.show_ai_insights,
        "Raw Data": self.show_raw_data,
    }
    if hasattr(self, "nav_buttons"):
        self._navigate(nav_map.get(label, self.show_dashboard), label)


def _change_theme_v5(self, value):
    self.theme_mode = "Light" if str(value).lower().startswith("light") or str(value).lower().startswith("aç") or str(value).lower().startswith("ac") else "Dark"
    set_palette_v5(self.theme_mode)
    # Rebuild the chrome so every widget receives the new colors.
    self.show_main_app()


def _change_language_v5(self, value):
    v = str(value).upper()
    self.language = "TR" if "TR" in v or "TÜRK" in v or "TURK" in v else "EN"
    self.show_main_app()


def clear_screen_v5(self):
    try:
        if getattr(self, "_clock_job", None):
            self.after_cancel(self._clock_job)
            self._clock_job = None
    except Exception:
        pass
    for w in self.winfo_children():
        w.destroy()


def show_main_app_v5(self):
    self.clear_screen()
    set_palette_v5(getattr(self, "theme_mode", "Dark"))
    self.configure(fg_color=COL_BG)

    self.sidebar = ctk.CTkFrame(self, width=270, corner_radius=0, fg_color=COL_PANEL, border_width=0)
    self.sidebar.pack(side="left", fill="y")
    self.sidebar.pack_propagate(False)

    self.main_right = ctk.CTkFrame(self, corner_radius=0, fg_color=COL_BG)
    self.main_right.pack(side="right", fill="both", expand=True)
    self.main_right.grid_columnconfigure(0, weight=1)
    self.main_right.grid_rowconfigure(1, weight=1)

    # Topbar with language, theme and live clock.
    topbar = ctk.CTkFrame(self.main_right, fg_color=COL_PANEL, height=56, corner_radius=0,
                          border_width=0)
    topbar.grid(row=0, column=0, sticky="ew")
    topbar.grid_columnconfigure(0, weight=1)

    left_title = ctk.CTkFrame(topbar, fg_color="transparent")
    left_title.grid(row=0, column=0, sticky="w", padx=22, pady=8)
    ctk.CTkLabel(left_title, text="LineSight", font=("Segoe UI", 16, "bold"), text_color=COL_TEXT).pack(side="left")
    ctk.CTkLabel(left_title, text=self.tr("Executive Decision Hub", "Yönetim Karar Merkezi"),
                 font=("Segoe UI", 11), text_color=COL_MUTED).pack(side="left", padx=(10, 0))

    controls = ctk.CTkFrame(topbar, fg_color="transparent")
    controls.grid(row=0, column=1, sticky="e", padx=20, pady=8)

    lang_values = ["TR", "EN"]
    self.lang_menu = ctk.CTkOptionMenu(
        controls, values=lang_values, width=82, height=34, corner_radius=12,
        fg_color=COL_CARD_ALT, button_color=COL_ACCENT, button_hover_color=COL_ACCENT_2,
        dropdown_fg_color=COL_PANEL, dropdown_hover_color=COL_CARD_ALT,
        text_color=COL_TEXT, command=self._change_language
    )
    self.lang_menu.set(getattr(self, "language", "TR"))
    self.lang_menu.pack(side="left", padx=(0, 10))

    theme_values = ["Dark", "Light"] if getattr(self, "language", "TR") == "EN" else ["Dark", "Light"]
    self.theme_menu = ctk.CTkOptionMenu(
        controls, values=theme_values, width=100, height=34, corner_radius=12,
        fg_color=COL_CARD_ALT, button_color=COL_ACCENT, button_hover_color=COL_ACCENT_2,
        dropdown_fg_color=COL_PANEL, dropdown_hover_color=COL_CARD_ALT,
        text_color=COL_TEXT, command=self._change_theme
    )
    self.theme_menu.set(getattr(self, "theme_mode", "Dark"))
    self.theme_menu.pack(side="left", padx=(0, 10))

    self.clock_label = ctk.CTkLabel(
        controls, text="", width=160, height=34, fg_color=COL_CARD_ALT, corner_radius=12,
        font=("Segoe UI", 12, "bold"), text_color=COL_TEXT
    )
    self.clock_label.pack(side="left")
    self._update_clock()

    self.content = ctk.CTkFrame(self.main_right, corner_radius=0, fg_color=COL_BG)
    self.content.grid(row=1, column=0, sticky="nsew")

    # Sidebar
    brand = ctk.CTkFrame(self.sidebar, fg_color="transparent")
    brand.pack(fill="x", padx=22, pady=(24, 18))
    badge_text = "EXECUTIVE SUITE" if getattr(self, "language", "TR") == "EN" else "YÖNETİCİ PANELİ"
    ctk.CTkLabel(brand, text=badge_text, font=("Segoe UI", 10, "bold"),
                 text_color=COL_ACCENT, fg_color=COL_ACCENT_SOFT, corner_radius=999,
                 padx=10, pady=5).pack(anchor="w", pady=(0, 10))
    ctk.CTkLabel(brand, text="LineSight", font=("Segoe UI", 25, "bold"), text_color=COL_TEXT).pack(anchor="w")
    ctk.CTkLabel(brand, text=self.tr("Production Quality & Maintenance Command Center", "Üretim Kalitesi ve Bakım Komuta Merkezi"),
                 font=("Segoe UI", 12), text_color=COL_MUTED, wraplength=220, justify="left").pack(anchor="w", pady=(4, 0))

    self.nav_buttons = {}
