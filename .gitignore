# ======================================================================
# V17 - EXPORT LOADING FEEDBACK ONLY
#   Adds a clear loading/progress dialog when the PDF report button is clicked.
#   Core analytics, PDF builder, AI summary, upload, charts and navigation stay unchanged.
# ======================================================================

def _export_text_v17(self, tr, en):
    try:
        return self.tr(en, tr)
    except Exception:
        return tr if getattr(self, "language", "TR") == "TR" else en


def _center_dialog_v17(self, dlg, w=440, h=235):
    try:
        self.update_idletasks()
        x = self.winfo_x() + max(0, (self.winfo_width() - w) // 2)
        y = self.winfo_y() + max(0, (self.winfo_height() - h) // 2)
        dlg.geometry(f"{w}x{h}+{x}+{y}")
    except Exception:
        dlg.geometry(f"{w}x{h}")


def _open_report_folder_v17(out_dir):
    try:
        if os.name == "nt":
            os.startfile(str(out_dir))
        elif sys.platform == "darwin":
            subprocess.Popen(["open", str(out_dir)])
        else:
            subprocess.Popen(["xdg-open", str(out_dir)])
    except Exception:
        pass


def _show_export_loading_v17(self):
    """Immediate visual feedback after clicking the report button."""
    try:
        dlg = ctk.CTkToplevel(self)
        self._export_dialog_v17 = dlg
        dlg.title(_export_text_v17(self, "Rapor hazırlanıyor", "Preparing report"))
        dlg.resizable(False, False)
        dlg.configure(fg_color=COL_BG)
        dlg.transient(self)
        dlg.protocol("WM_DELETE_WINDOW", lambda: None)
        _center_dialog_v17(self, dlg)

        card = ctk.CTkFrame(
            dlg,
            fg_color=COL_CARD,
            corner_radius=24,
            border_width=1,
            border_color=COL_BORDER,
        )
        card.pack(fill="both", expand=True, padx=18, pady=18)

        icon = ctk.CTkLabel(
            card,
            text="⟳",
            width=44,
            height=44,
            fg_color=COL_ACCENT_SOFT,
            corner_radius=16,
            font=("Segoe UI", 22, "bold"),
            text_color=COL_ACCENT,
        )
        icon.pack(pady=(18, 8))

        title = ctk.CTkLabel(
            card,
            text=_export_text_v17(self, "Veriler inceleniyor", "Analyzing data"),
            font=("Segoe UI", 20, "bold"),
            text_color=COL_TEXT,
        )
        title.pack(pady=(0, 4))

        detail = ctk.CTkLabel(
            card,
            text=_export_text_v17(
                self,
                "AI özeti, KPI'lar ve PDF rapor çıktısı hazırlanıyor. Lütfen bekle.",
                "AI summary, KPIs and PDF report output are being prepared. Please wait.",
            ),
            font=("Segoe UI", 12),
            text_color=COL_MUTED,
            wraplength=360,
            justify="center",
        )
        detail.pack(pady=(0, 12))

        progress = ctk.CTkProgressBar(
            card,
            mode="indeterminate",
            height=10,
            corner_radius=999,
            progress_color=COL_ACCENT,
        )
        progress.pack(fill="x", padx=34, pady=(0, 10))
        try:
            progress.start()
        except Exception:
            pass

        status = ctk.CTkLabel(
            card,
            text=_export_text_v17(self, "Yükleniyor...", "Loading..."),
            font=("Segoe UI", 12, "bold"),
            text_color=COL_ACCENT,
        )
        status.pack(pady=(0, 16))

        refs = {"dlg": dlg, "title": title, "detail": detail, "progress": progress, "status": status, "card": card}

        def animate(i=0):
            try:
                if not getattr(self, "_export_running_v17", False):
                    return
                if not dlg.winfo_exists():
                    return
                dots = "." * ((i % 3) + 1)
                status.configure(text=_export_text_v17(self, f"Yükleniyor{dots}", f"Loading{dots}"))
                dlg.after(420, lambda: animate(i + 1))
            except Exception:
                pass

        animate()
        try:
            dlg.grab_set()
            dlg.lift()
            dlg.focus_force()
        except Exception:
            pass
        return refs
    except Exception:
        return None


def _finish_export_loading_v17(self, refs, final_path, out_dir, err):
    self._export_running_v17 = False

    try:
        if refs and refs.get("progress") and refs["progress"].winfo_exists():
            try:
                refs["progress"].stop()
            except Exception:
                pass
            refs["progress"].set(1 if err is None else 0)
    except Exception:
        pass

    if err is not None:
        try:
            self.data_status.configure(
                text=_export_text_v17(self, f"PDF hatası:\n{err}", f"PDF failed:\n{err}"),
                text_color=COL_BAD,
            )
        except Exception:
            pass

        try:
            if refs and refs.get("dlg") and refs["dlg"].winfo_exists():
                refs["title"].configure(text=_export_text_v17(self, "Rapor oluşturulamadı", "Report could not be created"), text_color=COL_BAD)
                refs["detail"].configure(text=str(err), text_color=COL_MUTED)
                refs["status"].configure(text=_export_text_v17(self, "İşlem durduruldu", "Process stopped"), text_color=COL_BAD)
                ctk.CTkButton(
                    refs["card"],
                    text=_export_text_v17(self, "Kapat", "Close"),
                    height=34,
                    corner_radius=12,
                    fg_color=COL_BAD,
                    hover_color="#a83232",
                    command=refs["dlg"].destroy,
                ).pack(pady=(0, 14), padx=34, fill="x")
                refs["dlg"].protocol("WM_DELETE_WINDOW", refs["dlg"].destroy)
        except Exception:
            pass
        return

    try:
        size = os.path.getsize(str(final_path))
    except Exception:
        size = 0

    try:
        self.data_status.configure(
            text=_export_text_v17(
                self,
                f"PDF kaydedildi:\n{final_path.name}\n{size/1024:.1f} KB",
                f"PDF saved:\n{final_path.name}\n{size/1024:.1f} KB",
            ),
            text_color=COL_GOOD,
        )
    except Exception:
        pass

    # Keep the old useful behavior: open the folder, but remove the sudden final messagebox.
    _open_report_folder_v17(out_dir)

    try:
        if refs and refs.get("dlg") and refs["dlg"].winfo_exists():
            refs["title"].configure(text=_export_text_v17(self, "Rapor hazır", "Report ready"), text_color=COL_GOOD)
            refs["detail"].configure(
                text=_export_text_v17(
                    self,
                    f"PDF başarıyla oluşturuldu ve klasör açıldı.\nDosya: {final_path.name}",
                    f"PDF was created successfully and the folder was opened.\nFile: {final_path.name}",
                ),
                text_color=COL_MUTED,
            )
            refs["status"].configure(text=_export_text_v17(self, "Tamamlandı", "Completed"), text_color=COL_GOOD)

            btn_row = ctk.CTkFrame(refs["card"], fg_color="transparent")
            btn_row.pack(fill="x", padx=34, pady=(0, 14))
            btn_row.grid_columnconfigure(0, weight=1)
            btn_row.grid_columnconfigure(1, weight=1)

            ctk.CTkButton(
                btn_row,
                text=_export_text_v17(self, "Klasörü Aç", "Open Folder"),
                height=34,
                corner_radius=12,
                fg_color=COL_ACCENT,
                hover_color=COL_ACCENT_2,
                command=lambda: _open_report_folder_v17(out_dir),
            ).grid(row=0, column=0, sticky="ew", padx=(0, 6))
            ctk.CTkButton(
                btn_row,
                text=_export_text_v17(self, "Kapat", "Close"),
                height=34,
                corner_radius=12,
                fg_color=COL_CARD_ALT,
                hover_color=COL_PANEL_2,
                text_color=COL_TEXT,
                command=refs["dlg"].destroy,
            ).grid(row=0, column=1, sticky="ew", padx=(6, 0))
            refs["dlg"].protocol("WM_DELETE_WINDOW", refs["dlg"].destroy)
    except Exception:
        pass


def export_report_v17_loading(self):
    from pathlib import Path

    if getattr(self, "_export_running_v17", False):
        try:
            dlg = getattr(self, "_export_dialog_v17", None)
            if dlg and dlg.winfo_exists():
                dlg.lift()
                dlg.focus_force()
        except Exception:
            pass
        return

    self._export_running_v17 = True
    refs = _show_export_loading_v17(self)

    lang = getattr(self, "language", "TR")
    out_dir = _safe_reports_dir_v13()
    stamp = dt.datetime.now().strftime("%Y%m%d_%H%M%S")
    prefix = "LineSight_Rapor" if lang != "EN" else "LineSight_Report"
    final_path = out_dir / f"{prefix}_{stamp}.pdf"

    try:
        self.data_status.configure(
            text=_export_text_v17(self, "Veriler inceleniyor...\nRapor hazırlanıyor...", "Analyzing data...\nPreparing report..."),
            text_color=COL_MUTED,
        )
        self.update_idletasks()
    except Exception:
        pass

    df = self.df
    source = self.data_source

    def worker():
        err = None
        try:
            ai = _ai_summary_for_pdf_v14(self)
            build_pdf_styled_v15(df, str(final_path), ai=ai, source_name=source, language=lang)
            _validate_pdf_file_v4(str(final_path))
        except Exception as e:
            err = e
        try:
            self.after(0, lambda: _finish_export_loading_v17(self, refs, final_path, out_dir, err))
        except Exception:
            pass

    threading.Thread(target=worker, daemon=True).start()


LineSightApp.export_report = export_report_v17_loading




# ======================================================================
# V18 - CARD ALIGNMENT + TALLER DASHBOARD SUMMARY BOXES
#   - Align KPI rows and summary boxes more cleanly.
#   - Prevent middle dashboard texts from touching / overflowing the cards.
#   - Slightly enlarge cards without touching analytics or button logic.
# ======================================================================
def kpi_card_aligned_v18(self, parent, title, value, color, col, subtitle=""):
    """Safer, slightly taller KPI cards used across pages."""
    card = ctk.CTkFrame(
        parent,
        height=104,
        fg_color=COL_CARD,
        corner_radius=13,
        border_width=1,
        border_color=COL_BORDER,
    )
    card.grid(row=0, column=col, padx=6, pady=5, sticky="nsew")
    parent.grid_columnconfigure(col, weight=1, uniform="fpv18_kpi")
    card.grid_propagate(False)

    inner = ctk.CTkFrame(card, fg_color="transparent")
    inner.pack(fill="both", expand=True, padx=14, pady=(12, 12))

    ctk.CTkLabel(
        inner,
        text=_clip_v10(title, 24).upper(),
        font=("Segoe UI", 9.5, "bold"),
        text_color=COL_MUTED,
        anchor="w",
    ).pack(anchor="w", pady=(0, 4))

    ctk.CTkLabel(
        inner,
        text=_clip_v10(value, 22),
        font=("Segoe UI", 18, "bold"),
        text_color=color,
        anchor="w",
        justify="left",
        wraplength=220,
    ).pack(anchor="w")
    return card


def _dashboard_fact_card_v18(self, parent, title, value, color, col):
    """Dashboard small highlight cards - taller so the text never spills."""
    card = ctk.CTkFrame(
        parent,
        height=86,
        fg_color=COL_CARD,
        corner_radius=12,
        border_width=1,
        border_color=COL_BORDER,
    )
    card.grid(row=0, column=col, sticky="nsew", padx=6, pady=5)
    parent.grid_columnconfigure(col, weight=1, uniform="fpv18_fact")
    card.grid_propagate(False)

    inner = ctk.CTkFrame(card, fg_color="transparent")
    inner.pack(fill="both", expand=True, padx=14, pady=(12, 10))

    ctk.CTkLabel(
        inner,
        text=_clip_v10(title, 24).upper(),
        font=("Segoe UI", 9, "bold"),
        text_color=COL_MUTED,
        anchor="w",
    ).pack(anchor="w", pady=(0, 4))

    ctk.CTkLabel(
        inner,
        text=_clip_v10(value, 28),
        font=("Segoe UI", 14.5, "bold"),
        text_color=color,
        anchor="w",
        justify="left",
        wraplength=360,
    ).pack(anchor="w")
    return card


def show_dashboard_v18(self):
    self.clear_content()
    area = self._scroll_area()
    self._page_title(
        area,
        self.tr("Executive Dashboard", "Yönetim Dashboard"),
        self.tr(
            "Live production quality, cost and maintenance risk overview.",
            "Üretim kalitesi, maliyet ve bakım risklerinin kısa özeti.",
        ),
        icon="◈",
    )

    k = overall_kpis(self.df)
    ms = build_machine_summary(self.df)
    op = build_group_summary(self.df, "Operator_ID")
    sh = build_group_summary(self.df, "Shift")

    top = ms.iloc[0] if not ms.empty else None
    worst_op = op.iloc[0] if not op.empty else None
    worst_shift = sh.iloc[0] if not sh.empty else None
    cpk_txt = f"{k['cpk']:.2f}" if k['cpk'] is not None else "N/A"

    # KPI row
    kpi = ctk.CTkFrame(area, fg_color="transparent")
    kpi.pack(fill="x", padx=12, pady=(0, 6))
    cards = [
        (self.tr("Inspections", "Kontrol"), f"{k['total']:,}", COL_TEXT, ""),
        (self.tr("Pass Rate", "Geçiş"), f"{k['pass_rate']:.1f}%", COL_GOOD, ""),
        (self.tr("Failure Rate", "Hata"), f"{k['fail_rate']:.1f}%", COL_BAD, ""),
        (self.tr("Failure Cost", "Maliyet"), f"${k['cost']:,.0f}", COL_WARN, ""),
        ("Cpk", cpk_txt, COL_ACCENT, ""),
    ]
    for i, (t, v, c, s) in enumerate(cards):
        self._kpi_card(kpi, t, v, c, i, s)

    # Risk summary row - taller cards to stop overflow.
    glance = ctk.CTkFrame(area, fg_color="transparent")
    glance.pack(fill="x", padx=12, pady=(0, 8))
    facts = [
        (
            self.tr("Critical Machine", "Kritik Makine"),
            f"{top['Machine_ID']} · {top['Failure_Rate']:.1f}%" if top is not None else "-",
            COL_BAD,
        ),
        (
            self.tr("Risk Operator", "Riskli Operatör"),
            f"{worst_op['Operator_ID']} · {worst_op['Failure_Rate']:.1f}%" if worst_op is not None else "-",
            COL_WARN,
        ),
        (
            self.tr("Risk Shift", "Riskli Vardiya"),
            f"{worst_shift['Shift']} · {worst_shift['Failure_Rate']:.1f}%" if worst_shift is not None else "-",
            COL_ACCENT,
        ),
    ]
    for i, (t, v, c) in enumerate(facts):
        _dashboard_fact_card_v18(self, glance, t, v, c, i)

    # Chart row with matched spacing.
    charts = ctk.CTkFrame(area, fg_color="transparent")
    charts.pack(fill="both", expand=True, padx=12, pady=(0, 10))
    charts.grid_columnconfigure(0, weight=1, uniform="fpv18_chart")
    charts.grid_columnconfigure(1, weight=1, uniform="fpv18_chart")

    card1 = self._section_card(
        charts,
        self.tr("Failure Rate by Machine", "Makine Bazlı Hata Oranı"),
        "",
        use_grid=True,
        row=0,
        column=0,
        sticky="nsew",
        padx=(0, 6),
        pady=0,
    )
    fig, ax = self._styled_fig(6.25, 2.62)
    ax.bar(
        ms["Machine_ID"],
        ms["Failure_Rate"],
        color=[COL_BAD if v >= 15 else COL_WARN if v >= 8 else COL_GOOD for v in ms["Failure_Rate"]],
    )
    ax.set_ylabel(self.tr("Failure Rate (%)", "Hata Oranı (%)"))
    fig.tight_layout()
    self._embed_figure(card1, fig)

    card2 = self._section_card(
        charts,
        self.tr("Failure Cost by Machine", "Makine Bazlı Hata Maliyeti"),
        "",
        use_grid=True,
        row=0,
        column=1,
        sticky="nsew",
        padx=(6, 0),
        pady=0,
    )
    fig2, ax2 = self._styled_fig(6.25, 2.62)
    ax2.bar(ms["Machine_ID"], ms["Failure_Cost"], color=COL_ACCENT)
    ax2.set_ylabel(self.tr("Failure Cost ($)", "Hata Maliyeti ($)"))
    fig2.tight_layout()
    self._embed_figure(card2, fig2)


def show_machine_analysis_v18(self):
    self.clear_content()
    area = self._scroll_area()
    self._page_title(
        area,
        self.tr("Machine Analysis", "Makine Analizi"),
        self.tr("Compact risk, cost and capability view.", "Toplu risk, maliyet ve kabiliyet görünümü."),
        icon="⚙",
    )

    ms = build_machine_summary(self.df)
    top = ms.iloc[0] if not ms.empty else None

    if top is not None:
        strip = ctk.CTkFrame(area, fg_color="transparent")
        strip.pack(fill="x", padx=12, pady=(0, 6))
        metrics = [
            (self.tr("Criticality", "Kritiklik"), f"{top['Criticality_Score']:.1f}/100", COL_ACCENT, ""),
            (self.tr("Failure Rate", "Hata Oranı"), f"{top['Failure_Rate']:.1f}%", COL_BAD, ""),
            (self.tr("Cost", "Maliyet"), f"${top['Failure_Cost']:,.0f}", COL_WARN, ""),
            (
                "Cpk",
                f"{top['Cpk']:.2f}",
                COL_BAD if top['Cpk'] < 1 else COL_WARN if top['Cpk'] < 1.33 else COL_GOOD,
                "",
            ),
        ]
        for i, (t, v, c, s) in enumerate(metrics):
            self._kpi_card(strip, t, v, c, i, s)

    grid = ctk.CTkFrame(area, fg_color="transparent")
    grid.pack(fill="both", expand=True, padx=12, pady=(0, 8))
    grid.grid_columnconfigure(0, weight=1, uniform="fpv18_machine")
    grid.grid_columnconfigure(1, weight=1, uniform="fpv18_machine")

    chart = self._section_card(
        grid,
        self.tr("Criticality Score", "Kritiklik Skoru"),
        "",
        use_grid=True,
        row=0,
        column=0,
        sticky="nsew",
        padx=(0, 6),
        pady=0,
    )
    fig, ax = self._styled_fig(6.0, 2.45)
    order = ms.sort_values("Criticality_Score", ascending=True)
    ax.barh(order["Machine_ID"], order["Criticality_Score"], color=COL_ACCENT)
    ax.set_xlabel(self.tr("Criticality", "Kritiklik"))
    fig.tight_layout()
    self._embed_figure(chart, fig)

    cost = self._section_card(
        grid,
        self.tr("Cost / 1000 Units", "1000 Birim Maliyet"),
        "",
        use_grid=True,
        row=0,
        column=1,
        sticky="nsew",
        padx=(6, 0),
        pady=0,
    )
    fig2, ax2 = self._styled_fig(6.0, 2.45)
    o2 = ms.sort_values("Cost_per_1000_units", ascending=False)
    ax2.bar(o2["Machine_ID"], o2["Cost_per_1000_units"], color=COL_WARN)
    ax2.set_ylabel("$/1000")
    fig2.tight_layout()
    self._embed_figure(cost, fig2)

    self._table(area, ms, height=12, expand=True)


LineSightApp._kpi_card = kpi_card_aligned_v18
LineSightApp.show_dashboard = show_dashboard_v18
LineSightApp.show_machine_analysis = show_machine_analysis_v18

# ======================================================================
# RUN
# ======================================================================
if __name__ == "__main__":
    app = LineSightApp()
    app.mainloop()
