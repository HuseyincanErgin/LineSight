def render_quick_analysis_sidepanel_v3(self, result):
    for w in self._analysis_body.winfo_children():
        w.destroy()

    if result.get("headline"):
        ctk.CTkLabel(self._analysis_body, text=result["headline"], font=("Segoe UI", 11, "bold"),
                     wraplength=220, justify="left", text_color=COL_TEXT).pack(anchor="w", pady=(0, 6))

    pr_color = {"HIGH": COL_BAD, "MEDIUM": COL_WARN, "LOW": COL_GOOD}
    machines = result.get("machines", []) or []
    issues = [m for m in machines if str(m.get("priority", "")).upper() in ("HIGH", "MEDIUM")]
    for m in issues[:2]:
        pr = str(m.get("priority", "LOW")).upper()
        row = ctk.CTkFrame(self._analysis_body, fg_color=COL_CARD_ALT, corner_radius=12,
                           border_width=1, border_color=COL_BORDER)
        row.pack(fill="x", pady=4)
        ctk.CTkLabel(row, text=pr, width=58, fg_color=pr_color.get(pr, COL_GOOD),
                     corner_radius=8, font=("Segoe UI", 9, "bold"), text_color="#ffffff").pack(anchor="w", padx=8, pady=(8, 3))
        ctk.CTkLabel(row, text=f"{m.get('machine','')} — {m.get('recommendation','')}",
                     font=("Segoe UI", 10.2), wraplength=200, justify="left", text_color=COL_TEXT).pack(anchor="w", padx=8, pady=(0, 8))

    if not issues:
        ctk.CTkLabel(self._analysis_body, text="No high/medium alert currently shown.",
                     font=("Segoe UI", 10.5), text_color=COL_MUTED, wraplength=220, justify="left").pack(anchor="w")


def add_bubble_big_chat_v3(self, who, text, user):
    wrap = ctk.CTkFrame(self._chat, fg_color="transparent")
    wrap.pack(fill="x", pady=9)

    bubble = ctk.CTkFrame(
        wrap,
        fg_color=(COL_ACCENT if user else COL_CARD_ALT),
        corner_radius=18,
        border_width=(0 if user else 1),
        border_color=COL_BORDER,
    )

    # Large chat column; assistant uses almost full width.
    panel_w = max(900, self.content.winfo_width() - 430)
    if user:
        bubble.pack(anchor="e", padx=12)
        wrap_len = min(720, panel_w - 280)
    else:
        bubble.pack(anchor="w", padx=12, fill="x", expand=True)
        wrap_len = min(1080, panel_w)

    ctk.CTkLabel(bubble, text=who, font=("Segoe UI", 10, "bold"),
                 text_color=("#dbeafe" if user else COL_ACCENT)).pack(anchor="w", padx=18, pady=(12, 2))
    lbl = ctk.CTkLabel(
        bubble,
        text=text,
        font=("Segoe UI", 15),
        wraplength=wrap_len,
        justify="left",
        text_color="#ffffff" if user else COL_TEXT,
    )
    lbl.pack(anchor="w", padx=18, pady=(2, 15), fill="x" if not user else None, expand=(not user))
    self._scroll_chat_bottom()
    return lbl


