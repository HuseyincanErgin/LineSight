        self._run_quick_analysis()


def _register_pdf_fonts_v5():
    from reportlab.pdfbase import pdfmetrics
    from reportlab.pdfbase.ttfonts import TTFont
    candidates = [
        ("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf", "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf"),
        ("C:/Windows/Fonts/arial.ttf", "C:/Windows/Fonts/arialbd.ttf"),
        ("C:/Windows/Fonts/calibri.ttf", "C:/Windows/Fonts/calibrib.ttf"),
        ("/System/Library/Fonts/Supplemental/Arial.ttf", "/System/Library/Fonts/Supplemental/Arial Bold.ttf"),
        ("/Library/Fonts/Arial.ttf", "/Library/Fonts/Arial Bold.ttf"),
    ]
    for regular, bold in candidates:
        try:
            if os.path.exists(regular) and os.path.exists(bold):
                if "FP-Regular" not in pdfmetrics.getRegisteredFontNames():
                    pdfmetrics.registerFont(TTFont("FP-Regular", regular))
                if "FP-Bold" not in pdfmetrics.getRegisteredFontNames():
                    pdfmetrics.registerFont(TTFont("FP-Bold", bold))
                globals()["_PDF_REGULAR"] = "FP-Regular"
                globals()["_PDF_BOLD"] = "FP-Bold"
                return "FP-Regular", "FP-Bold"
        except Exception:
            continue
    globals()["_PDF_REGULAR"] = "Helvetica"
    globals()["_PDF_BOLD"] = "Helvetica-Bold"
    return "Helvetica", "Helvetica-Bold"

def _pdf_wrap_v5(text, max_chars):
    text = str(text or "")
    words = text.replace("\n", " ").split()
    lines, cur = [], ""
    for w in words:
        if len(cur) + len(w) + 1 <= max_chars:
            cur = (cur + " " + w).strip()
        else:
            if cur:
                lines.append(cur)
            cur = w
    if cur:
        lines.append(cur)
    return lines or [""]


def _pdf_text_v5(c, x, y, text, font="Helvetica", size=10, color="#dbe7ff", max_chars=None, leading=None):
    from reportlab.lib.colors import HexColor
    c.setFillColor(HexColor(color))
    c.setFont(font, size)
    leading = leading or size * 1.35
    if max_chars:
        for line in _pdf_wrap_v5(text, max_chars):
            c.drawString(x, y, line)
            y -= leading
        return y
    c.drawString(x, y, str(text or ""))
    return y - leading


def _pdf_center_v5(c, x, y, w, text, font="Helvetica", size=10, color="#dbe7ff"):
    from reportlab.lib.colors import HexColor
    c.setFillColor(HexColor(color))
    c.setFont(font, size)
    c.drawCentredString(x + w/2, y, str(text or ""))


def _pdf_round_rect_v5(c, x, y, w, h, fill="#101a2e", stroke="#243552", radius=7, line=0.7):
    from reportlab.lib.colors import HexColor
    c.setFillColor(HexColor(fill))
    c.setStrokeColor(HexColor(stroke))
    c.setLineWidth(line)
    c.roundRect(x, y, w, h, radius, fill=1, stroke=1)


def _pdf_badge_v5(c, x, y, text, fill="#2b1630", color="#ff4d6d", w=76, h=18):
    _pdf_round_rect_v5(c, x, y, w, h, fill=fill, stroke="#3d2646", radius=4, line=0.5)
    _pdf_center_v5(c, x, y + 5.5, w, text, font=globals().get("_PDF_BOLD", "Helvetica-Bold"), size=7.8, color=color)


def build_pdf_report_v5_visual(df, ai=None, output_path="LineSight_Executive_Report.pdf", source_name="Data", language="TR"):
    """Two-page dark report inspired by the user's uploaded sample report."""
    from reportlab.pdfgen import canvas
    from reportlab.lib.pagesizes import A4
    from reportlab.lib.colors import HexColor
    from reportlab.lib.units import mm

    regular, bold = _register_pdf_fonts_v5()
    # Ensure helper names exist even if fallback fonts are used.
    globals()["FP-Regular"] = regular
    globals()["FP-Bold"] = bold

    c = canvas.Canvas(output_path, pagesize=A4)
    W, H = A4

    k = overall_kpis(df)
    machine = build_machine_summary(df)
    op = build_group_summary(df, "Operator_ID")
    shift = build_group_summary(df, "Shift")
    combo = build_shift_operator_summary(df)
    if ai is None:
        ai = ai_analyze(df)

    tr = (language or "TR") == "TR"
    now = dt.datetime.now().strftime("%d.%m.%Y %H:%M") if tr else dt.datetime.now().strftime("%Y-%m-%d %H:%M")

    bg = "#070d1a"
    card = "#0c1324"
    card2 = "#111c30"
    section = "#192b46"
    purple = "#28133a"
    purple2 = "#351c4c"
    border = "#223451"
    text = "#dce7f8"
    muted = "#8796ad"
    red = "#e84a5f"
    yellow = "#f2a81d"
    green = "#56c271"

    def font(name):
        return bold if name == "bold" else regular

    def bg_page():
        c.setFillColor(HexColor(bg))
        c.rect(0, 0, W, H, fill=1, stroke=0)

    def header(page_title):
        _pdf_text_v5(c, 20*mm, H - 24*mm, "LineSight", font=font("bold"), size=17, color=red)
        _pdf_text_v5(c, 20*mm, H - 34*mm,
                     "Üretim Kalitesi & Bakım Karar Destek Platformu" if tr else "Production Quality & Maintenance Decision Platform",
                     font=font("regular"), size=8.5, color=muted)
        _pdf_text_v5(c, 20*mm, H - 42*mm,
                     "KVKK Uyumlu  ·  SPC  ·  Gemini Destekli" if tr else "Data-safe  ·  SPC  ·  Gemini-assisted",
                     font=font("regular"), size=7.5, color="#53627a")
        _pdf_text_v5(c, W - 43*mm, H - 22*mm, "Oluşturma Tarihi" if tr else "Generated", font=font("regular"), size=7.5, color=muted)
        _pdf_text_v5(c, W - 43*mm, H - 30*mm, now, font=font("bold"), size=8.2, color=text)
        _pdf_badge_v5(c, W - 49*mm, H - 41*mm, "PDF RAPOR" if tr else "PDF REPORT", w=31*mm, h=7*mm)
        _pdf_round_rect_v5(c, 20*mm, H - 63*mm, W - 40*mm, 16*mm, fill="#20172d", stroke="#30243e", radius=4)
        _pdf_text_v5(c, 25*mm, H - 56*mm, page_title, font=font("bold"), size=12.5, color=text)
        c.setStrokeColor(HexColor(red))
        c.setLineWidth(1.2)
        c.line(0, H - 78*mm, W, H - 78*mm)

    def section_header(y, title):
        _pdf_round_rect_v5(c, 20*mm, y, W - 40*mm, 10*mm, fill=section, stroke=section, radius=3, line=0)
        _pdf_text_v5(c, 24*mm, y + 3.2*mm, title, font=font("bold"), size=7.8, color="#b8c7dd")
        return y - 14*mm

    def row_line(y, left, right, color_right=text):
        _pdf_text_v5(c, 24*mm, y, left, font=font("regular"), size=8.3, color="#aebbd0", max_chars=68)
        _pdf_text_v5(c, W - 67*mm, y, right, font=font("bold"), size=8.3, color=color_right)
        c.setStrokeColor(HexColor("#182236"))
        c.setLineWidth(0.45)
        c.line(20*mm, y - 4.2*mm, W - 20*mm, y - 4.2*mm)
        return y - 8.8*mm

    # PAGE 1
    bg_page()
    header("AI Model Performans Raporu" if tr else "AI Model Performance Report")

    y = H - 94*mm
    y = section_header(y, "SİSTEM METRİKLERİ" if tr else "SYSTEM METRICS")
    gap = 3*mm
    box_w = (W - 40*mm - 2*gap) / 3
    cards = [
        ("TOPLAM KONTROL" if tr else "TOTAL INSPECTIONS", f"{k['total']:,}", red),
        ("GENEL CPK" if tr else "OVERALL CPK", f"{k['cpk']:.2f}" if k['cpk'] is not None else "N/A", yellow if (k['cpk'] or 0) < 1.33 else green),
        ("ARIZA" if tr else "FAILURES", f"{k['fail']:,}", red),
    ]
    for i, (title, value, color) in enumerate(cards):
        x = 20*mm + i*(box_w + gap)
        _pdf_round_rect_v5(c, x, y - 18*mm, box_w, 18*mm, fill=card, stroke="#16243a", radius=5)
        _pdf_center_v5(c, x, y - 7*mm, box_w, title, font=font("bold"), size=7.1, color=muted)
        _pdf_center_v5(c, x, y - 15*mm, box_w, value, font=font("bold"), size=17, color=color)
    y -= 28*mm

    y = section_header(y, "MAKİNE RİSK ÖZETİ" if tr else "MACHINE RISK SUMMARY")
    for _, r in machine.head(8).iterrows():
        color = red if r["Failure_Rate"] >= 15 else yellow if r["Failure_Rate"] >= 8 else green
        right = f"{r['Failure_Rate']:.0f}% arıza · ${r['Failure_Cost']:,.0f}" if tr else f"{r['Failure_Rate']:.0f}% fail · ${r['Failure_Cost']:,.0f}"
        y = row_line(y, f"{r['Machine_ID']} — Cpk {r['Cpk']:.2f} · Kritik Skor {r['Criticality_Score']:.0f}", right, color)
    y -= 3*mm

    y = section_header(y, "OPERATÖR & VARDİYA ÖZETİ" if tr else "OPERATOR & SHIFT SUMMARY")
    if not op.empty:
        r = op.iloc[0]
        y = row_line(y, "En riskli operatör" if tr else "Highest-risk operator", f"{r['Operator_ID']} · {r['Failure_Rate']:.1f}%", red)
    if not shift.empty:
        r = shift.iloc[0]
        y = row_line(y, "En riskli vardiya" if tr else "Highest-risk shift", f"{r['Shift']} · {r['Failure_Rate']:.1f}%", yellow)
    if combo is not None and not combo.empty:
        r = combo.iloc[0]
        y = row_line(y, "En riskli vardiya-operatör eşleşmesi" if tr else "Highest-risk shift/operator pair", f"{r['Shift']} / {r['Operator_ID']} · {r['Failure_Rate']:.1f}%", red)
    y = row_line(y, "Toplam arıza maliyeti" if tr else "Total failure cost", f"${k['cost']:,.0f}", red)

    y -= 3*mm
    y = section_header(y, "AI ANALİZ MOTORU" if tr else "AI ANALYSIS ENGINE")
    source = "Gemini + Yerel Analiz" if ai.get("source") == "gemini" and tr else "Gemini + Local Engine" if ai.get("source") == "gemini" else "Yerel Analiz Motoru" if tr else "Local Analysis Engine"
    y = row_line(y, "Algoritma" if tr else "Algorithm", source, red)
    y = row_line(y, "Karar dayanağı" if tr else "Decision basis", "Cp/Cpk · Arıza Oranı · Maliyet · Duruş" if tr else "Cp/Cpk · Failure Rate · Cost · Downtime", text)
    y = row_line(y, "Kayıt sayısı" if tr else "Training / record count", f"{k['total']:,}", text)

    _pdf_text_v5(c, 20*mm, 10*mm, "LineSight  ·  Koyu temalı yönetici raporu" if tr else "LineSight  ·  Dark executive report", font=font("regular"), size=7, color="#34445f")
    _pdf_text_v5(c, W - 53*mm, 10*mm, now, font=font("regular"), size=7, color="#34445f")

    # PAGE 2
    c.showPage()
    bg_page()
    _pdf_round_rect_v5(c, 20*mm, H - 48*mm, W - 40*mm, 26*mm, fill=purple2, stroke="#4b2864", radius=5)
    _pdf_text_v5(c, 28*mm, H - 34*mm, "✦  AI Çözümleri & Önerileri" if tr else "✦  AI Solutions & Recommendations", font=font("bold"), size=14, color=text)
    _pdf_text_v5(c, 30*mm, H - 42*mm, "YEREL ANALİZ MOTORU — DİJİTAL İKİZ" if tr else "LOCAL ANALYSIS ENGINE — DIGITAL TWIN", font=font("bold"), size=7.5, color=muted)
    _pdf_badge_v5(c, W - 55*mm, H - 39*mm, "YEREL ANALİZ" if tr else "LOCAL ANALYSIS", fill="#48213b", color="#ff6680", w=38*mm, h=8*mm)

    y = H - 67*mm
    _pdf_round_rect_v5(c, 26*mm, y - 24*mm, W - 52*mm, 24*mm, fill="#211633", stroke="#39234e", radius=4)
    _pdf_text_v5(c, 33*mm, y - 8*mm, "DURUM ÖZETİ" if tr else "SITUATION SUMMARY", font=font("bold"), size=8, color=muted)
    headline = (build_local_answer(df, "Genel üretim durumunu özetle").split("\n\n")[0] if tr else (ai.get("headline") or build_local_answer(df, "summary").split("\n\n")[0]))
    _pdf_text_v5(c, 33*mm, y - 17*mm, headline, font=font("regular"), size=8.4, color="#bfcbe0", max_chars=92, leading=10.5)
    y -= 36*mm

    _pdf_text_v5(c, 20*mm, y, "SOMUT ÖNERİLER" if tr else "ACTION RECOMMENDATIONS", font=font("bold"), size=8.2, color=muted)
    y -= 7*mm

    # Build recommendation texts.
    recs = []
    if tr:
        for _, r in machine.head(4).iterrows():
            recs.append((r["Machine_ID"], _machine_action_tr(r.to_dict(), df)))
    elif ai.get("machines"):
        for item in ai.get("machines", [])[:4]:
            recs.append((item.get("machine", ""), item.get("recommendation", "")))
    if not recs:
        for _, r in machine.head(4).iterrows():
            recs.append((r["Machine_ID"], _machine_action(r.to_dict(), df)))
    titles_tr = ["Kritik Makine Müdahalesi", "Cpk İyileştirme Planı", "Vardiya Kontrol Protokolü", "Öngörücü Bakım Planlaması"]
    titles_en = ["Critical Machine Intervention", "Cpk Improvement Plan", "Shift Control Protocol", "Predictive Maintenance Planning"]
    titles = titles_tr if tr else titles_en

    for idx, (machine_id, recommendation) in enumerate(recs[:4], start=1):
        h = 27*mm
        _pdf_round_rect_v5(c, 26*mm, y - h, W - 52*mm, h, fill=card, stroke="#1c2941", radius=4)
        c.setFillColor(HexColor("#5a2745"))
        c.circle(36*mm, y - 9.5*mm, 5.2*mm, fill=1, stroke=0)
        _pdf_center_v5(c, 31*mm, y - 12*mm, 10*mm, str(idx), font=font("bold"), size=8, color=text)
        _pdf_text_v5(c, 46*mm, y - 8.5*mm, titles[idx-1], font=font("bold"), size=10.2, color=text)
        _pdf_text_v5(c, 46*mm, y - 17*mm, recommendation, font=font("regular"), size=7.7, color="#aebbd0", max_chars=82, leading=9.5)
        y -= h + 5*mm

    # Bottom two cards
    bottom_y = 26*mm
    bw = (W - 52*mm - 5*mm) / 2
    _pdf_round_rect_v5(c, 26*mm, bottom_y, bw, 28*mm, fill=purple, stroke="#462348", radius=4)
    _pdf_text_v5(c, 31*mm, bottom_y + 20*mm, "⚠ KRİTİK RİSK" if tr else "⚠ CRITICAL RISK", font=font("bold"), size=8.5, color=red)
    top_m = machine.iloc[0] if not machine.empty else None
    risk_txt = (f"{top_m['Machine_ID']} için hızlı müdahale yapılmazsa arıza maliyeti ve duruş süreleri artmaya devam edebilir." if tr else f"Without immediate action on {top_m['Machine_ID']}, failure cost and downtime may continue to rise.") if top_m is not None else ("Kritik risk bulunamadı." if tr else "No critical risk found.")
    _pdf_text_v5(c, 31*mm, bottom_y + 12*mm, risk_txt, font=font("regular"), size=7.8, color="#bdc7da", max_chars=44, leading=9.5)

    _pdf_round_rect_v5(c, 31*mm + bw, bottom_y, bw, 28*mm, fill=purple, stroke="#462348", radius=4)
    _pdf_text_v5(c, 36*mm + bw, bottom_y + 20*mm, "✓ BEKLENEN ETKİ" if tr else "✓ EXPECTED IMPACT", font=font("bold"), size=8.5, color=red)
    impact_txt = "Öneriler uygulanırsa arıza oranı, bakım önceliklendirme ve süreç kabiliyeti ölçülebilir şekilde iyileştirilebilir." if tr else "Applying the actions should improve failure rate, maintenance prioritization and process capability in a measurable way."
    _pdf_text_v5(c, 36*mm + bw, bottom_y + 12*mm, impact_txt, font=font("regular"), size=7.8, color="#bdc7da", max_chars=44, leading=9.5)

    _pdf_text_v5(c, 20*mm, 10*mm, "LineSight  ·  AI çözümleri ve öneriler" if tr else "LineSight  ·  AI solutions and recommendations", font=font("regular"), size=7, color="#34445f")
    _pdf_text_v5(c, W - 53*mm, 10*mm, now, font=font("regular"), size=7, color="#34445f")

    c.save()
    return output_path


def export_report_pdf_v5(self):
    import tempfile
    import shutil

    initial = "LineSight_Yonetici_Raporu.pdf" if getattr(self, "language", "TR") == "TR" else "LineSight_Executive_Report.pdf"
    final_path = filedialog.asksaveasfilename(
        title=self.tr("Save PDF Report", "PDF Raporu Kaydet"),
        defaultextension=".pdf",
        filetypes=[("PDF Report", "*.pdf")],
        initialfile=initial,
    )
    if not final_path:
        return

    final_path = os.path.abspath(final_path)
    if not final_path.lower().endswith(".pdf"):
        final_path += ".pdf"

    final_dir = os.path.dirname(final_path)
    if final_dir and not os.path.exists(final_dir):
        os.makedirs(final_dir, exist_ok=True)

    tmp_fd, tmp_path = tempfile.mkstemp(prefix="linesight_v5_", suffix=".pdf")
    os.close(tmp_fd)
    try:
        os.remove(tmp_path)
    except Exception:
        pass

    try:
        self.data_status.configure(text=self.tr("Building PDF report...", "PDF rapor hazırlanıyor..."), text_color=COL_MUTED)
        self.update_idletasks()
        ai = self.ai_cache or ai_analyze(self.df, api_key=self.api_key)
        self.ai_cache = ai
        build_pdf_report_v5_visual(self.df, ai=ai, output_path=tmp_path, source_name=self.data_source, language=getattr(self, "language", "TR"))
        _validate_pdf_file_v4(tmp_path)
        shutil.copyfile(tmp_path, final_path)
        size = _validate_pdf_file_v4(final_path)
        self.data_status.configure(
            text=self.tr(
                f"PDF saved successfully:\n{os.path.basename(final_path)}\n{size/1024:.1f} KB",
                f"PDF başarıyla kaydedildi:\n{os.path.basename(final_path)}\n{size/1024:.1f} KB"
            ),
            text_color=COL_GOOD,
        )
        # Do not auto-open the PDF. This avoids Windows search/temp-path confusion and guarantees the saved file remains in place.
    except Exception as e:
        self.data_status.configure(text=self.tr(f"PDF export failed:\n{e}", f"PDF dışa aktarma başarısız:\n{e}"), text_color=COL_BAD)
    finally:
        try:
            if os.path.exists(tmp_path):
                os.remove(tmp_path)
        except Exception:
            pass


# Apply v5 overrides.
LineSightApp.__init__ = premium_init_v5
LineSightApp.clear_screen = clear_screen_v5
LineSightApp.tr = tr_v5
LineSightApp._update_clock = _update_clock_v5
LineSightApp._change_theme = _change_theme_v5
LineSightApp._change_language = _change_language_v5
LineSightApp._refresh_current_page = _refresh_current_page_v5
LineSightApp.show_main_app = show_main_app_v5
LineSightApp._navigate = navigate_v5
LineSightApp._page_title = page_title_v5
LineSightApp.show_ai_insights = show_ai_insights_v5
LineSightApp.export_report = export_report_pdf_v5



# ======================================================================
# V6 - READABLE CHAT + FULLER TR/EN UI + COMPACT RIGHT PANEL
# ======================================================================

def _ui_lang_v6(self):
    return getattr(self, "language", "TR")


def _force_answer_language_v6(df, question, language="TR", api_key=None, history=None):
    """Answer in the selected UI language, not merely in the question language."""
    language = "TR" if str(language).upper().startswith("TR") else "EN"
    local_answer = _build_local_answer_tr(df, question) if language == "TR" else _build_local_answer_en(df, question)
    if not api_key:
        return local_answer

    convo = ""
    if history:
        for h in history[-4:]:
            who = "User" if h["role"] == "user" else "Assistant"
            convo += f"{who}: {h['text']}\n"

    prompt = (
        "You are LineSight, a manufacturing quality and maintenance analyst. "
        "You must answer using only the calculated production statistics and the local analyst draft.\n\n"
        "RULES:\n"
        f"- Reply ONLY in {'Turkish' if language == 'TR' else 'English'}.\n"
        "- Preserve the focus and facts of the LOCAL ANALYST DRAFT.\n"
        "- Do not invent columns, causes, machines, shifts, or operators.\n"
        "- Keep the answer readable in a dashboard chat: 1 short summary, 4-6 bullets, 1 first-action sentence.\n"
        "- Avoid markdown tables; use short bullets.\n\n"
        f"DECISION SNAPSHOT:\n{build_decision_snapshot(df)['text']}\n\n"
        f"LOCAL ANALYST DRAFT:\n{local_answer}\n\n"
        f"FULL STATISTICS JSON:\n{build_data_context(df)}\n\n"
        + (f"Conversation so far:\n{convo}\n" if convo else "")
        + f"User question: {question}\n\nFinal answer:"
    )
    try:
        answer = call_gemini(prompt, api_key=api_key, temperature=0.12).strip()
        if _answer_is_weak(answer, question):
            return local_answer
        return answer
    except Exception:
        return local_answer


def _change_language_v6(self, value):
    v = str(value).upper()
    self.language = "TR" if "TR" in v or "TÜRK" in v or "TURK" in v else "EN"
    # Clear language-dependent generated text so the UI is not half TR / half EN.
    self.chat_history = []
    self.ai_cache = None
    self.show_main_app()


def _change_theme_v6(self, value):
    self.theme_mode = "Light" if str(value).lower().startswith("light") or str(value).lower().startswith("aç") or str(value).lower().startswith("ac") else "Dark"
    set_palette_v5(self.theme_mode)
    self.show_main_app()


def _save_key_v6(self):
    self.api_key = self._key_entry.get().strip()
    ok = bool(self.api_key)
    self._ai_status.configure(
        text=("Gemini connected" if ok else self.tr("Local analysis active", "Yerel analiz aktif")),
        text_color=COL_GOOD if ok else COL_MUTED,
    )
    if ok:
        self.ai_cache = None
        self._run_quick_analysis()


def _run_quick_analysis_v6(self):
    for w in self._analysis_body.winfo_children():
        w.destroy()
    self._analysis_status.configure(text=self.tr("Analyzing...", "Analiz ediliyor..."))
    ctk.CTkLabel(self._analysis_body, text=self.tr("Working on the latest KPI snapshot...", "Güncel KPI özeti inceleniyor..."),
                 font=("Segoe UI", 10), text_color=COL_MUTED, wraplength=220, justify="left").pack(anchor="w", pady=3)

    df_snapshot = self.df
    key_snapshot = self.api_key

    def worker():
        result = ai_analyze(df_snapshot, api_key=key_snapshot)
        self.after(0, lambda: self._quick_done(result))

    threading.Thread(target=worker, daemon=True).start()


def _quick_done_v6(self, result):
    self.ai_cache = result
    if not (hasattr(self, "_analysis_status") and self._analysis_status.winfo_exists()):
        return
    self._analysis_status.configure(
        text=("Gemini + local engine" if result.get("source") == "gemini" else self.tr("Local analysis active", "Yerel analiz aktif"))
    )
    self._render_quick_analysis(result)


def _render_quick_analysis_v6(self, result):
    for w in self._analysis_body.winfo_children():
        w.destroy()

    machine = build_machine_summary(self.df)
    if machine.empty:
        ctk.CTkLabel(self._analysis_body, text=self.tr("No alert available.", "Uyarı bulunamadı."),
                     font=("Segoe UI", 10), text_color=COL_MUTED).pack(anchor="w")
        return

    top = machine.iloc[0]
    lang = _ui_lang_v6(self)
    if lang == "TR":
        headline = f"En kritik makine {top['Machine_ID']}: skor {top['Criticality_Score']:.0f}/100, arıza oranı {top['Failure_Rate']:.1f}%, Cpk {top['Cpk']:.2f}."
    else:
        headline = f"Most critical machine is {top['Machine_ID']}: score {top['Criticality_Score']:.0f}/100, failure rate {top['Failure_Rate']:.1f}%, Cpk {top['Cpk']:.2f}."

    ctk.CTkLabel(self._analysis_body, text=headline, font=("Segoe UI", 11, "bold"),
                 wraplength=230, justify="left", text_color=COL_TEXT).pack(anchor="w", pady=(0, 6))

    for _, r in machine.head(2).iterrows():
        row = ctk.CTkFrame(self._analysis_body, fg_color=COL_CARD_ALT, corner_radius=11,
                           border_width=1, border_color=COL_BORDER)
        row.pack(fill="x", pady=4)
        pr = "HIGH" if r["Criticality_Score"] >= 60 else "MED" if r["Criticality_Score"] >= 30 else "LOW"
        pr_txt = pr if lang == "EN" else ("YÜKSEK" if pr == "HIGH" else "ORTA" if pr == "MED" else "DÜŞÜK")
        ctk.CTkLabel(row, text=pr_txt, width=62, fg_color=COL_BAD if pr == "HIGH" else COL_WARN if pr == "MED" else COL_GOOD,
                     corner_radius=8, font=("Segoe UI", 9, "bold"), text_color="#ffffff").pack(anchor="w", padx=9, pady=(8, 3))
        action = _machine_action_tr(r.to_dict(), self.df) if lang == "TR" else _machine_action(r.to_dict(), self.df)
        ctk.CTkLabel(row, text=action, font=("Segoe UI", 10), wraplength=205,
                     justify="left", text_color=COL_TEXT).pack(anchor="w", padx=9, pady=(0, 8))


def _calc_textbox_height_v6(text, chars_per_line=74):
    import math
    lines = 0
    for part in str(text).splitlines() or [""]:
        lines += max(1, math.ceil(len(part) / chars_per_line))
    return max(92, min(720, lines * 23 + 36))


def _add_bubble_v6(self, who, text, user):
    wrap = ctk.CTkFrame(self._chat, fg_color="transparent")
    wrap.pack(fill="x", pady=8)

    # Translate speaker labels for display.
    if who in ("You", "User"):
        who = self.tr("You", "Sen")
    elif who in ("AI Analyst", "Gemini"):
        who = self.tr("AI Analyst", "AI Analist")

    bubble_color = COL_ACCENT if user else COL_CARD_ALT
    bubble = ctk.CTkFrame(
        wrap,
        fg_color=bubble_color,
        corner_radius=18,
        border_width=0 if user else 1,
        border_color=COL_BORDER,
    )

    # Critical fix: never use the full window width as wraplength. The chat panel
    # can be narrower than the content area, especially with the right control panel.
    chat_w = self._chat.winfo_width()
    if chat_w < 300:
        chat_w = max(560, self.content.winfo_width() - 420)
    wrap_len = max(420, min(860, chat_w - 100))

    if user:
        bubble.pack(anchor="e", padx=(90, 14))
        ctk.CTkLabel(bubble, text=who, font=("Segoe UI", 10, "bold"),
                     text_color="#dbeafe").pack(anchor="w", padx=18, pady=(12, 2))
        lbl = ctk.CTkLabel(bubble, text=text, font=("Segoe UI", 15), wraplength=min(560, wrap_len),
                           justify="left", text_color="#ffffff")
        lbl.pack(anchor="w", padx=18, pady=(3, 16))
        self._scroll_chat_bottom()
        return lbl

    bubble.pack(anchor="w", fill="x", expand=True, padx=14)
    ctk.CTkLabel(bubble, text=who, font=("Segoe UI", 10, "bold"),
                 text_color=COL_ACCENT).pack(anchor="w", padx=18, pady=(12, 2))

    # Use a Textbox for assistant answers. CTkLabel can clip long Turkish text
    # when the window is resized; CTkTextbox wraps reliably by word.
    height = _calc_textbox_height_v6(text, chars_per_line=76)
    box = ctk.CTkTextbox(
        bubble,
        height=height,
        wrap="word",
        fg_color=bubble_color,
        border_width=0,
        text_color=COL_TEXT,
        font=("Segoe UI", 14),
        activate_scrollbars=False,
    )
    box.pack(fill="x", expand=True, padx=14, pady=(0, 14))
    box.insert("1.0", text)
    box.configure(state="disabled")
    self._scroll_chat_bottom()
    return box


def _finish_bubble_v6(self, widget, text):
    if widget is not None and widget.winfo_exists():
        if isinstance(widget, ctk.CTkTextbox):
            widget.configure(state="normal")
            widget.delete("1.0", "end")
            widget.insert("1.0", text)
            widget.configure(height=_calc_textbox_height_v6(text, chars_per_line=76))
            widget.configure(state="disabled")
        else:
            widget.configure(text=text)
    self.chat_history.append({"role": "assistant", "text": text})
    self._scroll_chat_bottom()


def _submit_question_v6(self, question):
    if not self.chat_history:
        for w in self._chat.winfo_children():
            w.destroy()

    self._add_bubble("You", question, user=True)
    self.chat_history.append({"role": "user", "text": question})
    thinking_text = self.tr("…thinking", "…düşünüyor")
    thinking = self._add_bubble("AI Analyst", thinking_text, user=False)

    key = self.api_key
    df = self.df
    hist = list(self.chat_history)
    lang = getattr(self, "language", "TR")

    def worker():
        try:
            ans = _force_answer_language_v6(df, question, language=lang, api_key=key, history=hist)
        except Exception as e:
            fallback = _build_local_answer_tr(df, question) if lang == "TR" else _build_local_answer_en(df, question)
            msg = (f"\n\nNot: Gemini çağrısı başarısız oldu; bu yanıt yerel analiz motorundan üretildi. Hata: {e}"
                   if lang == "TR" else f"\n\nNote: Gemini failed; this answer was generated by the local analysis engine. Error: {e}")
            ans = fallback + msg
        self.after(0, lambda: self._finish_bubble(thinking, ans))

    threading.Thread(target=worker, daemon=True).start()


def _clear_chat_v6(self):
    self.chat_history = []
    if hasattr(self, "_chat") and self._chat.winfo_exists():
        for w in self._chat.winfo_children():
            w.destroy()
        intro = ctk.CTkFrame(self._chat, fg_color=COL_CARD_ALT, corner_radius=18,
                             border_width=1, border_color=COL_BORDER)
        intro.pack(fill="x", padx=14, pady=18)
        ctk.CTkLabel(intro, text=self.tr("Conversation cleared.", "Sohbet temizlendi."),
                     font=("Segoe UI", 17, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=18, pady=(18, 6))
        ctk.CTkLabel(intro, text=self.tr("Ask a new question to restart the analysis flow.", "Analiz akışını yeniden başlatmak için yeni bir soru sor."),
                     font=("Segoe UI", 13), text_color=COL_MUTED, wraplength=850, justify="left").pack(anchor="w", padx=18, pady=(0, 18))


def show_main_app_v6(self):
    self.clear_screen()
    set_palette_v5(getattr(self, "theme_mode", "Dark"))
    self.configure(fg_color=COL_BG)

    self.sidebar = ctk.CTkFrame(self, width=270, corner_radius=0, fg_color=COL_PANEL, border_width=0)
    self.sidebar.pack(side="left", fill="y")
    self.sidebar.pack_propagate(False)

    self.main_right = ctk.CTkFrame(self, corner_radius=0, fg_color=COL_BG)
    self.main_right.pack(side="right", fill="both", expand=True)
    self.main_right.grid_columnconfigure(0, weight=1)
    self.main_right.grid_rowconfigure(1, weight=1)

    topbar = ctk.CTkFrame(self.main_right, fg_color=COL_PANEL, height=56, corner_radius=0, border_width=0)
    topbar.grid(row=0, column=0, sticky="ew")
    topbar.grid_columnconfigure(0, weight=1)

    left_title = ctk.CTkFrame(topbar, fg_color="transparent")
    left_title.grid(row=0, column=0, sticky="w", padx=22, pady=8)
    ctk.CTkLabel(left_title, text="LineSight", font=("Segoe UI", 16, "bold"), text_color=COL_TEXT).pack(side="left")
    ctk.CTkLabel(left_title, text=self.tr("Executive Decision Hub", "Yönetim Karar Merkezi"),
                 font=("Segoe UI", 11), text_color=COL_MUTED).pack(side="left", padx=(10, 0))

    controls = ctk.CTkFrame(topbar, fg_color="transparent")
    controls.grid(row=0, column=1, sticky="e", padx=20, pady=8)

    # Requested order from left to right: language, theme, live clock.
    self.lang_menu = ctk.CTkOptionMenu(
        controls, values=["TR", "EN"], width=82, height=34, corner_radius=12,
        fg_color=COL_CARD_ALT, button_color=COL_ACCENT, button_hover_color=COL_ACCENT_2,
        dropdown_fg_color=COL_PANEL, dropdown_hover_color=COL_CARD_ALT,
        text_color=COL_TEXT, command=self._change_language
    )
    self.lang_menu.set(getattr(self, "language", "TR"))
    self.lang_menu.pack(side="left", padx=(0, 10))

    self.theme_menu = ctk.CTkOptionMenu(
        controls, values=["Dark", "Light"], width=100, height=34, corner_radius=12,
        fg_color=COL_CARD_ALT, button_color=COL_ACCENT, button_hover_color=COL_ACCENT_2,
        dropdown_fg_color=COL_PANEL, dropdown_hover_color=COL_CARD_ALT,
        text_color=COL_TEXT, command=self._change_theme
    )
    self.theme_menu.set(getattr(self, "theme_mode", "Dark"))
    self.theme_menu.pack(side="left", padx=(0, 10))

    self.clock_label = ctk.CTkLabel(
        controls, text="", width=160, height=34, fg_color=COL_CARD_ALT, corner_radius=12,
        font=("Segoe UI", 12, "bold"), text_color=COL_TEXT
    )
    self.clock_label.pack(side="left")
    self._update_clock()

    self.content = ctk.CTkFrame(self.main_right, corner_radius=0, fg_color=COL_BG)
    self.content.grid(row=1, column=0, sticky="nsew")

    brand = ctk.CTkFrame(self.sidebar, fg_color="transparent")
    brand.pack(fill="x", padx=22, pady=(24, 18))
    ctk.CTkLabel(brand, text=self.tr("EXECUTIVE SUITE", "YÖNETİCİ PANELİ"), font=("Segoe UI", 10, "bold"),
                 text_color=COL_ACCENT, fg_color=COL_ACCENT_SOFT, corner_radius=999,
                 padx=10, pady=5).pack(anchor="w", pady=(0, 10))
    ctk.CTkLabel(brand, text="LineSight", font=("Segoe UI", 25, "bold"), text_color=COL_TEXT).pack(anchor="w")
    ctk.CTkLabel(brand, text=self.tr("Production Quality & Maintenance Command Center", "Üretim Kalitesi ve Bakım Komuta Merkezi"),
                 font=("Segoe UI", 12), text_color=COL_MUTED, wraplength=220, justify="left").pack(anchor="w", pady=(4, 0))

    self.nav_buttons = {}
    nav = [
        ("Dashboard", self.show_dashboard, self.tr("Dashboard", "Dashboard")),
        ("Machine Analysis", self.show_machine_analysis, self.tr("Machine Analysis", "Makine Analizi")),
        ("Operator / Shift", self.show_operator_shift, self.tr("Operator / Shift", "Operatör / Vardiya")),
        ("Process Capability", self.show_capability, self.tr("Process Capability", "Süreç Kabiliyeti")),
        ("AI Analysis", self.show_ai_insights, self.tr("AI Analysis", "AI Analizi")),
        ("Raw Data", self.show_raw_data, self.tr("Raw Data", "Ham Veri")),
    ]
    nav_frame = ctk.CTkFrame(self.sidebar, fg_color="transparent")
    nav_frame.pack(fill="x", padx=18, pady=(4, 12))
    for key, cmd, display in nav:
        b = ctk.CTkButton(nav_frame, text=display, width=220, height=44, corner_radius=14,
                          anchor="w", fg_color=COL_PANEL_2, hover_color=COL_CARD_ALT,
                          text_color=COL_TEXT, font=("Segoe UI", 13, "bold"),
                          command=lambda c=cmd, l=key: self._navigate(c, l))
        b.pack(pady=6, padx=4, fill="x")
        self.nav_buttons[key] = b

    utility = ctk.CTkFrame(self.sidebar, fg_color=COL_CARD, corner_radius=20, border_width=1, border_color=COL_BORDER)
    utility.pack(fill="x", padx=22, pady=(16, 10))
    ctk.CTkLabel(utility, text=self.tr("Workspace Actions", "Çalışma Alanı"), font=("Segoe UI", 13, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=16, pady=(14, 6))
    ctk.CTkButton(utility, text=self.tr("Upload CSV / Excel", "CSV / Excel Yükle"), height=42, corner_radius=12,
                  fg_color=COL_GOOD, hover_color="#16a34a", font=("Segoe UI", 13, "bold"), command=self.upload_csv).pack(fill="x", padx=14, pady=6)
    ctk.CTkButton(utility, text=self.tr("Export PDF Report", "PDF Rapor İndir"), height=42, corner_radius=12,
                  fg_color=COL_ACCENT, hover_color=COL_ACCENT_2, font=("Segoe UI", 13, "bold"), command=self.export_report).pack(fill="x", padx=14, pady=6)
    ctk.CTkButton(utility, text=self.tr("Logout", "Çıkış"), height=42, corner_radius=12,
                  fg_color="#7f1d1d", hover_color="#991b1b", font=("Segoe UI", 13, "bold"), command=self.show_login_screen).pack(fill="x", padx=14, pady=(6, 14))

    status = ctk.CTkFrame(self.sidebar, fg_color=COL_CARD, corner_radius=20, border_width=1, border_color=COL_BORDER)
    status.pack(side="bottom", fill="x", padx=22, pady=22)
    ctk.CTkLabel(status, text=self.tr("Current dataset", "Aktif veri seti"), font=("Segoe UI", 11, "bold"), text_color=COL_MUTED).pack(anchor="w", padx=14, pady=(12, 4))
    src_label = "Source" if getattr(self, "language", "TR") == "EN" else "Kaynak"
    self.data_status = ctk.CTkLabel(status, text=f"{src_label}: {self.data_source}",
                                    font=("Segoe UI", 12), text_color=COL_TEXT, wraplength=200, justify="left")
    self.data_status.pack(anchor="w", padx=14, pady=(0, 14))

    current = getattr(self, "current_nav_label", "Dashboard")
    nav_map = {key: cmd for key, cmd, _ in nav}
    self._navigate(nav_map.get(current, self.show_dashboard), current)


def show_ai_insights_v6(self):
    self.clear_content()
    lang = getattr(self, "language", "TR")
    page = ctk.CTkFrame(self.content, fg_color="transparent")
    page.pack(fill="both", expand=True, padx=10, pady=10)
    page.grid_columnconfigure(0, weight=7)
    page.grid_columnconfigure(1, weight=0)
    page.grid_rowconfigure(0, weight=1)

    # Large conversation area.
    chat_shell = ctk.CTkFrame(page, fg_color=COL_CARD, corner_radius=22, border_width=1, border_color=COL_BORDER)
    chat_shell.grid(row=0, column=0, sticky="nsew", padx=(0, 10), pady=0)
    chat_shell.grid_columnconfigure(0, weight=1)
    chat_shell.grid_rowconfigure(1, weight=1)

    chat_head = ctk.CTkFrame(chat_shell, fg_color="transparent")
    chat_head.grid(row=0, column=0, sticky="ew", padx=18, pady=(14, 6))
    ctk.CTkLabel(chat_head, text=self.tr("AI Conversation", "AI Konuşma Alanı"), font=("Segoe UI", 22, "bold"), text_color=COL_TEXT).pack(side="left")
    ctk.CTkLabel(chat_head, text=self.tr("Answers wrap inside the panel without clipping.", "Cevaplar panelin içine sığacak şekilde otomatik sarılır."), font=("Segoe UI", 12), text_color=COL_MUTED).pack(side="left", padx=12)
    ctk.CTkButton(chat_head, text=self.tr("Clear Chat", "Sohbeti Temizle"), width=110, height=34, corner_radius=10,
                  fg_color=COL_PANEL_2, hover_color=COL_CARD_ALT, text_color=COL_TEXT,
                  command=self._clear_chat).pack(side="right")

    self._chat = ctk.CTkScrollableFrame(chat_shell, fg_color=COL_BG, corner_radius=18,
                                        scrollbar_button_color=COL_PANEL_2,
                                        scrollbar_button_hover_color=COL_ACCENT)
    self._chat.grid(row=1, column=0, sticky="nsew", padx=16, pady=(0, 12))

    if self.chat_history:
        for h in self.chat_history:
            self._add_bubble("You" if h["role"] == "user" else "AI Analyst", h["text"], user=(h["role"] == "user"))
    else:
        intro = ctk.CTkFrame(self._chat, fg_color=COL_CARD_ALT, corner_radius=18, border_width=1, border_color=COL_BORDER)
        intro.pack(fill="x", padx=14, pady=18)
        ctk.CTkLabel(intro, text=self.tr("Ask a production question to begin.", "Başlamak için üretimle ilgili bir soru sor."), font=("Segoe UI", 17, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=18, pady=(18, 6))
        ctk.CTkLabel(intro, text=self.tr("The chat is now the main area of this page, so long AI answers stay readable during demos.", "Sohbet artık bu sayfanın ana alanı; uzun AI cevapları demo sırasında rahat okunur."), font=("Segoe UI", 13), text_color=COL_MUTED, wraplength=900, justify="left").pack(anchor="w", padx=18, pady=(0, 18))

    inrow = ctk.CTkFrame(chat_shell, fg_color="transparent")
    inrow.grid(row=2, column=0, sticky="ew", padx=16, pady=(0, 16))
    self._chat_entry = ctk.CTkEntry(inrow, placeholder_text=self.tr("Ask about machines, operators, night shift, Cpk or maintenance ideas...", "Makine, operatör, gece vardiyası, Cpk veya bakım önerileri hakkında sor..."),
                                    height=50, corner_radius=14, fg_color=COL_CARD_ALT,
                                    border_color=COL_BORDER, text_color=COL_TEXT, font=("Segoe UI", 15))
    self._chat_entry.pack(side="left", fill="x", expand=True)
    self._chat_entry.bind("<Return>", lambda e: self._send_chat())
    ctk.CTkButton(inrow, text=self.tr("Send", "Gönder"), width=106, height=50, corner_radius=14,
                  fg_color=COL_ACCENT, hover_color=COL_ACCENT_2,
                  font=("Segoe UI", 13, "bold"), command=self._send_chat).pack(side="left", padx=(10, 0))

    # Smaller right panel. Prompt starters come first, as requested.
    side = ctk.CTkFrame(page, fg_color=COL_CARD, corner_radius=22, border_width=1, border_color=COL_BORDER, width=285)
    side.grid(row=0, column=1, sticky="ns", pady=0)
    side.grid_propagate(False)

    ctk.CTkLabel(side, text=self.tr("AI Decision Panel", "AI Karar Paneli"), font=("Segoe UI", 18, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=14, pady=(16, 2))
    ctk.CTkLabel(side, text=self.tr("Quick prompts, compact settings and alerts.", "Hazır sorular, kompakt ayarlar ve uyarılar."), font=("Segoe UI", 10.5), text_color=COL_MUTED, wraplength=240, justify="left").pack(anchor="w", padx=14, pady=(0, 10))

    prompts = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=15, border_width=1, border_color=COL_BORDER)
    prompts.pack(fill="x", padx=10, pady=(0, 9))
    ctk.CTkLabel(prompts, text=self.tr("Prompt Starters", "Hazır Sorular"), font=("Segoe UI", 12, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=10, pady=(10, 5))
    preset_questions = [
        "Which machine is most critical and why?" if lang == "EN" else "En kritik makine hangisi ve neden?",
        "Which shift and operator produce the most failures?" if lang == "EN" else "En çok hatayı hangi vardiya ve operatör üretiyor?",
        "Is the overall process capability (Cpk) acceptable?" if lang == "EN" else "Genel süreç kabiliyeti (Cpk) kabul edilebilir mi?",
        "How should I prioritize maintenance across machines?" if lang == "EN" else "Makineler için bakım önceliğini nasıl belirlemeliyim?",
    ]
    for q in preset_questions:
        ctk.CTkButton(prompts, text=q, anchor="w", height=34, corner_radius=10,
                      fg_color=COL_CARD_ALT, hover_color=COL_ACCENT_SOFT,
                      text_color=COL_TEXT, font=("Segoe UI", 10.2),
                      command=lambda qq=q: self._submit_question(qq)).pack(fill="x", padx=10, pady=3)
    ctk.CTkLabel(prompts, text="", height=3).pack()

    keybox = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=15, border_width=1, border_color=COL_BORDER)
    keybox.pack(fill="x", padx=10, pady=(0, 9))
    ctk.CTkLabel(keybox, text="Gemini API Key", font=("Segoe UI", 12, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=10, pady=(10, 5))
    self._key_entry = ctk.CTkEntry(keybox, placeholder_text="paste AIza... key", show="*", height=32,
                                   corner_radius=9, fg_color=COL_CARD_ALT, border_color=COL_BORDER,
                                   text_color=COL_TEXT)
    self._key_entry.pack(fill="x", padx=10)
    if self.api_key:
        self._key_entry.insert(0, self.api_key)
    row = ctk.CTkFrame(keybox, fg_color="transparent")
    row.pack(fill="x", padx=10, pady=(8, 10))
    ctk.CTkButton(row, text=self.tr("Save", "Kaydet"), width=76, height=30, corner_radius=9,
                  fg_color=COL_GOOD, hover_color="#16a34a", command=self._save_key).pack(side="left")
    self._ai_status = ctk.CTkLabel(row, font=("Segoe UI", 10), text=("Gemini connected" if self.api_key else self.tr("Local active", "Yerel aktif")),
                                   text_color=(COL_GOOD if self.api_key else COL_MUTED))
    self._ai_status.pack(side="left", padx=8)

    alerts = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=15, border_width=1, border_color=COL_BORDER)
    alerts.pack(fill="x", padx=10, pady=(0, 9))
    head = ctk.CTkFrame(alerts, fg_color="transparent")
    head.pack(fill="x", padx=10, pady=(10, 2))
    ctk.CTkLabel(head, text=self.tr("Executive Alerts", "Yönetici Uyarıları"), font=("Segoe UI", 12, "bold"), text_color=COL_TEXT).pack(side="left")
    ctk.CTkButton(head, text=self.tr("Refresh", "Yenile"), width=66, height=26, corner_radius=9,
                  fg_color=COL_ACCENT, hover_color=COL_ACCENT_2, command=self._run_quick_analysis).pack(side="right")
    self._analysis_status = ctk.CTkLabel(alerts, text="", font=("Segoe UI", 9.5), text_color=COL_MUTED)
    self._analysis_status.pack(anchor="w", padx=10, pady=(0, 2))
    self._analysis_body = ctk.CTkFrame(alerts, fg_color="transparent")
    self._analysis_body.pack(fill="x", padx=10, pady=(3, 10))

    pdfbox = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=15, border_width=1, border_color=COL_BORDER)
    pdfbox.pack(fill="x", padx=10, pady=(0, 10))
    ctk.CTkLabel(pdfbox, text=self.tr("Report Output", "Rapor Çıktısı"), font=("Segoe UI", 12, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=10, pady=(10, 3))
    ctk.CTkButton(pdfbox, text=self.tr("Export PDF", "PDF İndir"), height=34, corner_radius=9,
                  fg_color=COL_ACCENT, hover_color=COL_ACCENT_2, command=self.export_report).pack(fill="x", padx=10, pady=(3, 10))

    if self.ai_cache is not None:
        self._render_quick_analysis(self.ai_cache)
    else:
        self._run_quick_analysis()


def show_dashboard_v6(self):
    self.clear_content()
    area = self._scroll_area()
    self._page_title(area, self.tr("Executive Dashboard", "Yönetim Dashboard"),
                     self.tr("Live production quality, cost and maintenance risk overview.", "Üretim kalitesi, maliyet ve bakım risklerinin canlı yönetim özeti."), icon="◈")
    k = overall_kpis(self.df)
    ms = build_machine_summary(self.df)
    op = build_group_summary(self.df, "Operator_ID")
    sh = build_group_summary(self.df, "Shift")
    top = ms.iloc[0] if not ms.empty else None
    worst_op = op.iloc[0] if not op.empty else None
    worst_shift = sh.iloc[0] if not sh.empty else None
    cpk_txt = f"{k['cpk']:.2f}" if k['cpk'] is not None else "N/A"

    kpi_frame = ctk.CTkFrame(area, fg_color="transparent")
    kpi_frame.pack(fill="x", padx=22, pady=(0, 8))
    cards = [
        (self.tr("Inspections", "Kontrol Sayısı"), f"{k['total']:,}", COL_TEXT, self.tr("Rows analyzed", "Analiz edilen kayıt")),
        (self.tr("Pass Rate", "Geçiş Oranı"), f"{k['pass_rate']:.1f}%", COL_GOOD, self.tr("Within specification", "Spesifikasyon içinde")),
        (self.tr("Failure Rate", "Hata Oranı"), f"{k['fail_rate']:.1f}%", COL_BAD, self.tr("Outside specification", "Spesifikasyon dışı")),
        (self.tr("Failure Cost", "Hata Maliyeti"), f"${k['cost']:,.0f}", COL_WARN, self.tr("Total quality loss", "Toplam kalite kaybı")),
        (self.tr("Overall Cpk", "Genel Cpk"), cpk_txt, COL_ACCENT, self.tr("Capability signal", "Kabiliyet göstergesi")),
    ]
    for i, (t, v, c, s) in enumerate(cards):
        self._kpi_card(kpi_frame, t, v, c, i, s)

    summary = self._section_card(area, self.tr("Command Summary", "Komuta Özeti"),
                                 self.tr("A quick executive story for the active dataset.", "Aktif veri seti için hızlı yönetici hikayesi."),
                                 padx=22, pady=(0, 10), fill="x")
    text = (f"{self.tr('Most critical machine', 'En kritik makine')} {top['Machine_ID']} - {self.tr('failure rate', 'hata oranı')} {top['Failure_Rate']:.1f}%, Cpk {top['Cpk']:.2f}, {self.tr('cost', 'maliyet')} ${top['Failure_Cost']:,.0f}." if top is not None else "-")
    text += "\n" + (f"{self.tr('Highest-risk operator', 'En riskli operatör')}: {worst_op['Operator_ID']} ({worst_op['Failure_Rate']:.1f}%)." if worst_op is not None else "")
    text += "\n" + (f"{self.tr('Highest-risk shift', 'En riskli vardiya')}: {worst_shift['Shift']} ({worst_shift['Failure_Rate']:.1f}%)." if worst_shift is not None else "")
    ctk.CTkLabel(summary, text=text, font=("Segoe UI", 14), text_color=COL_TEXT, wraplength=900, justify="left").pack(anchor="w", padx=18, pady=(4, 18))

    charts = ctk.CTkFrame(area, fg_color="transparent")
    charts.pack(fill="both", expand=True, padx=22, pady=(0, 12))
    charts.grid_columnconfigure(0, weight=1)
    charts.grid_columnconfigure(1, weight=1)
    card1 = self._section_card(charts, self.tr("Failure Rate by Machine", "Makine Bazlı Hata Oranı"), "", use_grid=True, row=0, column=0, sticky="nsew", padx=(0, 8), pady=0)
    fig, ax = self._styled_fig(6.5, 3.0)
    ax.bar(ms["Machine_ID"], ms["Failure_Rate"], color=[COL_BAD if v >= 15 else COL_WARN if v >= 8 else COL_GOOD for v in ms["Failure_Rate"]])
    ax.set_ylabel(self.tr("Failure Rate (%)", "Hata Oranı (%)"))
    ax.set_xlabel(self.tr("Machine", "Makine"))
    fig.tight_layout(); self._embed_figure(card1, fig)
    card2 = self._section_card(charts, self.tr("Failure Cost by Machine", "Makine Bazlı Hata Maliyeti"), "", use_grid=True, row=0, column=1, sticky="nsew", padx=(8, 0), pady=0)
    fig2, ax2 = self._styled_fig(6.5, 3.0)
    ax2.bar(ms["Machine_ID"], ms["Failure_Cost"], color=COL_ACCENT)
    ax2.set_ylabel(self.tr("Failure Cost ($)", "Hata Maliyeti ($)")); ax2.set_xlabel(self.tr("Machine", "Makine"))
    fig2.tight_layout(); self._embed_figure(card2, fig2)


def show_machine_analysis_v6(self):
    self.clear_content(); area = self._scroll_area()
    self._page_title(area, self.tr("Machine Analysis", "Makine Analizi"), self.tr("Machine-level risk, cost and capability view.", "Makine bazlı risk, maliyet ve kabiliyet görünümü."), icon="⚙")
    ms = build_machine_summary(self.df)
    top = ms.iloc[0] if not ms.empty else None
    if top is not None:
        strip = ctk.CTkFrame(area, fg_color="transparent"); strip.pack(fill="x", padx=22, pady=(0, 8))
        metrics = [(self.tr("Criticality", "Kritiklik"), f"{top['Criticality_Score']:.1f}/100", COL_ACCENT, ""), (self.tr("Failure Rate", "Hata Oranı"), f"{top['Failure_Rate']:.1f}%", COL_BAD, ""), (self.tr("Cost", "Maliyet"), f"${top['Failure_Cost']:,.0f}", COL_WARN, ""), ("Cpk", f"{top['Cpk']:.2f}", COL_BAD if top['Cpk'] < 1 else COL_WARN if top['Cpk'] < 1.33 else COL_GOOD, "")]
        for i, (t, v, c, s) in enumerate(metrics): self._kpi_card(strip, t, v, c, i, s)
    chart = self._section_card(area, self.tr("Criticality Score by Machine", "Makine Bazlı Kritiklik Skoru"), "", padx=22, pady=(0, 10), fill="both", expand=True)
    fig, ax = self._styled_fig(8, 3.2); order = ms.sort_values("Criticality_Score", ascending=True)
    ax.barh(order["Machine_ID"], order["Criticality_Score"], color=COL_ACCENT); ax.set_xlabel(self.tr("Criticality (0-100)", "Kritiklik (0-100)")); fig.tight_layout(); self._embed_figure(chart, fig)
    self._table(area, ms, height=10)


def show_operator_shift_v6(self):
    self.clear_content(); area = self._scroll_area()
    self._page_title(area, self.tr("Operator & Shift Performance", "Operatör & Vardiya Performansı"), self.tr("People and shift patterns for focused improvement.", "Odaklı iyileştirme için operatör ve vardiya örüntüleri."), icon="👥")
    op = build_group_summary(self.df, "Operator_ID"); sh = build_group_summary(self.df, "Shift"); combo = build_shift_operator_summary(self.df)
    strip = ctk.CTkFrame(area, fg_color="transparent"); strip.pack(fill="x", padx=22, pady=(0, 8))
    top_op = op.iloc[0] if not op.empty else None; top_sh = sh.iloc[0] if not sh.empty else None; top_combo = combo.iloc[0] if combo is not None and not combo.empty else None
    cards = [(self.tr("Highest-Failure Operator", "En Çok Hata Yapan Operatör"), f"{top_op['Operator_ID']} · {top_op['Failure_Rate']:.1f}%" if top_op is not None else "-", COL_BAD, ""), (self.tr("Riskiest Shift", "En Riskli Vardiya"), f"{top_sh['Shift']} · {top_sh['Failure_Rate']:.1f}%" if top_sh is not None else "-", COL_WARN, ""), (self.tr("Worst Pair", "En Riskli Eşleşme"), f"{top_combo['Shift']} / {top_combo['Operator_ID']} · {top_combo['Failure_Rate']:.1f}%" if top_combo is not None else "-", COL_ACCENT, "")]
    for i, (t,v,c,s) in enumerate(cards): self._kpi_card(strip,t,v,c,i,s)
    self._table(area, op, height=8); self._table(area, sh, height=5)


def show_capability_v6(self):
    self.clear_content(); area = self._scroll_area()
    self._page_title(area, self.tr("Process Capability (Cp / Cpk)", "Süreç Kabiliyeti (Cp / Cpk)"), self.tr("SPC view of specification fit and process health.", "Spesifikasyona uyum ve süreç sağlığı için SPC görünümü."), icon="◉")
    k = overall_kpis(self.df); verdict = capability_verdict(k['cpk']); vcolor = COL_GOOD if verdict == "Capable" else COL_WARN if verdict == "Marginal" else COL_BAD
    verdict_txt = {"Capable": self.tr("Capable", "Yeterli"), "Marginal": self.tr("Marginal", "Sınırda"), "Not Capable": self.tr("Not Capable", "Yetersiz"), "N/A": "N/A"}.get(verdict, verdict)
    strip = ctk.CTkFrame(area, fg_color="transparent"); strip.pack(fill="x", padx=22, pady=(0, 8))
    vals = [("Cp", f"{k['cp']:.2f}" if k['cp'] is not None else "N/A", COL_ACCENT, ""), ("Cpk", f"{k['cpk']:.2f}" if k['cpk'] is not None else "N/A", vcolor, ""), (self.tr("Verdict", "Yorum"), verdict_txt, vcolor, "")]
    for i,(t,v,c,s) in enumerate(vals): self._kpi_card(strip,t,v,c,i,s)
    ms = build_machine_summary(self.df)
    charts = ctk.CTkFrame(area, fg_color="transparent"); charts.pack(fill="both", expand=True, padx=22, pady=(0,10)); charts.grid_columnconfigure(0, weight=1); charts.grid_columnconfigure(1, weight=1)
    hist = self._section_card(charts, self.tr("Measurement Distribution", "Ölçüm Dağılımı"), "", use_grid=True, row=0, column=0, sticky="nsew", padx=(0,8), pady=0)
    lsl=float(self.df['LSL'].median()); usl=float(self.df['USL'].median()); fig,ax=self._styled_fig(6.5,3.0)
    ax.hist(self.df['Measurement'], bins=30, color=COL_ACCENT, alpha=.9); ax.axvline(lsl,color=COL_BAD,linestyle='--',linewidth=2,label='LSL'); ax.axvline(usl,color=COL_BAD,linestyle='--',linewidth=2,label='USL'); ax.axvline(self.df['Measurement'].mean(),color=COL_GOOD,linewidth=2,label=self.tr('Mean','Ortalama')); ax.legend(facecolor=COL_CARD, edgecolor=COL_BORDER, labelcolor=COL_TEXT); fig.tight_layout(); self._embed_figure(hist, fig)
    cpkc = self._section_card(charts, self.tr("Per-Machine Cpk", "Makine Bazlı Cpk"), "", use_grid=True, row=0, column=1, sticky="nsew", padx=(8,0), pady=0)
    fig2,ax2=self._styled_fig(6.5,3.0); ax2.bar(ms['Machine_ID'], ms['Cpk'].fillna(0), color=[COL_GOOD if x>=1.33 else COL_WARN if x>=1 else COL_BAD for x in ms['Cpk'].fillna(0)]); ax2.axhline(1.33,color=COL_GOOD,linestyle='--'); ax2.axhline(1.0,color=COL_WARN,linestyle='--'); ax2.set_ylabel('Cpk'); fig2.tight_layout(); self._embed_figure(cpkc, fig2)
    cap_tbl = ms[["Machine_ID", "Avg_Measurement", "Cp", "Cpk"]].copy(); cap_tbl[self.tr("Verdict", "Yorum")] = cap_tbl["Cpk"].apply(lambda x: {"Capable": self.tr("Capable", "Yeterli"), "Marginal": self.tr("Marginal", "Sınırda"), "Not Capable": self.tr("Not Capable", "Yetersiz"), "N/A":"N/A"}.get(capability_verdict(x), capability_verdict(x)))
    self._table(area, cap_tbl, height=6)


def show_raw_data_v6(self):
    self.clear_content(); area = ctk.CTkFrame(self.content, fg_color="transparent"); area.pack(fill="both", expand=True)
    self._page_title(area, self.tr("Raw Data Explorer", "Ham Veri Gezgini"), self.tr(f"Showing {min(200,len(self.df))} of {len(self.df)} rows.", f"{len(self.df)} satırın ilk {min(200,len(self.df))} satırı gösteriliyor."), icon="⌘")
    self._table(area, self.df.head(200), height=20, expand=True)


# Apply v6 overrides.
