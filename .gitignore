# ======================================================================
# DEMO DATA
# ======================================================================
def create_demo_data(rows=500):
    np.random.seed(42)

    machines = ["M01", "M02", "M03", "M04", "M05"]
    operators = ["OP01", "OP02", "OP03", "OP04", "OP05", "OP06"]
    shifts = ["Morning", "Evening", "Night"]
    products = ["Product A", "Product B", "Product C"]
    failure_types = [
        "Dimension Error", "Surface Defect", "Machine Jam",
        "Overheating", "Calibration Error",
    ]

    rows_out = []
    for _ in range(rows):
        machine = np.random.choice(machines)
        operator = np.random.choice(operators)
        shift = np.random.choice(shifts)
        product = np.random.choice(products)

        lsl, usl = 48, 52

        # Inject realistic problems: M03 runs hot/high, M05 runs low
        if machine == "M03":
            measurement = np.random.normal(52.2, 1.2)
        elif machine == "M05":
            measurement = np.random.normal(47.9, 1.1)
        else:
            measurement = np.random.normal(50, 0.8)

        status = "Pass" if lsl <= measurement <= usl else "Fail"

        if status == "Fail":
            failure_type = np.random.choice(failure_types)
            failure_cost = int(np.random.randint(400, 2500))
            downtime = int(np.random.randint(10, 120))
        else:
            failure_type = "None"
            failure_cost = 0
            downtime = 0

        rows_out.append({
            "Machine_ID": machine,
            "Operator_ID": operator,
            "Shift": shift,
            "Product_Type": product,
            "Measurement": round(measurement, 3),
            "LSL": lsl,
            "USL": usl,
            "Status": status,
            "Failure_Type": failure_type,
            "Failure_Cost": failure_cost,
            "Downtime_Minutes": downtime,
        })

    return pd.DataFrame(rows_out)


# ======================================================================
# FILE READING  (CSV or Excel) — tolerant of OneDrive / Excel file locks
# ======================================================================
def read_any(path):
    """
    Read a CSV or Excel file. If the file is locked (open in Excel) or is a
    OneDrive 'online-only' placeholder, fall back to copying it to a temp
    location first, and otherwise raise a clear, actionable error.
    """
    import io
    import shutil

    ext = os.path.splitext(path)[1].lower()

    def _read_bytes(p):
        with open(p, "rb") as f:
            return f.read()

    try:
        data = _read_bytes(path)
    except PermissionError:
        # Likely open in Excel or a OneDrive cloud placeholder -> try a copy
        tmp = os.path.join(tempfile.gettempdir(),
                           "fp_" + os.path.basename(path))
        try:
            shutil.copy2(path, tmp)
            data = _read_bytes(tmp)
        except Exception:
            raise PermissionError(
                "Cannot open the file — it appears to be open in Excel or still "
                "syncing in OneDrive.\nClose it in Excel (or right-click the file "
                "> 'Always keep on this device'), then try again."
            )

    bio = io.BytesIO(data)
    if ext in (".xlsx", ".xls", ".xlsm"):
        return pd.read_excel(bio)          # needs openpyxl for .xlsx
    return pd.read_csv(bio)


# ======================================================================
# DATA NORMALIZATION
#   Make an arbitrary uploaded CSV usable: coerce numeric columns,
#   derive missing columns where possible, fill gaps with safe defaults.
# ======================================================================
def _norm_key(name):
    """Lowercase + strip everything except letters/numbers, for fuzzy matching."""
    return "".join(ch for ch in str(name).lower() if ch.isalnum())


# Canonical column -> list of accepted aliases (matched after _norm_key)
COLUMN_ALIASES = {
    "Machine_ID":       ["machineid", "machine", "machineno", "machinenumber",
                         "equipmentid", "equipment", "makine", "makineid"],
    "Operator_ID":      ["operatorid", "operator", "operatorname", "worker",
                         "employee", "operator_id", "personel"],
    "Shift":            ["shift", "vardiya"],
    "Product_Type":     ["producttype", "product", "parttype", "urun"],
    "Status":           ["status", "passfail", "result", "qcresult", "qcstatus",
                         "passorfail", "sonuc", "durum"],
    "LSL":              ["lsl", "lowerspeclimit", "lowerlimit", "altlimit"],
    "USL":              ["usl", "upperspeclimit", "upperlimit", "ustlimit"],
    "Failure_Cost":     ["failurecost", "costperunitusd", "costperunit", "cost",
                         "scrapcost", "maliyet", "unitcost"],
    "Downtime_Minutes": ["downtimeminutes", "downtime", "downtimemin", "durus"],
    "Failure_Type":     ["failuretype", "defecttype", "defect", "arizatipi"],
    "Measurement":      ["measurement", "value", "reading", "olcum", "dimension",
                         "length1mm", "length1", "length", "diameter", "size",
                         "width", "boy", "olcu"],
}

# Columns that should NOT be auto-picked as a fallback measurement column
_NON_MEASURE = {"lsl", "usl", "cp", "cpk", "batchyield", "yield", "cost",
                "costperunitusd", "costperunit", "downtime", "downtimeminutes"}


def _build_rename_map(actual_cols):
    """Map canonical names to whichever actual column matches an alias."""
    norm_to_actual = {_norm_key(c): c for c in actual_cols}
    rename = {}
    used = set()
    for canonical, aliases in COLUMN_ALIASES.items():
        for alias in aliases:
            if alias in norm_to_actual and norm_to_actual[alias] not in used:
                rename[norm_to_actual[alias]] = canonical
                used.add(norm_to_actual[alias])
                break
    return rename, used


def normalize_data(df):
    df = df.copy()
    df.columns = [str(c).strip() for c in df.columns]

    # 1) Map known aliases (MachineID -> Machine_ID, PassFail -> Status, etc.)
    rename, used = _build_rename_map(df.columns)
    df = df.rename(columns=rename)

    # 2) If still no Measurement, pick the first sensible numeric/dimension column
    if "Measurement" not in df.columns:
        candidate = None
        # prefer columns that look like a dimension/length
        for c in df.columns:
            nk = _norm_key(c)
            if c in rename.values():
                continue
            if any(t in nk for t in ("length", "dimension", "diameter",
                                     "width", "size", "olcu", "measure")) \
                    and nk not in _NON_MEASURE:
                candidate = c
                break
        # otherwise first numeric column that isn't a spec limit / cost / yield
        if candidate is None:
            for c in df.columns:
                if _norm_key(c) in _NON_MEASURE or c in rename.values():
                    continue
                if pd.to_numeric(df[c], errors="coerce").notna().mean() > 0.8:
                    candidate = c
                    break
        if candidate is not None:
            df = df.rename(columns={candidate: "Measurement"})

    # 3) Hard requirement check (clear, friendly message)
    missing = [c for c in REQUIRED_COLS if c not in df.columns]
    if missing:
        raise ValueError(
            "Could not find required data. Missing: " + ", ".join(missing)
            + ".\nNeed at least a machine column (e.g. MachineID) and a "
              "measurement/dimension column (e.g. Length, Measurement)."
        )

    # Numeric coercion
    for col in ["Measurement", "LSL", "USL", "Failure_Cost", "Downtime_Minutes"]:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")

    # Default spec limits if absent (use data spread as a fallback)
    if "LSL" not in df.columns or df["LSL"].isna().all():
        df["LSL"] = round(df["Measurement"].mean() - 3 * df["Measurement"].std(), 3)
    if "USL" not in df.columns or df["USL"].isna().all():
        df["USL"] = round(df["Measurement"].mean() + 3 * df["Measurement"].std(), 3)

    df["LSL"] = df["LSL"].fillna(df["LSL"].median())
    df["USL"] = df["USL"].fillna(df["USL"].median())

    # Derive Pass/Fail if not provided; normalize text values
    if "Status" not in df.columns:
        df["Status"] = np.where(
            (df["Measurement"] >= df["LSL"]) & (df["Measurement"] <= df["USL"]),
            "Pass", "Fail",
        )
    df["Status"] = df["Status"].astype(str).str.strip().str.title()
    # tolerate 0/1, OK/NOK, Yes/No style values
    df["Status"] = df["Status"].replace({
        "1": "Pass", "0": "Fail", "True": "Pass", "False": "Fail",
        "Ok": "Pass", "Nok": "Fail", "Yes": "Pass", "No": "Fail",
        "Gecti": "Pass", "Kaldi": "Fail",
    })
    df.loc[~df["Status"].isin(["Pass", "Fail"]), "Status"] = np.where(
        df.loc[~df["Status"].isin(["Pass", "Fail"]), "Status"]
        .str.lower().str.startswith("pass"), "Pass", "Fail")

    # Optional categorical columns
    for col, default in [("Operator_ID", "Unknown"),
                         ("Shift", "Unknown"),
                         ("Product_Type", "Unknown"),
                         ("Failure_Type", "None")]:
        if col not in df.columns:
            df[col] = default
        df[col] = df[col].fillna(default).astype(str)

    # Cost / downtime defaults
    for col in ["Failure_Cost", "Downtime_Minutes"]:
        if col not in df.columns:
            df[col] = 0
        df[col] = pd.to_numeric(df[col], errors="coerce").fillna(0)

    # If the mapped cost is a per-unit cost, only count it for failed parts
    # (so "Failure_Cost" stays meaningful: cost incurred by failures).
    if "Failure_Cost" in df.columns and (df["Failure_Cost"] > 0).any():
        df["Failure_Cost"] = np.where(df["Status"] == "Fail",
                                      df["Failure_Cost"], 0)

    df["Machine_ID"] = df["Machine_ID"].astype(str)
    df = df.dropna(subset=["Measurement"]).reset_index(drop=True)
    return df


# ======================================================================
# CORE ANALYTICS  (pure functions, no UI — easy to test)
# ======================================================================
def process_capability(values, lsl, usl):
    """Cp and Cpk for one set of measurements. Returns None if not computable."""
    values = pd.to_numeric(pd.Series(values), errors="coerce").dropna()
    if len(values) < 2:
        return None
    mu = values.mean()
    sigma = values.std(ddof=1)
    if sigma == 0 or pd.isna(sigma):
        return None
    cp = (usl - lsl) / (6 * sigma)
    cpu = (usl - mu) / (3 * sigma)
    cpl = (mu - lsl) / (3 * sigma)
    cpk = min(cpu, cpl)
    return {"mean": mu, "sigma": sigma, "cp": cp, "cpk": cpk}


def capability_verdict(cpk):
    """Human-readable verdict for a Cpk value."""
    if cpk is None:
        return "N/A"
    if cpk >= 1.33:
        return "Capable"
    if cpk >= 1.0:
        return "Marginal"
    return "Not Capable"


def build_machine_summary(df):
    """Per-machine KPIs + capability + criticality score."""
    rows = []
    for mid, g in df.groupby("Machine_ID"):
        total = len(g)
        failures = int((g["Status"] == "Fail").sum())
        fail_rate = failures / total * 100 if total else 0
        cost = float(g["Failure_Cost"].sum())
        downtime = float(g["Downtime_Minutes"].sum())

        lsl = float(g["LSL"].median())
        usl = float(g["USL"].median())
        cap = process_capability(g["Measurement"], lsl, usl)
        cpk = cap["cpk"] if cap else np.nan
        cp = cap["cp"] if cap else np.nan

        rows.append({
            "Machine_ID": mid,
            "Inspections": total,
            "Failures": failures,
            "Failure_Rate": round(fail_rate, 2),
            "Failure_Cost": round(cost, 0),
            "Downtime_Minutes": round(downtime, 0),
            "Avg_Measurement": round(float(g["Measurement"].mean()), 3),
            "Cp": round(cp, 2) if pd.notna(cp) else np.nan,
            "Cpk": round(cpk, 2) if pd.notna(cpk) else np.nan,
            "Cost_per_1000_units": round(cost / total * 1000, 0) if total else 0,
        })

    summary = pd.DataFrame(rows)
    if summary.empty:
        return summary

    # Normalize components to 0-1 then weight them into a 0-100 criticality score
    def norm(s):
        rng = s.max() - s.min()
        return (s - s.min()) / rng if rng else s * 0

    fr_n = norm(summary["Failure_Rate"])
    cost_n = norm(summary["Failure_Cost"])
    down_n = norm(summary["Downtime_Minutes"])
    # Capability penalty: lower Cpk -> higher penalty (clamped at Cpk target 1.33)
    cpk_filled = summary["Cpk"].fillna(0)
    cap_pen = norm((1.33 - cpk_filled).clip(lower=0))

    summary["Criticality_Score"] = (
        fr_n * 35 + cost_n * 30 + down_n * 15 + cap_pen * 20
    ).round(1)

    return summary.sort_values("Criticality_Score", ascending=False).reset_index(drop=True)


def build_group_summary(df, key):
    """Generic performance summary for Operator_ID / Shift / Product_Type."""
    rows = []
    for val, g in df.groupby(key):
        total = len(g)
        failures = int((g["Status"] == "Fail").sum())
        rows.append({
            key: val,
            "Inspections": total,
            "Failures": failures,
            "Failure_Rate": round(failures / total * 100, 2) if total else 0,
            "Pass_Rate": round((total - failures) / total * 100, 2) if total else 0,
            "Failure_Cost": round(float(g["Failure_Cost"].sum()), 0),
            "Avg_Measurement": round(float(g["Measurement"].mean()), 3),
        })
    out = pd.DataFrame(rows)
    return out.sort_values("Failure_Rate", ascending=False).reset_index(drop=True)


def overall_kpis(df):
    total = len(df)
    fails = int((df["Status"] == "Fail").sum())
    passes = total - fails
    lsl = float(df["LSL"].median())
    usl = float(df["USL"].median())
    cap = process_capability(df["Measurement"], lsl, usl)
    return {
        "total": total,
        "pass": passes,
        "fail": fails,
        "pass_rate": passes / total * 100 if total else 0,
        "fail_rate": fails / total * 100 if total else 0,
        "cost": float(df["Failure_Cost"].sum()),
        "downtime": float(df["Downtime_Minutes"].sum()),
        "cp": cap["cp"] if cap else None,
        "cpk": cap["cpk"] if cap else None,
    }


def generate_ai_insights(df):
    """
    Rule-based 'AI' analyst. Produces a prioritized list of findings with a
    plain-English recommendation per machine, plus a top-level headline.
    """
    summary = build_machine_summary(df)
    insights = []

    for _, r in summary.iterrows():
        score = r["Criticality_Score"]
        cpk = r["Cpk"]
        reasons = []

        if pd.notna(cpk) and cpk < 1.0:
            reasons.append(f"low process capability (Cpk={cpk:.2f})")
        elif pd.notna(cpk) and cpk < 1.33:
            reasons.append(f"marginal process capability (Cpk={cpk:.2f})")

        if r["Failure_Rate"] >= 15:
            reasons.append(f"high failure rate ({r['Failure_Rate']:.1f}%)")
        if r["Failure_Cost"] >= summary["Failure_Cost"].median() and r["Failure_Cost"] > 0:
            reasons.append(f"high failure cost (${r['Failure_Cost']:,.0f})")
        if r["Downtime_Minutes"] >= summary["Downtime_Minutes"].median() and r["Downtime_Minutes"] > 0:
            reasons.append(f"significant downtime ({r['Downtime_Minutes']:.0f} min)")

        # Drift direction hint from spec center
        center = float(df["LSL"].median()) + (float(df["USL"].median()) - float(df["LSL"].median())) / 2
        drift = r["Avg_Measurement"] - center
        if abs(drift) > 0.5:
            direction = "above" if drift > 0 else "below"
            reasons.append(f"mean drifting {direction} target by {abs(drift):.2f}")

        if score >= 60:
            priority = "HIGH"
        elif score >= 30:
            priority = "MEDIUM"
        else:
            priority = "LOW"

        if not reasons:
            reasons.append("operating within normal parameters")

        msg = (
            f"Machine {r['Machine_ID']} shows " + ", ".join(reasons)
            + f". Maintenance priority: {priority}."
        )
        insights.append({
            "machine": r["Machine_ID"],
            "priority": priority,
            "score": score,
            "message": msg,
        })

    headline = ""
    if not summary.empty:
        top = summary.iloc[0]
        headline = (
            f"Most critical machine is {top['Machine_ID']} "
            f"(criticality score {top['Criticality_Score']:.0f}/100). "
            f"It accounts for ${top['Failure_Cost']:,.0f} in failure cost "
            f"and a {top['Failure_Rate']:.1f}% failure rate — inspect first."
        )

    return headline, insights


# ======================================================================
# REAL AI ANALYSIS  (Google Gemini)
#   We DON'T send raw rows. We compute trustworthy stats first, then let the
#   AI reason over the aggregated numbers and write the analyst narrative.
# ======================================================================
def build_data_context(df):
    """Compact JSON string of all pre-computed stats — shared by report and chat."""
    k = overall_kpis(df)
    machine = build_machine_summary(df)
    op = build_group_summary(df, "Operator_ID")
    shift = build_group_summary(df, "Shift")
    cp_txt = f"{k['cp']:.2f}" if k["cp"] else "N/A"
    cpk_txt = f"{k['cpk']:.2f}" if k["cpk"] else "N/A"
    stats = {
        "overall": {
            "inspections": k["total"],
            "pass_rate_pct": round(k["pass_rate"], 2),
            "failure_rate_pct": round(k["fail_rate"], 2),
            "total_failure_cost": round(k["cost"], 0),
            "total_downtime_min": round(k["downtime"], 0),
            "Cp": cp_txt,
            "Cpk": cpk_txt,
        },
        "machines": machine.to_dict(orient="records"),
        "operators": op.to_dict(orient="records"),
        "shifts": shift.to_dict(orient="records"),
    }
    return json.dumps(stats, default=str)


def _fmt_pct(x):
    try:
        return f"{float(x):.2f}%"
    except Exception:
        return "N/A"


def _fmt_money(x):
    try:
        return f"${float(x):,.0f}"
    except Exception:
        return "$0"


def _fmt_num(x, digits=2):
    try:
        if pd.isna(x):
            return "N/A"
        return f"{float(x):.{digits}f}"
    except Exception:
        return "N/A"


def build_shift_operator_summary(df):
    """Failure summary for every Shift + Operator pair."""
    rows = []
    if "Shift" not in df.columns or "Operator_ID" not in df.columns:
        return pd.DataFrame(rows)

    for (shift, op), g in df.groupby(["Shift", "Operator_ID"]):
        total = len(g)
        failures = int((g["Status"] == "Fail").sum())
        rows.append({
            "Shift": shift,
            "Operator_ID": op,
            "Inspections": total,
            "Failures": failures,
            "Failure_Rate": round(failures / total * 100, 2) if total else 0,
            "Failure_Cost": round(float(g["Failure_Cost"].sum()), 0),
            "Downtime_Minutes": round(float(g["Downtime_Minutes"].sum()), 0),
            "Avg_Measurement": round(float(g["Measurement"].mean()), 3),
        })
    out = pd.DataFrame(rows)
    if out.empty:
        return out
    return out.sort_values(
        ["Failure_Rate", "Failures", "Failure_Cost"],
        ascending=[False, False, False]
    ).reset_index(drop=True)


def _first_record(df):
    if df is None or df.empty:
        return None
    return df.iloc[0].to_dict()


def _machine_action(row, df):
    """Create a practical maintenance/quality action for a machine row."""
    if row is None:
        return "No machine-level action can be generated."

    mid = row.get("Machine_ID", "Unknown")
    cpk = row.get("Cpk", np.nan)
    cp = row.get("Cp", np.nan)
    fail_rate = float(row.get("Failure_Rate", 0) or 0)
    cost = float(row.get("Failure_Cost", 0) or 0)
    downtime = float(row.get("Downtime_Minutes", 0) or 0)
    avg = float(row.get("Avg_Measurement", np.nan) or np.nan)

    lsl = float(df["LSL"].median())
    usl = float(df["USL"].median())
    target = (lsl + usl) / 2
    drift = avg - target if pd.notna(avg) else 0

    actions = []
    if pd.notna(cpk) and cpk < 1.0:
        if abs(drift) >= 0.30:
            direction = "downward" if drift > 0 else "upward"
            actions.append(
                f"re-center the process {direction} toward the target "
                f"({target:.2f}) because the mean is {abs(drift):.2f} away from target"
            )
        else:
            actions.append(
                "reduce variation with calibration, tool-condition check, and tighter setup control "
                "because Cpk is below 1.00"
            )
    elif pd.notna(cpk) and cpk < 1.33:
        actions.append("treat capability as marginal; increase sampling frequency and verify setup parameters")

    if fail_rate >= 15:
        actions.append("open a root-cause action and inspect the next batches with containment control")
    elif fail_rate >= 8:
        actions.append("monitor closely and schedule a short preventive-maintenance check")

    if cost > 0:
        actions.append("attack the high-cost failure modes first instead of only counting failure frequency")
    if downtime > 0:
        actions.append("check the downtime drivers and add them to the preventive-maintenance checklist")

    if not actions:
        actions.append("keep standard preventive maintenance and routine SPC monitoring")

    return f"{mid}: " + "; ".join(actions) + "."


def build_decision_snapshot(df):
    """
    Creates a small, human-readable decision snapshot before Gemini sees the prompt.
    This prevents vague answers because the model receives the exact facts and the
    recommended direction, not only a raw JSON table.
    """
    k = overall_kpis(df)
    machine = build_machine_summary(df)
    op = build_group_summary(df, "Operator_ID")
    shift = build_group_summary(df, "Shift")
    combo = build_shift_operator_summary(df)

    top_machine = _first_record(machine)
    top_operator = _first_record(op)
    top_shift = _first_record(shift)
    top_combo = _first_record(combo)

    cp_txt = _fmt_num(k["cp"])
    cpk_txt = _fmt_num(k["cpk"])
    verdict = capability_verdict(k["cpk"])

    lines = [
        "DECISION SNAPSHOT — use these facts as ground truth:",
        f"Overall: {k['total']} inspections, pass rate {_fmt_pct(k['pass_rate'])}, "
        f"failure rate {_fmt_pct(k['fail_rate'])}, total failure cost {_fmt_money(k['cost'])}, "
        f"total downtime {_fmt_num(k['downtime'], 0)} minutes, Cp {cp_txt}, Cpk {cpk_txt} "
        f"({verdict}).",
    ]

    if top_machine:
        lines.append(
            f"Most critical machine: {top_machine['Machine_ID']} with criticality score "
            f"{_fmt_num(top_machine['Criticality_Score'], 1)}/100, failure rate "
            f"{_fmt_pct(top_machine['Failure_Rate'])}, failure cost "
            f"{_fmt_money(top_machine['Failure_Cost'])}, downtime "
            f"{_fmt_num(top_machine['Downtime_Minutes'], 0)} minutes, Cp "
            f"{_fmt_num(top_machine['Cp'])}, Cpk {_fmt_num(top_machine['Cpk'])}."
        )

    if top_shift:
        lines.append(
            f"Worst shift: {top_shift['Shift']} with failure rate "
            f"{_fmt_pct(top_shift['Failure_Rate'])}, {int(top_shift['Failures'])} failures, "
            f"failure cost {_fmt_money(top_shift['Failure_Cost'])}."
        )

    if top_operator:
        lines.append(
            f"Worst operator: {top_operator['Operator_ID']} with failure rate "
            f"{_fmt_pct(top_operator['Failure_Rate'])}, {int(top_operator['Failures'])} failures, "
            f"failure cost {_fmt_money(top_operator['Failure_Cost'])}."
        )

    if top_combo:
        lines.append(
            f"Worst shift-operator pair: {top_combo['Shift']} / {top_combo['Operator_ID']} "
            f"with failure rate {_fmt_pct(top_combo['Failure_Rate'])}, "
            f"{int(top_combo['Failures'])} failures from {int(top_combo['Inspections'])} inspections."
        )

    fail_rows = df[df["Status"] == "Fail"]
    if not fail_rows.empty and "Failure_Type" in fail_rows.columns:
        ft = fail_rows["Failure_Type"].value_counts().head(3)
        ft_txt = ", ".join([f"{idx}: {cnt}" for idx, cnt in ft.items()])
        lines.append(f"Most common failure types: {ft_txt}.")

    if not machine.empty:
        lines.append("Maintenance priority order:")
        for i, (_, row) in enumerate(machine.head(5).iterrows(), start=1):
            lines.append(
                f"{i}) {row['Machine_ID']} — score {_fmt_num(row['Criticality_Score'], 1)}, "
                f"failure rate {_fmt_pct(row['Failure_Rate'])}, cost {_fmt_money(row['Failure_Cost'])}, "
                f"Cpk {_fmt_num(row['Cpk'])}."
            )

        lines.append("Recommended actions by machine:")
        for _, row in machine.head(5).iterrows():
            lines.append("- " + _machine_action(row.to_dict(), df))

    if top_shift:
        lines.append(
            f"Shift action: for {top_shift['Shift']}, add first-piece approval at shift start, "
            "short calibration check, handover checklist, and supervisor review of abnormal measurements. "
            "If this is the night shift, also check fatigue, lighting, staffing, and machine warm-up behavior."
        )

    lines.append(
        "Cp/Cpk improvement rule: increase Cpk by centering the mean between LSL and USL, reducing standard "
        "deviation, recalibrating tools/sensors, improving setup repeatability, controlling raw material variation, "
        "and applying SPC alarms before measurements cross spec limits."
    )

    text = "\n".join(lines)
    return {
        "text": text,
        "overall": k,
        "machine_summary": machine,
        "operator_summary": op,
        "shift_summary": shift,
        "combo_summary": combo,
    }



def _is_turkish_question(question):
    """Tiny language hint so local answers follow the user's language."""
    q = (question or "").lower()
    tr_markers = [
        "gece", "vardiya", "arıza", "ariza", "bakım", "bakim", "öner", "tavsiye",
        "nasıl", "nasil", "değer", "deger", "artır", "artir", "azalt", "hangi",
        "neden", "kritik", "operatör", "operator", "süreç", "surec", "kabiliyet",
    ]
    return any(ch in q for ch in "çğıöşü") or any(m in q for m in tr_markers)


def _question_flags(question):
    q = (question or "").lower()
    return {
        "shift": any(x in q for x in ["shift", "vardiya", "gece", "night", "evening", "morning", "sabah", "akşam", "aksam"]),
        "night": any(x in q for x in ["night", "gece"]),
        "operator": any(x in q for x in ["operator", "operatör", "operat"]),
        "capability": any(x in q for x in ["cp", "cpk", "capability", "kabiliyet", "process capability", "süreç", "surec"]),
        "maintenance": any(x in q for x in ["maintenance", "bakım", "bakim", "arıza", "ariza", "failure", "fail", "prioritize", "öncelik", "oncelik"]),
        "improvement": any(x in q for x in ["how", "nasıl", "nasil", "increase", "artır", "artir", "reduce", "azalt", "improve", "iyileştir", "iyilestir", "recommend", "öner", "oner", "tavsiye"]),
        "critical": any(x in q for x in ["critical", "kritik", "risk", "most", "en "])
    }


def _select_shift_row(shift_summary, question):
    """Pick the shift that the user is asking about; fallback to worst shift."""
    if shift_summary is None or shift_summary.empty:
        return None

    q = (question or "").lower()
    priority_terms = []
    if "gece" in q or "night" in q:
        priority_terms = ["night", "gece"]
    elif "sabah" in q or "morning" in q:
        priority_terms = ["morning", "sabah"]
    elif "akşam" in q or "aksam" in q or "evening" in q:
        priority_terms = ["evening", "akşam", "aksam"]

    for term in priority_terms:
        for _, row in shift_summary.iterrows():
            if term in str(row.get("Shift", "")).lower():
                return row

    return shift_summary.iloc[0]


def _subset_for_shift(df, shift_name):
    if not shift_name or "Shift" not in df.columns:
        return df.iloc[0:0].copy()
    return df[df["Shift"].astype(str).str.lower() == str(shift_name).lower()].copy()


def _top_failure_type_text(df, lang="tr"):
    fail_rows = df[df["Status"] == "Fail"] if "Status" in df.columns else df.iloc[0:0]
    if fail_rows.empty or "Failure_Type" not in fail_rows.columns:
        return ""
    ft = fail_rows["Failure_Type"].astype(str).value_counts().head(3)
    if ft.empty:
        return ""
    joined = ", ".join([f"{idx}: {cnt}" for idx, cnt in ft.items() if str(idx).lower() != "none"])
    if not joined:
        return ""
    return (f"En sık hata tipleri: {joined}." if lang == "tr" else f"Most common failure types: {joined}.")


def _machine_action_tr(row, df):
    """Turkish machine-specific action text, grounded in the KPI row."""
    if row is None:
        return "Makine bazlı aksiyon üretilemedi."

    mid = row.get("Machine_ID", "Unknown")
    cpk = row.get("Cpk", np.nan)
    fail_rate = float(row.get("Failure_Rate", 0) or 0)
    cost = float(row.get("Failure_Cost", 0) or 0)
    downtime = float(row.get("Downtime_Minutes", 0) or 0)
    avg = float(row.get("Avg_Measurement", np.nan) or np.nan)

    lsl = float(df["LSL"].median())
    usl = float(df["USL"].median())
    target = (lsl + usl) / 2
    drift = avg - target if pd.notna(avg) else 0

    actions = []
    if pd.notna(cpk) and cpk < 1.0:
        if abs(drift) >= 0.30:
            yon = "aşağı" if drift > 0 else "yukarı"
            actions.append(
                f"ortalama hedef değerden {abs(drift):.2f} sapıyor; prosesi {yon} yönde merkeze ({target:.2f}) çek"
            )
        else:
            actions.append("Cpk 1.00 altında; varyasyonu azaltmak için kalibrasyon, takım aşınması ve setup tekrarını kontrol et")
    elif pd.notna(cpk) and cpk < 1.33:
        actions.append("Cpk marjinal; örnekleme sıklığını artır ve setup parametrelerini doğrula")

    if fail_rate >= 15:
        actions.append("arıza oranı yüksek; kök neden aksiyonu aç ve sonraki partilerde containment kontrolü uygula")
    elif fail_rate >= 8:
        actions.append("kısa önleyici bakım ve yakın SPC takibi planla")

    if cost > 0:
        actions.append(f"maliyet {_fmt_money(cost)}; en pahalı hata tiplerinden başla")
    if downtime > 0:
        actions.append(f"duruş {_fmt_num(downtime, 0)} dk; duruş nedenlerini bakım checklist'ine ekle")

    if not actions:
        actions.append("standart önleyici bakım ve rutin SPC izlemeye devam et")

    return f"{mid}: " + "; ".join(actions) + "."


def _build_local_answer_tr(df, question=""):
    snap = build_decision_snapshot(df)
    flags = _question_flags(question)
    k = snap["overall"]
    machine = snap["machine_summary"]
    shift = snap["shift_summary"]
    op = snap["operator_summary"]
    combo = snap["combo_summary"]

    parts = []

    # 1) If the user asks about a shift, answer that first. This fixes the old
    # behaviour where every answer started with the top machine and felt off-topic.
    if flags["shift"]:
        target_shift = _select_shift_row(shift, question)
        if target_shift is not None:
            shift_name = target_shift["Shift"]
            shift_df = _subset_for_shift(df, shift_name)
            parts.append(
                f"Önce {shift_name} vardiyasına odaklanalım: bu vardiyada arıza oranı "
                f"{_fmt_pct(target_shift['Failure_Rate'])}, arıza sayısı {int(target_shift['Failures'])}, "
                f"maliyet {_fmt_money(target_shift['Failure_Cost'])}. Genel arıza oranı ise "
                f"{_fmt_pct(k['fail_rate'])}, yani vardiya performansını genel ortalamayla birlikte okumalıyız."
            )

            if not shift_df.empty:
                sm = build_machine_summary(shift_df).sort_values(
                    ["Failure_Rate", "Failure_Cost", "Failures"], ascending=[False, False, False]
                ).reset_index(drop=True)
                if not sm.empty:
                    m = sm.iloc[0]
                    parts.append(
                        f"Bu vardiyada ilk kontrol edilecek makine {m['Machine_ID']}: "
                        f"arıza oranı {_fmt_pct(m['Failure_Rate'])}, arıza sayısı {int(m['Failures'])}, "
                        f"maliyet {_fmt_money(m['Failure_Cost'])}, Cpk {_fmt_num(m['Cpk'])}."
                    )

                so = build_group_summary(shift_df, "Operator_ID")
                if not so.empty:
                    worst_op = so.iloc[0]
                    parts.append(
                        f"Operatör tarafında {worst_op['Operator_ID']} öne çıkıyor: "
                        f"arıza oranı {_fmt_pct(worst_op['Failure_Rate'])}, "
                        f"{int(worst_op['Failures'])} arıza / {int(worst_op['Inspections'])} kontrol."
                    )

                ft_txt = _top_failure_type_text(shift_df, lang="tr")
                if ft_txt:
                    parts.append(ft_txt)

            if flags["improvement"] or flags["capability"] or flags["maintenance"]:
                parts.append(
                    "Bu vardiya için net aksiyon planı:\n"
                    "• Vardiya başlangıcında 10 dakikalık kalibrasyon + ilk parça onayı koy.\n"
                    "• Kritik makinede ölçüm ortalaması hedefin dışına kayıyorsa setup değerini merkeze çek; Cpk düşükse sadece muayene artırmak yetmez, varyasyonu düşürmek gerekir.\n"
                    "• Gece vardiyasında handover checklist, ışık/ergonomi kontrolü ve operatör yorgunluğu takibi ekle.\n"
                    "• Arıza oranı yüksek makinede bakım aralığını kısalt; bakım öncesi/sonrası Cpk ve arıza oranını ayrı ayrı karşılaştır.\n"
                    "• SPC alarm limitleri koy: ölçümler LSL/USL dışına çıkmadan önce trend sapmasını yakala."
                )

    # 2) Operator-specific question.
    if flags["operator"] and not op.empty:
        worst_op = op.iloc[0]
        parts.append(
            f"Operatör bazında en yüksek arıza oranı {worst_op['Operator_ID']} üzerinde: "
            f"{_fmt_pct(worst_op['Failure_Rate'])}, {int(worst_op['Failures'])} arıza, "
            f"maliyet {_fmt_money(worst_op['Failure_Cost'])}. Burada direkt suçlama değil; eğitim, iş talimatı, vardiya koşulları ve makine eşleşmesi birlikte incelenmeli."
        )
        if not combo.empty:
            worst_pair = combo.iloc[0]
            parts.append(
                f"En riskli vardiya-operatör kombinasyonu {worst_pair['Shift']} / {worst_pair['Operator_ID']}: "
                f"{_fmt_pct(worst_pair['Failure_Rate'])}, {int(worst_pair['Failures'])} arıza / "
                f"{int(worst_pair['Inspections'])} kontrol."
            )

    # 3) Capability question.
    if flags["capability"]:
        parts.append(
            f"Genel süreç kabiliyeti Cp {_fmt_num(k['cp'])}, Cpk {_fmt_num(k['cpk'])}; yorum: {capability_verdict(k['cpk'])}. "
            "Cpk'yi artırmak için iki ana kaldıraç var: ortalamayı LSL-USL merkezine çekmek ve standart sapmayı düşürmek. "
            "Pratikte bu; kalibrasyon, setup standardizasyonu, takım aşınması kontrolü, hammadde varyasyonunu azaltma ve SPC alarm sistemiyle yapılır."
        )
        if not machine.empty:
            bad = machine.sort_values(["Cpk", "Failure_Rate"], ascending=[True, False]).iloc[0]
            parts.append(
                f"Cpk açısından ilk bakılacak makine {bad['Machine_ID']}: Cpk {_fmt_num(bad['Cpk'])}, "
                f"Cp {_fmt_num(bad['Cp'])}, arıza oranı {_fmt_pct(bad['Failure_Rate'])}."
            )

    # 4) Machine / maintenance / criticality question.
    if (flags["maintenance"] or flags["critical"]) and not machine.empty:
        top = machine.iloc[0]
        order = " > ".join(machine["Machine_ID"].head(5).astype(str).tolist())
        parts.append(
            f"Makine bakım önceliği: {order}. En kritik makine {top['Machine_ID']}; "
            f"kritik skor {_fmt_num(top['Criticality_Score'], 1)}/100, arıza oranı {_fmt_pct(top['Failure_Rate'])}, "
            f"maliyet {_fmt_money(top['Failure_Cost'])}, Cpk {_fmt_num(top['Cpk'])}."
        )
        for _, row in machine.head(3).iterrows():
            parts.append("• " + _machine_action_tr(row.to_dict(), df))

    # 5) Generic fallback: concise executive answer.
    if not parts:
        if not machine.empty:
            top = machine.iloc[0]
            parts.append(
                f"Özetle ilk odak noktası {top['Machine_ID']}: kritik skor "
                f"{_fmt_num(top['Criticality_Score'], 1)}/100, arıza oranı "
                f"{_fmt_pct(top['Failure_Rate'])}, maliyet {_fmt_money(top['Failure_Cost'])}, "
                f"Cpk {_fmt_num(top['Cpk'])}."
            )
        if not shift.empty:
            sh = shift.iloc[0]
            parts.append(
                f"Vardiya tarafında {sh['Shift']} en riskli görünüyor: arıza oranı "
                f"{_fmt_pct(sh['Failure_Rate'])}, maliyet {_fmt_money(sh['Failure_Cost'])}."
            )
        parts.append(
            "İlk aksiyon: en kritik makinede kalibrasyon + setup kontrolü yap, ardından aynı vardiyada bakım öncesi/sonrası arıza oranı ve Cpk değerini karşılaştır."
        )

    return "\n\n".join(parts)


def _build_local_answer_en(df, question=""):
    snap = build_decision_snapshot(df)
    flags = _question_flags(question)
    k = snap["overall"]
    machine = snap["machine_summary"]
    shift = snap["shift_summary"]
    op = snap["operator_summary"]
    combo = snap["combo_summary"]

    parts = []

    if flags["shift"]:
        target_shift = _select_shift_row(shift, question)
        if target_shift is not None:
            shift_name = target_shift["Shift"]
            shift_df = _subset_for_shift(df, shift_name)
            parts.append(
                f"Start with the {shift_name} shift: failure rate {_fmt_pct(target_shift['Failure_Rate'])}, "
                f"{int(target_shift['Failures'])} failures, cost {_fmt_money(target_shift['Failure_Cost'])}. "
                f"Overall failure rate is {_fmt_pct(k['fail_rate'])}."
            )
            if not shift_df.empty:
                sm = build_machine_summary(shift_df).sort_values(
                    ["Failure_Rate", "Failure_Cost", "Failures"], ascending=[False, False, False]
                ).reset_index(drop=True)
                if not sm.empty:
                    m = sm.iloc[0]
                    parts.append(
                        f"Within this shift, first check machine {m['Machine_ID']}: failure rate "
                        f"{_fmt_pct(m['Failure_Rate'])}, {int(m['Failures'])} failures, "
                        f"cost {_fmt_money(m['Failure_Cost'])}, Cpk {_fmt_num(m['Cpk'])}."
                    )
                so = build_group_summary(shift_df, "Operator_ID")
                if not so.empty:
                    worst_op = so.iloc[0]
                    parts.append(
                        f"Operator hotspot: {worst_op['Operator_ID']} has {_fmt_pct(worst_op['Failure_Rate'])} "
                        f"failure rate, {int(worst_op['Failures'])} failures / {int(worst_op['Inspections'])} inspections."
                    )
            if flags["improvement"] or flags["capability"] or flags["maintenance"]:
                parts.append(
                    "Action plan:\n"
                    "• Add a 10-minute calibration and first-piece approval at shift start.\n"
                    "• Re-center the process if the mean is drifting; if Cpk is low, reduce variation, not only inspection frequency.\n"
                    "• Add shift handover, lighting/ergonomics checks, and fatigue monitoring for night work.\n"
                    "• Shorten the PM interval on the highest-failure machine and compare before/after Cpk and failure rate.\n"
                    "• Use SPC warning limits to catch drift before measurements cross LSL/USL."
                )

    if flags["operator"] and not op.empty:
        worst_op = op.iloc[0]
        parts.append(
            f"Worst operator-level failure rate is {worst_op['Operator_ID']}: {_fmt_pct(worst_op['Failure_Rate'])}, "
            f"{int(worst_op['Failures'])} failures, cost {_fmt_money(worst_op['Failure_Cost'])}. Treat this as a training/process-condition signal, not a blame signal."
        )
        if not combo.empty:
            worst_pair = combo.iloc[0]
            parts.append(
                f"Worst shift-operator pair: {worst_pair['Shift']} / {worst_pair['Operator_ID']} with "
                f"{_fmt_pct(worst_pair['Failure_Rate'])}, {int(worst_pair['Failures'])} failures / {int(worst_pair['Inspections'])} inspections."
            )

    if flags["capability"]:
        parts.append(
            f"Overall capability is Cp {_fmt_num(k['cp'])}, Cpk {_fmt_num(k['cpk'])}: {capability_verdict(k['cpk'])}. "
            "To increase Cpk, center the mean between LSL and USL and reduce standard deviation through calibration, setup standardization, tool-wear checks, material control, and SPC alarms."
        )
        if not machine.empty:
            bad = machine.sort_values(["Cpk", "Failure_Rate"], ascending=[True, False]).iloc[0]
            parts.append(
                f"Capability hotspot: {bad['Machine_ID']} has Cpk {_fmt_num(bad['Cpk'])}, Cp {_fmt_num(bad['Cp'])}, "
                f"failure rate {_fmt_pct(bad['Failure_Rate'])}."
            )

    if (flags["maintenance"] or flags["critical"]) and not machine.empty:
        top = machine.iloc[0]
        order = " > ".join(machine["Machine_ID"].head(5).astype(str).tolist())
        parts.append(
            f"Maintenance priority should be {order}. The most critical machine is {top['Machine_ID']}: "
            f"score {_fmt_num(top['Criticality_Score'], 1)}/100, failure rate {_fmt_pct(top['Failure_Rate'])}, "
            f"cost {_fmt_money(top['Failure_Cost'])}, Cpk {_fmt_num(top['Cpk'])}."
        )
        for _, row in machine.head(3).iterrows():
            parts.append("• " + _machine_action(row.to_dict(), df))

    if not parts:
        if not machine.empty:
            top = machine.iloc[0]
            parts.append(
                f"Top issue: {top['Machine_ID']} with score {_fmt_num(top['Criticality_Score'], 1)}/100, "
                f"failure rate {_fmt_pct(top['Failure_Rate'])}, cost {_fmt_money(top['Failure_Cost'])}, Cpk {_fmt_num(top['Cpk'])}."
            )
        if not shift.empty:
            sh = shift.iloc[0]
            parts.append(
                f"Shift hotspot: {sh['Shift']} with failure rate {_fmt_pct(sh['Failure_Rate'])} and cost {_fmt_money(sh['Failure_Cost'])}."
            )
        parts.append("First action: run calibration and setup checks on the critical machine, then compare before/after failure rate and Cpk.")

    return "\n\n".join(parts)


def build_local_answer(df, question=""):
    """
    Deterministic assistant answer. It answers the user's actual question first,
    then adds machine/capability context only when relevant. This is used as the
    safety backbone for Gemini so the chat does not drift into irrelevant output.
    """
    return _build_local_answer_tr(df, question) if _is_turkish_question(question) else _build_local_answer_en(df, question)

def build_ai_prompt(df):
    """Turn computed statistics into a structured-report prompt for the AI."""
    prompt = (
        "You are a senior manufacturing quality and maintenance analyst. "
        "Below are PRE-COMPUTED statistics from a production inspection dataset. "
        "Do NOT recompute numbers; trust the values given. Analyze them and "
        "produce a decision-support report.\n\n"
        "Cp/Cpk guide: >=1.33 capable, 1.00-1.33 marginal, <1.00 not capable. "
        "Criticality_Score is 0-100 (higher = more urgent).\n\n"
        f"DATA (JSON):\n{build_data_context(df)}\n\n"
        "Respond with ONLY valid JSON (no markdown, no code fences) in exactly "
        "this shape:\n"
        "{\n"
        '  "headline": "one-sentence top finding naming the most critical machine",\n'
        '  "machines": [\n'
        '    {"machine": "M03", "priority": "HIGH|MEDIUM|LOW", '
        '"recommendation": "one specific maintenance action and why"}\n'
        "  ],\n"
        '  "operator_shift_note": "one short insight about operator or shift patterns",\n'
        '  "narrative": "2-4 sentence executive summary"\n'
        "}\n"
        "Cover every machine in the machines array, ordered most to least critical."
    )
    return prompt



def _answer_is_weak(answer, question):
    """Simple guardrail: if Gemini drifts or becomes vague, use the local analyst answer."""
    a = (answer or "").strip().lower()
    q = (question or "").lower()
    if len(a) < 180:
        return True
    weak_markers = [
        "doesn't contain", "does not contain", "not enough information",
        "insufficient data", "cannot determine", "i can't determine",
        "veri yeterli değil", "yeterli veri yok", "belirleyemem", "tespit edemem",
    ]
    if any(m in a for m in weak_markers):
        return True

    flags = _question_flags(q)
    if flags["shift"] and not any(x in a for x in ["shift", "vardiya", "night", "gece", "morning", "evening"]):
        return True
    if flags["capability"] and not any(x in a for x in ["cpk", " cp ", "capability", "kabiliyet"]):
        return True
    if flags["maintenance"] and not any(x in a for x in ["maintenance", "bakım", "bakim", "calibration", "kalibrasyon", "setup", "spc"]):
        return True
    return False


def ask_gemini_question(df, question, api_key=None, history=None):
    """
    Free-form Q&A grounded in computed stats.

    Gemini is now used as a controlled writing layer, not as the sole analyst.
    The deterministic local answer is generated first and passed as a mandatory
    backbone. If Gemini drifts, the app returns the local answer instead.
    """
    convo = ""
    if history:
        for h in history[-4:]:
            who = "User" if h["role"] == "user" else "Assistant"
            convo += f"{who}: {h['text']}\n"

    snapshot = build_decision_snapshot(df)["text"]
    local_answer = build_local_answer(df, question)

    prompt = (
        "You are LineSight, a manufacturing quality and maintenance analyst. "
        "You must answer the user's exact question using only the calculated production statistics below.\n\n"

        "NON-NEGOTIABLE RULES:\n"
        "- The LOCAL ANALYST DRAFT below is the required backbone. Keep its focus and facts.\n"
        "- Do not start with a different issue unless the user explicitly asked for it.\n"
        "- Do not invent columns, causes, machines, shifts, or operators.\n"
        "- Do not recompute numbers; use the provided values.\n"
        "- Never give vague advice. Every recommendation must be tied to a machine, shift, operator, Cp/Cpk, failure rate, cost, downtime, or defect type when available.\n"
        "- If the user asks about a shift, answer the shift first. If the user asks about Cpk, answer Cpk first.\n"
        "- Reply in the same language as the user's question.\n\n"

        "OUTPUT STYLE:\n"
        "- 1 direct summary sentence.\n"
        "- 4 to 6 short, practical bullet points.\n"
        "- 1 final 'first action tomorrow' sentence.\n"
        "- Keep it concise but useful.\n\n"

        f"DECISION SNAPSHOT:\n{snapshot}\n\n"
        f"LOCAL ANALYST DRAFT — preserve this focus and facts:\n{local_answer}\n\n"
        f"FULL STATISTICS JSON, backup only:\n{build_data_context(df)}\n\n"
        + (f"Conversation so far:\n{convo}\n" if convo else "")
        + f"User question: {question}\n\n"
        "Final answer:"
    )

    try:
        answer = call_gemini(prompt, api_key=api_key, temperature=0.15).strip()
        if _answer_is_weak(answer, question):
            return local_answer
        return answer
    except Exception:
        return local_answer

def call_gemini(prompt, timeout=40, api_key=None, temperature=0.4):
    """Call the Gemini REST API and return the raw text response."""
    api_key = (api_key or get_api_key()).strip() if (api_key or get_api_key()) else ""
    if not api_key:
        raise RuntimeError("No Gemini API key set. Enter it on the AI Insights page "
                           "(or set GEMINI_API_KEY at the top of the file).")

    resp = requests.post(
        GEMINI_URL,
        headers={"Content-Type": "application/json", "x-goog-api-key": api_key},
        json={
            "contents": [{"parts": [{"text": prompt}]}],
            "generationConfig": {"temperature": temperature, "maxOutputTokens": 2048},
        },
        timeout=timeout,
    )
    if resp.status_code != 200:
        raise RuntimeError(f"Gemini API error {resp.status_code}: {resp.text[:300]}")

    data = resp.json()
    try:
        return data["candidates"][0]["content"]["parts"][0]["text"]
    except (KeyError, IndexError):
        raise RuntimeError(f"Unexpected Gemini response: {json.dumps(data)[:300]}")


def parse_ai_json(text):
    """Strip code fences and parse the model's JSON; tolerate minor noise."""
    t = text.strip()
    if t.startswith("```"):
        t = t.split("```", 2)[1] if "```" in t[3:] else t.strip("`")
        if t.lstrip().lower().startswith("json"):
            t = t.lstrip()[4:]
    # grab the outermost {...}
    start, end = t.find("{"), t.rfind("}")
    if start != -1 and end != -1:
        t = t[start:end + 1]
    return json.loads(t)


def ai_analyze(df, api_key=None):
    """
    Full AI pass. Returns a dict:
      {"source": "gemini"|"rule-based", "headline", "machines":[...],
       "operator_shift_note", "narrative"}
    Falls back to the rule-based engine if the API key is missing or the call fails.
    """
    try:
        prompt = build_ai_prompt(df)
        raw = call_gemini(prompt, api_key=api_key)
        parsed = parse_ai_json(raw)
        parsed.setdefault("machines", [])
        parsed.setdefault("operator_shift_note", "")
        parsed.setdefault("narrative", "")
        parsed.setdefault("headline", "")
        # normalize priority casing
        for m in parsed["machines"]:
            m["priority"] = str(m.get("priority", "LOW")).upper()
        parsed["source"] = "gemini"
        return parsed
    except Exception as e:
        # graceful fallback so the app never breaks
        headline, insights = generate_ai_insights(df)
        return {
            "source": "rule-based",
            "error": str(e),
            "headline": headline,
            "machines": [
                {"machine": i["machine"], "priority": i["priority"],
                 "recommendation": i["message"]}
                for i in insights
            ],
            "operator_shift_note": "",
            "narrative": "(AI unavailable — showing built-in rule-based analysis.)",
        }


# ======================================================================
# HTML REPORT EXPORT
# ======================================================================
def build_html_report(df, ai=None):
    k = overall_kpis(df)
    machine = build_machine_summary(df)
    if ai is None:
        ai = ai_analyze(df)
    headline = ai.get("headline", "")
    op = build_group_summary(df, "Operator_ID")
    shift = build_group_summary(df, "Shift")
    now = dt.datetime.now().strftime("%Y-%m-%d %H:%M")
    source_label = ("Google Gemini" if ai.get("source") == "gemini"
                    else "built-in rule engine")

    def df_to_html(d):
        return d.to_html(index=False, border=0, classes="tbl", na_rep="-")

    pr_color = {"HIGH": "#c0392b", "MEDIUM": "#d4a017", "LOW": "#2fa572"}
    insight_rows = "".join(
        f'<li><span class="badge" style="background:'
        f'{pr_color.get(m.get("priority","LOW"), "#2fa572")}">'
        f'{m.get("priority","LOW")}</span> <b>{m.get("machine","")}</b> — '
        f'{m.get("recommendation","")}</li>'
        for m in ai.get("machines", [])
    )
    narrative = ai.get("narrative", "")
    os_note = ai.get("operator_shift_note", "")

    cp_txt = f"{k['cp']:.2f}" if k["cp"] else "N/A"
    cpk_txt = f"{k['cpk']:.2f}" if k["cpk"] else "N/A"

    html = f"""<!DOCTYPE html>
<html lang="en"><head><meta charset="utf-8">
<title>LineSight Report</title>
<style>
  body {{ font-family: 'Segoe UI', Arial, sans-serif; background:#f4f6f8;
         color:#1c2733; margin:0; padding:40px; }}
  .wrap {{ max-width:980px; margin:0 auto; }}
  h1 {{ color:#1c2733; margin-bottom:4px; }}
  .sub {{ color:#6b7785; margin-bottom:30px; }}
  .kpis {{ display:flex; flex-wrap:wrap; gap:16px; margin-bottom:30px; }}
  .kpi {{ background:#fff; border-radius:12px; padding:18px 22px; flex:1;
          min-width:150px; box-shadow:0 1px 3px rgba(0,0,0,.08); }}
  .kpi .label {{ font-size:13px; color:#6b7785; }}
  .kpi .value {{ font-size:26px; font-weight:700; margin-top:6px; }}
  .card {{ background:#fff; border-radius:12px; padding:24px; margin-bottom:24px;
           box-shadow:0 1px 3px rgba(0,0,0,.08); }}
  h2 {{ margin-top:0; font-size:19px; border-bottom:2px solid #eef1f4; padding-bottom:10px; }}
  .headline {{ background:#eaf3fb; border-left:4px solid #3b8ed0; padding:16px 20px;
               border-radius:8px; font-size:16px; }}
  ul {{ list-style:none; padding:0; }}
  li {{ padding:10px 0; border-bottom:1px solid #f0f2f4; line-height:1.5; }}
  .badge {{ color:#fff; font-size:11px; font-weight:700; padding:3px 9px;
            border-radius:20px; margin-right:8px; }}
  table.tbl {{ width:100%; border-collapse:collapse; font-size:14px; }}
  table.tbl th {{ text-align:left; background:#f4f6f8; padding:9px 12px; color:#46505b; }}
  table.tbl td {{ padding:9px 12px; border-top:1px solid #eef1f4; }}
  .foot {{ color:#9aa5b1; font-size:12px; text-align:center; margin-top:30px; }}
</style></head><body><div class="wrap">
  <h1>LineSight — Production Quality Report</h1>
  <div class="sub">Generated {now} &middot; {k['total']} inspections analyzed</div>

  <div class="kpis">
    <div class="kpi"><div class="label">Inspections</div><div class="value">{k['total']}</div></div>
    <div class="kpi"><div class="label">Pass Rate</div><div class="value" style="color:#2fa572">{k['pass_rate']:.1f}%</div></div>
    <div class="kpi"><div class="label">Failure Rate</div><div class="value" style="color:#c0392b">{k['fail_rate']:.1f}%</div></div>
    <div class="kpi"><div class="label">Failure Cost</div><div class="value">${k['cost']:,.0f}</div></div>
    <div class="kpi"><div class="label">Cpk (overall)</div><div class="value">{cpk_txt}</div></div>
  </div>

  <div class="card">
    <h2>AI Insight Summary <span style="font-size:12px;color:#9aa5b1;font-weight:400">
        (source: {source_label})</span></h2>
    <div class="headline">{headline}</div>
    <p style="color:#46505b">{narrative}</p>
    <ul>{insight_rows}</ul>
    {f'<p style="color:#6b7785;font-size:13px"><b>Operator/Shift:</b> {os_note}</p>' if os_note else ''}
  </div>

  <div class="card">
    <h2>Machine Analysis</h2>
    {df_to_html(machine)}
  </div>

  <div class="card">
    <h2>Operator Performance</h2>
    {df_to_html(op)}
  </div>

  <div class="card">
    <h2>Shift Performance</h2>
    {df_to_html(shift)}
  </div>

  <div class="card">
    <h2>Process Capability (overall)</h2>
    <p>Cp = <b>{cp_txt}</b> &nbsp;&middot;&nbsp; Cpk = <b>{cpk_txt}</b>
    &nbsp;&middot;&nbsp; Verdict: <b>{capability_verdict(k['cpk'])}</b></p>
    <p style="color:#6b7785;font-size:13px">Cp/Cpk &ge; 1.33 is generally considered capable;
    1.00–1.33 marginal; below 1.00 not capable.</p>
  </div>

  <div class="foot">LineSight — automated decision support. Recommendations are
  rule-based and intended to assist, not replace, engineering judgment.</div>
</div></body></html>"""
    return html


# ======================================================================
# MAIN APP
# ======================================================================
class LineSightApp(ctk.CTk):
    def __init__(self):
        super().__init__()
        self.title("LineSight - Decision Support System")
        self.geometry("1280x860")
        self.minsize(1080, 760)

        self.df = create_demo_data()
        self.data_source = "Demo data"
        self.active_button = None
        self._canvas = None  # keep ref to matplotlib canvas to avoid GC
        self.ai_cache = None  # cached AI analysis result
        self.api_key = get_api_key()  # session API key (can be set in-app)
        self.chat_history = []  # AI Assistant conversation
        self.chat_history = []  # AI assistant conversation

        self.show_login_screen()

    # ------------------------------------------------------------------
    def clear_screen(self):
        for w in self.winfo_children():
            w.destroy()

    # ------------------------------------------------------------------
    # LOGIN
    # ------------------------------------------------------------------
    def show_login_screen(self):
        self.clear_screen()
        frame = ctk.CTkFrame(self, width=440, height=420, corner_radius=20)
        frame.place(relx=0.5, rely=0.5, anchor="center")
        frame.pack_propagate(False)

        ctk.CTkLabel(frame, text="LineSight",
                     font=("Arial", 34, "bold")).pack(pady=(45, 6))
        ctk.CTkLabel(frame, text="Production Quality & Maintenance",
                     font=("Arial", 14), text_color="#9aa5b1").pack(pady=(0, 30))

        self.username_entry = ctk.CTkEntry(frame, placeholder_text="Username", width=300, height=40)
        self.username_entry.pack(pady=8)
        self.password_entry = ctk.CTkEntry(frame, placeholder_text="Password",
                                           show="*", width=300, height=40)
        self.password_entry.pack(pady=8)

        ctk.CTkButton(frame, text="Login", width=300, height=42,
                      command=self.login).pack(pady=18)
        ctk.CTkLabel(frame, text="Demo login:  admin / admin",
                     font=("Arial", 12), text_color="#9aa5b1").pack()
        self.login_message = ctk.CTkLabel(frame, text="", text_color=COL_BAD)
        self.login_message.pack(pady=4)

        # Enter key submits
        self.password_entry.bind("<Return>", lambda e: self.login())

    def login(self):
        if self.username_entry.get() == "admin" and self.password_entry.get() == "admin":
            self.show_main_app()
        else:
            self.login_message.configure(text="Wrong username or password.")

    # ------------------------------------------------------------------
    # MAIN LAYOUT
    # ------------------------------------------------------------------
    def show_main_app(self):
        self.clear_screen()

        self.sidebar = ctk.CTkFrame(self, width=240, corner_radius=0)
        self.sidebar.pack(side="left", fill="y")
        self.sidebar.pack_propagate(False)

        self.content = ctk.CTkFrame(self, corner_radius=0, fg_color=COL_BG)
        self.content.pack(side="right", fill="both", expand=True)

        ctk.CTkLabel(self.sidebar, text="LineSight",
                     font=("Arial", 23, "bold")).pack(pady=(28, 2))
        ctk.CTkLabel(self.sidebar, text="Decision Support System",
                     font=("Arial", 12), text_color="#9aa5b1").pack(pady=(0, 26))

        self.nav_buttons = {}
        nav = [
            ("Dashboard", self.show_dashboard),
            ("Machine Analysis", self.show_machine_analysis),
            ("Operator / Shift", self.show_operator_shift),
            ("Process Capability", self.show_capability),
            ("AI Analysis", self.show_ai_insights),
            ("Raw Data", self.show_raw_data),
        ]
        for label, cmd in nav:
            b = ctk.CTkButton(self.sidebar, text=label, width=200, height=38,
                              anchor="w", fg_color="transparent",
                              command=lambda c=cmd, l=label: self._navigate(c, l))
            b.pack(pady=4, padx=20)
            self.nav_buttons[label] = b

        ctk.CTkButton(self.sidebar, text="Upload CSV", width=200, height=38,
                      fg_color=COL_GOOD, hover_color="#268a5f",
                      command=self.upload_csv).pack(pady=(28, 6), padx=20)
        ctk.CTkButton(self.sidebar, text="Export Report", width=200, height=38,
                      fg_color=COL_ACCENT, command=self.export_report).pack(pady=6, padx=20)
        ctk.CTkButton(self.sidebar, text="Logout", width=200, height=38,
                      fg_color="#8B0000", hover_color="#A00000",
                      command=self.show_login_screen).pack(pady=6, padx=20)

        self.data_status = ctk.CTkLabel(self.sidebar, text=f"Source: {self.data_source}",
                                        font=("Arial", 11), text_color="#9aa5b1",
                                        wraplength=200)
        self.data_status.pack(side="bottom", pady=18)

        self._navigate(self.show_dashboard, "Dashboard")

    def _navigate(self, command, label):
        for name, btn in self.nav_buttons.items():
            btn.configure(fg_color=COL_ACCENT if name == label else "transparent")
        command()

    def clear_content(self):
        self._canvas = None
        for w in self.content.winfo_children():
            w.destroy()

    def _scroll_area(self):
        area = ctk.CTkScrollableFrame(self.content, fg_color="transparent")
        area.pack(fill="both", expand=True, padx=4, pady=4)
        return area

    def _page_title(self, parent, text):
        ctk.CTkLabel(parent, text=text, font=("Arial", 28, "bold")).pack(
            anchor="w", padx=26, pady=(22, 14))

    # ------------------------------------------------------------------
    # CHART HELPER
    # ------------------------------------------------------------------
    def _embed_figure(self, parent, fig):
        canvas = FigureCanvasTkAgg(fig, master=parent)
        canvas.draw()
        widget = canvas.get_tk_widget()
        widget.pack(fill="both", expand=True, padx=10, pady=10)
        self._canvas = canvas  # keep reference

    def _styled_fig(self, w=6, h=3.2):
        fig = Figure(figsize=(w, h), dpi=100, facecolor=COL_CARD)
        ax = fig.add_subplot(111)
        ax.set_facecolor(COL_CARD)
        ax.tick_params(colors=COL_TEXT, labelsize=9)
        for s in ax.spines.values():
            s.set_color("#444")
        ax.title.set_color(COL_TEXT)
        ax.xaxis.label.set_color(COL_TEXT)
        ax.yaxis.label.set_color(COL_TEXT)
        return fig, ax

    # ------------------------------------------------------------------
    # DASHBOARD
    # ------------------------------------------------------------------
    def show_dashboard(self):
        self.clear_content()
        area = self._scroll_area()
        self._page_title(area, "Dashboard Overview")

        k = overall_kpis(self.df)
        cpk_txt = f"{k['cpk']:.2f}" if k["cpk"] else "N/A"

        kpi_frame = ctk.CTkFrame(area, fg_color="transparent")
        kpi_frame.pack(fill="x", padx=22, pady=(0, 10))
        cards = [
            ("Inspections", f"{k['total']}", COL_TEXT),
            ("Pass Rate", f"{k['pass_rate']:.1f}%", COL_GOOD),
            ("Failure Rate", f"{k['fail_rate']:.1f}%", COL_BAD),
            ("Failure Cost", f"${k['cost']:,.0f}", COL_WARN),
            ("Cpk", cpk_txt, COL_ACCENT),
        ]
        for i, (t, v, c) in enumerate(cards):
            self._kpi_card(kpi_frame, t, v, c, i)

        # Headline insight
        headline, _ = generate_ai_insights(self.df)
        ins = ctk.CTkFrame(area, fg_color=COL_CARD, corner_radius=12)
        ins.pack(fill="x", padx=22, pady=14)
        ctk.CTkLabel(ins, text="AI Insight Summary", font=("Arial", 18, "bold")).pack(
            anchor="w", padx=20, pady=(16, 4))
        ctk.CTkLabel(ins, text=headline, font=("Arial", 14), wraplength=820,
                     justify="left", text_color="#cdd6df").pack(
            anchor="w", padx=20, pady=(0, 18))

        # Failure-rate chart
        chart_card = ctk.CTkFrame(area, fg_color=COL_CARD, corner_radius=12)
        chart_card.pack(fill="both", expand=True, padx=22, pady=(0, 16))
        ctk.CTkLabel(chart_card, text="Failure Rate by Machine",
                     font=("Arial", 16, "bold")).pack(anchor="w", padx=20, pady=(14, 0))

        ms = build_machine_summary(self.df)
        fig, ax = self._styled_fig(7, 3)
        colors = [COL_BAD if v >= 15 else COL_WARN if v >= 8 else COL_GOOD
                  for v in ms["Failure_Rate"]]
        ax.bar(ms["Machine_ID"], ms["Failure_Rate"], color=colors)
        ax.set_ylabel("Failure Rate (%)")
        fig.tight_layout()
        self._embed_figure(chart_card, fig)

    def _kpi_card(self, parent, title, value, color, col):
        card = ctk.CTkFrame(parent, height=110, fg_color=COL_CARD, corner_radius=12)
        card.grid(row=0, column=col, padx=8, pady=10, sticky="nsew")
        parent.grid_columnconfigure(col, weight=1)
        ctk.CTkLabel(card, text=title, font=("Arial", 13),
                     text_color="#9aa5b1").pack(pady=(18, 4))
        ctk.CTkLabel(card, text=value, font=("Arial", 24, "bold"),
                     text_color=color).pack(pady=(0, 16))

    # ------------------------------------------------------------------
    # MACHINE ANALYSIS
    # ------------------------------------------------------------------
    def show_machine_analysis(self):
        self.clear_content()
        area = self._scroll_area()
        self._page_title(area, "Machine Analysis")

        ms = build_machine_summary(self.df)
        display = ms.copy()
        if "Criticality_Score" in display:
            display = display[[
                "Machine_ID", "Inspections", "Failures", "Failure_Rate",
                "Failure_Cost", "Downtime_Minutes", "Avg_Measurement",
                "Cp", "Cpk", "Cost_per_1000_units", "Criticality_Score",
            ]]

        self._table(area, display)

        chart_card = ctk.CTkFrame(area, fg_color=COL_CARD, corner_radius=12)
        chart_card.pack(fill="both", expand=True, padx=22, pady=14)
        ctk.CTkLabel(chart_card, text="Criticality Score by Machine",
                     font=("Arial", 16, "bold")).pack(anchor="w", padx=20, pady=(14, 0))
        fig, ax = self._styled_fig(7, 3)
        order = ms.sort_values("Criticality_Score", ascending=True)
        ax.barh(order["Machine_ID"], order["Criticality_Score"], color=COL_ACCENT)
        ax.set_xlabel("Criticality (0-100)")
        fig.tight_layout()
        self._embed_figure(chart_card, fig)

    # ------------------------------------------------------------------
    # OPERATOR / SHIFT
    # ------------------------------------------------------------------
    def show_operator_shift(self):
        self.clear_content()
        area = self._scroll_area()
        self._page_title(area, "Operator / Shift Performance")

        ctk.CTkLabel(area, text="Operator Performance",
                     font=("Arial", 17, "bold")).pack(anchor="w", padx=26, pady=(0, 4))
        op = build_group_summary(self.df, "Operator_ID")
        self._table(area, op, height=8)

        ctk.CTkLabel(area, text="Shift Performance",
                     font=("Arial", 17, "bold")).pack(anchor="w", padx=26, pady=(18, 4))
        sh = build_group_summary(self.df, "Shift")
        self._table(area, sh, height=5)

        chart_card = ctk.CTkFrame(area, fg_color=COL_CARD, corner_radius=12)
        chart_card.pack(fill="both", expand=True, padx=22, pady=14)
        ctk.CTkLabel(chart_card, text="Failure Rate by Shift",
                     font=("Arial", 16, "bold")).pack(anchor="w", padx=20, pady=(14, 0))
        fig, ax = self._styled_fig(7, 2.8)
        ax.bar(sh["Shift"], sh["Failure_Rate"], color=COL_WARN)
        ax.set_ylabel("Failure Rate (%)")
        fig.tight_layout()
        self._embed_figure(chart_card, fig)

    # ------------------------------------------------------------------
    # PROCESS CAPABILITY
    # ------------------------------------------------------------------
    def show_capability(self):
        self.clear_content()
        area = self._scroll_area()
        self._page_title(area, "Process Capability (Cp / Cpk)")

        k = overall_kpis(self.df)
        info = ctk.CTkFrame(area, fg_color=COL_CARD, corner_radius=12)
        info.pack(fill="x", padx=22, pady=(0, 12))
        cp_txt = f"{k['cp']:.2f}" if k["cp"] else "N/A"
        cpk_txt = f"{k['cpk']:.2f}" if k["cpk"] else "N/A"
        verdict = capability_verdict(k["cpk"])
        vcolor = (COL_GOOD if verdict == "Capable" else
                  COL_WARN if verdict == "Marginal" else COL_BAD)
        ctk.CTkLabel(info, text=f"Overall  Cp = {cp_txt}    Cpk = {cpk_txt}",
                     font=("Arial", 18, "bold")).pack(anchor="w", padx=20, pady=(16, 2))
        ctk.CTkLabel(info, text=f"Verdict: {verdict}", font=("Arial", 15, "bold"),
                     text_color=vcolor).pack(anchor="w", padx=20, pady=(0, 4))
        ctk.CTkLabel(info, text="Cpk ≥ 1.33 capable · 1.00–1.33 marginal · < 1.00 not capable",
                     font=("Arial", 12), text_color="#9aa5b1").pack(
            anchor="w", padx=20, pady=(0, 16))

        # Histogram with spec limits
        chart_card = ctk.CTkFrame(area, fg_color=COL_CARD, corner_radius=12)
        chart_card.pack(fill="both", expand=True, padx=22, pady=12)
        ctk.CTkLabel(chart_card, text="Measurement Distribution",
                     font=("Arial", 16, "bold")).pack(anchor="w", padx=20, pady=(14, 0))
        lsl = float(self.df["LSL"].median())
        usl = float(self.df["USL"].median())
        fig, ax = self._styled_fig(7, 3.4)
        ax.hist(self.df["Measurement"], bins=30, color=COL_ACCENT, alpha=0.85)
        ax.axvline(lsl, color=COL_BAD, linestyle="--", linewidth=2, label="LSL")
        ax.axvline(usl, color=COL_BAD, linestyle="--", linewidth=2, label="USL")
        ax.axvline(self.df["Measurement"].mean(), color=COL_GOOD,
                   linestyle="-", linewidth=2, label="Mean")
        leg = ax.legend(facecolor=COL_CARD, edgecolor="#444", labelcolor=COL_TEXT)
        ax.set_xlabel("Measurement")
        ax.set_ylabel("Count")
        fig.tight_layout()
        self._embed_figure(chart_card, fig)

        # Per-machine Cp/Cpk table
        ms = build_machine_summary(self.df)
        cap_tbl = ms[["Machine_ID", "Avg_Measurement", "Cp", "Cpk"]].copy()
        cap_tbl["Verdict"] = cap_tbl["Cpk"].apply(capability_verdict)
        ctk.CTkLabel(area, text="Per-Machine Capability",
                     font=("Arial", 16, "bold")).pack(anchor="w", padx=26, pady=(8, 4))
        self._table(area, cap_tbl, height=6)

    # ------------------------------------------------------------------
    # AI INSIGHTS
    # ------------------------------------------------------------------
    def show_ai_insights(self):
        self.clear_content()
        page = ctk.CTkFrame(self.content, fg_color="transparent")
        page.pack(fill="both", expand=True)

        # Use grid so the chat row receives most of the vertical space.
        page.grid_columnconfigure(0, weight=1)
        page.grid_rowconfigure(3, weight=1)

        # ---- compact API key row ----
        keyrow = ctk.CTkFrame(page, fg_color="transparent")
        keyrow.grid(row=0, column=0, sticky="ew", padx=26, pady=(10, 2))
        ctk.CTkLabel(keyrow, text="Gemini key:", font=("Arial", 12),
                     text_color="#9aa5b1").pack(side="left")
        self._key_entry = ctk.CTkEntry(keyrow, placeholder_text="paste AIza... key",
                                       show="*", height=30, width=260)
        self._key_entry.pack(side="left", padx=8)
        if self.api_key:
            self._key_entry.insert(0, self.api_key)
        ctk.CTkButton(keyrow, text="Save", width=70, height=30, fg_color=COL_GOOD,
                      hover_color="#268a5f", command=self._save_key).pack(side="left")
        self._ai_status = ctk.CTkLabel(
            keyrow, font=("Arial", 11),
            text=("key set ✓" if self.api_key else "no key — local engine active"),
            text_color=(COL_GOOD if self.api_key else "#9aa5b1"))
        self._ai_status.pack(side="left", padx=12)

        # ---- slim header banner ----
        banner = ctk.CTkFrame(page, fg_color="#1d3a4a", corner_radius=14, height=58)
        banner.grid(row=1, column=0, sticky="ew", padx=26, pady=(6, 8))
        banner.grid_propagate(False)
        ctk.CTkLabel(banner, text="🤖", font=("Arial", 23)).pack(
            side="left", padx=(18, 10), pady=10)
        txt = ctk.CTkFrame(banner, fg_color="transparent")
        txt.pack(side="left", fill="both", expand=True, pady=8)
        ctk.CTkLabel(txt, text="AI Analysis Assistant",
                     font=("Arial", 19, "bold")).pack(anchor="w")
        ctk.CTkLabel(txt, text="Chat area is enlarged. Answers use computed KPIs first, Gemini second.",
                     font=("Arial", 12), text_color="#9fc7dc").pack(anchor="w")

        # ---- compact tools row: quick analysis + preset chips ----
        tools = ctk.CTkFrame(page, fg_color="transparent", height=126)
        tools.grid(row=2, column=0, sticky="ew", padx=22, pady=(0, 6))
        tools.grid_propagate(False)
        tools.grid_columnconfigure(0, weight=1)
        tools.grid_columnconfigure(1, weight=1)

        analysis = ctk.CTkFrame(tools, fg_color=COL_CARD, corner_radius=14)
        analysis.grid(row=0, column=0, sticky="nsew", padx=(4, 6), pady=0)
        head = ctk.CTkFrame(analysis, fg_color="transparent")
        head.pack(fill="x", padx=12, pady=(8, 2))
        ctk.CTkLabel(head, text="⚠  Key Issues",
                     font=("Arial", 14, "bold")).pack(side="left")
        self._analysis_status = ctk.CTkLabel(head, text="", font=("Arial", 10),
                                             text_color="#9aa5b1")
        self._analysis_status.pack(side="left", padx=10)
        ctk.CTkButton(head, text="Refresh", width=70, height=24,
                      command=self._run_quick_analysis).pack(side="right")
        self._analysis_body = ctk.CTkFrame(analysis, fg_color="transparent")
        self._analysis_body.pack(fill="both", expand=True, padx=12, pady=(0, 8))

        chips = ctk.CTkFrame(tools, fg_color="transparent")
        chips.grid(row=0, column=1, sticky="nsew", padx=(6, 4), pady=0)
        presets = [
            "Which machine is most critical and why?",
            "Which shift and operator produce the most failures?",
            "Is the overall process capability (Cpk) acceptable?",
            "How should I prioritize maintenance across machines?",
        ]
        for i, q in enumerate(presets):
            chips.grid_columnconfigure(i % 2, weight=1)
            ctk.CTkButton(
                chips, text="↗  " + q, anchor="w", height=36,
                fg_color=COL_CARD, hover_color="#343434", text_color=COL_TEXT,
                font=("Arial", 12), corner_radius=10,
                command=lambda qq=q: self._submit_question(qq)
            ).grid(row=i // 2, column=i % 2, padx=4, pady=4, sticky="ew")

        if self.ai_cache is not None:
            self._render_quick_analysis(self.ai_cache)
        else:
            self._run_quick_analysis()

        # ---- large chat history row ----
        self._chat = ctk.CTkScrollableFrame(
            page, fg_color=COL_BG, corner_radius=14, height=430)
        self._chat.grid(row=3, column=0, sticky="nsew", padx=18, pady=(2, 6))

        if self.chat_history:
            for h in self.chat_history:
                self._add_bubble("You" if h["role"] == "user" else "AI Analyst",
                                 h["text"], user=(h["role"] == "user"))
        else:
            ctk.CTkLabel(self._chat,
                         text="Pick a question above or type your own to begin.",
                         font=("Arial", 14), text_color="#7a8590").pack(pady=50)

        # ---- input row ----
        inrow = ctk.CTkFrame(page, fg_color="transparent")
        inrow.grid(row=4, column=0, sticky="ew", padx=26, pady=(2, 14))
        self._chat_entry = ctk.CTkEntry(
            inrow, placeholder_text="Type your own question and press Enter…",
            height=44, font=("Arial", 14))
        self._chat_entry.pack(side="left", fill="x", expand=True)
        self._chat_entry.bind("<Return>", lambda e: self._send_chat())
        ctk.CTkButton(inrow, text="Send", width=90, height=44,
                      command=self._send_chat).pack(side="left", padx=(8, 0))

    def _run_quick_analysis(self):
        """Run the auto analysis (Gemini if key set, else rule engine) in background."""
        for w in self._analysis_body.winfo_children():
            w.destroy()
        self._analysis_status.configure(
            text="analyzing with Gemini…" if self.api_key else "rule-based analysis…")
        ctk.CTkLabel(self._analysis_body, text="⏳ Working…", font=("Arial", 13),
                     text_color="#9aa5b1").pack(anchor="w", pady=8)

        df_snapshot = self.df
        key_snapshot = self.api_key

        def worker():
            result = ai_analyze(df_snapshot, api_key=key_snapshot)
            self.after(0, lambda: self._quick_done(result))

        threading.Thread(target=worker, daemon=True).start()

    def _quick_done(self, result):
        self.ai_cache = result
        if not (hasattr(self, "_analysis_status") and
                self._analysis_status.winfo_exists()):
            return
        self._analysis_status.configure(
            text="via Gemini ✓" if result.get("source") == "gemini"
            else "rule engine (no/invalid key)")
        self._render_quick_analysis(result)

    def _render_quick_analysis(self, result):
        for w in self._analysis_body.winfo_children():
            w.destroy()

        if result.get("headline"):
            ctk.CTkLabel(self._analysis_body, text=result["headline"],
                         font=("Arial", 12, "bold"), wraplength=520,
                         justify="left", text_color="#cdd6df").pack(
                anchor="w", pady=(0, 4))

        pr_color = {"HIGH": COL_BAD, "MEDIUM": COL_WARN, "LOW": COL_GOOD}
        machines = result.get("machines", [])
        issues = [m for m in machines
                  if str(m.get("priority", "")).upper() in ("HIGH", "MEDIUM")]

        # Keep this card short so it does not steal vertical space from chat.
        for m in issues[:2]:
            pr = str(m.get("priority", "LOW")).upper()
            row = ctk.CTkFrame(self._analysis_body, fg_color=COL_BG, corner_radius=8)
            row.pack(fill="x", pady=2)
            ctk.CTkLabel(row, text=pr, width=58, fg_color=pr_color.get(pr, COL_GOOD),
                         corner_radius=6, font=("Arial", 10, "bold")).pack(
                side="left", padx=8, pady=5)
            txt = f"{m.get('machine','')} — {m.get('recommendation','')}"
            ctk.CTkLabel(row, text=txt, font=("Arial", 11), wraplength=430,
                         justify="left").pack(side="left", padx=4, pady=5,
                                              fill="x", expand=True)

        if len(issues) > 2:
            ctk.CTkLabel(self._analysis_body,
                         text=f"+ {len(issues) - 2} more issue(s). Use chat for details.",
                         font=("Arial", 10), text_color="#9aa5b1").pack(anchor="w", pady=(2, 0))

        ok_count = sum(1 for m in machines
                       if str(m.get("priority", "")).upper() == "LOW")
        if not issues and ok_count:
            ctk.CTkLabel(self._analysis_body,
                         text=f"✓ {ok_count} machine(s) operating within normal range.",
                         font=("Arial", 11), text_color=COL_GOOD).pack(
                anchor="w", pady=(4, 0))
        if not issues and not ok_count:
            ctk.CTkLabel(self._analysis_body, text="No analysis available.",
                         font=("Arial", 11), text_color="#9aa5b1").pack(anchor="w")

    def _save_key(self):
        self.api_key = self._key_entry.get().strip()
        ok = bool(self.api_key)
        self._ai_status.configure(text="key set ✓" if ok else "no key",
                                  text_color=COL_GOOD if ok else "#9aa5b1")
        if ok:
            self.ai_cache = None  # re-run with the real key
            self._run_quick_analysis()

    # ---- chat plumbing ----
    def _send_chat(self):
        q = self._chat_entry.get().strip()
        if q:
            self._chat_entry.delete(0, "end")
            self._submit_question(q)

    def _submit_question(self, question):
        # remove placeholder if present
        if not self.chat_history:
            for w in self._chat.winfo_children():
                w.destroy()

        self._add_bubble("You", question, user=True)
        self.chat_history.append({"role": "user", "text": question})
        thinking = self._add_bubble("AI Analyst", "…thinking", user=False)

        key = self.api_key
        df = self.df
        hist = list(self.chat_history)

        def worker():
            try:
                if not key:
                    # No key? Still answer from the built-in deterministic analyst.
                    ans = build_local_answer(df, question)
                else:
                    ans = ask_gemini_question(df, question, api_key=key, history=hist)
            except Exception as e:
                # If the API fails, do not leave the user with an error only.
                ans = build_local_answer(df, question) + f"\n\nNot: Gemini çağrısı başarısız oldu, bu yanıt yerleşik analiz motorundan üretildi. Hata: {e}"
            self.after(0, lambda: self._finish_bubble(thinking, ans))

        threading.Thread(target=worker, daemon=True).start()

    def _finish_bubble(self, label, text):
        if label is not None and label.winfo_exists():
            label.configure(text=text)
        self.chat_history.append({"role": "assistant", "text": text})
        self._scroll_chat_bottom()

    def _add_bubble(self, who, text, user):
        wrap = ctk.CTkFrame(self._chat, fg_color="transparent")
        wrap.pack(fill="x", pady=7)

        bubble = ctk.CTkFrame(
            wrap, fg_color=(COL_ACCENT if user else COL_CARD), corner_radius=14)

        panel_w = max(760, self.content.winfo_width() - 120)
        if user:
            bubble.pack(anchor="e", padx=10)
            wrap_len = min(760, panel_w - 260)
        else:
            # Assistant answers now use almost the full enlarged chat panel.
            bubble.pack(anchor="w", padx=10, fill="x", expand=True)
            wrap_len = min(1120, panel_w)

        ctk.CTkLabel(bubble, text=who, font=("Arial", 10, "bold"),
                     text_color=("#dbeeff" if user else COL_ACCENT)).pack(
            anchor="w", padx=18, pady=(11, 0))

        lbl = ctk.CTkLabel(
            bubble, text=text, font=("Arial", 14), wraplength=wrap_len,
            justify="left", text_color="#ffffff" if user else COL_TEXT)
        lbl.pack(anchor="w", padx=18, pady=(3, 14),
                 fill="x" if not user else None, expand=(not user))
        self._scroll_chat_bottom()
        return lbl

    def _scroll_chat_bottom(self):
        try:
            self.after(60, lambda: self._chat._parent_canvas.yview_moveto(1.0))
        except Exception:
            pass

    # ------------------------------------------------------------------
    # RAW DATA
    # ------------------------------------------------------------------
    def show_raw_data(self):
        self.clear_content()
        area = ctk.CTkFrame(self.content, fg_color="transparent")
        area.pack(fill="both", expand=True)
        self._page_title(area, f"Raw Data  (showing {min(200, len(self.df))} of {len(self.df)} rows)")
        self._table(area, self.df.head(200), height=20, expand=True)

    # ------------------------------------------------------------------
    # TABLE HELPER (styled ttk.Treeview)
    # ------------------------------------------------------------------
    def _table(self, parent, df, height=10, expand=False):
        frame = ctk.CTkFrame(parent, fg_color=COL_CARD, corner_radius=12)
        frame.pack(fill="both", expand=expand, padx=22, pady=10)

        style = ttk.Style()
        style.theme_use("default")
        style.configure("FP.Treeview", background=COL_CARD, foreground=COL_TEXT,
                        fieldbackground=COL_CARD, rowheight=26, borderwidth=0)
        style.configure("FP.Treeview.Heading", background="#1f1f1f",
                        foreground=COL_TEXT, relief="flat", font=("Arial", 10, "bold"))
        style.map("FP.Treeview", background=[("selected", COL_ACCENT)])

        cols = list(df.columns)
        tree = ttk.Treeview(frame, columns=cols, show="headings",
                            height=height, style="FP.Treeview")
        for c in cols:
            tree.heading(c, text=c)
            tree.column(c, width=max(90, min(160, len(str(c)) * 12)), anchor="center")
        for _, r in df.iterrows():
            tree.insert("", "end", values=[r[c] for c in cols])

        vsb = ttk.Scrollbar(frame, orient="vertical", command=tree.yview)
        tree.configure(yscrollcommand=vsb.set)
        tree.pack(side="left", fill="both", expand=True, padx=(10, 0), pady=10)
        vsb.pack(side="right", fill="y", pady=10, padx=(0, 10))

    # ------------------------------------------------------------------
    # FILE UPLOAD  (CSV or Excel)
    # ------------------------------------------------------------------
    def upload_csv(self):
        path = filedialog.askopenfilename(
            title="Select Data File",
            filetypes=[("Data Files", "*.csv *.xlsx *.xls *.xlsm"),
                       ("CSV Files", "*.csv"),
                       ("Excel Files", "*.xlsx *.xls *.xlsm")])
        if not path:
            return
        try:
            raw = read_any(path)
            self.df = normalize_data(raw)
            self.data_source = os.path.basename(path)
            self.ai_cache = None  # new data -> fresh AI analysis
            self.chat_history = []  # reset assistant conversation
            self.chat_history = []  # new data -> fresh conversation
            self.data_status.configure(text=f"Source: {self.data_source}",
                                       text_color="#9aa5b1")
            self._navigate(self.show_dashboard, "Dashboard")
        except Exception as e:
            self.data_status.configure(text=f"Upload failed: {e}", text_color=COL_BAD)

    # ------------------------------------------------------------------
    # REPORT EXPORT
    # ------------------------------------------------------------------
    def export_report(self):
        path = filedialog.asksaveasfilename(
            title="Save Report", defaultextension=".html",
            filetypes=[("HTML Report", "*.html")],
            initialfile="LineSight_Report.html")
        if not path:
            path = os.path.join(tempfile.gettempdir(), "LineSight_Report.html")
        try:
            self.data_status.configure(text="Building report…", text_color="#9aa5b1")
            self.update_idletasks()
            # reuse cached AI analysis; if none yet, run it now with the session key
            ai = self.ai_cache or ai_analyze(self.df, api_key=self.api_key)
            self.ai_cache = ai
            html = build_html_report(self.df, ai=ai)
            with open(path, "w", encoding="utf-8") as f:
                f.write(html)
            self.data_status.configure(text=f"Report saved:\n{os.path.basename(path)}",
                                       text_color=COL_GOOD)
            webbrowser.open("file://" + os.path.abspath(path))
        except Exception as e:
            self.data_status.configure(text=f"Report failed: {e}", text_color=COL_BAD)



# ======================================================================
# PREMIUM UI PATCH
# ======================================================================
# Re-assign the palette so every page looks more premium and presentation-ready.
COL_BG = "#081120"
COL_PANEL = "#0d1728"
COL_PANEL_2 = "#111f35"
COL_CARD = "#122038"
COL_CARD_ALT = "#182845"
COL_ACCENT = "#4f8cff"
COL_ACCENT_2 = "#7c5cff"
COL_ACCENT_SOFT = "#18345f"
COL_GOOD = "#22c55e"
COL_WARN = "#f59e0b"
COL_BAD = "#ef4444"
COL_TEXT = "#ecf3ff"
COL_MUTED = "#8aa0bf"
COL_BORDER = "#23314b"
COL_SHADOW = "#0b1322"
ctk.set_default_color_theme("dark-blue")


def premium_init(self):
    ctk.CTk.__init__(self)
    self.title("LineSight - Executive Decision Hub")
    self.geometry("1440x920")
    self.minsize(1180, 780)
    self.configure(fg_color=COL_BG)

    self.df = create_demo_data()
    self.data_source = "Demo data"
    self.active_button = None
    self._canvas = None
    self.ai_cache = None
    self.api_key = get_api_key()
    self.chat_history = []
    self.show_login_screen()


def premium_scroll_area(self):
    area = ctk.CTkScrollableFrame(
        self.content,
        fg_color="transparent",
        corner_radius=0,
        scrollbar_button_color=COL_PANEL_2,
        scrollbar_button_hover_color=COL_ACCENT,
    )
    area.pack(fill="both", expand=True, padx=6, pady=6)
    return area


def premium_page_title(self, parent, text, subtitle=None, icon="◈"):
    box = ctk.CTkFrame(
        parent, fg_color=COL_CARD, corner_radius=22,
        border_width=1, border_color=COL_BORDER
    )
    box.pack(fill="x", padx=22, pady=(18, 12))

    left = ctk.CTkFrame(box, fg_color="transparent")
    left.pack(side="left", fill="both", expand=True, padx=22, pady=18)
    ctk.CTkLabel(left, text=f"{icon}  {text}", font=("Segoe UI", 28, "bold"), text_color=COL_TEXT).pack(anchor="w")
    ctk.CTkLabel(
        left,
        text=subtitle or "Boardroom-ready production intelligence built from your live quality data.",
        font=("Segoe UI", 13),
        text_color=COL_MUTED,
        wraplength=760,
        justify="left",
    ).pack(anchor="w", pady=(6, 0))

    right = ctk.CTkFrame(box, fg_color="transparent")
    right.pack(side="right", padx=18, pady=18)
    records = len(self.df) if hasattr(self, 'df') and self.df is not None else 0
    for top, bottom, color in [
        ("DATA SOURCE", self.data_source, COL_ACCENT),
        ("ROWS", f"{records:,}", COL_ACCENT_2),
    ]:
        chip = ctk.CTkFrame(right, fg_color=COL_PANEL_2, corner_radius=14,
                            border_width=1, border_color=COL_BORDER)
        chip.pack(fill="x", pady=4)
        ctk.CTkLabel(chip, text=top, font=("Segoe UI", 10, "bold"), text_color=COL_MUTED).pack(anchor="w", padx=12, pady=(8, 0))
        ctk.CTkLabel(chip, text=bottom, font=("Segoe UI", 13, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=12, pady=(0, 8))
    return box


def premium_section_card(self, parent, title, subtitle="", use_grid=False, **pack_or_grid):
    card = ctk.CTkFrame(parent, fg_color=COL_CARD, corner_radius=18,
                        border_width=1, border_color=COL_BORDER)
    if use_grid:
        card.grid(**pack_or_grid)
    else:
        card.pack(**pack_or_grid)
    ctk.CTkLabel(card, text=title, font=("Segoe UI", 17, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=18, pady=(16, 0))
    if subtitle:
        ctk.CTkLabel(card, text=subtitle, font=("Segoe UI", 11), text_color=COL_MUTED,
                     wraplength=540, justify="left").pack(anchor="w", padx=18, pady=(2, 8))
    return card


def premium_kpi_card(self, parent, title, value, color, col, subtitle=""):
    card = ctk.CTkFrame(parent, height=120, fg_color=COL_CARD, corner_radius=18,
                        border_width=1, border_color=COL_BORDER)
    card.grid(row=0, column=col, padx=8, pady=8, sticky="nsew")
    parent.grid_columnconfigure(col, weight=1)
    ctk.CTkLabel(card, text=title.upper(), font=("Segoe UI", 11, "bold"), text_color=COL_MUTED).pack(anchor="w", padx=16, pady=(16, 4))
    ctk.CTkLabel(card, text=value, font=("Segoe UI", 28, "bold"), text_color=color).pack(anchor="w", padx=16)
    if subtitle:
        ctk.CTkLabel(card, text=subtitle, font=("Segoe UI", 11), text_color=COL_MUTED, wraplength=190, justify="left").pack(anchor="w", padx=16, pady=(6, 14))
    else:
        ctk.CTkLabel(card, text=" ", font=("Segoe UI", 11), text_color=COL_MUTED).pack(anchor="w", padx=16, pady=(6, 14))
    return card


def premium_styled_fig(self, w=6, h=3.2):
    fig = Figure(figsize=(w, h), dpi=100, facecolor=COL_CARD)
    ax = fig.add_subplot(111)
    ax.set_facecolor(COL_CARD)
    ax.tick_params(colors=COL_TEXT, labelsize=9)
    for s in ax.spines.values():
        s.set_color(COL_BORDER)
    ax.grid(axis="y", color=COL_BORDER, alpha=0.35, linewidth=0.8)
    ax.set_axisbelow(True)
    ax.title.set_color(COL_TEXT)
    ax.xaxis.label.set_color(COL_TEXT)
    ax.yaxis.label.set_color(COL_TEXT)
    return fig, ax


def premium_show_login_screen(self):
    self.clear_screen()
    self.configure(fg_color=COL_BG)

    shell = ctk.CTkFrame(self, fg_color="transparent")
    shell.pack(fill="both", expand=True, padx=36, pady=36)
    shell.grid_columnconfigure(0, weight=1)
    shell.grid_columnconfigure(1, weight=1)
    shell.grid_rowconfigure(0, weight=1)

    hero = ctk.CTkFrame(shell, fg_color=COL_CARD, corner_radius=26,
                        border_width=1, border_color=COL_BORDER)
    hero.grid(row=0, column=0, sticky="nsew", padx=(0, 14), pady=0)
    hero.pack_propagate(False)

    ctk.CTkLabel(hero, text="LINESIGHT", font=("Segoe UI", 12, "bold"), text_color=COL_ACCENT).pack(anchor="w", padx=28, pady=(34, 8))
    ctk.CTkLabel(hero, text="Turn raw production data\ninto executive-grade decisions.", font=("Segoe UI", 34, "bold"), text_color=COL_TEXT, justify="left").pack(anchor="w", padx=28)
    ctk.CTkLabel(hero, text="A premium decision-support cockpit for quality, maintenance, process capability and operator performance. Designed to impress in demos, reports and presentations.", font=("Segoe UI", 14), text_color=COL_MUTED, wraplength=480, justify="left").pack(anchor="w", padx=28, pady=(16, 22))

    feature_wrap = ctk.CTkFrame(hero, fg_color="transparent")
    feature_wrap.pack(fill="x", padx=24, pady=(6, 24))
    features = [
        ("Live KPI Narrative", "Critical machines, shift risk, cost impact and capability in one glance."),
        ("AI Workbench", "Ask focused production questions and get grounded operational answers."),
        ("Boardroom Visuals", "A cleaner, sharper interface that makes the project feel enterprise-level."),
    ]
    for title, desc in features:
        row = ctk.CTkFrame(feature_wrap, fg_color=COL_PANEL_2, corner_radius=18,
                           border_width=1, border_color=COL_BORDER)
        row.pack(fill="x", pady=7)
        ctk.CTkLabel(row, text="●", text_color=COL_ACCENT, font=("Segoe UI", 20, "bold")).pack(side="left", padx=(14, 10), pady=14)
        txt = ctk.CTkFrame(row, fg_color="transparent")
        txt.pack(side="left", fill="both", expand=True, pady=12)
        ctk.CTkLabel(txt, text=title, font=("Segoe UI", 13, "bold"), text_color=COL_TEXT).pack(anchor="w")
        ctk.CTkLabel(txt, text=desc, font=("Segoe UI", 12), text_color=COL_MUTED, wraplength=420, justify="left").pack(anchor="w")

    badge_row = ctk.CTkFrame(hero, fg_color="transparent")
    badge_row.pack(anchor="w", padx=28, pady=(0, 28))
    for label in ["QUALITY ANALYTICS", "MAINTENANCE", "CP / CPK", "AI INSIGHTS"]:
        chip = ctk.CTkLabel(badge_row, text=label, font=("Segoe UI", 10, "bold"),
                            text_color=COL_TEXT, fg_color=COL_ACCENT_SOFT, corner_radius=999,
                            padx=12, pady=6)
        chip.pack(side="left", padx=(0, 8))

    login_card = ctk.CTkFrame(shell, fg_color=COL_PANEL, corner_radius=26,
                              border_width=1, border_color=COL_BORDER, width=440)
    login_card.grid(row=0, column=1, sticky="nsew", padx=(14, 0), pady=0)
    login_card.pack_propagate(False)

    ctk.CTkLabel(login_card, text="Welcome back", font=("Segoe UI", 13, "bold"), text_color=COL_ACCENT).pack(anchor="w", padx=34, pady=(48, 6))
    ctk.CTkLabel(login_card, text="Sign in to the executive workspace", font=("Segoe UI", 28, "bold"), text_color=COL_TEXT, justify="left").pack(anchor="w", padx=34)
    ctk.CTkLabel(login_card, text="Use the demo credentials below to enter the application.", font=("Segoe UI", 13), text_color=COL_MUTED).pack(anchor="w", padx=34, pady=(10, 28))

    self.username_entry = ctk.CTkEntry(login_card, placeholder_text="Username", width=340, height=48,
                                       corner_radius=14, fg_color=COL_CARD_ALT, border_color=COL_BORDER,
                                       text_color=COL_TEXT)
    self.username_entry.pack(padx=34, pady=8)
    self.password_entry = ctk.CTkEntry(login_card, placeholder_text="Password", show="*", width=340, height=48,
                                       corner_radius=14, fg_color=COL_CARD_ALT, border_color=COL_BORDER,
                                       text_color=COL_TEXT)
    self.password_entry.pack(padx=34, pady=8)

    ctk.CTkButton(login_card, text="Enter LineSight", width=340, height=48,
                  corner_radius=14, fg_color=COL_ACCENT, hover_color=COL_ACCENT_2,
                  font=("Segoe UI", 14, "bold"), command=self.login).pack(padx=34, pady=(18, 12))
    ctk.CTkLabel(login_card, text="Demo login: admin / admin", font=("Segoe UI", 12), text_color=COL_MUTED).pack(anchor="w", padx=36)
    self.login_message = ctk.CTkLabel(login_card, text="", text_color=COL_BAD, font=("Segoe UI", 12))
    self.login_message.pack(anchor="w", padx=36, pady=(8, 0))

    info = ctk.CTkFrame(login_card, fg_color=COL_CARD, corner_radius=18,
                        border_width=1, border_color=COL_BORDER)
    info.pack(fill="x", padx=34, pady=(26, 0))
    ctk.CTkLabel(info, text="Presentation tip", font=("Segoe UI", 11, "bold"), text_color=COL_WARN).pack(anchor="w", padx=14, pady=(12, 2))
    ctk.CTkLabel(info, text="This interface is intentionally polished so the app feels like a serious enterprise analytics product even before the demo starts.", font=("Segoe UI", 12), text_color=COL_MUTED, wraplength=300, justify="left").pack(anchor="w", padx=14, pady=(0, 12))

    self.password_entry.bind("<Return>", lambda e: self.login())


def premium_show_main_app(self):
    self.clear_screen()
    self.configure(fg_color=COL_BG)

    self.sidebar = ctk.CTkFrame(self, width=270, corner_radius=0, fg_color=COL_PANEL,
                                border_width=0)
    self.sidebar.pack(side="left", fill="y")
    self.sidebar.pack_propagate(False)

    self.content = ctk.CTkFrame(self, corner_radius=0, fg_color=COL_BG)
    self.content.pack(side="right", fill="both", expand=True)

    brand = ctk.CTkFrame(self.sidebar, fg_color="transparent")
    brand.pack(fill="x", padx=22, pady=(24, 18))
    badge = ctk.CTkLabel(brand, text="EXECUTIVE SUITE", font=("Segoe UI", 10, "bold"),
                         text_color=COL_ACCENT, fg_color=COL_ACCENT_SOFT, corner_radius=999,
                         padx=10, pady=5)
    badge.pack(anchor="w", pady=(0, 10))
    ctk.CTkLabel(brand, text="LineSight", font=("Segoe UI", 25, "bold"), text_color=COL_TEXT).pack(anchor="w")
    ctk.CTkLabel(brand, text="Production Quality & Maintenance Command Center", font=("Segoe UI", 12), text_color=COL_MUTED, wraplength=220, justify="left").pack(anchor="w", pady=(4, 0))

    self.nav_buttons = {}
    nav = [
        ("Dashboard", self.show_dashboard),
        ("Machine Analysis", self.show_machine_analysis),
        ("Operator / Shift", self.show_operator_shift),
        ("Process Capability", self.show_capability),
        ("AI Analysis", self.show_ai_insights),
        ("Raw Data", self.show_raw_data),
    ]
    nav_frame = ctk.CTkFrame(self.sidebar, fg_color="transparent")
    nav_frame.pack(fill="x", padx=18, pady=(4, 12))
    for label, cmd in nav:
        b = ctk.CTkButton(nav_frame, text=label, width=220, height=44,
                          corner_radius=14, anchor="w", fg_color=COL_PANEL_2,
                          hover_color=COL_CARD_ALT, text_color=COL_TEXT,
                          font=("Segoe UI", 13, "bold"),
                          command=lambda c=cmd, l=label: self._navigate(c, l))
        b.pack(pady=6, padx=4, fill="x")
        self.nav_buttons[label] = b

    utility = ctk.CTkFrame(self.sidebar, fg_color=COL_CARD, corner_radius=20,
                           border_width=1, border_color=COL_BORDER)
    utility.pack(fill="x", padx=22, pady=(16, 10))
    ctk.CTkLabel(utility, text="Workspace Actions", font=("Segoe UI", 13, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=16, pady=(14, 6))
    ctk.CTkButton(utility, text="Upload CSV / Excel", height=42, corner_radius=12,
                  fg_color=COL_GOOD, hover_color="#16a34a", font=("Segoe UI", 13, "bold"),
                  command=self.upload_csv).pack(fill="x", padx=14, pady=6)
    ctk.CTkButton(utility, text="Export HTML Report", height=42, corner_radius=12,
                  fg_color=COL_ACCENT, hover_color=COL_ACCENT_2, font=("Segoe UI", 13, "bold"),
                  command=self.export_report).pack(fill="x", padx=14, pady=6)
    ctk.CTkButton(utility, text="Logout", height=42, corner_radius=12,
                  fg_color="#7f1d1d", hover_color="#991b1b", font=("Segoe UI", 13, "bold"),
                  command=self.show_login_screen).pack(fill="x", padx=14, pady=(6, 14))

    status = ctk.CTkFrame(self.sidebar, fg_color=COL_CARD, corner_radius=20,
                          border_width=1, border_color=COL_BORDER)
    status.pack(side="bottom", fill="x", padx=22, pady=22)
    ctk.CTkLabel(status, text="Current dataset", font=("Segoe UI", 11, "bold"), text_color=COL_MUTED).pack(anchor="w", padx=14, pady=(12, 4))
    self.data_status = ctk.CTkLabel(status, text=f"Source: {self.data_source}",
                                    font=("Segoe UI", 12), text_color=COL_TEXT,
                                    wraplength=200, justify="left")
    self.data_status.pack(anchor="w", padx=14, pady=(0, 14))

    self._navigate(self.show_dashboard, "Dashboard")


def premium_navigate(self, command, label):
    for name, btn in self.nav_buttons.items():
        selected = name == label
        btn.configure(
            fg_color=COL_ACCENT if selected else COL_PANEL_2,
            hover_color=COL_ACCENT_2 if selected else COL_CARD_ALT,
            text_color="#ffffff" if selected else COL_TEXT,
        )
    command()


def premium_show_dashboard(self):
    self.clear_content()
    area = self._scroll_area()
    self._page_title(area, "Executive Dashboard", "A premium overview of plant quality, cost and maintenance risk — ideal for a first impression in demos and presentations.", icon="◈")

    k = overall_kpis(self.df)
    ms = build_machine_summary(self.df)
    op = build_group_summary(self.df, "Operator_ID")
    sh = build_group_summary(self.df, "Shift")
    top = ms.iloc[0] if not ms.empty else None

    hero = self._section_card(area, "Command Summary", "This top section makes the project feel like an enterprise command center, not a simple student dashboard.", padx=22, pady=(0, 10), fill="x")
    body = ctk.CTkFrame(hero, fg_color="transparent")
    body.pack(fill="x", padx=18, pady=(6, 18))
    left = ctk.CTkFrame(body, fg_color="transparent")
    left.pack(side="left", fill="both", expand=True)
    summary = build_local_answer(self.df, "Which machine is most critical and what should management focus on first?")
    ctk.CTkLabel(left, text="LineSight transforms production noise into a clear action narrative.", font=("Segoe UI", 22, "bold"), text_color=COL_TEXT, justify="left").pack(anchor="w")
    ctk.CTkLabel(left, text=summary.split("\n\n")[0], font=("Segoe UI", 13), text_color=COL_MUTED, wraplength=760, justify="left").pack(anchor="w", pady=(8, 0))

    spotlight = ctk.CTkFrame(body, fg_color=COL_PANEL_2, corner_radius=18,
                             border_width=1, border_color=COL_BORDER, width=290)
    spotlight.pack(side="right", padx=(16, 0), fill="y")
    if top is not None:
        ctk.CTkLabel(spotlight, text="Spotlight Machine", font=("Segoe UI", 11, "bold"), text_color=COL_ACCENT).pack(anchor="w", padx=16, pady=(16, 2))
        ctk.CTkLabel(spotlight, text=str(top["Machine_ID"]), font=("Segoe UI", 28, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=16)
        ctk.CTkLabel(spotlight, text=f"Criticality {top['Criticality_Score']:.1f}/100", font=("Segoe UI", 13), text_color=COL_MUTED).pack(anchor="w", padx=16, pady=(4, 2))
        ctk.CTkLabel(spotlight, text=f"Fail rate {top['Failure_Rate']:.2f}% · Cpk {top['Cpk']:.2f}", font=("Segoe UI", 12), text_color=COL_TEXT).pack(anchor="w", padx=16, pady=(0, 2))
        ctk.CTkLabel(spotlight, text=f"Failure cost ${top['Failure_Cost']:,.0f}", font=("Segoe UI", 12), text_color=COL_TEXT).pack(anchor="w", padx=16, pady=(0, 16))

    cpk_txt = f"{k['cpk']:.2f}" if k['cpk'] is not None else "N/A"
    kpi_frame = ctk.CTkFrame(area, fg_color="transparent")
    kpi_frame.pack(fill="x", padx=22, pady=(4, 4))
    cards = [
        ("Inspections", f"{k['total']:,}", COL_TEXT, "Records analyzed in the active dataset"),
        ("Pass Rate", f"{k['pass_rate']:.1f}%", COL_GOOD, "Healthy output moving through inspection"),
        ("Failure Rate", f"{k['fail_rate']:.1f}%", COL_BAD, "Share of inspections currently failing spec"),
        ("Failure Cost", f"${k['cost']:,.0f}", COL_WARN, "Accumulated quality loss in the dataset"),
        ("Overall Cpk", cpk_txt, COL_ACCENT, "Quick capability signal for executive review"),
    ]
    for i, (t, v, c, s) in enumerate(cards):
        self._kpi_card(kpi_frame, t, v, c, i, s)

    glance = ctk.CTkFrame(area, fg_color="transparent")
    glance.pack(fill="x", padx=22, pady=(6, 8))
    for _col in range(3):
        glance.grid_columnconfigure(_col, weight=1)
    worst_op = op.iloc[0] if not op.empty else None
    worst_shift = sh.iloc[0] if not sh.empty else None
    items = [
        ("Riskiest Machine", f"{top['Machine_ID']} · {top['Failure_Rate']:.2f}% fail" if top is not None else "-", "Focus maintenance and root-cause effort here first."),
        ("Worst Operator", f"{worst_op['Operator_ID']} · {worst_op['Failure_Rate']:.2f}% fail" if worst_op is not None else "-", "Treat this as a training/process signal, not blame."),
        ("Riskiest Shift", f"{worst_shift['Shift']} · {worst_shift['Failure_Rate']:.2f}% fail" if worst_shift is not None else "-", "Good place for shift-specific controls and handover checks."),
    ]
    for idx, (title, value, note) in enumerate(items):
        card = ctk.CTkFrame(glance, fg_color=COL_CARD_ALT, corner_radius=18,
                            border_width=1, border_color=COL_BORDER)
        card.grid(row=0, column=idx, sticky="nsew", padx=7, pady=0)
        ctk.CTkLabel(card, text=title.upper(), font=("Segoe UI", 10, "bold"), text_color=COL_MUTED).pack(anchor="w", padx=15, pady=(14, 6))
        ctk.CTkLabel(card, text=value, font=("Segoe UI", 18, "bold"), text_color=COL_TEXT, wraplength=260, justify="left").pack(anchor="w", padx=15)
        ctk.CTkLabel(card, text=note, font=("Segoe UI", 11), text_color=COL_MUTED, wraplength=260, justify="left").pack(anchor="w", padx=15, pady=(6, 14))

    charts = ctk.CTkFrame(area, fg_color="transparent")
    charts.pack(fill="both", expand=True, padx=22, pady=(4, 12))
    for c in range(2):
        charts.grid_columnconfigure(c, weight=1)

    left_card = self._section_card(charts, "Failure Rate by Machine", "See where defects concentrate first.", use_grid=True, row=0, column=0, sticky="nsew", padx=(0, 8), pady=0)
    fig, ax = self._styled_fig(6.6, 3.2)
    colors = [COL_BAD if v >= 15 else COL_WARN if v >= 8 else COL_GOOD for v in ms["Failure_Rate"]]
    ax.bar(ms["Machine_ID"], ms["Failure_Rate"], color=colors)
    ax.set_ylabel("Failure Rate (%)")
    ax.set_xlabel("Machine")
    fig.tight_layout()
    self._embed_figure(left_card, fig)

    right_card = self._section_card(charts, "Failure Cost by Machine", "Useful for demonstrating business impact, not just quality loss.", use_grid=True, row=0, column=1, sticky="nsew", padx=(8, 0), pady=0)
    fig2, ax2 = self._styled_fig(6.6, 3.2)
    ax2.bar(ms["Machine_ID"], ms["Failure_Cost"], color=COL_ACCENT)
    ax2.set_ylabel("Failure Cost ($)")
    ax2.set_xlabel("Machine")
    fig2.tight_layout()
    self._embed_figure(right_card, fig2)


def premium_show_machine_analysis(self):
    self.clear_content()
    area = self._scroll_area()
    self._page_title(area, "Machine Analysis", "A machine-by-machine risk lens for maintenance prioritization, cost exposure and process drift.", icon="⚙")
    ms = build_machine_summary(self.df)
    top = ms.iloc[0] if not ms.empty else None

    if top is not None:
        highlight = self._section_card(area, f"Critical Machine Spotlight — {top['Machine_ID']}", "Use this section to tell a convincing story about why this machine deserves immediate attention.", padx=22, pady=(0, 10), fill="x")
        strip = ctk.CTkFrame(highlight, fg_color="transparent")
        strip.pack(fill="x", padx=12, pady=(2, 12))
        metrics = [
            ("Criticality Score", f"{top['Criticality_Score']:.1f}/100", COL_ACCENT, "Composite urgency signal"),
            ("Failure Rate", f"{top['Failure_Rate']:.2f}%", COL_BAD, "Share of failed inspections"),
            ("Failure Cost", f"${top['Failure_Cost']:,.0f}", COL_WARN, "Loss linked to failures"),
            ("Cpk", f"{top['Cpk']:.2f}", COL_GOOD if top['Cpk'] >= 1.33 else COL_WARN if top['Cpk'] >= 1.0 else COL_BAD, "Process capability health"),
        ]
        for i, (t, v, c, s) in enumerate(metrics):
            self._kpi_card(strip, t, v, c, i, s)

    charts = ctk.CTkFrame(area, fg_color="transparent")
    charts.pack(fill="both", expand=True, padx=22, pady=(0, 10))
    for c in range(2):
        charts.grid_columnconfigure(c, weight=1)

    card1 = self._section_card(charts, "Criticality Score by Machine", "The closer a bar is to 100, the stronger the case for urgent maintenance.", use_grid=True, row=0, column=0, sticky="nsew", padx=(0, 8), pady=0)
    fig, ax = self._styled_fig(6.5, 3.2)
    order = ms.sort_values("Criticality_Score", ascending=True)
    ax.barh(order["Machine_ID"], order["Criticality_Score"], color=COL_ACCENT)
    ax.set_xlabel("Criticality (0-100)")
    fig.tight_layout()
    self._embed_figure(card1, fig)

    card2 = self._section_card(charts, "Cost per 1000 Units", "A clean way to show cost-normalized quality pain across machines.", use_grid=True, row=0, column=1, sticky="nsew", padx=(8, 0), pady=0)
    fig2, ax2 = self._styled_fig(6.5, 3.2)
    order2 = ms.sort_values("Cost_per_1000_units", ascending=False)
    ax2.bar(order2["Machine_ID"], order2["Cost_per_1000_units"], color=COL_WARN)
    ax2.set_ylabel("Cost / 1000 units")
    ax2.set_xlabel("Machine")
    fig2.tight_layout()
    self._embed_figure(card2, fig2)

    display = ms[["Machine_ID", "Inspections", "Failures", "Failure_Rate", "Failure_Cost", "Downtime_Minutes", "Avg_Measurement", "Cp", "Cpk", "Cost_per_1000_units", "Criticality_Score"]].copy() if not ms.empty else ms
    self._table(area, display, height=10)


def premium_show_operator_shift(self):
    self.clear_content()
    area = self._scroll_area()
    self._page_title(area, "Operator & Shift Performance", "Explore people and shift patterns with a polished view that feels far more advanced than a typical class project.", icon="👥")

    op = build_group_summary(self.df, "Operator_ID")
    sh = build_group_summary(self.df, "Shift")
    combo = build_shift_operator_summary(self.df)
    top_op = op.iloc[0] if not op.empty else None
    top_sh = sh.iloc[0] if not sh.empty else None
    top_combo = combo.iloc[0] if combo is not None and not combo.empty else None

    strip = ctk.CTkFrame(area, fg_color="transparent")
    strip.pack(fill="x", padx=22, pady=(0, 8))
    cards = [
        ("Highest-Failure Operator", f"{top_op['Operator_ID']} · {top_op['Failure_Rate']:.2f}%" if top_op is not None else "-", COL_BAD, "Good prompt for training and work-instruction review."),
        ("Riskiest Shift", f"{top_sh['Shift']} · {top_sh['Failure_Rate']:.2f}%" if top_sh is not None else "-", COL_WARN, "Strong candidate for shift-specific control actions."),
        ("Worst Shift/Operator Pair", f"{top_combo['Shift']} / {top_combo['Operator_ID']} · {top_combo['Failure_Rate']:.2f}%" if top_combo is not None else "-", COL_ACCENT, "Useful for a very concrete improvement story."),
    ]
    for i, (t, v, c, s) in enumerate(cards):
        self._kpi_card(strip, t, v, c, i, s)

    charts = ctk.CTkFrame(area, fg_color="transparent")
    charts.pack(fill="both", expand=True, padx=22, pady=(0, 10))
    for c in range(2):
        charts.grid_columnconfigure(c, weight=1)

    card1 = self._section_card(charts, "Failure Rate by Shift", "Quickly demonstrates whether one shift needs extra controls.", use_grid=True, row=0, column=0, sticky="nsew", padx=(0, 8), pady=0)
    fig, ax = self._styled_fig(6.5, 3.0)
    ax.bar(sh["Shift"], sh["Failure_Rate"], color=[COL_GOOD, COL_WARN, COL_BAD][:len(sh)])
    ax.set_ylabel("Failure Rate (%)")
    ax.set_xlabel("Shift")
    fig.tight_layout()
    self._embed_figure(card1, fig)

    card2 = self._section_card(charts, "Top Operators by Failure Rate", "A sharper conversation starter for coaching, standards and training.", use_grid=True, row=0, column=1, sticky="nsew", padx=(8, 0), pady=0)
    fig2, ax2 = self._styled_fig(6.5, 3.0)
    top5 = op.head(5)
    ax2.bar(top5["Operator_ID"], top5["Failure_Rate"], color=COL_ACCENT_2)
    ax2.set_ylabel("Failure Rate (%)")
    ax2.set_xlabel("Operator")
    fig2.tight_layout()
    self._embed_figure(card2, fig2)

    ctk.CTkLabel(area, text="Operator Table", font=("Segoe UI", 17, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=28, pady=(6, 0))
    self._table(area, op, height=8)
    ctk.CTkLabel(area, text="Shift Table", font=("Segoe UI", 17, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=28, pady=(10, 0))
    self._table(area, sh, height=5)


def premium_show_capability(self):
    self.clear_content()
    area = self._scroll_area()
    self._page_title(area, "Process Capability (Cp / Cpk)", "This page now feels like a serious SPC workspace — clear verdicts, elegant visuals and machine-level capability context.", icon="◉")

    k = overall_kpis(self.df)
    cp_txt = f"{k['cp']:.2f}" if k['cp'] is not None else "N/A"
    cpk_txt = f"{k['cpk']:.2f}" if k['cpk'] is not None else "N/A"
    verdict = capability_verdict(k['cpk'])
    vcolor = COL_GOOD if verdict == "Capable" else COL_WARN if verdict == "Marginal" else COL_BAD

    info = self._section_card(area, "Capability Verdict", "A fast, executive-friendly reading of how well the overall process fits inside specification limits.", padx=22, pady=(0, 10), fill="x")
    row = ctk.CTkFrame(info, fg_color="transparent")
    row.pack(fill="x", padx=12, pady=(4, 12))
    metrics = [
        ("Overall Cp", cp_txt, COL_ACCENT, "Spread versus spec width"),
        ("Overall Cpk", cpk_txt, vcolor, "Centered capability indicator"),
        ("Verdict", verdict, vcolor, "Capable / Marginal / Not Capable"),
    ]
    for i, (t, v, c, s) in enumerate(metrics):
        self._kpi_card(row, t, v, c, i, s)

    charts = ctk.CTkFrame(area, fg_color="transparent")
    charts.pack(fill="both", expand=True, padx=22, pady=(0, 10))
    for c in range(2):
        charts.grid_columnconfigure(c, weight=1)

    hist_card = self._section_card(charts, "Measurement Distribution", "Shows how the process is behaving against LSL/USL at a glance.", use_grid=True, row=0, column=0, sticky="nsew", padx=(0, 8), pady=0)
    lsl = float(self.df["LSL"].median())
    usl = float(self.df["USL"].median())
    fig, ax = self._styled_fig(6.6, 3.2)
    ax.hist(self.df["Measurement"], bins=30, color=COL_ACCENT, alpha=0.92)
    ax.axvline(lsl, color=COL_BAD, linestyle="--", linewidth=2, label="LSL")
    ax.axvline(usl, color=COL_BAD, linestyle="--", linewidth=2, label="USL")
    ax.axvline(self.df["Measurement"].mean(), color=COL_GOOD, linestyle="-", linewidth=2, label="Mean")
    ax.set_xlabel("Measurement")
    ax.set_ylabel("Count")
    leg = ax.legend(facecolor=COL_CARD, edgecolor=COL_BORDER, labelcolor=COL_TEXT)
    fig.tight_layout()
    self._embed_figure(hist_card, fig)

    ms = build_machine_summary(self.df)
    cpk_card = self._section_card(charts, "Per-Machine Cpk", "A strong visual for identifying which machines are capability bottlenecks.", use_grid=True, row=0, column=1, sticky="nsew", padx=(8, 0), pady=0)
    fig2, ax2 = self._styled_fig(6.6, 3.2)
    ax2.bar(ms["Machine_ID"], ms["Cpk"].fillna(0), color=[COL_GOOD if x >= 1.33 else COL_WARN if x >= 1.0 else COL_BAD for x in ms["Cpk"].fillna(0)])
    ax2.axhline(1.33, color=COL_GOOD, linestyle="--", linewidth=1.5)
    ax2.axhline(1.00, color=COL_WARN, linestyle="--", linewidth=1.5)
    ax2.set_ylabel("Cpk")
    ax2.set_xlabel("Machine")
    fig2.tight_layout()
    self._embed_figure(cpk_card, fig2)

    cap_tbl = ms[["Machine_ID", "Avg_Measurement", "Cp", "Cpk"]].copy()
    cap_tbl["Verdict"] = cap_tbl["Cpk"].apply(capability_verdict)
    self._table(area, cap_tbl, height=6)


def premium_show_ai_insights(self):
    self.clear_content()
    page = ctk.CTkFrame(self.content, fg_color="transparent")
    page.pack(fill="both", expand=True)
    page.grid_columnconfigure(0, weight=1)
    page.grid_rowconfigure(2, weight=1)

    # Header / workbench intro
    hero = ctk.CTkFrame(page, fg_color=COL_CARD, corner_radius=22,
                        border_width=1, border_color=COL_BORDER)
    hero.grid(row=0, column=0, sticky="ew", padx=22, pady=(18, 10))
    left = ctk.CTkFrame(hero, fg_color="transparent")
    left.pack(side="left", fill="both", expand=True, padx=22, pady=18)
    ctk.CTkLabel(left, text="✦ AI Decision Workbench", font=("Segoe UI", 27, "bold"), text_color=COL_TEXT).pack(anchor="w")
    ctk.CTkLabel(left, text="A polished Q&A space where the app looks like a serious enterprise analytics platform — even before the conversation starts.", font=("Segoe UI", 13), text_color=COL_MUTED, wraplength=760, justify="left").pack(anchor="w", pady=(6, 0))
    chips = ctk.CTkFrame(left, fg_color="transparent")
    chips.pack(anchor="w", pady=(12, 0))
    for label, fg in [("Grounded on KPIs", COL_ACCENT_SOFT), ("Gemini-Enhanced", COL_PANEL_2), ("Presentation Ready", COL_ACCENT_2)]:
        ctk.CTkLabel(chips, text=label, font=("Segoe UI", 10, "bold"), text_color=COL_TEXT,
                     fg_color=fg, corner_radius=999, padx=12, pady=6).pack(side="left", padx=(0, 8))

    right = ctk.CTkFrame(hero, fg_color=COL_PANEL_2, corner_radius=18,
                         border_width=1, border_color=COL_BORDER, width=340)
    right.pack(side="right", padx=18, pady=18)
    ctk.CTkLabel(right, text="Gemini API Key", font=("Segoe UI", 12, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=14, pady=(14, 6))
    self._key_entry = ctk.CTkEntry(right, placeholder_text="paste AIza... key", show="*", height=38,
                                   corner_radius=12, fg_color=COL_CARD_ALT, border_color=COL_BORDER,
                                   text_color=COL_TEXT)
    self._key_entry.pack(fill="x", padx=14)
    if self.api_key:
        self._key_entry.insert(0, self.api_key)
    btnrow = ctk.CTkFrame(right, fg_color="transparent")
    btnrow.pack(fill="x", padx=14, pady=(10, 14))
    ctk.CTkButton(btnrow, text="Save Key", width=110, height=34, corner_radius=10,
                  fg_color=COL_GOOD, hover_color="#16a34a", command=self._save_key).pack(side="left")
    self._ai_status = ctk.CTkLabel(btnrow, font=("Segoe UI", 11), text=("Gemini connected" if self.api_key else "Local analyst mode"), text_color=(COL_GOOD if self.api_key else COL_MUTED))
    self._ai_status.pack(side="left", padx=12)

    # Tools row
    tools = ctk.CTkFrame(page, fg_color="transparent")
    tools.grid(row=1, column=0, sticky="ew", padx=22, pady=(0, 8))
    for c in range(2):
        tools.grid_columnconfigure(c, weight=1)

    analysis = self._section_card(tools, "Executive Alerts", "A compact issue panel that keeps the screen looking active and intelligent.", use_grid=True, row=0, column=0, sticky="nsew", padx=(0, 8), pady=0)
    head = ctk.CTkFrame(analysis, fg_color="transparent")
    head.pack(fill="x", padx=16, pady=(0, 6))
    self._analysis_status = ctk.CTkLabel(head, text="", font=("Segoe UI", 10), text_color=COL_MUTED)
    self._analysis_status.pack(side="left")
    ctk.CTkButton(head, text="Refresh", width=80, height=28, corner_radius=10,
                  fg_color=COL_ACCENT, hover_color=COL_ACCENT_2,
                  command=self._run_quick_analysis).pack(side="right")
    self._analysis_body = ctk.CTkFrame(analysis, fg_color="transparent")
    self._analysis_body.pack(fill="both", expand=True, padx=16, pady=(0, 12))

    presets_card = self._section_card(tools, "Fast Prompt Starters", "Stylish shortcut questions to make the app feel interactive from the first click.", use_grid=True, row=0, column=1, sticky="nsew", padx=(8, 0), pady=0)
    preset_wrap = ctk.CTkFrame(presets_card, fg_color="transparent")
    preset_wrap.pack(fill="x", padx=12, pady=(4, 12))
    presets = [
        "Which machine is most critical and why?",
        "Which shift and operator produce the most failures?",
        "Is the overall process capability (Cpk) acceptable?",
        "How should I prioritize maintenance across machines?",
    ]
    for i, q in enumerate(presets):
        preset_wrap.grid_columnconfigure(i % 2, weight=1)
        ctk.CTkButton(
            preset_wrap, text=q, anchor="w", height=40, corner_radius=12,
            fg_color=COL_PANEL_2, hover_color=COL_CARD_ALT, text_color=COL_TEXT,
            font=("Segoe UI", 12), command=lambda qq=q: self._submit_question(qq)
        ).grid(row=i // 2, column=i % 2, padx=5, pady=5, sticky="ew")

    if self.ai_cache is not None:
        self._render_quick_analysis(self.ai_cache)
    else:
        self._run_quick_analysis()

    # Chat shell
    chat_shell = ctk.CTkFrame(page, fg_color=COL_CARD, corner_radius=22,
                              border_width=1, border_color=COL_BORDER)
    chat_shell.grid(row=2, column=0, sticky="nsew", padx=22, pady=(0, 12))
    chat_shell.grid_columnconfigure(0, weight=1)
    chat_shell.grid_rowconfigure(1, weight=1)

    chat_head = ctk.CTkFrame(chat_shell, fg_color="transparent")
    chat_head.grid(row=0, column=0, sticky="ew", padx=18, pady=(14, 6))
    ctk.CTkLabel(chat_head, text="AI Conversation", font=("Segoe UI", 16, "bold"), text_color=COL_TEXT).pack(side="left")
    ctk.CTkLabel(chat_head, text="Ask a question, show off the interface, and let the app feel enterprise-grade.", font=("Segoe UI", 11), text_color=COL_MUTED).pack(side="left", padx=12)

    self._chat = ctk.CTkScrollableFrame(chat_shell, fg_color=COL_BG, corner_radius=18,
                                        scrollbar_button_color=COL_PANEL_2,
                                        scrollbar_button_hover_color=COL_ACCENT)
    self._chat.grid(row=1, column=0, sticky="nsew", padx=16, pady=(0, 10))

    if self.chat_history:
        for h in self.chat_history:
            self._add_bubble("You" if h["role"] == "user" else "AI Analyst", h["text"], user=(h["role"] == "user"))
    else:
        intro = ctk.CTkFrame(self._chat, fg_color=COL_CARD_ALT, corner_radius=18,
                             border_width=1, border_color=COL_BORDER)
        intro.pack(fill="x", padx=10, pady=18)
        ctk.CTkLabel(intro, text="Start with a prompt above or ask your own question below.", font=("Segoe UI", 15, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=16, pady=(16, 6))
        ctk.CTkLabel(intro, text="The layout is intentionally larger and more premium so even a quiet screen feels like a serious AI workbench.", font=("Segoe UI", 12), text_color=COL_MUTED, wraplength=900, justify="left").pack(anchor="w", padx=16, pady=(0, 16))

    inrow = ctk.CTkFrame(chat_shell, fg_color="transparent")
    inrow.grid(row=2, column=0, sticky="ew", padx=16, pady=(0, 16))
    self._chat_entry = ctk.CTkEntry(inrow, placeholder_text="Ask about machines, operators, night shift, Cpk, maintenance or improvement ideas…",
                                    height=46, corner_radius=14, fg_color=COL_CARD_ALT,
                                    border_color=COL_BORDER, text_color=COL_TEXT,
                                    font=("Segoe UI", 14))
    self._chat_entry.pack(side="left", fill="x", expand=True)
    self._chat_entry.bind("<Return>", lambda e: self._send_chat())
    ctk.CTkButton(inrow, text="Send", width=100, height=46, corner_radius=14,
                  fg_color=COL_ACCENT, hover_color=COL_ACCENT_2,
                  font=("Segoe UI", 13, "bold"), command=self._send_chat).pack(side="left", padx=(10, 0))


def premium_render_quick_analysis(self, result):
    for w in self._analysis_body.winfo_children():
        w.destroy()

    if result.get("headline"):
        ctk.CTkLabel(self._analysis_body, text=result["headline"], font=("Segoe UI", 12, "bold"),
                     wraplength=520, justify="left", text_color=COL_TEXT).pack(anchor="w", pady=(0, 8))

    pr_color = {"HIGH": COL_BAD, "MEDIUM": COL_WARN, "LOW": COL_GOOD}
    machines = result.get("machines", [])
    issues = [m for m in machines if str(m.get("priority", "")).upper() in ("HIGH", "MEDIUM")]

    for m in issues[:3]:
        pr = str(m.get("priority", "LOW")).upper()
        row = ctk.CTkFrame(self._analysis_body, fg_color=COL_PANEL_2, corner_radius=12,
                           border_width=1, border_color=COL_BORDER)
        row.pack(fill="x", pady=4)
        ctk.CTkLabel(row, text=pr, width=70, fg_color=pr_color.get(pr, COL_GOOD),
                     corner_radius=8, font=("Segoe UI", 10, "bold"), text_color="#ffffff").pack(side="left", padx=10, pady=10)
        txt = ctk.CTkLabel(row, text=f"{m.get('machine', '')} — {m.get('recommendation', '')}",
                           font=("Segoe UI", 11), wraplength=430, justify="left",
                           text_color=COL_TEXT)
        txt.pack(side="left", fill="x", expand=True, padx=(0, 10), pady=8)

    if not issues:
        ok_count = sum(1 for m in machines if str(m.get("priority", "")).upper() == "LOW")
        ctk.CTkLabel(self._analysis_body,
                     text=(f"{ok_count} machine(s) currently appear to be in the normal range." if ok_count else "No issue summary available yet."),
                     font=("Segoe UI", 11), text_color=COL_MUTED, wraplength=520, justify="left").pack(anchor="w", pady=4)


def premium_add_bubble(self, who, text, user):
    wrap = ctk.CTkFrame(self._chat, fg_color="transparent")
    wrap.pack(fill="x", pady=8)

    bubble = ctk.CTkFrame(
        wrap,
        fg_color=(COL_ACCENT if user else COL_CARD_ALT),
        corner_radius=18,
        border_width=(0 if user else 1),
        border_color=COL_BORDER,
    )

    panel_w = max(820, self.content.winfo_width() - 120)
    if user:
        bubble.pack(anchor="e", padx=12)
        wrap_len = min(700, panel_w - 340)
    else:
        bubble.pack(anchor="w", padx=12, fill="x", expand=True)
        wrap_len = min(1160, panel_w)

    ctk.CTkLabel(bubble, text=who, font=("Segoe UI", 10, "bold"),
                 text_color=("#dbeafe" if user else COL_ACCENT)).pack(anchor="w", padx=18, pady=(12, 2))
    lbl = ctk.CTkLabel(
        bubble, text=text, font=("Segoe UI", 14), wraplength=wrap_len,
        justify="left", text_color="#ffffff" if user else COL_TEXT
    )
    lbl.pack(anchor="w", padx=18, pady=(2, 14), fill="x" if not user else None, expand=(not user))
    self._scroll_chat_bottom()
    return lbl


def premium_show_raw_data(self):
    self.clear_content()
    area = ctk.CTkFrame(self.content, fg_color="transparent")
    area.pack(fill="both", expand=True)
    self._page_title(area, "Raw Data Explorer", f"Showing {min(200, len(self.df))} of {len(self.df)} rows from the active dataset. Even the raw table now looks more polished and deliberate.", icon="⌘")

    k = overall_kpis(self.df)
    strip = ctk.CTkFrame(area, fg_color="transparent")
    strip.pack(fill="x", padx=22, pady=(0, 6))
    cards = [
        ("Rows Loaded", f"{len(self.df):,}", COL_TEXT, "Total observations in memory"),
        ("Pass", f"{k['pass']:,}", COL_GOOD, "Measurements within specification"),
        ("Fail", f"{k['fail']:,}", COL_BAD, "Measurements outside specification"),
    ]
    for i, (t, v, c, s) in enumerate(cards):
        self._kpi_card(strip, t, v, c, i, s)
    self._table(area, self.df.head(200), height=20, expand=True)


def premium_table(self, parent, df, height=10, expand=False):
    frame = ctk.CTkFrame(parent, fg_color=COL_CARD, corner_radius=18,
                         border_width=1, border_color=COL_BORDER)
    frame.pack(fill="both", expand=expand, padx=22, pady=10)

    style = ttk.Style()
    try:
        style.theme_use("clam")
    except Exception:
        pass
    style.configure("FP.Treeview", background=COL_CARD_ALT, foreground=COL_TEXT,
                    fieldbackground=COL_CARD_ALT, rowheight=30, borderwidth=0,
                    relief="flat", font=("Segoe UI", 10))
    style.configure("FP.Treeview.Heading", background=COL_PANEL_2,
                    foreground=COL_TEXT, relief="flat", font=("Segoe UI", 10, "bold"))
    style.map("FP.Treeview", background=[("selected", COL_ACCENT)], foreground=[("selected", "#ffffff")])

    cols = list(df.columns)
    tree = ttk.Treeview(frame, columns=cols, show="headings", height=height, style="FP.Treeview")
    for c in cols:
        tree.heading(c, text=c)
        tree.column(c, width=max(110, min(190, len(str(c)) * 12)), anchor="center")

    tree.tag_configure("odd", background=COL_CARD_ALT)
    tree.tag_configure("even", background=COL_CARD)

    for idx, (_, r) in enumerate(df.iterrows()):
        tag = "even" if idx % 2 == 0 else "odd"
        tree.insert("", "end", values=[r[c] for c in cols], tags=(tag,))

    vsb = ttk.Scrollbar(frame, orient="vertical", command=tree.yview)
    hsb = ttk.Scrollbar(frame, orient="horizontal", command=tree.xview)
    tree.configure(yscrollcommand=vsb.set, xscrollcommand=hsb.set)
    tree.pack(side="top", fill="both", expand=True, padx=12, pady=(12, 4))
    hsb.pack(side="bottom", fill="x", padx=12, pady=(0, 10))
    vsb.place(relx=0.985, rely=0.02, relheight=0.88, anchor="ne")


# Apply the patch.
LineSightApp.__init__ = premium_init
LineSightApp._scroll_area = premium_scroll_area
LineSightApp._page_title = premium_page_title
LineSightApp._section_card = premium_section_card
LineSightApp._kpi_card = premium_kpi_card
LineSightApp._styled_fig = premium_styled_fig
LineSightApp.show_login_screen = premium_show_login_screen
LineSightApp.show_main_app = premium_show_main_app
LineSightApp._navigate = premium_navigate
LineSightApp.show_dashboard = premium_show_dashboard
LineSightApp.show_machine_analysis = premium_show_machine_analysis
LineSightApp.show_operator_shift = premium_show_operator_shift
LineSightApp.show_capability = premium_show_capability
LineSightApp.show_ai_insights = premium_show_ai_insights
LineSightApp._render_quick_analysis = premium_render_quick_analysis
LineSightApp._add_bubble = premium_add_bubble
LineSightApp.show_raw_data = premium_show_raw_data
LineSightApp._table = premium_table



# ======================================================================
# UX + PDF REPORT PATCH (v2)
# ======================================================================
def build_pdf_report(df, ai=None, output_path="LineSight_Report.pdf", source_name="Data"):
    from reportlab.lib import colors
    from reportlab.lib.pagesizes import A4
    from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
    from reportlab.lib.units import mm
    from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, Table, TableStyle, PageBreak

    if ai is None:
        ai = ai_analyze(df)

    k = overall_kpis(df)
    machine = build_machine_summary(df)
    op = build_group_summary(df, "Operator_ID")
    shift = build_group_summary(df, "Shift")
    now = dt.datetime.now().strftime("%Y-%m-%d %H:%M")

    doc = SimpleDocTemplate(
        output_path,
        pagesize=A4,
        leftMargin=14 * mm,
        rightMargin=14 * mm,
        topMargin=14 * mm,
        bottomMargin=14 * mm,
        title="LineSight Report",
    )

    styles = getSampleStyleSheet()
    title_style = ParagraphStyle(
        "TitleFP", parent=styles["Title"], fontName="Helvetica-Bold",
        fontSize=22, leading=26, textColor=colors.HexColor("#0f2347"), spaceAfter=8
    )
    sub_style = ParagraphStyle(
        "SubFP", parent=styles["Normal"], fontSize=10.5, leading=14,
        textColor=colors.HexColor("#4a5a78"), spaceAfter=8
    )
    h_style = ParagraphStyle(
        "HeaderFP", parent=styles["Heading2"], fontName="Helvetica-Bold",
        fontSize=14, leading=17, textColor=colors.HexColor("#102a56"), spaceBefore=8, spaceAfter=8
    )
    body_style = ParagraphStyle(
        "BodyFP", parent=styles["BodyText"], fontSize=9.5, leading=13,
        textColor=colors.HexColor("#1a2740")
    )
    small_style = ParagraphStyle(
        "SmallFP", parent=styles["BodyText"], fontSize=8.8, leading=12,
        textColor=colors.HexColor("#40506d")
    )

    story = []
    story.append(Paragraph("LineSight — Executive Production Report", title_style))
    story.append(Paragraph(
        f"Generated on {now} • Source: {source_name} • Premium decision-support summary for manufacturing quality, maintenance, operator/shift performance and process capability.",
        sub_style,
    ))
    story.append(Spacer(1, 6))

    # KPI table
    cp_txt = f"{k['cp']:.2f}" if k['cp'] is not None else "N/A"
    cpk_txt = f"{k['cpk']:.2f}" if k['cpk'] is not None else "N/A"
    kpi_data = [
        ["Inspections", "Pass Rate", "Failure Rate", "Failure Cost", "Downtime", "Cp / Cpk"],
        [
            f"{k['total']:,}",
            f"{k['pass_rate']:.1f}%",
            f"{k['fail_rate']:.1f}%",
            f"${k['cost']:,.0f}",
            f"{k['downtime']:,.0f} min",
            f"{cp_txt} / {cpk_txt}",
        ],
    ]
    t = Table(kpi_data, colWidths=[28*mm, 28*mm, 28*mm, 32*mm, 28*mm, 34*mm])
    t.setStyle(TableStyle([
        ('BACKGROUND', (0,0), (-1,0), colors.HexColor('#102a56')),
        ('TEXTCOLOR', (0,0), (-1,0), colors.white),
        ('BACKGROUND', (0,1), (-1,1), colors.HexColor('#eef4ff')),
        ('TEXTCOLOR', (0,1), (-1,1), colors.HexColor('#14213d')),
        ('FONTNAME', (0,0), (-1,0), 'Helvetica-Bold'),
        ('FONTNAME', (0,1), (-1,1), 'Helvetica-Bold'),
        ('FONTSIZE', (0,0), (-1,-1), 9),
        ('ALIGN', (0,0), (-1,-1), 'CENTER'),
        ('GRID', (0,0), (-1,-1), 0.4, colors.HexColor('#9eb3d6')),
        ('BOTTOMPADDING', (0,0), (-1,-1), 8),
        ('TOPPADDING', (0,0), (-1,-1), 8),
    ]))
    story.append(t)
    story.append(Spacer(1, 10))

    story.append(Paragraph("Executive Summary", h_style))
    story.append(Paragraph(ai.get("headline", "No headline available."), body_style))
    if ai.get("narrative"):
        story.append(Spacer(1, 4))
        story.append(Paragraph(ai.get("narrative"), body_style))
    if ai.get("operator_shift_note"):
        story.append(Spacer(1, 4))
        story.append(Paragraph(f"<b>Operator / Shift Insight:</b> {ai.get('operator_shift_note')}", body_style))

    story.append(Spacer(1, 10))
    story.append(Paragraph("Priority Recommendations", h_style))
    recs = ai.get("machines", [])[:5]
    if recs:
        for item in recs:
            story.append(Paragraph(
                f"<b>{item.get('machine','Unknown')}</b> — <b>{item.get('priority','')}</b>: {item.get('recommendation','')}",
                body_style,
            ))
            story.append(Spacer(1, 4))
    else:
        story.append(Paragraph("No AI recommendations available.", body_style))

    def _prep_table(df_in, keep_cols, max_rows=None):
        if df_in is None or df_in.empty:
            return [["No data"]]
        temp = df_in[keep_cols].copy()
        if max_rows is not None:
            temp = temp.head(max_rows)
        rows = [keep_cols]
        for _, r in temp.iterrows():
            line = []
            for c in keep_cols:
                val = r[c]
                if isinstance(val, float):
                    if "Rate" in c:
                        line.append(f"{val:.2f}%")
                    elif c in ("Cp", "Cpk", "Avg_Measurement", "Criticality_Score"):
                        line.append(f"{val:.2f}")
                    else:
                        line.append(f"{val:,.0f}")
                else:
                    line.append(str(val))
            rows.append(line)
        return rows

    def _styled_table(data, col_widths=None):
        tbl = Table(data, colWidths=col_widths, repeatRows=1)
        tbl.setStyle(TableStyle([
            ('BACKGROUND', (0,0), (-1,0), colors.HexColor('#173b75')),
            ('TEXTCOLOR', (0,0), (-1,0), colors.white),
            ('FONTNAME', (0,0), (-1,0), 'Helvetica-Bold'),
            ('FONTSIZE', (0,0), (-1,-1), 8.3),
            ('GRID', (0,0), (-1,-1), 0.35, colors.HexColor('#a8bad8')),
            ('ROWBACKGROUNDS', (0,1), (-1,-1), [colors.HexColor('#f8fbff'), colors.HexColor('#edf3ff')]),
            ('TEXTCOLOR', (0,1), (-1,-1), colors.HexColor('#10233d')),
            ('ALIGN', (0,0), (-1,-1), 'CENTER'),
            ('VALIGN', (0,0), (-1,-1), 'MIDDLE'),
            ('TOPPADDING', (0,0), (-1,-1), 5),
            ('BOTTOMPADDING', (0,0), (-1,-1), 5),
        ]))
        return tbl

    story.append(Spacer(1, 6))
    story.append(Paragraph("Machine Analysis", h_style))
    mach_cols = ["Machine_ID", "Failures", "Failure_Rate", "Failure_Cost", "Downtime_Minutes", "Cp", "Cpk", "Criticality_Score"]
    story.append(_styled_table(_prep_table(machine, mach_cols), col_widths=[23*mm, 18*mm, 22*mm, 24*mm, 28*mm, 15*mm, 15*mm, 24*mm]))

    story.append(Spacer(1, 10))
    story.append(Paragraph("Operator Performance", h_style))
    op_cols = ["Operator_ID", "Inspections", "Failures", "Failure_Rate", "Pass_Rate", "Failure_Cost"]
    story.append(_styled_table(_prep_table(op, op_cols, 8), col_widths=[26*mm, 24*mm, 20*mm, 24*mm, 24*mm, 28*mm]))

    story.append(Spacer(1, 10))
    story.append(Paragraph("Shift Performance", h_style))
    sh_cols = ["Shift", "Inspections", "Failures", "Failure_Rate", "Pass_Rate", "Failure_Cost"]
    story.append(_styled_table(_prep_table(shift, sh_cols), col_widths=[28*mm, 24*mm, 22*mm, 24*mm, 24*mm, 30*mm]))

    story.append(Spacer(1, 10))
    story.append(Paragraph("Capability Interpretation", h_style))
    story.append(Paragraph(
        f"Overall verdict: <b>{capability_verdict(k['cpk'])}</b>. As a guide, Cpk ≥ 1.33 is generally capable, 1.00–1.33 is marginal, and below 1.00 is not capable. Improve Cpk by centering the mean between LSL and USL, reducing variation, recalibrating equipment, standardizing setup, and using SPC warnings before measurements cross specification limits.",
        small_style,
    ))

    def _footer(canvas, doc):
        canvas.saveState()
        canvas.setFont('Helvetica', 8)
        canvas.setFillColor(colors.HexColor('#5d6d8a'))
        canvas.drawRightString(doc.pagesize[0] - 14*mm, 8*mm, f"LineSight • Page {doc.page}")
        canvas.restoreState()

    doc.build(story, onFirstPage=_footer, onLaterPages=_footer)
    return output_path


def premium_export_report_pdf(self):
    path = filedialog.asksaveasfilename(
        title="Save PDF Report",
        defaultextension=".pdf",
        filetypes=[("PDF Report", "*.pdf")],
        initialfile="LineSight_Executive_Report.pdf",
    )
    if not path:
        path = os.path.join(tempfile.gettempdir(), "LineSight_Executive_Report.pdf")
    try:
        self.data_status.configure(text="Building PDF report…", text_color=COL_MUTED)
        self.update_idletasks()
        ai = self.ai_cache or ai_analyze(self.df, api_key=self.api_key)
        self.ai_cache = ai
        build_pdf_report(self.df, ai=ai, output_path=path, source_name=self.data_source)
        self.data_status.configure(text=f"PDF report saved:\n{os.path.basename(path)}", text_color=COL_GOOD)
        webbrowser.open("file://" + os.path.abspath(path))
    except Exception as e:
        self.data_status.configure(text=f"PDF export failed: {e}", text_color=COL_BAD)


def premium_clear_chat(self):
    self.chat_history = []
    if hasattr(self, '_chat') and self._chat.winfo_exists():
        for w in self._chat.winfo_children():
            w.destroy()
        intro = ctk.CTkFrame(self._chat, fg_color=COL_CARD_ALT, corner_radius=18,
                             border_width=1, border_color=COL_BORDER)
        intro.pack(fill="x", padx=10, pady=18)
        ctk.CTkLabel(intro, text="Conversation cleared.", font=("Segoe UI", 15, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=16, pady=(16, 6))
        ctk.CTkLabel(intro, text="Ask a new question to restart the AI analysis flow.", font=("Segoe UI", 12), text_color=COL_MUTED).pack(anchor="w", padx=16, pady=(0, 16))


