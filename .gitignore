"""
LineSight - Production Quality & Maintenance Decision Support System
---------------------------------------------------------------------------
A desktop analytics tool for manufacturing data. It takes inspection data and
automatically computes machine failure rates, operator/shift performance,
process capability (Cp/Cpk), failure-cost projections, finds the riskiest
machine, sends the computed stats to Google Gemini for a real AI analysis,
and exports a self-contained HTML report.

Stack: customtkinter (UI) + pandas/numpy (analytics) + matplotlib (charts)
       + Gemini API (AI insights)
"""

import os
import json
import queue
import webbrowser
import datetime as dt
import tempfile
import threading

import numpy as np
import pandas as pd
import requests

import customtkinter as ctk
from tkinter import filedialog, ttk
from matplotlib.figure import Figure
from matplotlib.backends.backend_tkagg import FigureCanvasTkAgg


