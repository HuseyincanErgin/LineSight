    ctk.CTkLabel(pdfbox, text=self.tr("Exports a two-page dark executive PDF inspired by the uploaded sample report.", "Yüklediğin örnek rapora benzer iki sayfalık koyu temalı yönetici PDF'i üretir."), font=("Segoe UI", 10.5), text_color=COL_MUTED, wraplength=240, justify="left").pack(anchor="w", padx=12, pady=(0, 8))
    ctk.CTkButton(pdfbox, text=self.tr("Export PDF Report", "PDF Rapor İndir"), height=38, corner_radius=10,
