# ======================================================================
# FINAL FIX PATCH (v3) — BIG CHAT + SAFE PDF EXPORT
# ======================================================================
def _pdf_escape(value):
    """Escape user/model text so ReportLab Paragraph never breaks on &, <, >."""
    from xml.sax.saxutils import escape
    if value is None:
        return ""
    return escape(str(value)).replace("\n", "<br/>")


def _pdf_plain(value):
    if value is None:
        return ""
    return str(value).replace("\n", " ").strip()


def build_pdf_report_v3(df, ai=None, output_path="LineSight_Report.pdf", source_name="Data"):
    """
    Safe PDF report builder.
    - Does not rely on HTML conversion.
    - Escapes all Paragraph text.
    - Builds a complete executive report with tables.
    """
    from reportlab.lib import colors
    from reportlab.lib.pagesizes import A4
    from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
    from reportlab.lib.units import mm
    from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, Table, TableStyle, KeepTogether

    if ai is None:
        ai = ai_analyze(df)

    k = overall_kpis(df)
    machine = build_machine_summary(df)
    op = build_group_summary(df, "Operator_ID")
    shift = build_group_summary(df, "Shift")
    now = dt.datetime.now().strftime("%Y-%m-%d %H:%M")

    doc = SimpleDocTemplate(
        output_path,
        pagesize=A4,
        leftMargin=13 * mm,
        rightMargin=13 * mm,
        topMargin=13 * mm,
        bottomMargin=13 * mm,
        title="LineSight Executive Report",
        author="LineSight",
    )

    styles = getSampleStyleSheet()
    styles.add(ParagraphStyle(
        name="FPTitle", parent=styles["Title"], fontName="Helvetica-Bold",
        fontSize=22, leading=26, textColor=colors.HexColor("#0b1f3f"), spaceAfter=8
    ))
    styles.add(ParagraphStyle(
        name="FPSubtitle", parent=styles["Normal"], fontName="Helvetica",
        fontSize=9.8, leading=13, textColor=colors.HexColor("#4b5f82"), spaceAfter=8
    ))
    styles.add(ParagraphStyle(
        name="FPHeading", parent=styles["Heading2"], fontName="Helvetica-Bold",
        fontSize=13.5, leading=17, textColor=colors.HexColor("#123364"), spaceBefore=9, spaceAfter=7
    ))
    styles.add(ParagraphStyle(
        name="FPBody", parent=styles["BodyText"], fontName="Helvetica",
        fontSize=9.4, leading=12.7, textColor=colors.HexColor("#15243c"), spaceAfter=4
    ))
    styles.add(ParagraphStyle(
        name="FPSmall", parent=styles["BodyText"], fontName="Helvetica",
        fontSize=8.5, leading=11.2, textColor=colors.HexColor("#3c4f70"), spaceAfter=3
    ))

    story = []
    story.append(Paragraph("LineSight — Executive Production Report", styles["FPTitle"]))
    story.append(Paragraph(
        _pdf_escape(f"Generated: {now} • Dataset: {source_name} • A decision-support report for production quality, maintenance priority, operator/shift performance and Cp/Cpk capability."),
        styles["FPSubtitle"],
    ))
    story.append(Spacer(1, 5))

    cp_txt = f"{k['cp']:.2f}" if k.get('cp') is not None else "N/A"
    cpk_txt = f"{k['cpk']:.2f}" if k.get('cpk') is not None else "N/A"
    kpi_data = [
        ["Inspections", "Pass Rate", "Failure Rate", "Failure Cost", "Downtime", "Cp / Cpk"],
        [f"{k['total']:,}", f"{k['pass_rate']:.1f}%", f"{k['fail_rate']:.1f}%", f"${k['cost']:,.0f}", f"{k['downtime']:,.0f} min", f"{cp_txt} / {cpk_txt}"],
    ]
    kpi_tbl = Table(kpi_data, colWidths=[29*mm, 29*mm, 29*mm, 31*mm, 28*mm, 34*mm])
    kpi_tbl.setStyle(TableStyle([
        ('BACKGROUND', (0,0), (-1,0), colors.HexColor('#0e2d5f')),
        ('TEXTCOLOR', (0,0), (-1,0), colors.white),
        ('BACKGROUND', (0,1), (-1,1), colors.HexColor('#edf4ff')),
        ('TEXTCOLOR', (0,1), (-1,1), colors.HexColor('#10213e')),
        ('FONTNAME', (0,0), (-1,0), 'Helvetica-Bold'),
        ('FONTNAME', (0,1), (-1,1), 'Helvetica-Bold'),
        ('FONTSIZE', (0,0), (-1,-1), 8.8),
        ('ALIGN', (0,0), (-1,-1), 'CENTER'),
        ('VALIGN', (0,0), (-1,-1), 'MIDDLE'),
        ('GRID', (0,0), (-1,-1), 0.35, colors.HexColor('#9cb3d6')),
        ('TOPPADDING', (0,0), (-1,-1), 7),
        ('BOTTOMPADDING', (0,0), (-1,-1), 7),
    ]))
    story.append(kpi_tbl)

    story.append(Paragraph("Executive Summary", styles["FPHeading"]))
    story.append(Paragraph(_pdf_escape(ai.get("headline", "No executive headline generated.")), styles["FPBody"]))
    if ai.get("narrative"):
        story.append(Paragraph(_pdf_escape(ai.get("narrative")), styles["FPBody"]))
    if ai.get("operator_shift_note"):
        story.append(Paragraph("<b>Operator / Shift:</b> " + _pdf_escape(ai.get("operator_shift_note")), styles["FPBody"]))

    story.append(Paragraph("Priority Recommendations", styles["FPHeading"]))
    recs = ai.get("machines", []) or []
    if recs:
        rec_blocks = []
        for item in recs[:6]:
            rec_blocks.append(Paragraph(
                f"<b>{_pdf_escape(item.get('machine','Unknown'))}</b> — <b>{_pdf_escape(item.get('priority',''))}</b>: {_pdf_escape(item.get('recommendation',''))}",
                styles["FPBody"],
            ))
        story.extend(rec_blocks)
    else:
        story.append(Paragraph("No AI recommendations available.", styles["FPBody"]))

    def _format_cell(value, col=""):
        if pd.isna(value):
            return "-"
        if isinstance(value, (float, np.floating)):
            if "Rate" in col:
                return f"{float(value):.2f}%"
            if col in ("Cp", "Cpk", "Avg_Measurement", "Criticality_Score"):
                return f"{float(value):.2f}"
            if "Cost" in col:
                return f"${float(value):,.0f}"
            return f"{float(value):,.0f}"
        if isinstance(value, (int, np.integer)):
            if "Cost" in col:
                return f"${int(value):,}"
            return f"{int(value):,}"
        return _pdf_plain(value)

    def _prep_table(df_in, keep_cols, max_rows=None):
        if df_in is None or df_in.empty:
            return [["No data"]]
        temp = df_in[keep_cols].copy()
        if max_rows is not None:
            temp = temp.head(max_rows)
        rows = [keep_cols]
        for _, row in temp.iterrows():
            rows.append([_format_cell(row[c], c) for c in keep_cols])
        return rows

    def _styled_table(data, col_widths):
        tbl = Table(data, colWidths=col_widths, repeatRows=1)
        tbl.setStyle(TableStyle([
            ('BACKGROUND', (0,0), (-1,0), colors.HexColor('#173b75')),
            ('TEXTCOLOR', (0,0), (-1,0), colors.white),
            ('FONTNAME', (0,0), (-1,0), 'Helvetica-Bold'),
            ('FONTSIZE', (0,0), (-1,-1), 7.7),
            ('GRID', (0,0), (-1,-1), 0.3, colors.HexColor('#a9bad8')),
            ('ROWBACKGROUNDS', (0,1), (-1,-1), [colors.HexColor('#f8fbff'), colors.HexColor('#edf3ff')]),
            ('TEXTCOLOR', (0,1), (-1,-1), colors.HexColor('#10233d')),
            ('ALIGN', (0,0), (-1,-1), 'CENTER'),
            ('VALIGN', (0,0), (-1,-1), 'MIDDLE'),
            ('TOPPADDING', (0,0), (-1,-1), 4),
            ('BOTTOMPADDING', (0,0), (-1,-1), 4),
        ]))
        return tbl

    story.append(Paragraph("Machine Analysis", styles["FPHeading"]))
    mach_cols = ["Machine_ID", "Failures", "Failure_Rate", "Failure_Cost", "Downtime_Minutes", "Cp", "Cpk", "Criticality_Score"]
    story.append(_styled_table(_prep_table(machine, mach_cols), [23*mm, 18*mm, 22*mm, 25*mm, 28*mm, 15*mm, 15*mm, 24*mm]))

    story.append(Paragraph("Operator Performance", styles["FPHeading"]))
    op_cols = ["Operator_ID", "Inspections", "Failures", "Failure_Rate", "Pass_Rate", "Failure_Cost"]
    story.append(_styled_table(_prep_table(op, op_cols, 10), [27*mm, 25*mm, 20*mm, 24*mm, 24*mm, 30*mm]))

    story.append(Paragraph("Shift Performance", styles["FPHeading"]))
    sh_cols = ["Shift", "Inspections", "Failures", "Failure_Rate", "Pass_Rate", "Failure_Cost"]
    story.append(_styled_table(_prep_table(shift, sh_cols), [28*mm, 25*mm, 20*mm, 24*mm, 24*mm, 30*mm]))

    story.append(Paragraph("Cp / Cpk Interpretation", styles["FPHeading"]))
    story.append(Paragraph(
        _pdf_escape(f"Overall capability verdict: {capability_verdict(k.get('cpk'))}. Guide: Cpk >= 1.33 is capable, 1.00-1.33 is marginal, and below 1.00 is not capable. Increase Cpk by centering the mean between LSL and USL, reducing variation, recalibrating sensors/tools, standardizing setup and using SPC warning limits."),
        styles["FPSmall"],
    ))

    def _footer(canvas, doc):
        canvas.saveState()
        canvas.setFont('Helvetica', 8)
        canvas.setFillColor(colors.HexColor('#657692'))
        canvas.drawString(13*mm, 8*mm, "LineSight — generated executive report")
        canvas.drawRightString(doc.pagesize[0] - 13*mm, 8*mm, f"Page {doc.page}")
        canvas.restoreState()

    doc.build(story, onFirstPage=_footer, onLaterPages=_footer)
    return output_path


def export_report_pdf_v3(self):
    """Generate PDF safely; never leave a broken 0-byte final file after an error."""
    import uuid
    import shutil

    final_path = filedialog.asksaveasfilename(
        title="Save PDF Report",
        defaultextension=".pdf",
        filetypes=[("PDF Report", "*.pdf")],
        initialfile="LineSight_Executive_Report.pdf",
    )
    if not final_path:
        return

    final_path = os.path.abspath(final_path)
    folder = os.path.dirname(final_path) or os.getcwd()
    tmp_path = os.path.join(folder, f".linesight_tmp_{uuid.uuid4().hex}.pdf")

    try:
        self.data_status.configure(text="Building PDF report…", text_color=COL_MUTED)
        self.update_idletasks()

        ai = self.ai_cache or ai_analyze(self.df, api_key=self.api_key)
        self.ai_cache = ai
        build_pdf_report_v3(self.df, ai=ai, output_path=tmp_path, source_name=self.data_source)

        size = os.path.getsize(tmp_path) if os.path.exists(tmp_path) else 0
        if size < 1024:
            raise RuntimeError(f"PDF was not generated correctly. Temporary file size: {size} bytes.")

        # Replace only after successful build. This prevents 0-byte final reports.
        os.replace(tmp_path, final_path)
        final_size = os.path.getsize(final_path)
        if final_size < 1024:
            raise RuntimeError(f"Final PDF seems invalid. File size: {final_size} bytes.")

        self.data_status.configure(text=f"PDF report saved:\n{os.path.basename(final_path)}\n{final_size/1024:.1f} KB", text_color=COL_GOOD)
        webbrowser.open("file://" + final_path)
    except Exception as e:
        try:
            if os.path.exists(tmp_path):
                os.remove(tmp_path)
        except Exception:
            pass
        self.data_status.configure(text=f"PDF export failed:\n{e}", text_color=COL_BAD)


