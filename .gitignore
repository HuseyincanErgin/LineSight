def navigate_v5(self, command, label):
    self.current_nav_label = label
    for name, btn in self.nav_buttons.items():
        selected = name == label
        btn.configure(
            fg_color=COL_ACCENT if selected else COL_PANEL_2,
            hover_color=COL_ACCENT_2 if selected else COL_CARD_ALT,
            text_color="#ffffff" if selected else COL_TEXT,
        )
    command()


def page_title_v5(self, parent, text, subtitle=None, icon="◈"):
    # Translate key page titles lightly while preserving original English structure.
    if getattr(self, "language", "TR") == "TR":
        title_map = {
            "Executive Dashboard": "Yönetim Dashboard",
            "Machine Analysis": "Makine Analizi",
            "Operator & Shift Performance": "Operatör & Vardiya Performansı",
            "Process Capability (Cp / Cpk)": "Süreç Kabiliyeti (Cp / Cpk)",
            "Raw Data Explorer": "Ham Veri Gezgini",
        }
        text = title_map.get(text, text)
    return premium_page_title(self, parent, text, subtitle, icon)


