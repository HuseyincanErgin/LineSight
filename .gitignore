# ======================================================================
# V6.1 - PDF TEXT SAFETY PATCH
# ======================================================================
def _machine_action_tr_pdf_v6(row, df):
    mid = row.get("Machine_ID", "-")
    cpk = row.get("Cpk", np.nan)
    fr = float(row.get("Failure_Rate", 0) or 0)
    cost = float(row.get("Failure_Cost", 0) or 0)
    parts = [f"Cpk {cpk:.2f}", f"arıza oranı {fr:.1f}%", f"maliyet ${cost:,.0f}"]
    return f"{mid}: " + "; ".join(parts) + "; kalibrasyon, setup standardı ve en pahalı hata tipleri için kök neden aksiyonu başlat."


def _machine_action_en_pdf_v6(row, df):
    mid = row.get("Machine_ID", "-")
    cpk = row.get("Cpk", np.nan)
    fr = float(row.get("Failure_Rate", 0) or 0)
    cost = float(row.get("Failure_Cost", 0) or 0)
    return f"{mid}: Cpk {cpk:.2f}; failure rate {fr:.1f}%; cost ${cost:,.0f}; start calibration, setup standardization and root-cause action on the costliest defects."


def build_pdf_report_v6_visual_safe(df, ai=None, output_path="LineSight_Executive_Report.pdf", source_name="Data", language="TR"):
    # The original v5 report layout is good, but long recommendation strings can
    # exceed the card height in ReportLab. For PDF only, use shorter action lines.
    old_tr = globals().get("_machine_action_tr")
    old_en = globals().get("_machine_action")
    globals()["_machine_action_tr"] = _machine_action_tr_pdf_v6
    globals()["_machine_action"] = _machine_action_en_pdf_v6
    try:
        return build_pdf_report_v5_visual(df, ai=ai, output_path=output_path, source_name=source_name, language=language)
    finally:
        if old_tr is not None:
            globals()["_machine_action_tr"] = old_tr
        if old_en is not None:
            globals()["_machine_action"] = old_en


def export_report_pdf_v6(self):
    import tempfile
    import shutil

    initial = "LineSight_Yonetici_Raporu.pdf" if getattr(self, "language", "TR") == "TR" else "LineSight_Executive_Report.pdf"
    final_path = filedialog.asksaveasfilename(
        title=self.tr("Save PDF Report", "PDF Raporu Kaydet"),
        defaultextension=".pdf",
        filetypes=[("PDF Report", "*.pdf")],
        initialfile=initial,
    )
    if not final_path:
        return

    final_path = os.path.abspath(final_path)
    if not final_path.lower().endswith(".pdf"):
        final_path += ".pdf"
    final_dir = os.path.dirname(final_path)
    if final_dir and not os.path.exists(final_dir):
        os.makedirs(final_dir, exist_ok=True)

    tmp_fd, tmp_path = tempfile.mkstemp(prefix="linesight_v6_", suffix=".pdf")
    os.close(tmp_fd)
    try:
        os.remove(tmp_path)
    except Exception:
        pass

    try:
        self.data_status.configure(text=self.tr("Building PDF report...", "PDF rapor hazırlanıyor..."), text_color=COL_MUTED)
        self.update_idletasks()
        ai = self.ai_cache or ai_analyze(self.df, api_key=self.api_key)
        self.ai_cache = ai
        build_pdf_report_v6_visual_safe(self.df, ai=ai, output_path=tmp_path, source_name=self.data_source, language=getattr(self, "language", "TR"))
        _validate_pdf_file_v4(tmp_path)
        shutil.copyfile(tmp_path, final_path)
        size = _validate_pdf_file_v4(final_path)
        self.data_status.configure(
            text=self.tr(
                f"PDF saved successfully:\n{os.path.basename(final_path)}\n{size/1024:.1f} KB",
                f"PDF başarıyla kaydedildi:\n{os.path.basename(final_path)}\n{size/1024:.1f} KB",
            ),
            text_color=COL_GOOD,
        )
    except Exception as e:
        self.data_status.configure(text=self.tr(f"PDF export failed:\n{e}", f"PDF dışa aktarma başarısız:\n{e}"), text_color=COL_BAD)
    finally:
        try:
            if os.path.exists(tmp_path):
                os.remove(tmp_path)
        except Exception:
            pass


LineSightApp.export_report = export_report_pdf_v6



# ======================================================================
# V7 - COMPACT UI + ALL RAW DATA + BULLETPROOF LOCAL PDF EXPORT
# ======================================================================
from pathlib import Path as _FPPath
import time as _fptime
import textwrap as _fp_textwrap


def _shorten_v7(text, limit=70):
    text = str(text or "")
    return text if len(text) <= limit else text[:limit-3] + "..."


def _register_pdf_fonts_v7():
    """Register a Unicode-capable font when available; fallback stays valid."""
    try:
        from reportlab.pdfbase import pdfmetrics
        from reportlab.pdfbase.ttfonts import TTFont
        candidates = []
        if os.name == "nt":
            win = os.environ.get("WINDIR", r"C:\Windows")
            candidates += [
                (os.path.join(win, "Fonts", "arial.ttf"), os.path.join(win, "Fonts", "arialbd.ttf")),
                (os.path.join(win, "Fonts", "segoeui.ttf"), os.path.join(win, "Fonts", "segoeuib.ttf")),
            ]
        candidates += [
            ("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf", "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf"),
            ("/usr/share/fonts/truetype/liberation2/LiberationSans-Regular.ttf", "/usr/share/fonts/truetype/liberation2/LiberationSans-Bold.ttf"),
        ]
        for reg, bold in candidates:
            if os.path.exists(reg) and os.path.exists(bold):
                try:
                    pdfmetrics.registerFont(TTFont("FPV7-Regular", reg))
                    pdfmetrics.registerFont(TTFont("FPV7-Bold", bold))
                    return "FPV7-Regular", "FPV7-Bold", True
                except Exception:
                    continue
    except Exception:
        pass
    return "Helvetica", "Helvetica-Bold", False


def _ascii_safe_v7(text):
    # Used only if no Unicode font can be registered. Keeps PDF generation valid.
    repl = str.maketrans({
        "ı":"i", "İ":"I", "ğ":"g", "Ğ":"G", "ü":"u", "Ü":"U", "ş":"s", "Ş":"S", "ö":"o", "Ö":"O", "ç":"c", "Ç":"C",
        "—":"-", "–":"-", "·":"-", "’":"'", "“":"\"", "”":"\"",
    })
    return str(text or "").translate(repl)


def _draw_text_v7(c, x, y, text, font, size=9, color="#dce7f8", unicode_ok=True):
    from reportlab.lib.colors import HexColor
    c.setFont(font, size)
    c.setFillColor(HexColor(color))
    c.drawString(x, y, str(text if unicode_ok else _ascii_safe_v7(text)))


def _draw_right_v7(c, x, y, text, font, size=9, color="#dce7f8", unicode_ok=True):
    from reportlab.lib.colors import HexColor
    c.setFont(font, size)
    c.setFillColor(HexColor(color))
    c.drawRightString(x, y, str(text if unicode_ok else _ascii_safe_v7(text)))


def _round_rect_v7(c, x, y, w, h, fill="#0c1324", stroke="#223451", radius=8, line=1):
    from reportlab.lib.colors import HexColor
    c.setFillColor(HexColor(fill))
    c.setStrokeColor(HexColor(stroke))
    c.setLineWidth(line)
    c.roundRect(x, y, w, h, radius, fill=1, stroke=1 if line else 0)


def _wrap_draw_v7(c, text, x, y, max_width, font, size=9, color="#dce7f8", leading=12, max_lines=None, unicode_ok=True):
    from reportlab.pdfbase import pdfmetrics
    raw = str(text or "").replace("\r", " ")
    if not unicode_ok:
        raw = _ascii_safe_v7(raw)
    words = raw.replace("\n", " \n ").split(" ")
    lines = []
    current = ""
    for word in words:
        if word == "\n":
            if current:
                lines.append(current)
                current = ""
            continue
        trial = (current + " " + word).strip()
        if not trial:
            continue
        try:
            width = pdfmetrics.stringWidth(trial, font, size)
        except Exception:
            width = len(trial) * size * 0.5
        if width <= max_width or not current:
            current = trial
        else:
            lines.append(current)
            current = word
    if current:
        lines.append(current)
    if max_lines and len(lines) > max_lines:
        lines = lines[:max_lines]
        if lines:
            lines[-1] = lines[-1].rstrip(" .") + "..."
    for i, line in enumerate(lines):
        _draw_text_v7(c, x, y - i * leading, line, font, size, color, unicode_ok=unicode_ok)
    return y - len(lines) * leading


def _metric_card_pdf_v7(c, x, y, w, h, title, value, accent, regular, bold, unicode_ok=True):
    _round_rect_v7(c, x, y, w, h, fill="#0c1324", stroke="#18263d", radius=8)
    _draw_text_v7(c, x + 10, y + h - 15, title.upper(), bold, 7.4, "#8796ad", unicode_ok)
    _draw_text_v7(c, x + 10, y + 12, value, bold, 18, accent, unicode_ok)


def _truncate_action_v7(text, limit=155):
    text = str(text or "").replace("\n", " ").strip()
    return text if len(text) <= limit else text[:limit-3].rstrip() + "..."


def build_pdf_report_v7(df, ai=None, output_path="LineSight_Report.pdf", source_name="Data", language="TR"):
    """Local, durable PDF generator. No file-dialog paths, no auto-opening the PDF itself."""
    from reportlab.pdfgen import canvas
    from reportlab.lib.pagesizes import A4
    from reportlab.lib.colors import HexColor
    from reportlab.lib.units import mm

    regular, bold, unicode_ok = _register_pdf_fonts_v7()
    tr = (language or "TR").upper() == "TR"
    if ai is None:
        ai = ai_analyze(df)

    k = overall_kpis(df)
    machine = build_machine_summary(df)
    op = build_group_summary(df, "Operator_ID")
    shift = build_group_summary(df, "Shift")
    combo = build_shift_operator_summary(df)
    W, H = A4
    c = canvas.Canvas(str(output_path), pagesize=A4)
    c.setTitle("LineSight Report")

    bg = "#070d1a"; card="#0c1324"; section="#192b46"; border="#223451"
    text="#dce7f8"; muted="#8796ad"; red="#e84a5f"; yellow="#f2a81d"; green="#56c271"; purple="#221533"
    now = dt.datetime.now().strftime("%d.%m.%Y %H:%M") if tr else dt.datetime.now().strftime("%Y-%m-%d %H:%M")

    def page_bg():
        c.setFillColor(HexColor(bg)); c.rect(0, 0, W, H, fill=1, stroke=0)

    def header(title):
        _draw_text_v7(c, 17*mm, H-20*mm, "LineSight", bold, 17, red, unicode_ok)
        _draw_text_v7(c, 17*mm, H-29*mm, "Üretim Kalitesi ve Bakım Karar Destek Sistemi" if tr else "Production Quality and Maintenance Decision System", regular, 8.5, muted, unicode_ok)
        _draw_right_v7(c, W-17*mm, H-20*mm, "Oluşturma Tarihi" if tr else "Generated", regular, 7.5, muted, unicode_ok)
        _draw_right_v7(c, W-17*mm, H-28*mm, now, bold, 8.2, text, unicode_ok)
        _round_rect_v7(c, 17*mm, H-52*mm, W-34*mm, 15*mm, fill="#20172d", stroke="#30243e", radius=5)
        _draw_text_v7(c, 22*mm, H-43.5*mm, title, bold, 12.2, text, unicode_ok)
        c.setStrokeColor(HexColor(red)); c.setLineWidth(1); c.line(0, H-61*mm, W, H-61*mm)

    def section_title(y, title):
        _round_rect_v7(c, 17*mm, y, W-34*mm, 8.5*mm, fill=section, stroke=section, radius=3, line=0)
        _draw_text_v7(c, 21*mm, y+2.6*mm, title, bold, 7.8, "#b8c7dd", unicode_ok)
        return y - 13*mm

    def row(y, left, right, color_right=text):
        _wrap_draw_v7(c, left, 21*mm, y, 102*mm, regular, 8.2, "#b7c4d8", 10, max_lines=1, unicode_ok=unicode_ok)
        _draw_right_v7(c, W-20*mm, y, right, bold, 8.2, color_right, unicode_ok)
        c.setStrokeColor(HexColor("#182236")); c.setLineWidth(.4); c.line(17*mm, y-4*mm, W-17*mm, y-4*mm)
        return y - 8.4*mm

    # Page 1
    page_bg(); header("AI Model Performans Raporu" if tr else "AI Model Performance Report")
    y = H - 77*mm
    y = section_title(y, "SİSTEM METRİKLERİ" if tr else "SYSTEM METRICS")
    gap = 3*mm; box_w = (W - 34*mm - 2*gap) / 3
    metric_cards = [
        ("Toplam Kontrol" if tr else "Total Inspections", f"{k['total']:,}", red),
        ("Genel Cpk" if tr else "Overall Cpk", f"{k['cpk']:.2f}" if k.get('cpk') is not None else "N/A", yellow if (k.get('cpk') or 0) < 1.33 else green),
        ("Arıza" if tr else "Failures", f"{k['fail']:,}", red),
    ]
    for i, (t, v, col) in enumerate(metric_cards):
        _metric_card_pdf_v7(c, 17*mm + i*(box_w+gap), y-17*mm, box_w, 17*mm, t, v, col, regular, bold, unicode_ok)
    y -= 27*mm

    y = section_title(y, "MAKİNE RİSK ÖZETİ" if tr else "MACHINE RISK SUMMARY")
    for _, r in machine.head(8).iterrows():
        col = red if r["Failure_Rate"] >= 15 else yellow if r["Failure_Rate"] >= 8 else green
        left = f"{r['Machine_ID']} - Cpk {r['Cpk']:.2f} - Kritik Skor {r['Criticality_Score']:.0f}" if tr else f"{r['Machine_ID']} - Cpk {r['Cpk']:.2f} - Criticality {r['Criticality_Score']:.0f}"
        right = f"{r['Failure_Rate']:.1f}% hata - ${r['Failure_Cost']:,.0f}" if tr else f"{r['Failure_Rate']:.1f}% fail - ${r['Failure_Cost']:,.0f}"
        y = row(y, left, right, col)
    y -= 2*mm

    y = section_title(y, "OPERATÖR VE VARDİYA ÖZETİ" if tr else "OPERATOR AND SHIFT SUMMARY")
    if not op.empty:
        r = op.iloc[0]; y = row(y, "En riskli operatör" if tr else "Highest-risk operator", f"{r['Operator_ID']} - {r['Failure_Rate']:.1f}%", red)
    if not shift.empty:
        r = shift.iloc[0]; y = row(y, "En riskli vardiya" if tr else "Highest-risk shift", f"{r['Shift']} - {r['Failure_Rate']:.1f}%", yellow)
    if combo is not None and not combo.empty:
        r = combo.iloc[0]; y = row(y, "En riskli vardiya/operatör" if tr else "Highest-risk shift/operator", f"{r['Shift']} / {r['Operator_ID']} - {r['Failure_Rate']:.1f}%", red)
    y = row(y, "Toplam arıza maliyeti" if tr else "Total failure cost", f"${k['cost']:,.0f}", red)
    y -= 2*mm

    y = section_title(y, "AI ANALİZ MOTORU" if tr else "AI ANALYSIS ENGINE")
    source = "Gemini + Yerel Analiz" if tr and ai.get("source") == "gemini" else "Gemini + Local Engine" if ai.get("source") == "gemini" else "Yerel Analiz Motoru" if tr else "Local Analysis Engine"
    y = row(y, "Analiz Kaynağı" if tr else "Analysis Source", source, red)
    y = row(y, "Karar dayanağı" if tr else "Decision basis", "Cp/Cpk - Hata Oranı - Maliyet - Duruş" if tr else "Cp/Cpk - Failure Rate - Cost - Downtime", text)
    y = row(y, "Kayıt sayısı" if tr else "Record count", f"{k['total']:,}", text)

    _draw_text_v7(c, 17*mm, 10*mm, "LineSight - yönetici raporu" if tr else "LineSight - executive report", regular, 7, "#34445f", unicode_ok)
    _draw_right_v7(c, W-17*mm, 10*mm, now, regular, 7, "#34445f", unicode_ok)

    # Page 2
    c.showPage(); page_bg()
    _round_rect_v7(c, 17*mm, H-47*mm, W-34*mm, 25*mm, fill="#351c4c", stroke="#4b2864", radius=8)
    _draw_text_v7(c, 24*mm, H-34*mm, "AI Çözümleri ve Önerileri" if tr else "AI Solutions and Recommendations", bold, 14, text, unicode_ok)
    _draw_text_v7(c, 24*mm, H-42*mm, "Yerel analiz motoru - üretim dijital ikizi" if tr else "Local analysis engine - production digital twin", bold, 7.5, muted, unicode_ok)

    y = H - 66*mm
    _round_rect_v7(c, 24*mm, y-23*mm, W-48*mm, 23*mm, fill="#211633", stroke="#39234e", radius=5)
    _draw_text_v7(c, 30*mm, y-7*mm, "DURUM ÖZETİ" if tr else "SITUATION SUMMARY", bold, 8, muted, unicode_ok)
    top = machine.iloc[0] if not machine.empty else None
    if top is not None:
        headline = (f"En kritik makine {top['Machine_ID']}. Hata oranı {top['Failure_Rate']:.1f}%, maliyet ${top['Failure_Cost']:,.0f}, Cpk {top['Cpk']:.2f}." if tr else f"Most critical machine is {top['Machine_ID']}. Failure rate {top['Failure_Rate']:.1f}%, cost ${top['Failure_Cost']:,.0f}, Cpk {top['Cpk']:.2f}.")
    else:
        headline = ai.get("headline", "-")
    _wrap_draw_v7(c, headline, 30*mm, y-16*mm, W-60*mm, regular, 8.4, "#bfcbe0", 10.5, max_lines=2, unicode_ok=unicode_ok)
    y -= 34*mm

    _draw_text_v7(c, 17*mm, y, "SOMUT ÖNERİLER" if tr else "ACTION RECOMMENDATIONS", bold, 8.2, muted, unicode_ok)
    y -= 8*mm
    recs = []
    for _, r in machine.head(4).iterrows():
        if tr:
            action = f"{r['Machine_ID']}: Cpk {r['Cpk']:.2f}, hata oranı {r['Failure_Rate']:.1f}%, maliyet ${r['Failure_Cost']:,.0f}. Kalibrasyon, setup standardı ve kök neden aksiyonu başlat."
            title = f"{r['Machine_ID']} için öncelikli aksiyon"
        else:
            action = f"{r['Machine_ID']}: Cpk {r['Cpk']:.2f}, failure rate {r['Failure_Rate']:.1f}%, cost ${r['Failure_Cost']:,.0f}. Start calibration, setup standardization and root-cause action."
            title = f"Priority action for {r['Machine_ID']}"
        recs.append((title, action))

    for idx, (title, body) in enumerate(recs, start=1):
        h = 22*mm
        _round_rect_v7(c, 24*mm, y-h, W-48*mm, h, fill=card, stroke=border, radius=6)
        _round_rect_v7(c, 30*mm, y-h+8*mm, 9*mm, 9*mm, fill="#5a2743", stroke="#7a3659", radius=5)
        _draw_text_v7(c, 33.2*mm, y-h+10.4*mm, str(idx), bold, 7.5, "#ffffff", unicode_ok)
        _draw_text_v7(c, 44*mm, y-8*mm, title, bold, 9, text, unicode_ok)
        _wrap_draw_v7(c, _truncate_action_v7(body, 170), 44*mm, y-15.5*mm, W-70*mm, regular, 8.0, "#bfcbe0", 9.3, max_lines=2, unicode_ok=unicode_ok)
        y -= h + 5*mm

    # bottom risk/effect cards
    risk_y = 22*mm
    half = (W - 42*mm) / 2
    _round_rect_v7(c, 17*mm, risk_y, half, 26*mm, fill="#221633", stroke="#3d2852", radius=6)
    _round_rect_v7(c, 24*mm + half, risk_y, half, 26*mm, fill="#221633", stroke="#3d2852", radius=6)
    _draw_text_v7(c, 22*mm, risk_y+18*mm, "KRİTİK RİSK" if tr else "CRITICAL RISK", bold, 8, red, unicode_ok)
    _wrap_draw_v7(c, "İlk aksiyonlar uygulanmazsa hata maliyeti ve duruş süresi artabilir." if tr else "If first actions are not applied, failure cost and downtime may increase.", 22*mm, risk_y+11*mm, half-10*mm, regular, 8.2, "#bfcbe0", 9.5, 2, unicode_ok)
    _draw_text_v7(c, 29*mm + half, risk_y+18*mm, "BEKLENEN ETKİ" if tr else "EXPECTED IMPACT", bold, 8, green, unicode_ok)
    _wrap_draw_v7(c, "Kalibrasyon ve standart iş kontrolleri Cpk, arıza oranı ve bakım önceliğini iyileştirir." if tr else "Calibration and standard work checks improve Cpk, failure rate and maintenance priority.", 29*mm + half, risk_y+11*mm, half-10*mm, regular, 8.2, "#bfcbe0", 9.5, 2, unicode_ok)

    c.save()
    return str(output_path)


def _v7_reports_dir():
    home = _FPPath.home()
    candidates = [home / "Downloads", home / "Desktop", home / "Masaüstü", home]
    base = next((p for p in candidates if p.exists() and p.is_dir()), home)
    out = base / "LineSight_Reports"
    out.mkdir(parents=True, exist_ok=True)
    return out


def export_report_pdf_v7(self):
    """Save directly into a real local folder. This avoids Windows Search/virtual-folder PDF opening errors."""
    import shutil
    out_dir = _v7_reports_dir()
    stamp = dt.datetime.now().strftime("%Y%m%d_%H%M%S")
    name = ("LineSight_Yonetici_Raporu" if getattr(self, "language", "TR") == "TR" else "LineSight_Executive_Report") + f"_{stamp}.pdf"
    final_path = out_dir / name
    tmp_path = out_dir / (".__tmp_" + name)
    try:
        self.data_status.configure(text=self.tr("Building PDF report...", "PDF rapor hazırlanıyor..."), text_color=COL_MUTED)
        self.update_idletasks()
        ai = self.ai_cache or ai_analyze(self.df, api_key=self.api_key)
        self.ai_cache = ai
        if tmp_path.exists():
            tmp_path.unlink()
        build_pdf_report_v7(self.df, ai=ai, output_path=str(tmp_path), source_name=self.data_source, language=getattr(self, "language", "TR"))
        _validate_pdf_file_v4(str(tmp_path))
        os.replace(str(tmp_path), str(final_path))
        size = _validate_pdf_file_v4(str(final_path))
        self.data_status.configure(
            text=self.tr(
                f"PDF saved. Open it from:\n{final_path}\n{size/1024:.1f} KB",
                f"PDF kaydedildi. Buradan aç:\n{final_path}\n{size/1024:.1f} KB",
            ),
            text_color=COL_GOOD,
        )
        # Open the containing folder, not the PDF itself. This prevents Adobe from trying stale virtual search paths.
        try:
            if os.name == "nt":
                os.startfile(str(out_dir))
            elif sys.platform == "darwin":
                subprocess.Popen(["open", str(out_dir)])
            else:
                subprocess.Popen(["xdg-open", str(out_dir)])
        except Exception:
            pass
    except Exception as e:
        try:
            if tmp_path.exists():
                tmp_path.unlink()
        except Exception:
            pass
        self.data_status.configure(text=self.tr(f"PDF export failed:\n{e}", f"PDF dışa aktarma başarısız:\n{e}"), text_color=COL_BAD)


def compact_page_title_v7(self, parent, text, subtitle=None, icon="◈"):
    box = ctk.CTkFrame(parent, fg_color=COL_CARD, corner_radius=16,
                       border_width=1, border_color=COL_BORDER, height=92)
    box.pack(fill="x", padx=16, pady=(12, 8))
    box.pack_propagate(False)
    box.grid_columnconfigure(0, weight=1)
    box.grid_columnconfigure(1, weight=0)

    left = ctk.CTkFrame(box, fg_color="transparent")
    left.grid(row=0, column=0, sticky="nsew", padx=(18, 10), pady=12)
    ctk.CTkLabel(left, text=f"{icon}  {text}", font=("Segoe UI", 23, "bold"), text_color=COL_TEXT).pack(anchor="w")
    if subtitle:
        ctk.CTkLabel(left, text=subtitle, font=("Segoe UI", 12), text_color=COL_MUTED,
                     wraplength=760, justify="left").pack(anchor="w", pady=(4, 0))

    right = ctk.CTkFrame(box, fg_color="transparent")
    right.grid(row=0, column=1, sticky="e", padx=(0, 14), pady=10)
    records = len(self.df) if hasattr(self, "df") and self.df is not None else 0
    meta = [("DATA" if getattr(self, "language", "TR") == "EN" else "VERİ", _shorten_v7(self.data_source, 28)),
            ("ROWS" if getattr(self, "language", "TR") == "EN" else "SATIR", f"{records:,}")]
    for top, bottom in meta:
        chip = ctk.CTkFrame(right, fg_color=COL_PANEL_2, corner_radius=12, border_width=1, border_color=COL_BORDER, width=175, height=30)
        chip.pack(side="top", pady=3)
        chip.pack_propagate(False)
        ctk.CTkLabel(chip, text=f"{top}: {bottom}", font=("Segoe UI", 10.5, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=10, pady=6)
    return box


def compact_kpi_card_v7(self, parent, title, value, color, col, subtitle=""):
    card = ctk.CTkFrame(parent, height=86, fg_color=COL_CARD, corner_radius=14,
                        border_width=1, border_color=COL_BORDER)
    card.grid(row=0, column=col, padx=6, pady=5, sticky="nsew")
    parent.grid_columnconfigure(col, weight=1)
    card.grid_propagate(False)
    ctk.CTkLabel(card, text=str(title).upper(), font=("Segoe UI", 9.5, "bold"), text_color=COL_MUTED).pack(anchor="w", padx=12, pady=(10, 2))
    ctk.CTkLabel(card, text=str(value), font=("Segoe UI", 21, "bold"), text_color=color).pack(anchor="w", padx=12)
    if subtitle:
        ctk.CTkLabel(card, text=subtitle, font=("Segoe UI", 9.5), text_color=COL_MUTED, wraplength=160, justify="left").pack(anchor="w", padx=12, pady=(2, 8))
    return card


def compact_section_card_v7(self, parent, title, subtitle="", use_grid=False, **pack_or_grid):
    card = ctk.CTkFrame(parent, fg_color=COL_CARD, corner_radius=15,
                        border_width=1, border_color=COL_BORDER)
    if use_grid:
        card.grid(**pack_or_grid)
    else:
        card.pack(**pack_or_grid)
    ctk.CTkLabel(card, text=title, font=("Segoe UI", 15, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=15, pady=(12, 0))
    if subtitle:
        ctk.CTkLabel(card, text=subtitle, font=("Segoe UI", 10.5), text_color=COL_MUTED,
                     wraplength=520, justify="left").pack(anchor="w", padx=15, pady=(2, 5))
    return card


def show_raw_data_v7(self):
    self.clear_content()
    area = ctk.CTkFrame(self.content, fg_color="transparent")
    area.pack(fill="both", expand=True)
    self._page_title(
        area,
        self.tr("Raw Data Explorer", "Ham Veri Gezgini"),
        self.tr(f"Showing all {len(self.df)} rows.", f"Tüm {len(self.df)} satır gösteriliyor."),
        icon="⌘",
    )
    self._table(area, self.df, height=26, expand=True)


def _calc_textbox_height_v7(text, chars_per_line=86):
    lines = 2
    for paragraph in str(text or "").splitlines() or [""]:
        lines += max(1, (len(paragraph) // max(30, chars_per_line)) + 1)
    return min(520, max(110, lines * 24 + 34))


def _add_bubble_v7(self, who, text, user):
    wrap = ctk.CTkFrame(self._chat, fg_color="transparent")
    wrap.pack(fill="x", pady=8)

    if who in ("You", "User"):
        who = self.tr("You", "Sen")
    elif who in ("AI Analyst", "Gemini"):
        who = self.tr("AI Analyst", "AI Analist")

    bubble_color = COL_ACCENT if user else COL_CARD_ALT
    bubble = ctk.CTkFrame(wrap, fg_color=bubble_color, corner_radius=16,
                          border_width=0 if user else 1, border_color=COL_BORDER)

    chat_w = self._chat.winfo_width()
    if chat_w < 500:
        chat_w = max(780, self.content.winfo_width() - 360)
    chars_per_line = max(52, int((chat_w - 110) / 8.2))
    wrap_len = max(520, min(1120, chat_w - 90))

    if user:
        bubble.pack(anchor="e", padx=(120, 14))
        ctk.CTkLabel(bubble, text=who, font=("Segoe UI", 10, "bold"), text_color="#dbeafe").pack(anchor="w", padx=18, pady=(10, 2))
        lbl = ctk.CTkLabel(bubble, text=text, font=("Segoe UI", 15), wraplength=min(650, wrap_len), justify="left", text_color="#ffffff")
        lbl.pack(anchor="w", padx=18, pady=(3, 14))
        self._scroll_chat_bottom()
        return lbl

    bubble.pack(anchor="w", fill="x", expand=True, padx=14)
    ctk.CTkLabel(bubble, text=who, font=("Segoe UI", 10, "bold"), text_color=COL_ACCENT).pack(anchor="w", padx=18, pady=(10, 2))

    height = _calc_textbox_height_v7(text, chars_per_line=chars_per_line)
    box = ctk.CTkTextbox(
        bubble,
        width=wrap_len,
        height=height,
        wrap="word",
        fg_color=bubble_color,
        border_width=0,
        text_color=COL_TEXT,
        font=("Segoe UI", 15),
        activate_scrollbars=True if height >= 520 else False,
    )
    box.pack(fill="x", expand=True, padx=14, pady=(0, 14))
    box.insert("1.0", str(text or ""))
    box.configure(state="disabled")
    self._scroll_chat_bottom()
    return box


def _finish_bubble_v7(self, widget, text):
    if widget is not None and widget.winfo_exists():
        if isinstance(widget, ctk.CTkTextbox):
            chat_w = self._chat.winfo_width()
            if chat_w < 500:
                chat_w = max(780, self.content.winfo_width() - 360)
            chars_per_line = max(52, int((chat_w - 110) / 8.2))
            widget.configure(state="normal")
            widget.delete("1.0", "end")
            widget.insert("1.0", str(text or ""))
            widget.configure(height=_calc_textbox_height_v7(text, chars_per_line=chars_per_line))
            widget.configure(state="disabled")
        else:
            widget.configure(text=text)
    self.chat_history.append({"role": "assistant", "text": text})
    self._scroll_chat_bottom()


def _render_quick_analysis_v7(self, result):
    for w in self._analysis_body.winfo_children():
        w.destroy()
    machines = result.get("machines", []) or []
    if result.get("headline"):
        ctk.CTkLabel(self._analysis_body, text=_shorten_v7(result["headline"], 100),
                     font=("Segoe UI", 10.3, "bold"), wraplength=230,
                     justify="left", text_color=COL_TEXT).pack(anchor="w", pady=(0, 5))
    issues = [m for m in machines if str(m.get("priority", "")).upper() in ("HIGH", "MEDIUM")]
    pr_color = {"HIGH": COL_BAD, "MEDIUM": COL_WARN, "LOW": COL_GOOD}
    for m in issues[:1]:
        pr = str(m.get("priority", "LOW")).upper()
        row = ctk.CTkFrame(self._analysis_body, fg_color=COL_CARD_ALT, corner_radius=10, border_width=1, border_color=COL_BORDER)
        row.pack(fill="x", pady=2)
        ctk.CTkLabel(row, text=pr, width=54, fg_color=pr_color.get(pr, COL_GOOD), corner_radius=8,
                     font=("Segoe UI", 9, "bold"), text_color="#ffffff").pack(side="left", padx=7, pady=7)
        ctk.CTkLabel(row, text=_shorten_v7(f"{m.get('machine','')} - {m.get('recommendation','')}", 74),
                     font=("Segoe UI", 9.5), wraplength=158, justify="left", text_color=COL_TEXT).pack(side="left", padx=(0, 7), pady=6)
    if len(issues) > 1:
        ctk.CTkLabel(self._analysis_body, text=f"+{len(issues)-1} {self.tr('more alerts', 'ek uyarı')}",
                     font=("Segoe UI", 9), text_color=COL_MUTED).pack(anchor="w", pady=(2, 0))
    if not issues and not result.get("headline"):
        ctk.CTkLabel(self._analysis_body, text=self.tr("No critical alert.", "Kritik uyarı yok."),
                     font=("Segoe UI", 10), text_color=COL_MUTED).pack(anchor="w")


# Apply V7 overrides last.
LineSightApp._page_title = compact_page_title_v7
LineSightApp._kpi_card = compact_kpi_card_v7
LineSightApp._section_card = compact_section_card_v7
LineSightApp.show_raw_data = show_raw_data_v7
LineSightApp._add_bubble = _add_bubble_v7
LineSightApp._finish_bubble = _finish_bubble_v7
LineSightApp._render_quick_analysis = _render_quick_analysis_v7
LineSightApp.export_report = export_report_pdf_v7



# ======================================================================
# V8 - FINAL FIT/PDF EXPORT PATCH
#   - removes unnecessary empty-chat subtitle
#   - widens data/source chips so labels do not get clipped
#   - keeps right AI control panel compact and scrollable
#   - exports PDF without calling Gemini, so API key cannot break report output
# ======================================================================

def _report_ai_safe_v8(df, language="TR"):
    """Build a deterministic report summary without calling Gemini.

    The PDF export must never depend on API latency, invalid keys, model output,
    markdown, or very long Gemini text. This local summary is stable and enough
    for the executive PDF structure.
    """
    headline, insights = generate_ai_insights(df)
    lang = str(language or "TR").upper()
    if lang == "TR":
        ms = build_machine_summary(df)
        if not ms.empty:
            top = ms.iloc[0]
            headline = (
                f"En kritik makine {top['Machine_ID']}: kritik skor {top['Criticality_Score']:.0f}/100, "
                f"arıza oranı {top['Failure_Rate']:.1f}%, maliyet ${top['Failure_Cost']:,.0f}, Cpk {top['Cpk']:.2f}."
            )
        machines = []
        for i in insights:
            pr = i.get("priority", "LOW")
            pr_tr = "YÜKSEK" if pr == "HIGH" else "ORTA" if pr == "MEDIUM" else "DÜŞÜK"
            machines.append({
                "machine": i.get("machine", ""),
                "priority": pr_tr,
                "recommendation": i.get("message", ""),
            })
        return {
            "source": "local",
            "headline": headline,
            "machines": machines,
            "operator_shift_note": "Operatör ve vardiya kırılımları hata oranı, maliyet ve kontrol sayısı ile değerlendirilmiştir.",
            "narrative": "Bu rapor, Gemini API durumundan bağımsız olarak yerel analiz motoru ile güvenli biçimde üretilmiştir.",
        }
    return {
        "source": "local",
        "headline": headline,
        "machines": [
            {"machine": i.get("machine", ""), "priority": i.get("priority", "LOW"), "recommendation": i.get("message", "")}
            for i in insights
        ],
        "operator_shift_note": "Operator and shift patterns were evaluated using failure rate, cost and inspection count.",
        "narrative": "This report is safely generated by the local analysis engine, independent of the Gemini API state.",
    }


def _save_key_v8(self):
    self.api_key = self._key_entry.get().strip()
    ok = bool(self.api_key)
    self._ai_status.configure(
        text=(self.tr("Gemini connected", "Gemini bağlı") if ok else self.tr("Local active", "Yerel aktif")),
        text_color=COL_GOOD if ok else COL_MUTED,
    )
    # Re-run only the small alert panel; PDF export intentionally remains local/safe.
    if ok and hasattr(self, "_analysis_body"):
        self.ai_cache = None
        self._run_quick_analysis()


def export_report_pdf_v8(self):
    """Bulletproof PDF export: never calls Gemini, never opens stale Adobe paths."""
    out_dir = _v7_reports_dir()
    stamp = dt.datetime.now().strftime("%Y%m%d_%H%M%S")
    lang = getattr(self, "language", "TR")
    name_prefix = "LineSight_Yonetici_Raporu" if lang == "TR" else "LineSight_Executive_Report"
    final_path = out_dir / f"{name_prefix}_{stamp}.pdf"
    tmp_path = out_dir / f".__tmp_{name_prefix}_{stamp}.pdf"
    try:
        self.data_status.configure(text=self.tr("Building PDF report...", "PDF rapor hazırlanıyor..."), text_color=COL_MUTED)
        self.update_idletasks()

        # Important: use local deterministic report AI to avoid API-key/Gemini errors.
        ai = _report_ai_safe_v8(self.df, lang)
        if tmp_path.exists():
            tmp_path.unlink()

        build_pdf_report_v7(self.df, ai=ai, output_path=str(tmp_path), source_name=self.data_source, language=lang)
        _validate_pdf_file_v4(str(tmp_path))
        os.replace(str(tmp_path), str(final_path))
        size = _validate_pdf_file_v4(str(final_path))
        self.data_status.configure(
            text=self.tr(
                f"PDF saved:\n{final_path}\n{size/1024:.1f} KB",
                f"PDF kaydedildi:\n{final_path}\n{size/1024:.1f} KB",
            ),
            text_color=COL_GOOD,
        )
        # Open only the real folder, not the file. Adobe will not receive a stale/virtual path.
        try:
            if os.name == "nt":
                os.startfile(str(out_dir))
            elif sys.platform == "darwin":
                subprocess.Popen(["open", str(out_dir)])
            else:
                subprocess.Popen(["xdg-open", str(out_dir)])
        except Exception:
            pass
    except Exception as e:
        try:
            if tmp_path.exists():
                tmp_path.unlink()
        except Exception:
            pass
        self.data_status.configure(
            text=self.tr(f"PDF export failed:\n{e}", f"PDF dışa aktarma başarısız:\n{e}"),
            text_color=COL_BAD,
        )


def compact_page_title_v8(self, parent, text, subtitle=None, icon="◈"):
    """Smaller header with wider source chip: no clipped VERİ/DATA text."""
    box = ctk.CTkFrame(parent, fg_color=COL_CARD, corner_radius=14,
                       border_width=1, border_color=COL_BORDER, height=76)
    box.pack(fill="x", padx=14, pady=(10, 6))
    box.pack_propagate(False)
    box.grid_columnconfigure(0, weight=1)
    box.grid_columnconfigure(1, weight=0)

    left = ctk.CTkFrame(box, fg_color="transparent")
    left.grid(row=0, column=0, sticky="nsew", padx=(18, 8), pady=10)
    ctk.CTkLabel(left, text=f"{icon}  {text}", font=("Segoe UI", 21, "bold"), text_color=COL_TEXT).pack(anchor="w")
    if subtitle:
        ctk.CTkLabel(left, text=subtitle, font=("Segoe UI", 11), text_color=COL_MUTED,
                     wraplength=780, justify="left").pack(anchor="w", pady=(2, 0))

    right = ctk.CTkFrame(box, fg_color="transparent")
    right.grid(row=0, column=1, sticky="e", padx=(0, 12), pady=9)
    records = len(self.df) if hasattr(self, "df") and self.df is not None else 0
    is_en = getattr(self, "language", "TR") == "EN"
    source_label = "DATA" if is_en else "VERİ"
    row_label = "ROWS" if is_en else "SATIR"
    source_name = _shorten_v7(str(getattr(self, "data_source", "Data")), 42)

    source_chip = ctk.CTkFrame(right, fg_color=COL_PANEL_2, corner_radius=11,
                               border_width=1, border_color=COL_BORDER, width=340, height=27)
    source_chip.pack(side="top", pady=(0, 4))
    source_chip.pack_propagate(False)
    ctk.CTkLabel(source_chip, text=f"{source_label}: {source_name}", font=("Segoe UI", 10.2, "bold"),
                 text_color=COL_TEXT, anchor="w").pack(fill="x", padx=12, pady=5)

    row_chip = ctk.CTkFrame(right, fg_color=COL_PANEL_2, corner_radius=11,
                            border_width=1, border_color=COL_BORDER, width=340, height=27)
    row_chip.pack(side="top")
    row_chip.pack_propagate(False)
    ctk.CTkLabel(row_chip, text=f"{row_label}: {records:,}", font=("Segoe UI", 10.2, "bold"),
                 text_color=COL_TEXT, anchor="w").pack(fill="x", padx=12, pady=5)
    return box


def show_ai_insights_v8(self):
    self.clear_content()
    lang = getattr(self, "language", "TR")
    page = ctk.CTkFrame(self.content, fg_color="transparent")
    page.pack(fill="both", expand=True, padx=10, pady=10)
    page.grid_columnconfigure(0, weight=1)
    page.grid_columnconfigure(1, weight=0)
    page.grid_rowconfigure(0, weight=1)

    # Main large chat panel.
    chat_shell = ctk.CTkFrame(page, fg_color=COL_CARD, corner_radius=20, border_width=1, border_color=COL_BORDER)
    chat_shell.grid(row=0, column=0, sticky="nsew", padx=(0, 10), pady=0)
    chat_shell.grid_columnconfigure(0, weight=1)
    chat_shell.grid_rowconfigure(1, weight=1)

    chat_head = ctk.CTkFrame(chat_shell, fg_color="transparent")
    chat_head.grid(row=0, column=0, sticky="ew", padx=18, pady=(12, 5))
    ctk.CTkLabel(chat_head, text=self.tr("AI Conversation", "AI Konuşma Alanı"), font=("Segoe UI", 21, "bold"), text_color=COL_TEXT).pack(side="left")
    ctk.CTkButton(chat_head, text=self.tr("Clear Chat", "Sohbeti Temizle"), width=104, height=32, corner_radius=10,
                  fg_color=COL_PANEL_2, hover_color=COL_CARD_ALT, text_color=COL_TEXT,
                  command=self._clear_chat).pack(side="right")

    self._chat = ctk.CTkScrollableFrame(chat_shell, fg_color=COL_BG, corner_radius=16,
                                        scrollbar_button_color=COL_PANEL_2,
                                        scrollbar_button_hover_color=COL_ACCENT)
    self._chat.grid(row=1, column=0, sticky="nsew", padx=14, pady=(0, 10))

    if self.chat_history:
        for h in self.chat_history:
            self._add_bubble("You" if h["role"] == "user" else "AI Analyst", h["text"], user=(h["role"] == "user"))
    else:
        intro = ctk.CTkFrame(self._chat, fg_color=COL_CARD_ALT, corner_radius=16, border_width=1, border_color=COL_BORDER)
        intro.pack(fill="x", padx=12, pady=16)
        ctk.CTkLabel(intro, text=self.tr("Ask a production question to begin.", "Başlamak için üretimle ilgili bir soru sor."),
                     font=("Segoe UI", 17, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=18, pady=18)

    inrow = ctk.CTkFrame(chat_shell, fg_color="transparent")
    inrow.grid(row=2, column=0, sticky="ew", padx=14, pady=(0, 14))
    self._chat_entry = ctk.CTkEntry(inrow, placeholder_text=self.tr("Ask about machines, operators, night shift, Cpk or maintenance ideas...", "Makine, operatör, gece vardiyası, Cpk veya bakım önerileri hakkında sor..."),
                                    height=48, corner_radius=13, fg_color=COL_CARD_ALT,
                                    border_color=COL_BORDER, text_color=COL_TEXT, font=("Segoe UI", 15))
    self._chat_entry.pack(side="left", fill="x", expand=True)
    self._chat_entry.bind("<Return>", lambda e: self._send_chat())
    ctk.CTkButton(inrow, text=self.tr("Send", "Gönder"), width=100, height=48, corner_radius=13,
                  fg_color=COL_ACCENT, hover_color=COL_ACCENT_2,
                  font=("Segoe UI", 13, "bold"), command=self._send_chat).pack(side="left", padx=(10, 0))

    # Right panel is scrollable: no section gets cut when Gemini/API status appears.
    side = ctk.CTkScrollableFrame(page, fg_color=COL_CARD, corner_radius=20,
                                  border_width=1, border_color=COL_BORDER,
                                  width=360,
                                  scrollbar_button_color=COL_PANEL_2,
                                  scrollbar_button_hover_color=COL_ACCENT)
    side.grid(row=0, column=1, sticky="ns", pady=0)
    side.grid_propagate(False)

    ctk.CTkLabel(side, text=self.tr("AI Decision Panel", "AI Karar Paneli"), font=("Segoe UI", 17, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=14, pady=(14, 2))
    ctk.CTkLabel(side, text=self.tr("Quick prompts, settings and report output.", "Hazır sorular, ayarlar ve rapor çıktısı."), font=("Segoe UI", 10), text_color=COL_MUTED, wraplength=310, justify="left").pack(anchor="w", padx=14, pady=(0, 8))

    prompts = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=14, border_width=1, border_color=COL_BORDER)
    prompts.pack(fill="x", padx=10, pady=(0, 8))
    ctk.CTkLabel(prompts, text=self.tr("Prompt Starters", "Hazır Sorular"), font=("Segoe UI", 12, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=10, pady=(9, 4))
    preset_pairs = [
        ("Most critical machine?", "En kritik makine?", "Which machine is most critical and why?", "En kritik makine hangisi ve neden?"),
        ("Worst shift/operator?", "Vardiya + operatör?", "Which shift and operator produce the most failures?", "En çok hata hangi vardiya ve operatörde görülüyor?"),
        ("Is Cpk acceptable?", "Cpk kabul mü?", "Is the overall process capability (Cpk) acceptable?", "Genel Cpk değeri süreç için kabul edilebilir mi?"),
        ("Maintenance priority?", "Bakım önceliği?", "How should I prioritize maintenance across machines?", "Makine bakım önceliğini nasıl belirlemeliyim?"),
    ]
    for short_en, short_tr, full_en, full_tr in preset_pairs:
        text = full_en if lang == "EN" else full_tr
        question = full_en if lang == "EN" else full_tr
        ctk.CTkButton(prompts, text=text, anchor="w", height=42, corner_radius=9,
                      fg_color=COL_CARD_ALT, hover_color=COL_ACCENT_SOFT,
                      text_color=COL_TEXT, font=("Segoe UI", 10.2),
                      command=lambda qq=question: self._submit_question(qq)).pack(fill="x", padx=10, pady=3)
    ctk.CTkLabel(prompts, text="", height=2).pack()

    keybox = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=14, border_width=1, border_color=COL_BORDER)
    keybox.pack(fill="x", padx=10, pady=(0, 8))
    ctk.CTkLabel(keybox, text="Gemini API Key", font=("Segoe UI", 12, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=10, pady=(9, 4))
    self._key_entry = ctk.CTkEntry(keybox, placeholder_text="paste AIza... key", show="*", height=32,
                                   corner_radius=9, fg_color=COL_CARD_ALT, border_color=COL_BORDER,
                                   text_color=COL_TEXT)
    self._key_entry.pack(fill="x", padx=10)
    if self.api_key:
        self._key_entry.insert(0, self.api_key)
    row = ctk.CTkFrame(keybox, fg_color="transparent")
    row.pack(fill="x", padx=10, pady=(7, 9))
    ctk.CTkButton(row, text=self.tr("Save", "Kaydet"), width=74, height=29, corner_radius=9,
                  fg_color=COL_GOOD, hover_color="#16a34a", command=self._save_key).pack(side="left")
    self._ai_status = ctk.CTkLabel(row, font=("Segoe UI", 10),
                                   text=(self.tr("Gemini connected", "Gemini bağlı") if self.api_key else self.tr("Local active", "Yerel aktif")),
                                   text_color=(COL_GOOD if self.api_key else COL_MUTED), wraplength=205, justify="left")
    self._ai_status.pack(side="left", padx=8)

    alerts = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=14, border_width=1, border_color=COL_BORDER)
    alerts.pack(fill="x", padx=10, pady=(0, 8))
    head = ctk.CTkFrame(alerts, fg_color="transparent")
    head.pack(fill="x", padx=10, pady=(9, 2))
    ctk.CTkLabel(head, text=self.tr("Executive Alerts", "Yönetici Uyarıları"), font=("Segoe UI", 12, "bold"), text_color=COL_TEXT).pack(side="left")
    ctk.CTkButton(head, text=self.tr("Refresh", "Yenile"), width=64, height=25, corner_radius=8,
                  fg_color=COL_ACCENT, hover_color=COL_ACCENT_2, command=self._run_quick_analysis).pack(side="right")
    self._analysis_status = ctk.CTkLabel(alerts, text="", font=("Segoe UI", 9.5), text_color=COL_MUTED)
    self._analysis_status.pack(anchor="w", padx=10, pady=(0, 2))
    self._analysis_body = ctk.CTkFrame(alerts, fg_color="transparent")
    self._analysis_body.pack(fill="x", padx=10, pady=(2, 8))

    pdfbox = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=14, border_width=1, border_color=COL_BORDER)
    pdfbox.pack(fill="x", padx=10, pady=(0, 10))
    ctk.CTkLabel(pdfbox, text=self.tr("Report Output", "Rapor Çıktısı"), font=("Segoe UI", 12, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=10, pady=(9, 3))
    ctk.CTkLabel(pdfbox, text=self.tr("Export uses the local engine, so Gemini API cannot break the report.", "Rapor yerel motorla çıkar; Gemini API raporu bozmaz."), font=("Segoe UI", 9.5), text_color=COL_MUTED, wraplength=300, justify="left").pack(anchor="w", padx=10, pady=(0, 4))
    ctk.CTkButton(pdfbox, text=self.tr("Export PDF", "PDF İndir"), height=32, corner_radius=9,
                  fg_color=COL_ACCENT, hover_color=COL_ACCENT_2, command=self.export_report).pack(fill="x", padx=10, pady=(3, 10))

    if self.ai_cache is not None:
        self._render_quick_analysis(self.ai_cache)
    else:
        self._run_quick_analysis()


def show_raw_data_v8(self):
    self.clear_content()
    area = ctk.CTkFrame(self.content, fg_color="transparent")
    area.pack(fill="both", expand=True)
    self._page_title(
        area,
        self.tr("Raw Data Explorer", "Ham Veri Gezgini"),
        self.tr(f"Showing all {len(self.df)} rows.", f"Tüm {len(self.df)} satır gösteriliyor."),
        icon="⌘",
    )
    self._table(area, self.df, height=30, expand=True)


# Apply V8 overrides last.
LineSightApp._page_title = compact_page_title_v8
LineSightApp.show_ai_insights = show_ai_insights_v8
LineSightApp.show_raw_data = show_raw_data_v8
LineSightApp.export_report = export_report_pdf_v8
LineSightApp._save_key = _save_key_v8



# ======================================================================
# V9 - LAYOUT + PDF HARD FIX
# ======================================================================
# This patch intentionally avoids CTkScrollableFrame on the AI right panel,
# makes all high cards/table pages more compact, and replaces PDF generation
# with a canvas-based writer that cannot create a broken XML/Paragraph PDF.

def _set_grid_weights_v9(frame, cols):
    for i in range(cols):
        frame.grid_columnconfigure(i, weight=1)


def _one_line_v9(text, max_len=64):
    text = str(text or "").replace("\n", " ").strip()
    return text if len(text) <= max_len else text[: max_len - 1] + "…"


def compact_kpi_card_v9(self, parent, title, value, color, col, subtitle=""):
    card = ctk.CTkFrame(parent, height=72, fg_color=COL_CARD, corner_radius=13,
                        border_width=1, border_color=COL_BORDER)
    card.grid(row=0, column=col, padx=5, pady=4, sticky="nsew")
    parent.grid_columnconfigure(col, weight=1)
    ctk.CTkLabel(card, text=_one_line_v9(title, 26).upper(), font=("Segoe UI", 9.5, "bold"),
                 text_color=COL_MUTED).pack(anchor="w", padx=12, pady=(10, 1))
    ctk.CTkLabel(card, text=_one_line_v9(value, 26), font=("Segoe UI", 19, "bold"),
                 text_color=color).pack(anchor="w", padx=12, pady=(0, 8))
    return card


def compact_page_title_v9(self, parent, text, subtitle=None, icon="◈"):
    # Small, single-row page header. The source chip is wider so VERİ/DATA does not clip.
    box = ctk.CTkFrame(parent, fg_color=COL_CARD, corner_radius=12,
                       border_width=1, border_color=COL_BORDER, height=58)
    box.pack(fill="x", padx=10, pady=(8, 5))
    box.pack_propagate(False)
    box.grid_columnconfigure(0, weight=1)
    box.grid_columnconfigure(1, weight=0)

    left = ctk.CTkFrame(box, fg_color="transparent")
    left.grid(row=0, column=0, sticky="nsew", padx=(14, 8), pady=7)
    ctk.CTkLabel(left, text=f"{icon}  {text}", font=("Segoe UI", 18, "bold"),
                 text_color=COL_TEXT).pack(anchor="w")
    if subtitle:
        ctk.CTkLabel(left, text=subtitle, font=("Segoe UI", 10), text_color=COL_MUTED,
                     wraplength=760, justify="left").pack(anchor="w", pady=(1, 0))

    lang = getattr(self, "language", "TR")
    source_label = "DATA" if lang == "EN" else "VERİ"
    row_label = "ROWS" if lang == "EN" else "SATIR"
    records = len(self.df) if hasattr(self, "df") and self.df is not None else 0
    source_name = _shorten_v7(str(getattr(self, "data_source", "Data")), 50)

    right = ctk.CTkFrame(box, fg_color=COL_PANEL_2, corner_radius=11,
                         border_width=1, border_color=COL_BORDER, width=460, height=38)
    right.grid(row=0, column=1, sticky="e", padx=(0, 12), pady=9)
    right.pack_propagate(False)
    ctk.CTkLabel(right, text=f"{source_label}: {source_name}     {row_label}: {records:,}",
                 font=("Segoe UI", 10.5, "bold"), text_color=COL_TEXT,
                 anchor="w").pack(fill="x", padx=13, pady=8)
    return box


def section_card_compact_v9(self, parent, title, subtitle="", use_grid=False, **pack_or_grid):
    card = ctk.CTkFrame(parent, fg_color=COL_CARD, corner_radius=13,
                        border_width=1, border_color=COL_BORDER)
    if use_grid:
        card.grid(**pack_or_grid)
    else:
        card.pack(**pack_or_grid)
    ctk.CTkLabel(card, text=title, font=("Segoe UI", 14, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=14, pady=(10, 2))
    if subtitle:
        ctk.CTkLabel(card, text=subtitle, font=("Segoe UI", 9.5), text_color=COL_MUTED,
                     wraplength=520, justify="left").pack(anchor="w", padx=14, pady=(0, 4))
    return card


def table_compact_v9(self, parent, df, height=10, expand=False):
    frame = ctk.CTkFrame(parent, fg_color=COL_CARD, corner_radius=12,
                         border_width=1, border_color=COL_BORDER)
    frame.pack(fill="both", expand=expand, padx=10, pady=6)
    style = ttk.Style()
    try:
        style.theme_use("clam")
    except Exception:
        pass
    style.configure("FP.Treeview", background=COL_CARD_ALT, foreground=COL_TEXT,
                    fieldbackground=COL_CARD_ALT, rowheight=25, borderwidth=0,
                    relief="flat", font=("Segoe UI", 9.5))
    style.configure("FP.Treeview.Heading", background=COL_PANEL_2,
                    foreground=COL_TEXT, relief="flat", font=("Segoe UI", 9.5, "bold"))
    style.map("FP.Treeview", background=[("selected", COL_ACCENT)], foreground=[("selected", "#ffffff")])
    cols = list(df.columns)
    tree = ttk.Treeview(frame, columns=cols, show="headings", height=height, style="FP.Treeview")
    for c in cols:
        tree.heading(c, text=c)
        tree.column(c, width=max(95, min(175, len(str(c)) * 10)), anchor="center")
    tree.tag_configure("odd", background=COL_CARD_ALT)
    tree.tag_configure("even", background=COL_CARD)
    for idx, (_, r) in enumerate(df.iterrows()):
        tree.insert("", "end", values=[r[c] for c in cols], tags=("even" if idx % 2 == 0 else "odd",))
    vsb = ttk.Scrollbar(frame, orient="vertical", command=tree.yview)
    hsb = ttk.Scrollbar(frame, orient="horizontal", command=tree.xview)
    tree.configure(yscrollcommand=vsb.set, xscrollcommand=hsb.set)
    tree.pack(side="top", fill="both", expand=True, padx=8, pady=(8, 2))
    hsb.pack(side="bottom", fill="x", padx=8, pady=(0, 8))
    vsb.place(relx=0.99, rely=0.03, relheight=0.86, anchor="ne")


def show_dashboard_v9(self):
    self.clear_content()
    area = self._scroll_area()
    self._page_title(area, self.tr("Executive Dashboard", "Yönetim Dashboard"),
                     self.tr("Live production quality, cost and maintenance risk overview.", "Üretim kalitesi, maliyet ve bakım risklerinin kısa özeti."), icon="◈")
    k = overall_kpis(self.df)
    ms = build_machine_summary(self.df)
    op = build_group_summary(self.df, "Operator_ID")
    sh = build_group_summary(self.df, "Shift")
    top = ms.iloc[0] if not ms.empty else None
    worst_op = op.iloc[0] if not op.empty else None
    worst_shift = sh.iloc[0] if not sh.empty else None
    cpk_txt = f"{k['cpk']:.2f}" if k['cpk'] is not None else "N/A"

    kpi = ctk.CTkFrame(area, fg_color="transparent"); kpi.pack(fill="x", padx=10, pady=(0, 4))
    cards = [
        (self.tr("Inspections", "Kontrol"), f"{k['total']:,}", COL_TEXT, ""),
        (self.tr("Pass Rate", "Geçiş"), f"{k['pass_rate']:.1f}%", COL_GOOD, ""),
        (self.tr("Failure Rate", "Hata"), f"{k['fail_rate']:.1f}%", COL_BAD, ""),
        (self.tr("Failure Cost", "Maliyet"), f"${k['cost']:,.0f}", COL_WARN, ""),
        ("Cpk", cpk_txt, COL_ACCENT, ""),
    ]
    for i, (t,v,c,s) in enumerate(cards): self._kpi_card(kpi, t, v, c, i, s)

    glance = ctk.CTkFrame(area, fg_color="transparent"); glance.pack(fill="x", padx=10, pady=(0, 4)); _set_grid_weights_v9(glance, 3)
    facts = [
        (self.tr("Critical Machine", "Kritik Makine"), f"{top['Machine_ID']} · {top['Failure_Rate']:.1f}%" if top is not None else "-", COL_BAD),
        (self.tr("Risk Operator", "Riskli Operatör"), f"{worst_op['Operator_ID']} · {worst_op['Failure_Rate']:.1f}%" if worst_op is not None else "-", COL_WARN),
        (self.tr("Risk Shift", "Riskli Vardiya"), f"{worst_shift['Shift']} · {worst_shift['Failure_Rate']:.1f}%" if worst_shift is not None else "-", COL_ACCENT),
    ]
    for i, (t,v,c) in enumerate(facts):
        card = ctk.CTkFrame(glance, fg_color=COL_CARD, corner_radius=12, border_width=1, border_color=COL_BORDER, height=58)
        card.grid(row=0, column=i, sticky="ew", padx=5); card.pack_propagate(False)
        ctk.CTkLabel(card, text=t.upper(), font=("Segoe UI", 9, "bold"), text_color=COL_MUTED).pack(anchor="w", padx=12, pady=(8,1))
        ctk.CTkLabel(card, text=v, font=("Segoe UI", 17, "bold"), text_color=c).pack(anchor="w", padx=12)

    charts = ctk.CTkFrame(area, fg_color="transparent"); charts.pack(fill="both", expand=True, padx=10, pady=(0,8)); _set_grid_weights_v9(charts, 2)
    card1 = self._section_card(charts, self.tr("Failure Rate by Machine", "Makine Bazlı Hata Oranı"), "", use_grid=True, row=0, column=0, sticky="nsew", padx=(0,5), pady=0)
    fig, ax = self._styled_fig(6.2, 2.55); ax.bar(ms["Machine_ID"], ms["Failure_Rate"], color=[COL_BAD if v>=15 else COL_WARN if v>=8 else COL_GOOD for v in ms["Failure_Rate"]]); ax.set_ylabel(self.tr("Failure Rate (%)", "Hata Oranı (%)")); fig.tight_layout(); self._embed_figure(card1, fig)
    card2 = self._section_card(charts, self.tr("Failure Cost by Machine", "Makine Bazlı Hata Maliyeti"), "", use_grid=True, row=0, column=1, sticky="nsew", padx=(5,0), pady=0)
    fig2, ax2 = self._styled_fig(6.2, 2.55); ax2.bar(ms["Machine_ID"], ms["Failure_Cost"], color=COL_ACCENT); ax2.set_ylabel(self.tr("Failure Cost ($)", "Hata Maliyeti ($)")); fig2.tight_layout(); self._embed_figure(card2, fig2)


def show_machine_analysis_v9(self):
    self.clear_content(); area = self._scroll_area()
    self._page_title(area, self.tr("Machine Analysis", "Makine Analizi"), self.tr("Compact risk, cost and capability view.", "Toplu risk, maliyet ve kabiliyet görünümü."), icon="⚙")
    ms = build_machine_summary(self.df); top = ms.iloc[0] if not ms.empty else None
    if top is not None:
        strip = ctk.CTkFrame(area, fg_color="transparent"); strip.pack(fill="x", padx=10, pady=(0,4))
        metrics = [(self.tr("Criticality", "Kritiklik"), f"{top['Criticality_Score']:.1f}/100", COL_ACCENT, ""), (self.tr("Failure Rate", "Hata Oranı"), f"{top['Failure_Rate']:.1f}%", COL_BAD, ""), (self.tr("Cost", "Maliyet"), f"${top['Failure_Cost']:,.0f}", COL_WARN, ""), ("Cpk", f"{top['Cpk']:.2f}", COL_BAD if top['Cpk'] < 1 else COL_WARN if top['Cpk'] < 1.33 else COL_GOOD, "")]
        for i,(t,v,c,s) in enumerate(metrics): self._kpi_card(strip,t,v,c,i,s)
    grid = ctk.CTkFrame(area, fg_color="transparent"); grid.pack(fill="both", expand=True, padx=10, pady=(0,6)); grid.grid_columnconfigure(0, weight=1); grid.grid_columnconfigure(1, weight=1)
    chart = self._section_card(grid, self.tr("Criticality Score", "Kritiklik Skoru"), "", use_grid=True, row=0, column=0, sticky="nsew", padx=(0,5), pady=0)
    fig, ax = self._styled_fig(6.0, 2.35); order=ms.sort_values("Criticality_Score", ascending=True); ax.barh(order["Machine_ID"], order["Criticality_Score"], color=COL_ACCENT); ax.set_xlabel(self.tr("Criticality", "Kritiklik")); fig.tight_layout(); self._embed_figure(chart, fig)
    cost = self._section_card(grid, self.tr("Cost / 1000 Units", "1000 Birim Maliyet"), "", use_grid=True, row=0, column=1, sticky="nsew", padx=(5,0), pady=0)
    fig2, ax2 = self._styled_fig(6.0, 2.35); o2=ms.sort_values("Cost_per_1000_units", ascending=False); ax2.bar(o2["Machine_ID"], o2["Cost_per_1000_units"], color=COL_WARN); ax2.set_ylabel("$/1000"); fig2.tight_layout(); self._embed_figure(cost, fig2)
    self._table(area, ms, height=12, expand=True)


def show_operator_shift_v9(self):
    self.clear_content(); area = self._scroll_area()
    self._page_title(area, self.tr("Operator & Shift Performance", "Operatör & Vardiya Performansı"), self.tr("Compact people and shift patterns for focused improvement.", "Odaklı iyileştirme için toplu operatör ve vardiya görünümü."), icon="👥")
    op = build_group_summary(self.df, "Operator_ID"); sh = build_group_summary(self.df, "Shift"); combo = build_shift_operator_summary(self.df)
    top_op = op.iloc[0] if not op.empty else None; top_sh = sh.iloc[0] if not sh.empty else None; top_combo = combo.iloc[0] if combo is not None and not combo.empty else None
    strip = ctk.CTkFrame(area, fg_color="transparent"); strip.pack(fill="x", padx=10, pady=(0,4))
    cards = [(self.tr("Highest-Failure Operator", "En Çok Hata Yapan Operatör"), f"{top_op['Operator_ID']} · {top_op['Failure_Rate']:.1f}%" if top_op is not None else "-", COL_BAD, ""), (self.tr("Riskiest Shift", "En Riskli Vardiya"), f"{top_sh['Shift']} · {top_sh['Failure_Rate']:.1f}%" if top_sh is not None else "-", COL_WARN, ""), (self.tr("Worst Pair", "En Riskli Eşleşme"), f"{top_combo['Shift']} / {top_combo['Operator_ID']} · {top_combo['Failure_Rate']:.1f}%" if top_combo is not None else "-", COL_ACCENT, "")]
    for i,(t,v,c,s) in enumerate(cards): self._kpi_card(strip,t,v,c,i,s)
    grid = ctk.CTkFrame(area, fg_color="transparent"); grid.pack(fill="both", expand=True, padx=10, pady=(0,6)); grid.grid_columnconfigure(0, weight=1); grid.grid_columnconfigure(1, weight=1)
    left = ctk.CTkFrame(grid, fg_color="transparent"); left.grid(row=0, column=0, sticky="nsew", padx=(0,5)); right = ctk.CTkFrame(grid, fg_color="transparent"); right.grid(row=0, column=1, sticky="nsew", padx=(5,0))
    ctk.CTkLabel(left, text=self.tr("Operator Table", "Operatör Tablosu"), font=("Segoe UI", 13, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=10, pady=(0,0)); self._table(left, op, height=11, expand=True)
    ctk.CTkLabel(right, text=self.tr("Shift Table", "Vardiya Tablosu"), font=("Segoe UI", 13, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=10, pady=(0,0)); self._table(right, sh, height=6, expand=True)


def show_capability_v9(self):
    self.clear_content(); area = self._scroll_area()
    self._page_title(area, self.tr("Process Capability (Cp / Cpk)", "Süreç Kabiliyeti (Cp / Cpk)"), self.tr("Compact SPC view of specification fit and process health.", "Spesifikasyon uyumu ve süreç sağlığı için toplu SPC görünümü."), icon="◉")
    k = overall_kpis(self.df); verdict = capability_verdict(k['cpk']); vcolor = COL_GOOD if verdict == "Capable" else COL_WARN if verdict == "Marginal" else COL_BAD
    verdict_txt = {"Capable": self.tr("Capable", "Yeterli"), "Marginal": self.tr("Marginal", "Sınırda"), "Not Capable": self.tr("Not Capable", "Yetersiz"), "N/A": "N/A"}.get(verdict, verdict)
    strip = ctk.CTkFrame(area, fg_color="transparent"); strip.pack(fill="x", padx=10, pady=(0,4))
    vals=[("Cp", f"{k['cp']:.2f}" if k['cp'] is not None else "N/A", COL_ACCENT, ""), ("Cpk", f"{k['cpk']:.2f}" if k['cpk'] is not None else "N/A", vcolor, ""), (self.tr("Verdict", "Yorum"), verdict_txt, vcolor, "")]
    for i,(t,v,c,s) in enumerate(vals): self._kpi_card(strip,t,v,c,i,s)
    ms=build_machine_summary(self.df); charts=ctk.CTkFrame(area, fg_color="transparent"); charts.pack(fill="both", expand=True, padx=10, pady=(0,6)); charts.grid_columnconfigure(0, weight=1); charts.grid_columnconfigure(1, weight=1)
    hist=self._section_card(charts,self.tr("Measurement Distribution","Ölçüm Dağılımı"),"",use_grid=True,row=0,column=0,sticky="nsew",padx=(0,5),pady=0)
    lsl=float(self.df['LSL'].median()); usl=float(self.df['USL'].median()); fig,ax=self._styled_fig(6.0,2.35); ax.hist(self.df['Measurement'],bins=30,color=COL_ACCENT,alpha=.9); ax.axvline(lsl,color=COL_BAD,linestyle='--',linewidth=2,label='LSL'); ax.axvline(usl,color=COL_BAD,linestyle='--',linewidth=2,label='USL'); ax.axvline(self.df['Measurement'].mean(),color=COL_GOOD,linewidth=2,label=self.tr('Mean','Ortalama')); ax.legend(facecolor=COL_CARD,edgecolor=COL_BORDER,labelcolor=COL_TEXT,fontsize=8); fig.tight_layout(); self._embed_figure(hist,fig)
    cpkc=self._section_card(charts,self.tr("Per-Machine Cpk","Makine Bazlı Cpk"),"",use_grid=True,row=0,column=1,sticky="nsew",padx=(5,0),pady=0)
    fig2,ax2=self._styled_fig(6.0,2.35); ax2.bar(ms['Machine_ID'],ms['Cpk'].fillna(0),color=[COL_GOOD if x>=1.33 else COL_WARN if x>=1 else COL_BAD for x in ms['Cpk'].fillna(0)]); ax2.axhline(1.33,color=COL_GOOD,linestyle='--'); ax2.axhline(1.0,color=COL_WARN,linestyle='--'); ax2.set_ylabel('Cpk'); fig2.tight_layout(); self._embed_figure(cpkc,fig2)
    cap_tbl=ms[["Machine_ID","Avg_Measurement","Cp","Cpk"]].copy(); cap_tbl[self.tr("Verdict","Yorum")]=cap_tbl["Cpk"].apply(lambda x: {"Capable": self.tr("Capable","Yeterli"), "Marginal": self.tr("Marginal","Sınırda"), "Not Capable": self.tr("Not Capable","Yetersiz"), "N/A":"N/A"}.get(capability_verdict(x), capability_verdict(x)))
    self._table(area, cap_tbl, height=8, expand=True)


def show_raw_data_v9(self):
    self.clear_content(); area = ctk.CTkFrame(self.content, fg_color="transparent"); area.pack(fill="both", expand=True)
    self._page_title(area, self.tr("Raw Data Explorer", "Ham Veri Gezgini"), self.tr(f"Showing all {len(self.df)} rows.", f"Tüm {len(self.df)} satır gösteriliyor."), icon="⌘")
    self._table(area, self.df, height=30, expand=True)


def show_ai_insights_v9(self):
    self.clear_content()
    lang = getattr(self, "language", "TR")
    page = ctk.CTkFrame(self.content, fg_color="transparent")
    page.pack(fill="both", expand=True, padx=8, pady=8)
    page.grid_columnconfigure(0, weight=1)
    page.grid_columnconfigure(1, weight=0)
    page.grid_rowconfigure(0, weight=1)

    chat_shell = ctk.CTkFrame(page, fg_color=COL_CARD, corner_radius=18, border_width=1, border_color=COL_BORDER)
    chat_shell.grid(row=0, column=0, sticky="nsew", padx=(0, 8), pady=0)
    chat_shell.grid_columnconfigure(0, weight=1)
    chat_shell.grid_rowconfigure(1, weight=1)
    chat_head = ctk.CTkFrame(chat_shell, fg_color="transparent")
    chat_head.grid(row=0, column=0, sticky="ew", padx=16, pady=(10, 4))
    ctk.CTkLabel(chat_head, text=self.tr("AI Conversation", "AI Konuşma Alanı"), font=("Segoe UI", 19, "bold"), text_color=COL_TEXT).pack(side="left")
    ctk.CTkButton(chat_head, text=self.tr("Clear", "Temizle"), width=82, height=30, corner_radius=9,
                  fg_color=COL_PANEL_2, hover_color=COL_CARD_ALT, text_color=COL_TEXT, command=self._clear_chat).pack(side="right")

    self._chat = ctk.CTkScrollableFrame(chat_shell, fg_color=COL_BG, corner_radius=14,
                                        scrollbar_button_color=COL_PANEL_2, scrollbar_button_hover_color=COL_ACCENT)
    self._chat.grid(row=1, column=0, sticky="nsew", padx=12, pady=(0, 8))
    if self.chat_history:
        for h in self.chat_history:
            self._add_bubble("You" if h["role"] == "user" else "AI Analyst", h["text"], user=(h["role"] == "user"))
    else:
        intro = ctk.CTkFrame(self._chat, fg_color=COL_CARD_ALT, corner_radius=14, border_width=1, border_color=COL_BORDER)
        intro.pack(fill="x", padx=12, pady=14)
        ctk.CTkLabel(intro, text=self.tr("Ask a production question to begin.", "Başlamak için üretimle ilgili bir soru sor."),
                     font=("Segoe UI", 16, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=16, pady=16)

    inrow = ctk.CTkFrame(chat_shell, fg_color="transparent")
    inrow.grid(row=2, column=0, sticky="ew", padx=12, pady=(0, 12))
    self._chat_entry = ctk.CTkEntry(inrow, placeholder_text=self.tr("Ask about machines, operators, night shift, Cpk or maintenance ideas...", "Makine, operatör, gece vardiyası, Cpk veya bakım önerileri hakkında sor..."),
                                    height=46, corner_radius=12, fg_color=COL_CARD_ALT, border_color=COL_BORDER, text_color=COL_TEXT, font=("Segoe UI", 14))
    self._chat_entry.pack(side="left", fill="x", expand=True)
    self._chat_entry.bind("<Return>", lambda e: self._send_chat())
    ctk.CTkButton(inrow, text=self.tr("Send", "Gönder"), width=98, height=46, corner_radius=12,
                  fg_color=COL_ACCENT, hover_color=COL_ACCENT_2, font=("Segoe UI", 12, "bold"), command=self._send_chat).pack(side="left", padx=(8,0))

    # Normal frame, not scrollable: fixes the blank right panel issue.
    side = ctk.CTkFrame(page, fg_color=COL_CARD, corner_radius=18, border_width=1, border_color=COL_BORDER, width=390)
    side.grid(row=0, column=1, sticky="ns", pady=0)
    side.pack_propagate(False)

    ctk.CTkLabel(side, text=self.tr("AI Decision Panel", "AI Karar Paneli"), font=("Segoe UI", 17, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=14, pady=(12, 2))

    prompts = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=12, border_width=1, border_color=COL_BORDER)
    prompts.pack(fill="x", padx=10, pady=(6, 7))
    ctk.CTkLabel(prompts, text=self.tr("Prompt Starters", "Hazır Sorular"), font=("Segoe UI", 12, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=10, pady=(8, 3))
    preset_pairs = [
        ("Most critical machine?", "En kritik makine?", "Which machine is most critical and why?", "En kritik makine hangisi ve neden?"),
        ("Worst shift/operator?", "Vardiya + operatör?", "Which shift and operator produce the most failures?", "En çok hata hangi vardiya ve operatörde görülüyor?"),
        ("Is Cpk acceptable?", "Cpk kabul mü?", "Is the overall process capability (Cpk) acceptable?", "Genel Cpk değeri süreç için kabul edilebilir mi?"),
        ("Maintenance priority?", "Bakım önceliği?", "How should I prioritize maintenance across machines?", "Makine bakım önceliğini nasıl belirlemeliyim?"),
    ]
    for short_en, short_tr, full_en, full_tr in preset_pairs:
        text = full_en if lang == "EN" else full_tr
        question = full_en if lang == "EN" else full_tr
        ctk.CTkButton(prompts, text=text, anchor="w", height=44, corner_radius=9,
                      fg_color=COL_CARD_ALT, hover_color=COL_ACCENT_SOFT, text_color=COL_TEXT,
                      font=("Segoe UI", 10.1), command=lambda qq=question: self._submit_question(qq)).pack(fill="x", padx=9, pady=3)
    ctk.CTkLabel(prompts, text="", height=2).pack()

    keybox = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=12, border_width=1, border_color=COL_BORDER)
    keybox.pack(fill="x", padx=10, pady=(0, 7))
    ctk.CTkLabel(keybox, text="Gemini API Key", font=("Segoe UI", 12, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=10, pady=(8,3))
    self._key_entry = ctk.CTkEntry(keybox, placeholder_text="paste AIza... key", show="*", height=31, corner_radius=8, fg_color=COL_CARD_ALT, border_color=COL_BORDER, text_color=COL_TEXT)
    self._key_entry.pack(fill="x", padx=10)
    if self.api_key: self._key_entry.insert(0, self.api_key)
    kr = ctk.CTkFrame(keybox, fg_color="transparent"); kr.pack(fill="x", padx=10, pady=(6,8))
    ctk.CTkButton(kr, text=self.tr("Save", "Kaydet"), width=72, height=28, corner_radius=8, fg_color=COL_GOOD, hover_color="#16a34a", command=self._save_key).pack(side="left")
    self._ai_status = ctk.CTkLabel(kr, font=("Segoe UI", 10), text=(self.tr("Gemini connected", "Gemini bağlı") if self.api_key else self.tr("Local active", "Yerel aktif")), text_color=(COL_GOOD if self.api_key else COL_MUTED), wraplength=240, justify="left")
    self._ai_status.pack(side="left", padx=8)

    alerts = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=12, border_width=1, border_color=COL_BORDER)
    alerts.pack(fill="x", padx=10, pady=(0, 7))
    ah = ctk.CTkFrame(alerts, fg_color="transparent"); ah.pack(fill="x", padx=10, pady=(8, 2))
    ctk.CTkLabel(ah, text=self.tr("Executive Alerts", "Yönetici Uyarıları"), font=("Segoe UI", 12, "bold"), text_color=COL_TEXT).pack(side="left")
    ctk.CTkButton(ah, text=self.tr("Refresh", "Yenile"), width=62, height=25, corner_radius=8, fg_color=COL_ACCENT, hover_color=COL_ACCENT_2, command=self._run_quick_analysis).pack(side="right")
    self._analysis_status = ctk.CTkLabel(alerts, text="", font=("Segoe UI", 9.5), text_color=COL_MUTED)
    self._analysis_status.pack(anchor="w", padx=10, pady=(0,2))
    self._analysis_body = ctk.CTkFrame(alerts, fg_color="transparent")
    self._analysis_body.pack(fill="x", padx=10, pady=(2,8))

    pdfbox = ctk.CTkFrame(side, fg_color=COL_PANEL_2, corner_radius=12, border_width=1, border_color=COL_BORDER)
    pdfbox.pack(fill="x", padx=10, pady=(0, 7))
    ctk.CTkLabel(pdfbox, text=self.tr("Report Output", "Rapor Çıktısı"), font=("Segoe UI", 12, "bold"), text_color=COL_TEXT).pack(anchor="w", padx=10, pady=(8,2))
    ctk.CTkLabel(pdfbox, text=self.tr("PDF export uses the local engine.", "PDF çıktısı yerel motorla alınır."), font=("Segoe UI", 9.5), text_color=COL_MUTED, wraplength=330, justify="left").pack(anchor="w", padx=10, pady=(0,3))
    ctk.CTkButton(pdfbox, text=self.tr("Export PDF", "PDF İndir"), height=31, corner_radius=8, fg_color=COL_ACCENT, hover_color=COL_ACCENT_2, command=self.export_report).pack(fill="x", padx=10, pady=(3,9))

    if self.ai_cache is not None: self._render_quick_analysis(self.ai_cache)
    else: self._run_quick_analysis()


# ------------------------------ PDF V9 ------------------------------
def _pdf_font_v9():
    from reportlab.pdfbase import pdfmetrics
    from reportlab.pdfbase.ttfonts import TTFont
    candidates = [
        r"C:\Windows\Fonts\arial.ttf",
        r"C:\Windows\Fonts\segoeui.ttf",
        "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf",
        "/usr/share/fonts/truetype/liberation2/LiberationSans-Regular.ttf",
    ]
    for path in candidates:
        try:
            if os.path.exists(path):
                pdfmetrics.registerFont(TTFont("FPRegular", path))
                return "FPRegular", True
        except Exception:
            pass
    return "Helvetica", False


def _pdf_clean_v9(text, unicode_ok=True):
    text = str(text or "").replace("\r", " ").replace("\n", " ").strip()
    if not unicode_ok:
        text = text.encode("latin-1", "replace").decode("latin-1")
    return text


def _pdf_wrap_v9(text, max_chars=90, max_lines=None):
    import textwrap
    raw = _pdf_clean_v9(text)
    lines = []
    for chunk in raw.split(" | "):
        lines.extend(textwrap.wrap(chunk, width=max_chars) or [""])
    if max_lines and len(lines) > max_lines:
        lines = lines[:max_lines]
        lines[-1] = lines[-1][: max(0, max_chars - 1)] + "…"
    return lines


def _draw_wrapped_v9(c, text, x, y, max_chars, line_h, font_name, font_size, color, max_lines=None):
    c.setFont(font_name, font_size)
    c.setFillColor(color)
    for line in _pdf_wrap_v9(text, max_chars=max_chars, max_lines=max_lines):
        c.drawString(x, y, line)
        y -= line_h
    return y


def _draw_card_v9(c, x, y, w, h, fill, stroke):
    c.setFillColor(fill)
    c.setStrokeColor(stroke)
    c.roundRect(x, y, w, h, 8, stroke=1, fill=1)


def build_pdf_report_canvas_v9(df, output_path, source_name="Data", language="TR"):
    from reportlab.pdfgen import canvas
    from reportlab.lib.pagesizes import A4
    from reportlab.lib import colors
    from reportlab.lib.units import mm

    font_name, unicode_ok = _pdf_font_v9()
    bold_font = font_name  # robust single-font output; no missing bold file issues.
    W, H = A4
    c = canvas.Canvas(str(output_path), pagesize=A4)
    c.setTitle("LineSight Report")

    bg = colors.HexColor("#07101f")
    card = colors.HexColor("#0d1728")
    card2 = colors.HexColor("#13223a")
    stripe = colors.HexColor("#1c2e4c")
    accent = colors.HexColor("#4f8cff")
    red = colors.HexColor("#ef4444")
    amber = colors.HexColor("#f59e0b")
    green = colors.HexColor("#22c55e")
    text = colors.HexColor("#f2f6ff")
    muted = colors.HexColor("#9aa9c0")
    line = colors.HexColor("#23314b")

    lang_tr = language != "EN"
    title = "LineSight" if not lang_tr else "LineSight"
    report_title = "Production Quality Executive Report" if not lang_tr else "Üretim Kalitesi Yönetici Raporu"
    k = overall_kpis(df)
    ms = build_machine_summary(df)
    op = build_group_summary(df, "Operator_ID")
    sh = build_group_summary(df, "Shift")
    combo = build_shift_operator_summary(df)
    top = ms.iloc[0] if not ms.empty else None
    top_op = op.iloc[0] if not op.empty else None
    top_sh = sh.iloc[0] if not sh.empty else None
    top_combo = combo.iloc[0] if combo is not None and not combo.empty else None
    date_str = dt.datetime.now().strftime("%d.%m.%Y %H:%M" if lang_tr else "%Y-%m-%d %H:%M")

    def draw_header(page_title):
        c.setFillColor(bg); c.rect(0, 0, W, H, stroke=0, fill=1)
        c.setFont(bold_font, 18); c.setFillColor(text); c.drawString(20*mm, H-22*mm, _pdf_clean_v9(title, unicode_ok))
        c.setFont(font_name, 8.5); c.setFillColor(muted); c.drawString(20*mm, H-29*mm, _pdf_clean_v9("Decision Support System" if not lang_tr else "Yönetim Karar Merkezi", unicode_ok))
        c.setFont(font_name, 8); c.drawRightString(W-20*mm, H-22*mm, _pdf_clean_v9(("Generated" if not lang_tr else "Oluşturma") + f": {date_str}", unicode_ok))
        _draw_card_v9(c, 20*mm, H-48*mm, W-40*mm, 12*mm, colors.HexColor("#1d1430"), line)
        c.setFont(bold_font, 12); c.setFillColor(text); c.drawString(25*mm, H-40.5*mm, _pdf_clean_v9(page_title, unicode_ok))
        c.setStrokeColor(red); c.setLineWidth(1.1); c.line(0, H-55*mm, W, H-55*mm)

    draw_header(report_title)
    y = H - 68*mm
    c.setFont(bold_font, 8); c.setFillColor(muted); c.drawString(20*mm, y, _pdf_clean_v9("SYSTEM METRICS" if not lang_tr else "SİSTEM METRİKLERİ", unicode_ok)); y -= 4*mm
    metric_w = (W - 48*mm) / 4
    metrics = [
        ("Inspections" if not lang_tr else "Kontrol", f"{k['total']:,}", accent),
        ("Failure Rate" if not lang_tr else "Hata Oranı", f"{k['fail_rate']:.1f}%", red),
        ("Failure Cost" if not lang_tr else "Hata Maliyeti", f"${k['cost']:,.0f}", amber),
        ("Cpk" if not lang_tr else "Cpk", f"{k['cpk']:.2f}" if k['cpk'] is not None else "N/A", green if k['cpk'] and k['cpk']>=1.33 else red),
    ]
    for i, (lab, val, col) in enumerate(metrics):
        x = 20*mm + i * (metric_w + 2.5*mm)
        _draw_card_v9(c, x, y-17*mm, metric_w, 16*mm, card, line)
        c.setFont(font_name, 7); c.setFillColor(muted); c.drawCentredString(x+metric_w/2, y-6*mm, _pdf_clean_v9(lab.upper(), unicode_ok))
        c.setFont(bold_font, 15); c.setFillColor(col); c.drawCentredString(x+metric_w/2, y-13*mm, _pdf_clean_v9(val, unicode_ok))
    y -= 27*mm

    # Machine table
    _draw_card_v9(c, 20*mm, y-7*mm, W-40*mm, 8*mm, stripe, line)
    c.setFont(bold_font, 8); c.setFillColor(muted); c.drawString(24*mm, y-2*mm, _pdf_clean_v9("MACHINE RISK SUMMARY" if not lang_tr else "MAKİNE RİSK ÖZETİ", unicode_ok)); y -= 13*mm
    c.setFont(bold_font, 8); c.setFillColor(text)
    headers = ["Machine", "Fail %", "Cost", "Downtime", "Cp", "Cpk", "Score"] if not lang_tr else ["Makine", "Hata %", "Maliyet", "Duruş", "Cp", "Cpk", "Skor"]
    xs = [22, 48, 72, 101, 132, 150, 170]
    for x, h in zip(xs, headers): c.drawString(x*mm, y, _pdf_clean_v9(h, unicode_ok))
    y -= 5*mm
    c.setFont(font_name, 8); c.setFillColor(text)
    for _, r in ms.head(8).iterrows():
        vals = [r['Machine_ID'], f"{r['Failure_Rate']:.1f}", f"${r['Failure_Cost']:,.0f}", f"{r['Downtime_Minutes']:,.0f}m", f"{r['Cp']:.2f}", f"{r['Cpk']:.2f}", f"{r['Criticality_Score']:.1f}"]
        c.setStrokeColor(line); c.line(20*mm, y-2*mm, W-20*mm, y-2*mm)
        for x, v in zip(xs, vals): c.drawString(x*mm, y, _pdf_clean_v9(v, unicode_ok))
        y -= 7*mm

    y -= 5*mm
    _draw_card_v9(c, 20*mm, y-7*mm, W-40*mm, 8*mm, stripe, line)
    c.setFont(bold_font, 8); c.setFillColor(muted); c.drawString(24*mm, y-2*mm, _pdf_clean_v9("OPERATOR & SHIFT SUMMARY" if not lang_tr else "OPERATÖR & VARDİYA ÖZETİ", unicode_ok)); y -= 15*mm
    summary_lines = []
    if top_op is not None: summary_lines.append(("Highest-risk operator" if not lang_tr else "En riskli operatör") + f": {top_op['Operator_ID']} · {top_op['Failure_Rate']:.1f}%")
    if top_sh is not None: summary_lines.append(("Riskiest shift" if not lang_tr else "En riskli vardiya") + f": {top_sh['Shift']} · {top_sh['Failure_Rate']:.1f}%")
    if top_combo is not None: summary_lines.append(("Worst pair" if not lang_tr else "En riskli eşleşme") + f": {top_combo['Shift']} / {top_combo['Operator_ID']} · {top_combo['Failure_Rate']:.1f}%")
    for s in summary_lines:
        c.setFont(font_name, 9); c.setFillColor(text); c.drawString(24*mm, y, _pdf_clean_v9(s, unicode_ok)); y -= 7*mm

    c.showPage()
    draw_header("AI Solutions & Recommendations" if not lang_tr else "AI Çözümleri & Önerileri")
    y = H - 68*mm
    _draw_card_v9(c, 20*mm, y-24*mm, W-40*mm, 24*mm, colors.HexColor("#211738"), line)
    if top is not None:
        overview = (f"Main risk is {top['Machine_ID']} with {top['Failure_Rate']:.1f}% failure rate, ${top['Failure_Cost']:,.0f} cost and Cpk {top['Cpk']:.2f}." if not lang_tr else f"Ana risk {top['Machine_ID']}: hata oranı %{top['Failure_Rate']:.1f}, maliyet ${top['Failure_Cost']:,.0f}, Cpk {top['Cpk']:.2f}.")
    else:
        overview = "No machine risk found." if not lang_tr else "Makine riski bulunamadı."
    y2 = _draw_wrapped_v9(c, overview, 25*mm, y-9*mm, 120, 5*mm, font_name, 9, text, max_lines=3)
    y -= 35*mm
    c.setFont(bold_font, 8); c.setFillColor(muted); c.drawString(20*mm, y, _pdf_clean_v9("CONCRETE ACTIONS" if not lang_tr else "SOMUT AKSİYONLAR", unicode_ok)); y -= 6*mm
    actions = []
    for _, r in ms.head(4).iterrows():
        if lang_tr:
            actions.append(f"{r['Machine_ID']}: Kalibrasyon ve setup standardını kontrol et; Cpk {r['Cpk']:.2f}, hata oranı %{r['Failure_Rate']:.1f}. En pahalı hata tiplerinden kök neden aksiyonu başlat.")
        else:
            actions.append(f"{r['Machine_ID']}: Check calibration and setup standard; Cpk {r['Cpk']:.2f}, failure rate {r['Failure_Rate']:.1f}%. Start root-cause action on costliest defect types.")
    if top_op is not None:
        actions.append((f"Operator coaching: focus on {top_op['Operator_ID']} and compare before/after failure rate." if not lang_tr else f"Operatör koçluğu: {top_op['Operator_ID']} için eğitim ver, öncesi/sonrası hata oranını karşılaştır."))
    if top_sh is not None:
        actions.append((f"Shift control: add first-piece approval and handover checklist for {top_sh['Shift']}." if not lang_tr else f"Vardiya kontrolü: {top_sh['Shift']} için ilk parça onayı ve devir teslim checklist'i ekle."))

    for idx, act in enumerate(actions[:6], 1):
        h = 20*mm
        _draw_card_v9(c, 20*mm, y-h, W-40*mm, h-2*mm, card, line)
        c.setFillColor(colors.HexColor("#4b2036")); c.circle(27*mm, y-9*mm, 4*mm, stroke=0, fill=1)
        c.setFont(bold_font, 8); c.setFillColor(text); c.drawCentredString(27*mm, y-11*mm, str(idx))
        _draw_wrapped_v9(c, act, 36*mm, y-7*mm, 105, 4.7*mm, font_name, 8.5, text, max_lines=3)
        y -= h + 3*mm
        if y < 35*mm:
            c.showPage(); draw_header("AI Solutions & Recommendations" if not lang_tr else "AI Çözümleri & Önerileri"); y = H - 68*mm

    if y > 45*mm:
        half = (W - 45*mm)/2
        _draw_card_v9(c, 20*mm, 24*mm, half, 21*mm, colors.HexColor("#211738"), line)
        _draw_card_v9(c, 25*mm+half, 24*mm, half, 21*mm, colors.HexColor("#211738"), line)
        c.setFont(bold_font, 8); c.setFillColor(red); c.drawString(24*mm, 39*mm, _pdf_clean_v9("CRITICAL RISK" if not lang_tr else "KRİTİK RİSK", unicode_ok))
        c.setFont(font_name, 8); c.setFillColor(text); c.drawString(24*mm, 32*mm, _pdf_clean_v9(("Capability and failure cost may rise if no action is taken." if not lang_tr else "Aksiyon alınmazsa kabiliyet ve hata maliyeti kötüleşebilir."), unicode_ok))
        c.setFont(bold_font, 8); c.setFillColor(green); c.drawString((29*mm+half), 39*mm, _pdf_clean_v9("EXPECTED IMPACT" if not lang_tr else "BEKLENEN ETKİ", unicode_ok))
        c.setFont(font_name, 8); c.setFillColor(text); c.drawString((29*mm+half), 32*mm, _pdf_clean_v9(("Lower defects, clearer priorities and stronger SPC control." if not lang_tr else "Daha az hata, net bakım önceliği ve daha güçlü SPC kontrolü."), unicode_ok))

    c.save()
    return str(output_path)


def export_report_pdf_v9(self):
    out_dir = _v7_reports_dir()
    stamp = dt.datetime.now().strftime("%Y%m%d_%H%M%S")
    lang = getattr(self, "language", "TR")
    prefix = "LineSight_Yonetici_Raporu" if lang != "EN" else "LineSight_Executive_Report"
    final_path = out_dir / f"{prefix}_{stamp}.pdf"
    tmp_path = out_dir / f".__tmp_{prefix}_{stamp}.pdf"
    try:
        self.data_status.configure(text=self.tr("Building PDF...", "PDF hazırlanıyor..."), text_color=COL_MUTED)
        self.update_idletasks()
        if tmp_path.exists(): tmp_path.unlink()
        build_pdf_report_canvas_v9(self.df, tmp_path, source_name=self.data_source, language=lang)
        _validate_pdf_file_v4(str(tmp_path))
        os.replace(str(tmp_path), str(final_path))
        size = _validate_pdf_file_v4(str(final_path))
        self.data_status.configure(text=self.tr(f"PDF saved:\n{final_path}\n{size/1024:.1f} KB", f"PDF kaydedildi:\n{final_path}\n{size/1024:.1f} KB"), text_color=COL_GOOD)
        try:
            # Open only the folder. Do not open the PDF file with Adobe automatically.
            if os.name == "nt": os.startfile(str(out_dir))
            elif sys.platform == "darwin": subprocess.Popen(["open", str(out_dir)])
            else: subprocess.Popen(["xdg-open", str(out_dir)])
        except Exception:
            pass
    except Exception as e:
        try:
            if tmp_path.exists(): tmp_path.unlink()
        except Exception: pass
        self.data_status.configure(text=self.tr(f"PDF export failed: {e}", f"PDF hatası: {e}"), text_color=COL_BAD)


# Apply V9 overrides last.
LineSightApp._kpi_card = compact_kpi_card_v9
LineSightApp._page_title = compact_page_title_v9
LineSightApp._section_card = section_card_compact_v9
LineSightApp._table = table_compact_v9
LineSightApp.show_dashboard = show_dashboard_v9
LineSightApp.show_machine_analysis = show_machine_analysis_v9
LineSightApp.show_operator_shift = show_operator_shift_v9
LineSightApp.show_capability = show_capability_v9
LineSightApp.show_raw_data = show_raw_data_v9
LineSightApp.show_ai_insights = show_ai_insights_v9
LineSightApp.export_report = export_report_pdf_v9



